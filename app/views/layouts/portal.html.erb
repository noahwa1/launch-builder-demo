<!DOCTYPE html>
<html>
<head>
  <title>Creators Portal — Premiere Collectibles</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@rails/ujs@7.1.3/lib/assets/compiled/rails-ujs.min.js"></script>
  <script>if (typeof Rails !== 'undefined') Rails.start();</script>
  <style>
    /* ═══════════════════════════════════════════
       LAUNCH CREATORS PORTAL — DESIGN SYSTEM
       ═══════════════════════════════════════════ */

    :root {
      --accent: #003262;
      --accent-light: #1a4a7a;
      --accent-glow: rgba(0,50,98,0.12);
      --accent-wash: rgba(0,50,98,0.04);
      --accent-gold: #C5A44E;
      --sidebar-bg: #0F0F12;
      --page-bg: #F8F8FA;
      --surface: #fff;
      --text-primary: #111118;
      --text-secondary: #6E6E78;
      --text-muted: #9D9DA7;
      --border: rgba(0,0,0,0.06);
      --border-strong: rgba(0,0,0,0.1);
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
      --shadow-md: 0 2px 8px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--page-bg);
      color: var(--text-primary);
      display: flex;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 260px;
      background: var(--sidebar-bg);
      color: #fff;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 100;
      overflow: hidden;
    }
    .sidebar::before {
      content: '';
      position: absolute;
      top: -40%;
      left: -20%;
      width: 140%;
      height: 100%;
      background: radial-gradient(ellipse at 30% 20%, rgba(0,50,98,0.08), transparent 60%);
      pointer-events: none;
    }

    .sidebar-brand {
      padding: 28px 24px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      position: relative;
    }
    .sidebar-brand h2 {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.3px;
    }
    .sidebar-brand span {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: rgba(255,255,255,0.35);
      display: block;
      margin-top: 3px;
    }

    .sidebar-nav {
      flex: 1;
      padding: 16px 12px;
      position: relative;
    }
    .sidebar-nav a {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.15s ease;
      gap: 12px;
      border-radius: 10px;
      margin-bottom: 2px;
      position: relative;
    }
    .sidebar-nav a svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.6;
      transition: opacity 0.15s;
    }
    .sidebar-nav a:hover {
      color: rgba(255,255,255,0.85);
      background: rgba(255,255,255,0.05);
    }
    .sidebar-nav a:hover svg { opacity: 0.85; }
    .sidebar-nav a.active {
      color: #fff;
      background: rgba(0,50,98,0.25);
    }
    .sidebar-nav a.active svg { opacity: 1; }
    .sidebar-nav a.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      bottom: 8px;
      width: 3px;
      border-radius: 0 3px 3px 0;
      background: linear-gradient(180deg, var(--accent), var(--accent-light));
    }
    .sidebar-nav .badge {
      background: var(--accent);
      color: #fff;
      font-size: 11px;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 10px;
      margin-left: auto;
    }

    /* ── Sidebar dropdown ── */
    .sidebar-dropdown-toggle {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.15s ease;
      gap: 12px;
      border-radius: 10px;
      margin-bottom: 2px;
      position: relative;
      cursor: pointer;
      border: none;
      background: none;
      width: 100%;
      font-family: inherit;
    }
    .sidebar-dropdown-toggle svg { width: 20px; height: 20px; flex-shrink: 0; opacity: 0.6; transition: opacity 0.15s; }
    .sidebar-dropdown-toggle:hover { color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); }
    .sidebar-dropdown-toggle:hover svg { opacity: 0.85; }
    .sidebar-dropdown-toggle.open { color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); }
    .sidebar-dropdown-toggle .chevron {
      margin-left: auto; width: 16px; height: 16px; transition: transform 0.2s ease; opacity: 0.4;
    }
    .sidebar-dropdown-toggle.open .chevron { transform: rotate(180deg); opacity: 0.7; }

    .sidebar-subnav {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .sidebar-subnav.open { max-height: 200px; }
    .sidebar-subnav a {
      display: flex;
      align-items: center;
      padding: 8px 14px 8px 46px;
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: all 0.15s ease;
      border-radius: 8px;
      margin-bottom: 1px;
    }
    .sidebar-subnav a:hover { color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.04); }
    .sidebar-subnav a.active { color: #fff; background: rgba(0,50,98,0.2); }

    .sidebar-user {
      padding: 20px 24px;
      border-top: 1px solid rgba(255,255,255,0.04);
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
    }
    .sidebar-user .avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
      flex-shrink: 0;
    }
    .sidebar-user .info { flex: 1; min-width: 0; }
    .sidebar-user .info .name {
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sidebar-user .info .role {
      font-size: 11px;
      color: rgba(255,255,255,0.35);
    }
    .sidebar-user .logout {
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      font-size: 12px;
      font-weight: 500;
      transition: color 0.15s;
    }
    .sidebar-user .logout:hover { color: #EF4444; }

    /* ── Main content area ── */
    .main {
      margin-left: 260px;
      flex: 1;
      min-height: 100vh;
    }

    /* ── Frosted glass topbar ── */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(248,248,250,0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 18px 36px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .topbar h1 {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: var(--text-primary);
    }

    .content {
      padding: 32px 36px;
    }

    /* ── Staggered content reveal ── */
    .content > *:nth-child(1) { animation: fadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both; }
    .content > *:nth-child(2) { animation: fadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both; }
    .content > *:nth-child(3) { animation: fadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both; }
    .content > *:nth-child(4) { animation: fadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both; }
    .content > *:nth-child(5) { animation: fadeInUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both; }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Cards ── */
    .card {
      background: var(--surface);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      padding: 24px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .card:hover {
      box-shadow: var(--shadow-md);
    }
    .card h3 {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 16px;
    }

    /* ── Stats grid ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: var(--surface);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      padding: 22px 24px;
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }
    .stat-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
    }
    .stat-card .label {
      font-size: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }
    .stat-card .value {
      font-size: 32px;
      font-weight: 300;
      margin-top: 6px;
      color: var(--text-primary);
      letter-spacing: -0.5px;
    }
    .stat-card .sub {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 2px;
    }

    /* ── Tables ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    thead th {
      text-align: left;
      padding: 10px 14px;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-strong);
    }
    tbody td {
      padding: 13px 14px;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
    }
    tbody tr {
      transition: background 0.1s ease;
    }
    tbody tr:hover {
      background: var(--accent-wash);
    }
    tbody tr:last-child td { border-bottom: none; }

    /* ── Status badges (Linear-style with dot indicators) ── */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: var(--radius-sm);
      font-size: 12px;
      font-weight: 600;
    }
    .status-badge::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .status-draft { background: rgba(0,0,0,0.04); color: var(--text-secondary); }
    .status-draft::before { background: var(--text-muted); }
    .status-submitted { background: rgba(0,50,98,0.08); color: #003262; }
    .status-submitted::before { background: var(--accent); }
    .status-in_review { background: rgba(245,158,11,0.08); color: #D97706; }
    .status-in_review::before { background: #F59E0B; animation: pulse-dot 2s ease-in-out infinite; }
    .status-approved { background: rgba(34,197,94,0.08); color: #16A34A; }
    .status-approved::before { background: #22C55E; }
    .status-live { background: rgba(34,197,94,0.08); color: #16A34A; }
    .status-live::before { background: #22C55E; }
    .status-rejected { background: rgba(239,68,68,0.08); color: #DC2626; }
    .status-rejected::before { background: #EF4444; }
    .status-pending { background: rgba(245,158,11,0.08); color: #D97706; }
    .status-pending::before { background: #F59E0B; animation: pulse-dot 2s ease-in-out infinite; }
    .status-processing { background: rgba(0,50,98,0.08); color: #003262; }
    .status-processing::before { background: var(--accent); animation: pulse-dot 2s ease-in-out infinite; }
    .status-paid { background: rgba(34,197,94,0.08); color: #16A34A; }
    .status-paid::before { background: #22C55E; }
    .status-cancelled { background: rgba(239,68,68,0.08); color: #DC2626; }
    .status-cancelled::before { background: #EF4444; }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 18px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      color: #fff;
      box-shadow: 0 2px 8px rgba(0,50,98,0.25);
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(0,50,98,0.35);
    }
    .btn-primary:active { transform: scale(0.97); box-shadow: 0 2px 6px rgba(0,50,98,0.25); }
    .btn-secondary {
      background: var(--surface);
      color: var(--text-primary);
      border: 1px solid var(--border-strong);
      box-shadow: var(--shadow-sm);
    }
    .btn-secondary:hover {
      background: var(--page-bg);
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }
    .btn-danger {
      background: linear-gradient(135deg, #EF4444, #F87171);
      color: #fff;
      box-shadow: 0 2px 8px rgba(239,68,68,0.25);
    }
    .btn-danger:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(239,68,68,0.35);
    }
    .btn-sm { padding: 6px 14px; font-size: 13px; }

    /* ── Forms ── */
    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 6px;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 10px 14px;
      background: #F8F8FA;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 14px;
      font-family: inherit;
      color: var(--text-primary);
      transition: all 0.2s ease;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      background: #fff;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder { color: var(--text-muted); }
    .form-group textarea { min-height: 100px; resize: vertical; }
    .form-group .hint { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
    .form-group .error { font-size: 12px; color: #EF4444; margin-top: 4px; }

    /* ── Flash messages ── */
    .flash {
      padding: 14px 20px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      animation: flashSlideDown 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .flash::before { font-size: 16px; }
    .flash-notice {
      background: rgba(34,197,94,0.06);
      color: #16A34A;
      border-left: 3px solid #22C55E;
    }
    .flash-notice::before { content: '\2713'; }
    .flash-alert {
      background: rgba(239,68,68,0.06);
      color: #DC2626;
      border-left: 3px solid #EF4444;
    }
    .flash-alert::before { content: '\26A0'; }

    @keyframes flashSlideDown {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Messages ── */
    .message-list { display: flex; flex-direction: column; gap: 12px; }
    .message-item {
      padding: 18px;
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      background: var(--surface);
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.15s ease;
    }
    .message-item:hover { box-shadow: var(--shadow-md); }
    .message-item.from-admin {
      background: linear-gradient(135deg, rgba(0,50,98,0.03), rgba(0,50,98,0.02));
      border-color: rgba(0,50,98,0.1);
    }
    .message-item .meta {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 8px;
      display: flex;
      justify-content: space-between;
    }
    .message-item .meta .sender { font-weight: 600; color: var(--text-primary); }
    .message-item .body { font-size: 14px; line-height: 1.6; color: var(--text-secondary); }

    /* ── Pagination ── */
    .pagination {
      display: flex;
      gap: 4px;
      margin-top: 24px;
      justify-content: center;
    }
    .pagination a, .pagination span {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
      font-size: 13px;
      font-weight: 500;
      text-decoration: none;
      color: var(--text-secondary);
      transition: all 0.15s ease;
    }
    .pagination a:hover {
      background: var(--surface);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }
    .pagination .current {
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      color: #fff;
      box-shadow: 0 2px 8px rgba(0,50,98,0.3);
    }

    /* ── Bar chart ── */
    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      height: 200px;
      padding: 0 12px;
      border-bottom: 1px solid var(--border);
      position: relative;
    }
    .bar-chart::before,
    .bar-chart::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      border-top: 1px dashed rgba(0,0,0,0.04);
    }
    .bar-chart::before { top: 33%; }
    .bar-chart::after { top: 66%; }
    .bar-chart .bar-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .bar-chart .bar {
      width: 100%;
      max-width: 48px;
      background: linear-gradient(180deg, var(--accent), var(--accent-light));
      border-radius: 6px 6px 0 0;
      min-height: 4px;
      transition: filter 0.15s ease;
      animation: barGrow 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }
    .bar-chart .bar:hover { filter: brightness(1.15); }
    .bar-chart .bar-label {
      font-size: 10px;
      color: var(--text-muted);
      margin-top: 8px;
      text-align: center;
      font-weight: 500;
    }

    @keyframes barGrow {
      from { transform: scaleY(0); transform-origin: bottom; }
      to { transform: scaleY(1); transform-origin: bottom; }
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 64px 24px;
      color: var(--text-muted);
    }
    .empty-state h3 {
      color: var(--text-primary);
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .empty-state p {
      font-size: 14px;
      margin-bottom: 20px;
      color: var(--text-secondary);
    }

    /* ── Two column layout ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; } }

    /* ── Utility classes ── */
    .detail-label { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
    .text-muted { color: var(--text-muted); }
    .text-secondary { color: var(--text-secondary); }

    /* ── Hamburger menu button ── */
    .mobile-menu-btn {
      display: none;
      width: 44px;
      height: 44px;
      border: none;
      background: none;
      cursor: pointer;
      color: var(--text-primary);
      padding: 0;
      flex-shrink: 0;
    }
    .mobile-menu-btn svg { width: 24px; height: 24px; }

    /* ── Sidebar overlay ── */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 99;
      -webkit-tap-highlight-color: transparent;
    }
    .sidebar-overlay.open { display: block; }

    /* ── Mobile breakpoint ── */
    @media (max-width: 768px) {
      .mobile-menu-btn { display: flex; align-items: center; justify-content: center; }

      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.25s ease;
      }
      .sidebar.open { transform: translateX(0); }

      .main { margin-left: 0; }

      .topbar {
        padding: 12px 16px;
        gap: 8px;
      }
      .topbar h1 { font-size: 20px; }

      .content { padding: 16px; }

      .stats-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
      .stat-card { padding: 16px; }
      .stat-card .value { font-size: 24px; }

      .two-col { grid-template-columns: 1fr; }

      .card { padding: 18px; }

      .btn { padding: 10px 16px; min-height: 44px; }
      .btn-sm { min-height: 36px; }

      .sidebar-nav a { padding: 12px 14px; min-height: 44px; }
    }

    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .content > * { animation: none !important; }
      .flash { animation: none !important; }
      .bar-chart .bar { animation: none !important; }
      .stat-card:hover,
      .btn-primary:hover,
      .btn-secondary:hover,
      .btn-danger:hover { transform: none; }
      .btn:active { transform: none; }
      .status-badge::before { animation: none !important; }
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sidebar-brand">
      <h2>Premiere</h2>
      <span>Creators Portal</span>
    </div>
    <nav class="sidebar-nav">
      <% if defined?(current_campaign) && current_campaign %>
        <a href="<%= portal_campaign_path(current_campaign) %>" class="<%= 'active' if controller_name == 'campaigns' && action_name == 'show' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          Campaign
        </a>
        <a href="<%= portal_campaign_campaign_assets_path(current_campaign) %>" class="<%= 'active' if controller_name == 'campaign_assets' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Content
        </a>
        <a href="<%= links_portal_campaign_path(current_campaign) %>" class="<%= 'active' if controller_name == 'campaigns' && action_name.in?(%w[links update_links]) %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          Links
        </a>
        <a href="<%= portal_campaign_landing_page_path(current_campaign) %>" class="<%= 'active' if controller_name == 'landing_pages' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          Landing Page
        </a>
        <% if current_campaign.deliverables_enabled? %>
          <% del_pending = current_campaign.admin_deliverables.pending.count %>
          <a href="<%= portal_campaign_deliverables_path(current_campaign) %>" class="<%= 'active' if controller_name == 'deliverables' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/></svg>
            Deliverables
            <% if del_pending > 0 %>
              <span class="badge"><%= del_pending %></span>
            <% end %>
          </a>
        <% end %>
        <% studio_active = controller_name == 'live_events' && action_name.in?(%w[studio recorder]) %>
        <button class="sidebar-dropdown-toggle <%= 'open' if studio_active %>" onclick="toggleStudioMenu(this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg>
          Studio
          <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="sidebar-subnav <%= 'open' if studio_active %>" id="studioSubnav">
          <a href="<%= recorder_portal_campaign_live_events_path(current_campaign) %>" class="<%= 'active' if controller_name == 'live_events' && action_name == 'recorder' %>">Record</a>
          <a href="<%= studio_portal_campaign_live_events_path(current_campaign) %>" class="<%= 'active' if controller_name == 'live_events' && action_name == 'studio' %>">Go Live</a>
        </div>
        <% social_active = controller_name.in?(%w[social_posts social_calendar social_performance]) %>
        <button class="sidebar-dropdown-toggle <%= 'open' if social_active %>" onclick="toggleSocialMenu(this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          Social
          <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="sidebar-subnav <%= 'open' if social_active %>" id="socialSubnav">
          <a href="<%= portal_campaign_social_calendar_index_path(current_campaign) %>" class="<%= 'active' if controller_name == 'social_calendar' %>">Content Calendar</a>
          <a href="<%= portal_campaign_social_posts_path(current_campaign) %>" class="<%= 'active' if controller_name == 'social_posts' %>">Post Generator</a>
          <a href="<%= portal_campaign_social_performance_index_path(current_campaign) %>" class="<%= 'active' if controller_name == 'social_performance' %>">Performance</a>
        </div>
        <% fans_active = controller_name.in?(%w[contacts drip_campaigns referrals]) %>
        <button class="sidebar-dropdown-toggle <%= 'open' if fans_active %>" onclick="toggleFansMenu(this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Fans
          <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="sidebar-subnav <%= 'open' if fans_active %>" id="fansSubnav">
          <a href="<%= portal_campaign_contacts_path(current_campaign) %>" class="<%= 'active' if controller_name == 'contacts' %>">Fan CRM</a>
          <a href="<%= portal_campaign_drip_campaigns_path(current_campaign) %>" class="<%= 'active' if controller_name == 'drip_campaigns' %>">Drip Campaigns</a>
          <a href="<%= portal_campaign_referrals_path(current_campaign) %>" class="<%= 'active' if controller_name == 'referrals' %>">Referrals</a>
        </div>
      <% end %>
      <a href="<%= portal_messages_path %>" class="<%= 'active' if controller_name == 'messages' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        Messages
        <% if defined?(unread_message_count) && unread_message_count > 0 %>
          <span class="badge"><%= unread_message_count %></span>
        <% end %>
      </a>
      <% if defined?(current_campaign) && current_campaign %>
        <div style="border-top:1px solid rgba(255,255,255,0.04);margin:8px 0;"></div>
      <% end %>
      <a href="<%= portal_sales_path %>" class="<%= 'active' if controller_name == 'sales' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        Sales
      </a>
      <a href="<%= portal_royalties_path %>" class="<%= 'active' if controller_name == 'royalties' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/></svg>
        Royalties
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="avatar"><%= current_user.initials %></div>
      <div class="info">
        <div class="name"><%= current_user.full_name %></div>
        <div class="role">Creator</div>
      </div>
      <%= button_to 'Logout', destroy_user_session_path, method: :delete, class: 'logout', form: { style: 'display:inline' }, style: 'background:none;border:none;cursor:pointer;font-family:inherit;' %>
    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <div class="main">
    <div class="topbar">
      <button class="mobile-menu-btn" onclick="toggleSidebar()" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <h1><%= yield :page_title %></h1>
      <div style="display:flex;align-items:center;gap:12px;">
        <!-- Notification bell -->
        <div style="position:relative;" id="notifBellWrap">
          <button onclick="toggleNotifDropdown()" style="background:none;border:none;cursor:pointer;padding:6px;position:relative;color:var(--text-secondary);" aria-label="Notifications">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            <% if defined?(unread_notification_count) && unread_notification_count > 0 %>
              <span style="position:absolute;top:2px;right:2px;width:16px;height:16px;background:#EF4444;color:#fff;border-radius:50%;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;line-height:1;"><%= unread_notification_count > 9 ? '9+' : unread_notification_count %></span>
            <% end %>
          </button>
          <div id="notifDropdown" style="display:none;position:absolute;right:0;top:100%;margin-top:8px;width:340px;max-height:420px;overflow-y:auto;background:#fff;border-radius:12px;border:1px solid var(--border-strong);box-shadow:var(--shadow-lg);z-index:200;">
            <div style="padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
              <span style="font-size:13px;font-weight:700;">Notifications</span>
              <% if defined?(unread_notification_count) && unread_notification_count > 0 %>
                <%= button_to 'Mark all read', mark_all_read_portal_notifications_path, method: :patch, style: 'background:none;border:none;cursor:pointer;font-size:11px;font-weight:600;color:var(--accent);font-family:inherit;padding:0;', form: { style: 'display:inline' } %>
              <% end %>
            </div>
            <div id="notifDropdownContent" style="font-size:13px;">
              <div style="padding:24px;text-align:center;color:var(--text-muted);font-size:12px;">Loading...</div>
            </div>
          </div>
        </div>
        <%= yield :page_actions %>
      </div>
    </div>
    <div class="content">
      <% if notice %><div class="flash flash-notice"><%= notice %></div><% end %>
      <% if alert %><div class="flash flash-alert"><%= alert %></div><% end %>
      <%= yield %>
    </div>
  </div>
<script>
(function() {
  var sidebar = document.querySelector('.sidebar');
  var overlay = document.getElementById('sidebarOverlay');

  window.toggleSidebar = function() {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('open');
    document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
  };

  window.closeSidebar = function() {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  // Close sidebar when a nav link is clicked (on mobile)
  sidebar.querySelectorAll('.sidebar-nav a').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth <= 768) closeSidebar();
    });
  });

  // Dropdown toggles
  window.toggleSocialMenu = function(btn) {
    btn.classList.toggle('open');
    var subnav = btn.nextElementSibling;
    subnav.classList.toggle('open');
  };

  window.toggleStudioMenu = function(btn) {
    btn.classList.toggle('open');
    var subnav = btn.nextElementSibling;
    subnav.classList.toggle('open');
  };

  window.toggleFansMenu = function(btn) {
    btn.classList.toggle('open');
    var subnav = btn.nextElementSibling;
    subnav.classList.toggle('open');
  };

  // Notification dropdown
  var notifOpen = false;
  var notifLoaded = false;
  window.toggleNotifDropdown = function() {
    var dd = document.getElementById('notifDropdown');
    notifOpen = !notifOpen;
    dd.style.display = notifOpen ? 'block' : 'none';
    if (notifOpen && !notifLoaded) {
      fetch('<%= recent_portal_notifications_path %>', { headers: { 'Accept': 'text/html' } })
        .then(function(r) { return r.text(); })
        .then(function(html) {
          document.getElementById('notifDropdownContent').innerHTML = html;
          notifLoaded = true;
        });
    }
  };
  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('notifBellWrap');
    if (wrap && !wrap.contains(e.target) && notifOpen) {
      document.getElementById('notifDropdown').style.display = 'none';
      notifOpen = false;
    }
  });
})();
</script>
</body>
</html>
