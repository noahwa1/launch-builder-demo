<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Helvetica, Arial, sans-serif; font-size: 12px; color: #333; }
    h1 { font-size: 20px; margin-bottom: 4px; }
    h2 { font-size: 14px; color: #666; margin-bottom: 20px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th { text-align: left; padding: 8px; font-size: 10px; text-transform: uppercase; color: #666; border-bottom: 2px solid #333; }
    td { padding: 8px; border-bottom: 1px solid #ddd; }
    .total td { border-top: 2px solid #333; font-weight: bold; }
    .header { border-bottom: 2px solid #333; padding-bottom: 16px; margin-bottom: 20px; }
    .meta { color: #666; font-size: 11px; }
    .footer { margin-top: 40px; padding-top: 12px; border-top: 1px solid #ddd; font-size: 10px; color: #999; text-align: center; }
  </style>
</head>
<body>
  <%= yield %>
  <div class="footer">Launch Publishing &mdash; Royalty Statement &mdash; Generated <%= Date.today.strftime('%B %d, %Y') %></div>
</body>
</html>
