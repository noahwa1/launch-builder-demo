<!DOCTYPE html>
<html>
<head>
  <title>Sign Up — Launch Creators Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: #0F0F12;
    }

    /* -- Animated gradient mesh background -- */
    .bg-mesh {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 40%, rgba(79,70,229,0.35), transparent),
        radial-gradient(ellipse 60% 80% at 80% 20%, rgba(124,58,237,0.25), transparent),
        radial-gradient(ellipse 70% 50% at 60% 80%, rgba(79,70,229,0.2), transparent),
        radial-gradient(ellipse 90% 70% at 40% 60%, rgba(99,102,241,0.15), transparent);
      background-size: 200% 200%;
      animation: meshShift 30s ease-in-out infinite;
    }
    .bg-mesh::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 40%, rgba(15,15,18,0.6));
    }

    @keyframes meshShift {
      0%, 100% { background-position: 0% 0%; }
      25% { background-position: 100% 50%; }
      50% { background-position: 50% 100%; }
      75% { background-position: 0% 50%; }
    }

    /* -- Login card -- */
    .login-card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.5);
      border-radius: 20px;
      padding: 48px 40px 40px;
      width: 100%;
      max-width: 420px;
      box-shadow:
        0 4px 6px rgba(0,0,0,0.04),
        0 12px 24px rgba(0,0,0,0.08),
        0 32px 64px rgba(0,0,0,0.16);
      animation: cardEntrance 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes cardEntrance {
      from {
        opacity: 0;
        transform: translateY(24px) scale(0.97);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    /* -- Brand header -- */
    .brand { text-align: center; margin-bottom: 36px; }
    .brand h1 {
      font-size: 28px;
      font-weight: 800;
      color: #111118;
      letter-spacing: -0.5px;
      line-height: 1.1;
    }
    .brand .subtitle {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: #6E6E78;
      margin-top: 6px;
    }
    .brand .accent-line {
      width: 40px;
      height: 3px;
      background: linear-gradient(135deg, #4F46E5, #7C3AED);
      border-radius: 2px;
      margin: 12px auto 0;
    }

    /* -- Flash messages -- */
    .flash {
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
      animation: slideDown 0.3s ease both;
    }
    .flash::before { font-size: 16px; }
    .flash-alert {
      background: rgba(239,68,68,0.08);
      color: #DC2626;
      border-left: 3px solid #DC2626;
    }
    .flash-alert::before { content: '\26A0'; }
    .flash-notice {
      background: rgba(34,197,94,0.08);
      color: #16A34A;
      border-left: 3px solid #16A34A;
    }
    .flash-notice::before { content: '\2713'; }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* -- Validation errors -- */
    .error-list {
      padding: 14px 16px;
      border-radius: 10px;
      background: rgba(239,68,68,0.08);
      border-left: 3px solid #DC2626;
      margin-bottom: 20px;
      animation: slideDown 0.3s ease both;
    }
    .error-list h3 {
      font-size: 13px;
      font-weight: 600;
      color: #DC2626;
      margin-bottom: 6px;
    }
    .error-list ul {
      list-style: none;
      padding: 0;
    }
    .error-list ul li {
      font-size: 12px;
      color: #DC2626;
      padding: 2px 0;
    }
    .error-list ul li::before {
      content: '\2022';
      margin-right: 6px;
    }

    /* -- Form fields -- */
    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #111118;
      margin-bottom: 6px;
    }
    .form-group input[type="email"],
    .form-group input[type="password"],
    .form-group input[type="text"] {
      width: 100%;
      padding: 12px 14px;
      background: #F8F8FA;
      border: 1.5px solid rgba(0,0,0,0.06);
      border-radius: 10px;
      font-size: 14px;
      font-family: inherit;
      color: #111118;
      transition: all 0.2s ease;
    }
    .form-group input:focus {
      outline: none;
      background: #fff;
      border-color: #4F46E5;
      box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
    }
    .form-group input::placeholder { color: #9D9DA7; }

    /* -- Side-by-side name fields -- */
    .name-row {
      display: flex;
      gap: 12px;
    }
    .name-row .form-group {
      flex: 1;
    }

    /* -- Sign-up button -- */
    .btn-login {
      display: block;
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #4F46E5, #6366F1);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(79,70,229,0.3);
      margin-top: 8px;
    }
    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(79,70,229,0.4);
    }
    .btn-login:active {
      transform: scale(0.97);
      box-shadow: 0 2px 6px rgba(79,70,229,0.3);
    }

    /* -- Sign-in link -- */
    .signup-link {
      text-align: center;
      margin-top: 24px;
      font-size: 13px;
      color: #6E6E78;
    }
    .signup-link a {
      color: #4F46E5;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.15s;
    }
    .signup-link a:hover { color: #4338CA; }

    /* -- Demo info -- */
    .demo-info {
      margin-top: 24px;
      padding: 16px;
      background: #F8F8FA;
      border: 1px solid rgba(0,0,0,0.04);
      border-radius: 10px;
      font-size: 12px;
      color: #6E6E78;
      line-height: 1.6;
    }
    .demo-info strong { color: #111118; font-weight: 600; }

    /* -- Reduced motion -- */
    @media (prefers-reduced-motion: reduce) {
      .bg-mesh { animation: none; }
      .login-card { animation: none; }
      .flash { animation: none; }
      .error-list { animation: none; }
      .btn-login { transition: none; }
      .btn-login:hover { transform: none; }
      .btn-login:active { transform: none; }
    }
  </style>
</head>
<body>
  <div class="bg-mesh"></div>

  <div class="login-card">
    <div class="brand">
      <h1>Launch</h1>
      <div class="subtitle">Creators Portal</div>
      <div class="accent-line"></div>
    </div>

    <% if alert %><div class="flash flash-alert"><%= alert %></div><% end %>
    <% if notice %><div class="flash flash-notice"><%= notice %></div><% end %>

    <% if resource.errors.any? %>
      <div class="error-list">
        <h3><%= pluralize(resource.errors.count, "error") %> prevented sign up:</h3>
        <ul>
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="name-row">
        <div class="form-group">
          <%= f.label :first_name %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "First name" %>
        </div>

        <div class="form-group">
          <%= f.label :last_name %>
          <%= f.text_field :last_name, autocomplete: "family-name", placeholder: "Last name" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "Password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm password" %>
      </div>

      <%= f.submit "Sign up", class: "btn-login" %>
    <% end %>

    <div class="signup-link">
      Already have an account? <%= link_to "Sign in", new_session_path(resource_name) %>
    </div>

    <div class="demo-info">
      <strong>Demo accounts:</strong><br>
      Creator: creator@launch.com / password<br>
      Admin: admin@launch.com / password
    </div>
  </div>
</body>
</html>
