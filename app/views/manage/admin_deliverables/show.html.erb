<% content_for :page_title, @deliverable.title %>
<% content_for :page_actions do %>
  <%= link_to 'Edit', edit_manage_campaign_admin_deliverable_path(@campaign, @deliverable), class: 'btn btn-secondary btn-sm' %>
  <%= link_to 'All Deliverables', manage_campaign_admin_deliverables_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<style>
  .del-detail { display: grid; grid-template-columns: 1fr 340px; gap: 16px; }
  @media (max-width: 900px) { .del-detail { grid-template-columns: 1fr; } }
  .note-thread { margin-top: 4px; }
  .note-item {
    display: flex; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--border);
  }
  .note-avatar {
    width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center;
    justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0;
  }
  .note-avatar.admin { background: var(--accent); color: #fff; }
  .note-avatar.creator { background: #F59E0B; color: #fff; }
  .note-body { flex: 1; }
  .note-body .header { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .note-body .header strong { color: var(--text-primary); }
  .note-body .text { font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
</style>

<div class="del-detail">
  <!-- Main Column -->
  <div>
    <div class="card">
      <div class="d-flex justify-between mb-16" style="align-items:flex-start;">
        <div>
          <span class="fw-600 text-muted text-upper" style="padding:2px 8px;border-radius:4px;font-size:10px;background:rgba(0,0,0,0.04);"><%= @deliverable.category_label %></span>
          <% if @deliverable.revision_count > 0 %>
            <span class="fw-600" style="padding:2px 8px;border-radius:4px;font-size:10px;background:rgba(99,102,241,0.08);color:#6366F1;margin-left:4px;">v<%= @deliverable.revision_count + 1 %></span>
          <% end %>
        </div>
        <span class="rounded text-xs fw-700 text-upper" style="padding:4px 12px;color:<%= @deliverable.status_color %>;background:rgba(0,0,0,0.04);">
          <%= @deliverable.status.titleize %>
        </span>
      </div>

      <h2 class="fw-700 mb-8" style="font-size:20px;"><%= @deliverable.title %></h2>

      <% if @deliverable.description.present? %>
        <div class="text-base text-secondary mb-16" style="line-height:1.7;white-space:pre-wrap;"><%= @deliverable.description %></div>
      <% end %>

      <% if @deliverable.file.present? %>
        <div class="p-16 border mb-16" style="background:var(--page-bg);border-radius:var(--radius-sm);">
          <div class="d-flex items-center" style="gap:10px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="color:var(--accent);flex-shrink:0;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            <div class="flex-1">
              <div class="text-md fw-600"><%= File.basename(@deliverable.file.url) rescue 'Attached file' %></div>
            </div>
            <a href="<%= @deliverable.file.url %>" target="_blank" class="btn btn-secondary btn-sm">Download</a>
          </div>
          <% ext = File.extname(@deliverable.file.url).downcase rescue '' %>
          <% if %w[.jpg .jpeg .png .gif .webp].include?(ext) %>
            <img src="<%= @deliverable.file.url %>" class="w-full rounded-md mt-12" style="max-width:100%;">
          <% end %>
        </div>
      <% end %>

      <% if @deliverable.creator_notes.present? %>
        <div class="p-12 mb-16" style="background:rgba(239,68,68,0.04);border-left:3px solid #EF4444;border-radius:0 8px 8px 0;">
          <div class="text-xs fw-600 text-upper" style="color:#EF4444;margin-bottom:4px;">Creator's Revision Notes</div>
          <div class="text-md" style="white-space:pre-wrap;"><%= @deliverable.creator_notes %></div>
        </div>
      <% end %>
    </div>

    <!-- Notes Thread -->
    <div class="card note-thread">
      <h3 class="subheading">Notes & Conversation</h3>
      <% if @notes.any? %>
        <% @notes.each do |note| %>
          <div class="note-item">
            <div class="note-avatar <%= note.user.admin? ? 'admin' : 'creator' %>"><%= note.user.initials %></div>
            <div class="note-body">
              <div class="header"><strong><%= note.user.full_name %></strong> · <%= time_ago_in_words(note.created_at) %> ago</div>
              <div class="text"><%= note.body %></div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-md text-muted text-center p-16">No notes yet.</p>
      <% end %>

      <!-- Add Note -->
      <%= form_tag add_note_manage_campaign_admin_deliverable_path(@campaign, @deliverable), style: 'padding-top:16px;border-top:1px solid var(--border);', class: 'd-flex gap-8 mt-16' do %>
        <input type="text" name="body" placeholder="Add a note..." required class="flex-1 text-md rounded-md border" style="padding:8px 12px;font-family:inherit;">
        <button type="submit" class="btn btn-secondary btn-sm">Send</button>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div>
    <!-- Info -->
    <div class="card">
      <h4 class="text-md fw-700 mb-12">Details</h4>
      <div class="text-md" style="display:flex;flex-direction:column;gap:10px;">
        <div>
          <div class="detail-label">Created by</div>
          <div><%= @deliverable.creator&.full_name %></div>
        </div>
        <div>
          <div class="detail-label">Created</div>
          <div><%= @deliverable.created_at.strftime('%b %d, %Y at %I:%M %p') %></div>
        </div>
        <% if @deliverable.due_date.present? %>
          <div>
            <div class="detail-label">Due date</div>
            <div class="fw-600" style="color:<%= @deliverable.due_date < Date.today ? '#EF4444' : 'var(--text-primary)' %>;"><%= @deliverable.due_date.strftime('%b %d, %Y') %></div>
          </div>
        <% end %>
        <div>
          <div class="detail-label">Revisions</div>
          <div><%= @deliverable.revision_count %></div>
        </div>
      </div>
    </div>

    <!-- Upload Revision -->
    <% if @deliverable.revision_requested? %>
      <div class="card mt-4" style="border:1px solid rgba(239,68,68,0.2);">
        <h4 class="text-md fw-700 mb-12" style="color:#EF4444;">Revision Requested</h4>
        <p class="text-md text-secondary mb-12">Upload a revised version to send back for review.</p>
        <%= form_tag revise_manage_campaign_admin_deliverable_path(@campaign, @deliverable), method: :patch, multipart: true do %>
          <div style="margin-bottom:10px;">
            <input type="file" name="file" class="text-md">
          </div>
          <div style="margin-bottom:10px;">
            <input type="text" name="note" placeholder="Note about what changed..." class="w-full text-md rounded-md border" style="padding:8px 12px;font-family:inherit;">
          </div>
          <button type="submit" class="btn btn-primary btn-sm w-full">Upload Revision</button>
        <% end %>
      </div>
    <% end %>

    <!-- Danger Zone -->
    <div class="card mt-4">
      <%= link_to 'Delete Deliverable', manage_campaign_admin_deliverable_path(@campaign, @deliverable), method: :delete, data: { confirm: 'Delete this deliverable?' }, class: 'text-sm text-danger' %>
    </div>
  </div>
</div>
