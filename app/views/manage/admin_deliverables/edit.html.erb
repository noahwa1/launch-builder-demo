<% content_for :page_title, "Edit: #{@deliverable.title}" %>
<% content_for :page_actions do %>
  <%= link_to '← Back', manage_campaign_admin_deliverable_path(@campaign, @deliverable), class: 'btn btn-secondary btn-sm' %>
<% end %>

<div class="card" style="max-width:600px;">
  <h3 style="margin-bottom:16px;">Edit Deliverable</h3>

  <%= form_for @deliverable, url: manage_campaign_admin_deliverable_path(@campaign, @deliverable), html: { multipart: true } do |f| %>
    <div class="form-group" style="margin-bottom:14px;">
      <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">Title *</label>
      <%= f.text_field :title, style: 'width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;' %>
    </div>

    <div class="form-group" style="margin-bottom:14px;">
      <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">Category *</label>
      <%= f.select :category, AdminDeliverable::CATEGORIES.map { |c| [c.titleize, c] }, {}, style: 'width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;' %>
    </div>

    <div class="form-group" style="margin-bottom:14px;">
      <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">Description</label>
      <%= f.text_area :description, rows: 4, style: 'width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;resize:vertical;' %>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:14px;">
      <div class="form-group">
        <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">Replace File</label>
        <%= f.file_field :file, style: 'font-size:13px;' %>
        <% if @deliverable.file.present? %>
          <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Current: <%= File.basename(@deliverable.file.url) rescue 'uploaded' %></p>
        <% end %>
      </div>
      <div class="form-group">
        <label style="display:block;font-size:12px;font-weight:600;color:var(--text-secondary);margin-bottom:5px;">Feedback Due By</label>
        <%= f.date_field :due_date, style: 'width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;' %>
      </div>
    </div>

    <div style="display:flex;gap:12px;">
      <%= f.submit 'Save Changes', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', manage_campaign_admin_deliverable_path(@campaign, @deliverable), class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
