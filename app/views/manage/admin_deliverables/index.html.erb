<% content_for :page_title, "Deliverables — #{@campaign.title}" %>
<% content_for :page_actions do %>
  <%= link_to 'New Deliverable', new_manage_campaign_admin_deliverable_path(@campaign), class: 'btn btn-primary btn-sm' %>
  <%= link_to 'Back to Campaign', manage_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<style>
  .del-stats { display: flex; gap: 12px; margin-bottom: 20px; }
  .del-stat {
    flex: 1; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: 16px; text-align: center;
  }
  .del-stat .num { font-size: 28px; font-weight: 800; }
  .del-stat .label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }
  .del-card {
    display: flex; align-items: center; gap: 14px; padding: 14px 16px;
    border-bottom: 1px solid var(--border); transition: background 0.1s;
  }
  .del-card:hover { background: var(--accent-wash); }
  .del-card:last-child { border-bottom: none; }
  .del-icon {
    width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center;
    justify-content: center; flex-shrink: 0; font-size: 18px;
  }
  .del-info { flex: 1; }
  .del-info h4 { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .del-info h4 a { color: var(--text-primary); text-decoration: none; }
  .del-info h4 a:hover { color: var(--accent); }
  .del-info .meta { font-size: 12px; color: var(--text-muted); display: flex; gap: 12px; }
  .del-status {
    padding: 3px 10px; border-radius: 6px; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.3px; white-space: nowrap;
  }
  .del-cat {
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
    background: rgba(0,0,0,0.04); color: var(--text-muted); text-transform: uppercase;
  }
</style>

<div class="del-stats">
  <div class="del-stat">
    <div class="num"><%= @deliverables.count %></div>
    <div class="label">Total</div>
  </div>
  <div class="del-stat">
    <div class="num" style="color:#D97706;"><%= @pending_count %></div>
    <div class="label">Awaiting Review</div>
  </div>
  <div class="del-stat">
    <div class="num" style="color:#EF4444;"><%= @revision_count %></div>
    <div class="label">Needs Revision</div>
  </div>
  <div class="del-stat">
    <div class="num" style="color:#16A34A;"><%= @deliverables.approved.count %></div>
    <div class="label">Approved</div>
  </div>
</div>

<div class="card">
  <% if @deliverables.any? %>
    <% @deliverables.each do |del| %>
      <div class="del-card">
        <div class="del-icon" style="background:rgba(0,50,98,0.06);color:var(--accent);">
          <% case del.category %>
          <% when 'ad_creative' %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          <% when 'copy' %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          <% when 'video_edit' %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
          <% else %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          <% end %>
        </div>
        <div class="del-info">
          <h4><%= link_to del.title, manage_campaign_admin_deliverable_path(@campaign, del) %></h4>
          <div class="meta">
            <span class="del-cat"><%= del.category_label %></span>
            <span>by <%= del.creator&.full_name %></span>
            <span><%= time_ago_in_words(del.created_at) %> ago</span>
            <% if del.revision_count > 0 %>
              <span>v<%= del.revision_count + 1 %></span>
            <% end %>
            <% if del.due_date.present? %>
              <span style="color:<%= del.due_date < Date.today ? '#EF4444' : 'var(--text-muted)' %>;">Due <%= del.due_date.strftime('%b %d') %></span>
            <% end %>
          </div>
        </div>
        <span class="del-status" style="background:rgba(0,0,0,0.04);color:<%= del.status_color %>;"><%= del.status.titleize %></span>
      </div>
    <% end %>
  <% else %>
    <div style="text-align:center;padding:40px;color:var(--text-muted);">
      <p style="font-size:14px;font-weight:600;">No deliverables yet</p>
      <p style="font-size:13px;margin-top:4px;">Create a deliverable to send content to the creator for review.</p>
    </div>
  <% end %>
</div>
