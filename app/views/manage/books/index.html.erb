<% content_for :page_title, 'Books' %>
<% content_for :page_actions do %>
  <%= link_to 'New Book', new_manage_book_path, class: 'btn btn-primary' %>
<% end %>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Cover</th>
          <th>Title</th>
          <th>ISBN</th>
          <th>Author</th>
          <th>Publisher</th>
          <th>Release Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
          <tr>
            <td>
              <% if book.cover.present? %>
                <img src="<%= book.cover.url %>" style="width:40px;height:56px;object-fit:cover;border-radius:4px;" alt="">
              <% else %>
                <div style="width:40px;height:56px;background:var(--border);border-radius:4px;display:flex;align-items:center;justify-content:center;">
                  <span class="text-muted" style="font-size:10px;">No img</span>
                </div>
              <% end %>
            </td>
            <td style="font-weight:500;"><%= book.title %></td>
            <td class="text-muted"><%= book.isbn || '—' %></td>
            <td><%= book.author.full_name %></td>
            <td class="text-muted"><%= book.publisher&.name || '—' %></td>
            <td class="text-muted"><%= book.release_date&.strftime('%b %d, %Y') || '—' %></td>
            <td><%= link_to 'View', manage_book_path(book), class: 'btn btn-secondary btn-sm' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= paginate @books %>
</div>

<% if @books.empty? %>
  <div class="card">
    <p class="text-muted" style="text-align:center;padding:24px;">No books yet.</p>
  </div>
<% end %>
