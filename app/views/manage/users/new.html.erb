<% content_for :page_title, 'Invite User' %>
<% content_for :page_actions do %>
  <%= link_to 'All Users', manage_users_path, class: 'btn btn-secondary btn-sm' %>
<% end %>

<div class="card" style="max-width:640px;">
  <div style="padding:14px 18px;background:rgba(79,70,229,0.06);border:1px solid rgba(79,70,229,0.12);border-radius:10px;margin-bottom:24px;font-size:13px;color:var(--text-secondary);line-height:1.6;">
    <strong>Admin</strong> = team member with full admin panel access.<br>
    <strong>Creator</strong> = author/partner account with portal access. An author profile is created automatically.
  </div>

  <%= form_with model: @user, url: manage_users_path, method: :post do |f| %>
    <div class="form-group">
      <%= f.label :first_name %>
      <%= f.text_field :first_name, placeholder: 'First name' %>
    </div>
    <div class="form-group">
      <%= f.label :last_name %>
      <%= f.text_field :last_name, placeholder: 'Last name' %>
    </div>
    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, placeholder: 'user@example.com' %>
    </div>
    <div class="form-group">
      <%= f.label :password %>
      <%= f.password_field :password, placeholder: 'Minimum 6 characters' %>
    </div>
    <div class="form-group">
      <%= f.label :role %>
      <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, {} %>
    </div>
    <div style="display:flex;gap:10px;margin-top:24px;">
      <%= f.submit 'Create User', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', manage_users_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
