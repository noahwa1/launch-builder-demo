<% content_for :page_title, @user.full_name %>
<% content_for :page_actions do %>
  <%= link_to 'Edit', edit_manage_user_path(@user), class: 'btn btn-primary btn-sm' %>
  <% unless @user == current_user %>
    <%= button_to (@user.active? ? 'Disable Account' : 'Enable Account'), toggle_active_manage_user_path(@user), method: :patch, class: "btn #{@user.active? ? 'btn-danger' : 'btn-success'} btn-sm", form: { style: 'display:inline' } %>
  <% end %>
  <%= link_to 'All Users', manage_users_path, class: 'btn btn-secondary btn-sm' %>
<% end %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="label">Role</div>
    <div style="margin-top:8px;"><span class="status-badge status-<%= @user.admin? ? 'submitted' : 'approved' %>"><%= @user.role.titleize %></span></div>
  </div>
  <div class="stat-card">
    <div class="label">Status</div>
    <div style="margin-top:8px;">
      <% if @user.active? %>
        <span class="status-badge status-approved">Active</span>
      <% else %>
        <span class="status-badge status-rejected">Disabled</span>
      <% end %>
    </div>
  </div>
  <div class="stat-card">
    <div class="label">Email</div>
    <div style="font-size:14px;font-weight:500;margin-top:8px;"><%= @user.email %></div>
  </div>
  <div class="stat-card">
    <div class="label">Joined</div>
    <div style="font-size:14px;font-weight:500;margin-top:8px;"><%= @user.created_at.strftime('%B %d, %Y') %></div>
  </div>
</div>

<div class="two-col">
  <!-- User Details -->
  <div class="card">
    <h3>Details</h3>
    <div style="margin-bottom:12px;">
      <div class="detail-label">Full Name</div>
      <div style="font-size:15px;margin-top:4px;"><%= @user.full_name %></div>
    </div>
    <div style="margin-bottom:12px;">
      <div class="detail-label">Email</div>
      <div style="font-size:15px;margin-top:4px;"><%= @user.email %></div>
    </div>
    <% if @user.author %>
      <div style="margin-bottom:12px;">
        <div class="detail-label">Linked Author</div>
        <div style="font-size:15px;margin-top:4px;">
          <%= link_to @user.author.full_name, manage_author_path(@user.author), style: 'color:var(--accent);text-decoration:none;font-weight:500;' %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Campaigns (for creators) -->
  <div class="card">
    <h3>Campaigns</h3>
    <% if @campaigns.any? %>
      <% @campaigns.each do |campaign| %>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);">
          <div>
            <div style="font-size:14px;font-weight:500;"><%= campaign.title %></div>
            <div class="text-muted" style="font-size:12px;"><%= campaign.status.titleize %> — <%= campaign.progress_percentage %>%</div>
          </div>
          <%= link_to 'View', manage_campaign_path(campaign), class: 'btn btn-secondary btn-sm' %>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted" style="text-align:center;padding:16px;">
        <%= @user.admin? ? 'Admin accounts do not have campaigns.' : 'No campaigns yet.' %>
      </p>
    <% end %>
  </div>
</div>
