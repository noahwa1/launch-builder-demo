<% content_for :page_title, @campaign.title %>
<% content_for :page_actions do %>
  <%= link_to 'Edit', edit_manage_campaign_path(@campaign), class: 'btn btn-primary btn-sm' %>
  <%= button_to 'Duplicate', duplicate_manage_campaign_path(@campaign), method: :post, class: 'btn btn-secondary btn-sm', form: { style: 'display:inline' }, data: { confirm: 'Duplicate this campaign for a new project?' } %>
  <%= link_to 'All Campaigns', manage_campaigns_path, class: 'btn btn-secondary btn-sm' %>
<% end %>

<style>
  .checklist-toggle { display: inline-flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 8px; border: 1px solid var(--border); cursor: pointer; font-size: 13px; transition: all 0.15s; text-decoration: none; color: var(--text-primary); }
  .checklist-toggle:hover { border-color: var(--accent); background: var(--accent-wash); }
  .checklist-toggle.complete { background: rgba(34,197,94,0.06); border-color: rgba(34,197,94,0.2); }
  .checklist-toggle .dot { width: 8px; height: 8px; border-radius: 50%; }
  .checklist-toggle .dot.not_started { background: var(--text-muted); }
  .checklist-toggle .dot.in_progress { background: var(--accent); }
  .checklist-toggle .dot.complete { background: #22C55E; }
  .asset-review-card { border: 1px solid var(--border); border-radius: var(--radius-md); padding: 16px; margin-bottom: 12px; }
  .asset-review-actions { display: flex; gap: 8px; margin-top: 12px; }
  .notes-input { width: 100%; margin-top: 8px; }
</style>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="label">Author</div>
    <div style="font-size:16px;font-weight:600;margin-top:8px;"><%= @campaign.author.full_name %></div>
  </div>
  <div class="stat-card">
    <div class="label">Progress</div>
    <div class="value"><%= @campaign.progress_percentage %>%</div>
  </div>
  <div class="stat-card">
    <div class="label">Status</div>
    <div style="margin-top:8px;"><span class="status-badge status-<%= @campaign.status %>"><%= @campaign.status.titleize %></span></div>
  </div>
  <div class="stat-card">
    <div class="label">Pending Review</div>
    <div class="value"><%= @pending_assets.count %></div>
  </div>
</div>

<%# ── Campaign Phase ── %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <h3>Campaign Phase</h3>
    <div style="display:flex;gap:8px;align-items:center;">
      <% if @campaign.can_advance? %>
        <%= button_to "Advance to #{Campaign.phases.key(Campaign.phases[@campaign.phase] + 1)&.titleize}", advance_phase_manage_campaign_path(@campaign), method: :patch, class: 'btn btn-primary btn-sm', form: { style: 'display:inline;' } %>
      <% end %>
    </div>
  </div>

  <%# Phase progress bar %>
  <div style="display:flex;gap:4px;margin-bottom:16px;">
    <% Campaign.phases.each do |name, idx| %>
      <% current_idx = Campaign.phases[@campaign.phase] %>
      <% is_current = name == @campaign.phase %>
      <% is_past = idx < current_idx %>
      <% is_future = idx > current_idx %>
      <div style="flex:1;text-align:center;">
        <div style="height:6px;border-radius:3px;margin-bottom:6px;background:<%= is_past ? '#16A34A' : (is_current ? 'var(--accent)' : 'var(--border)') %>;"></div>
        <div style="font-size:11px;font-weight:<%= is_current ? '700' : '500' %>;color:<%= is_current ? 'var(--accent)' : (is_past ? '#16A34A' : 'var(--text-muted)') %>;text-transform:uppercase;letter-spacing:0.3px;"><%= name.titleize %></div>
      </div>
    <% end %>
  </div>

  <%# Blockers %>
  <% blockers = @campaign.phase_blockers %>
  <% if blockers.any? %>
    <div style="padding:12px 16px;background:rgba(245,158,11,0.04);border:1px solid rgba(245,158,11,0.15);border-radius:8px;margin-bottom:12px;">
      <div style="font-size:12px;font-weight:600;color:#D97706;margin-bottom:6px;">Blockers for advancing past <%= @campaign.phase.titleize %></div>
      <ul style="margin:0;padding-left:18px;">
        <% blockers.each do |b| %>
          <li style="font-size:13px;color:var(--text-secondary);margin-bottom:2px;"><%= b %></li>
        <% end %>
      </ul>
    </div>
  <% elsif !%w[live wrap_up].include?(@campaign.phase) %>
    <div style="padding:10px 16px;background:rgba(34,197,94,0.04);border:1px solid rgba(34,197,94,0.15);border-radius:8px;margin-bottom:12px;">
      <div style="font-size:13px;font-weight:600;color:#16A34A;">All clear — ready to advance</div>
    </div>
  <% end %>

  <%# Manual phase override %>
  <details style="margin-top:4px;">
    <summary style="font-size:12px;color:var(--text-muted);cursor:pointer;">Manual phase override</summary>
    <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
      <% Campaign.phases.each_key do |name| %>
        <% if name != @campaign.phase %>
          <%= button_to name.titleize, set_phase_manage_campaign_path(@campaign, phase: name), method: :patch, class: 'btn btn-secondary btn-sm', form: { style: 'display:inline;' }, data: { confirm: "Override phase to #{name.titleize}?" } %>
        <% else %>
          <span style="padding:6px 14px;border-radius:6px;font-size:12px;font-weight:600;background:var(--accent-wash);color:var(--accent);"><%= name.titleize %> (current)</span>
        <% end %>
      <% end %>
    </div>
  </details>
</div>

<%# ── Campaign Brief & Dates ── %>
<% if @campaign.brief.present? || @campaign.launch_date.present? || @campaign.content_deadline.present? %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3>Campaign Brief</h3>
    <%= link_to 'Edit', edit_manage_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
  </div>
  <% if @campaign.brief.present? %>
    <div style="font-size:14px;line-height:1.7;color:var(--text-secondary);white-space:pre-wrap;margin-bottom:16px;padding:16px;background:var(--page-bg);border-radius:var(--radius-sm);"><%= @campaign.brief %></div>
  <% end %>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;">
    <% if @campaign.launch_date.present? %>
      <div style="padding:12px;background:var(--page-bg);border-radius:var(--radius-sm);border-left:3px solid var(--accent);">
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;">Launch Date</div>
        <div style="font-size:15px;font-weight:700;margin-top:4px;"><%= @campaign.launch_date.strftime('%b %d, %Y') %></div>
        <% days_until = (@campaign.launch_date - Date.today).to_i %>
        <div style="font-size:11px;color:<%= days_until > 14 ? '#16A34A' : (days_until > 0 ? '#D97706' : 'var(--text-muted)') %>;margin-top:2px;">
          <%= days_until > 0 ? "#{days_until} days away" : (days_until == 0 ? 'Today!' : "#{days_until.abs} days ago") %>
        </div>
      </div>
    <% end %>
    <% if @campaign.content_deadline.present? %>
      <div style="padding:12px;background:var(--page-bg);border-radius:var(--radius-sm);border-left:3px solid #F59E0B;">
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;">Content Deadline</div>
        <div style="font-size:15px;font-weight:700;margin-top:4px;"><%= @campaign.content_deadline.strftime('%b %d, %Y') %></div>
        <% days_until_cd = (@campaign.content_deadline - Date.today).to_i %>
        <div style="font-size:11px;color:<%= days_until_cd > 7 ? '#16A34A' : (days_until_cd > 0 ? '#D97706' : '#EF4444') %>;margin-top:2px;">
          <%= days_until_cd > 0 ? "#{days_until_cd} days left" : (days_until_cd == 0 ? 'Due today' : "#{days_until_cd.abs} days overdue") %>
        </div>
      </div>
    <% end %>
    <% if @campaign.review_deadline.present? %>
      <div style="padding:12px;background:var(--page-bg);border-radius:var(--radius-sm);border-left:3px solid #8B5CF6;">
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;">Review Deadline</div>
        <div style="font-size:15px;font-weight:700;margin-top:4px;"><%= @campaign.review_deadline.strftime('%b %d, %Y') %></div>
        <% days_until_rd = (@campaign.review_deadline - Date.today).to_i %>
        <div style="font-size:11px;color:<%= days_until_rd > 7 ? '#16A34A' : (days_until_rd > 0 ? '#D97706' : '#EF4444') %>;margin-top:2px;">
          <%= days_until_rd > 0 ? "#{days_until_rd} days left" : (days_until_rd == 0 ? 'Due today' : "#{days_until_rd.abs} days overdue") %>
        </div>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── Pre-filled Details (Links, Ad Access, Logistics) ── %>
<% has_details = [@campaign.signed_editions_url, @campaign.ad_access_notes, @campaign.bookplate_address, @campaign.management_emails].any?(&:present?) %>
<% if has_details %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3>Pre-filled Details</h3>
    <%= link_to 'Edit', edit_manage_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <% if @campaign.signed_editions_url.present? %>
      <div>
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:4px;">Signed Editions URL</div>
        <a href="<%= @campaign.signed_editions_url %>" target="_blank" style="font-size:13px;color:var(--accent);word-break:break-all;"><%= @campaign.signed_editions_url %></a>
      </div>
    <% end %>
    <% if @campaign.management_emails.present? %>
      <div>
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:4px;">Management Emails</div>
        <div style="font-size:13px;"><%= @campaign.management_emails %></div>
      </div>
    <% end %>
    <% if @campaign.bookplate_address.present? %>
      <div>
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:4px;">Bookplate Address</div>
        <div style="font-size:13px;white-space:pre-wrap;"><%= @campaign.bookplate_address %></div>
      </div>
    <% end %>
    <% if @campaign.bookplate_design.present? %>
      <div>
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:4px;">Bookplate Design</div>
        <div style="font-size:13px;">Uploaded</div>
      </div>
    <% end %>
  </div>
  <% if @campaign.ad_access_notes.present? %>
    <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
      <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:6px;">Ad Access Instructions</div>
      <div style="font-size:13px;color:var(--text-secondary);white-space:pre-wrap;padding:12px;background:var(--page-bg);border-radius:var(--radius-sm);"><%= @campaign.ad_access_notes %></div>
    </div>
  <% end %>
</div>
<% end %>

<%# ── Creator Confirmations Status ── %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3>Creator Confirmations</h3>
    <% conf_count = @campaign.confirmable_sections.count { |s| @confirmations[s]&.persisted? && !@confirmations[s]&.has_changes_requested? } %>
    <span style="font-size:13px;font-weight:600;color:var(--text-muted);"><%= conf_count %>/<%= @campaign.confirmable_sections.size %> confirmed</span>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(200px, 1fr));gap:10px;">
    <% @campaign.confirmable_sections.each do |section| %>
      <% conf = @confirmations[section] %>
      <div style="padding:14px;border-radius:10px;border:1px solid <%= conf&.persisted? ? (conf.has_changes_requested? ? 'rgba(245,158,11,0.3)' : 'rgba(34,197,94,0.3)') : 'var(--border)' %>;background:<%= conf&.persisted? ? (conf.has_changes_requested? ? 'rgba(245,158,11,0.02)' : 'rgba(34,197,94,0.02)') : 'var(--surface)' %>;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <% if conf&.persisted? && !conf.has_changes_requested? %>
            <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <% elsif conf&.has_changes_requested? %>
            <svg viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <% else %>
            <span style="width:16px;height:16px;border-radius:50%;border:2px solid var(--border-strong);display:inline-block;"></span>
          <% end %>
          <span style="font-size:14px;font-weight:600;"><%= section.titleize %></span>
        </div>
        <% if conf&.persisted? && !conf.has_changes_requested? %>
          <div style="font-size:12px;color:#16A34A;font-weight:500;">Confirmed <%= conf.confirmed_at.strftime('%b %d') %></div>
        <% elsif conf&.has_changes_requested? %>
          <div style="font-size:12px;color:#D97706;font-weight:600;">Changes Requested</div>
          <div style="font-size:12px;color:var(--text-secondary);margin-top:4px;background:rgba(245,158,11,0.04);padding:6px 8px;border-radius:6px;"><%= conf.notes %></div>
        <% else %>
          <div style="font-size:12px;color:var(--text-muted);">Awaiting creator review</div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Campaign Type & Features ── %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <h3>Campaign Type & Features</h3>
    <%= link_to 'Edit', edit_manage_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
  </div>
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
    <% type_config = Campaign::CAMPAIGN_TYPES[@campaign.campaign_type] || Campaign::CAMPAIGN_TYPES['full'] %>
    <span style="padding:5px 14px;border-radius:8px;font-size:13px;font-weight:700;background:var(--accent-wash);color:var(--accent);"><%= type_config[:label] %></span>
    <span style="font-size:13px;color:var(--text-secondary);"><%= type_config[:description] %></span>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(170px, 1fr));gap:8px;">
    <% Campaign::FEATURE_FLAGS.each do |flag| %>
      <% enabled = @campaign.send("#{flag}_enabled?") %>
      <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:8px;border:1px solid var(--border);background:<%= enabled ? 'rgba(34,197,94,0.04)' : 'var(--page-bg)' %>;">
        <span style="width:8px;height:8px;border-radius:50%;background:<%= enabled ? '#16A34A' : '#D1D5DB' %>;flex-shrink:0;"></span>
        <span style="font-size:13px;font-weight:500;color:<%= enabled ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%= flag.titleize %></span>
      </div>
    <% end %>
  </div>
</div>

<%# ── Onboarding Example Category ── %>
<div class="card" style="margin-bottom:20px;">
  <h3>Onboarding Examples</h3>
  <p class="text-secondary" style="font-size:13px;margin-bottom:12px;">Choose which example campaigns the creator sees during their welcome onboarding.</p>
  <%= form_with model: @campaign, url: update_settings_manage_campaign_path(@campaign), method: :patch, style: 'display:flex;align-items:center;gap:12px;' do |f| %>
    <%= f.select :example_category, options_for_select(Campaign::EXAMPLE_CATEGORIES.map { |c| [c.titleize, c] }, @campaign.example_category), { include_blank: 'None (default)' }, style: 'padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;background:var(--surface);min-width:180px;' %>
    <button type="submit" class="btn btn-primary btn-sm">Save</button>
    <% if @campaign.onboarding_completed? %>
      <span class="text-muted" style="font-size:12px;">Onboarding completed <%= time_ago_in_words(@campaign.onboarding_completed_at) %> ago</span>
    <% else %>
      <span style="font-size:12px;color:#D97706;">Not yet onboarded</span>
    <% end %>
  <% end %>
</div>

<%# ── Personal Videos Toggle ── %>
<div class="card" style="margin-bottom:20px;">
  <h3>Personal Videos</h3>
  <p class="text-secondary" style="font-size:13px;margin-bottom:12px;">When enabled, creators can record rapid-fire personalized videos for each buyer from the recorder Queue mode.</p>
  <div style="display:flex;align-items:center;gap:12px;">
    <%= form_with model: @campaign, url: update_settings_manage_campaign_path(@campaign), method: :patch, style: 'display:inline;' do |f| %>
      <%= f.hidden_field :personal_videos_enabled, value: !@campaign.personal_videos_enabled? %>
      <button type="submit" class="btn <%= @campaign.personal_videos_enabled? ? 'btn-success' : 'btn-secondary' %> btn-sm">
        Personal Videos: <%= @campaign.personal_videos_enabled? ? 'ON' : 'OFF' %>
      </button>
    <% end %>
    <% if @campaign.personal_videos_enabled? %>
      <% pv_total = @campaign.landing_page&.page_submissions&.count || 0 %>
      <% pv_done = @campaign.personal_videos.count %>
      <span class="text-muted" style="font-size:12px;"><%= pv_done %>/<%= pv_total %> videos recorded</span>
    <% end %>
  </div>
</div>

<div class="two-col">
  <!-- Checklist -->
  <div class="card">
    <h3>Checklist</h3>
    <% Campaign::CATEGORIES.each do |cat| %>
      <% items = @items_by_category[cat] || [] %>
      <% next if items.empty? %>
      <div style="margin-bottom:16px;">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);margin-bottom:8px;"><%= cat.titleize %></div>
        <% items.each do |item| %>
          <%= button_to toggle_checklist_item_manage_campaign_path(@campaign, checklist_item_id: item.id), method: :patch, class: "checklist-toggle #{item.status}", form: { style: 'display:inline' } do %>
            <span class="dot <%= item.status %>"></span>
            <%= item.title %>
            <% if item.optional? %><span style="font-size:10px;color:var(--text-muted);">(optional)</span><% end %>
          <% end %>
          <br>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Deliverables -->
  <% if @campaign.deliverables_enabled? %>
    <div class="card" style="margin-bottom:16px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <h3>Deliverables</h3>
        <%= link_to 'Manage', manage_campaign_admin_deliverables_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      </div>
      <% revisions = @campaign.admin_deliverables.needs_revision %>
      <% pending_del = @campaign.admin_deliverables.pending %>
      <% if revisions.any? %>
        <div style="padding:10px 14px;background:rgba(239,68,68,0.04);border-left:3px solid #EF4444;border-radius:0 8px 8px 0;margin-bottom:10px;">
          <div style="font-size:12px;font-weight:600;color:#EF4444;"><%= revisions.count %> revision<%= 's' if revisions.count != 1 %> requested</div>
          <% revisions.limit(3).each do |del| %>
            <div style="font-size:13px;margin-top:4px;">
              <%= link_to del.title, manage_campaign_admin_deliverable_path(@campaign, del), style: 'color:var(--text-primary);font-weight:500;' %>
            </div>
          <% end %>
        </div>
      <% end %>
      <div style="display:flex;gap:16px;font-size:13px;">
        <span><strong><%= @campaign.admin_deliverables.count %></strong> total</span>
        <span style="color:#D97706;"><strong><%= pending_del.count %></strong> awaiting review</span>
        <span style="color:#16A34A;"><strong><%= @campaign.admin_deliverables.approved.count %></strong> approved</span>
      </div>
      <div style="margin-top:12px;">
        <%= link_to 'New Deliverable', new_manage_campaign_admin_deliverable_path(@campaign), class: 'btn btn-primary btn-sm' %>
      </div>
    </div>
  <% end %>

  <!-- Assets Pending Review -->
  <div>
    <div class="card">
      <h3>Assets Pending Review (<%= @pending_assets.count %>)</h3>
      <% if @pending_assets.any? %>
        <% @pending_assets.each do |asset| %>
          <div class="asset-review-card">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div>
                <div style="font-weight:600;font-size:14px;"><%= asset.original_filename || 'Unnamed' %></div>
                <div class="text-muted" style="font-size:12px;"><%= asset.asset_type.titleize %> — uploaded <%= time_ago_in_words(asset.created_at) %> ago</div>
              </div>
              <span class="status-badge status-pending">Pending</span>
            </div>
            <div class="asset-review-actions">
              <%= button_to 'Approve', approve_manage_campaign_campaign_asset_path(@campaign, asset), method: :patch, class: 'btn btn-success btn-sm', form: { style: 'display:inline' } %>
              <%= form_with url: request_changes_manage_campaign_campaign_asset_path(@campaign, asset), method: :patch, style: 'display:flex;gap:6px;flex:1;' do %>
                <input type="text" name="admin_notes" placeholder="Notes for creator..." class="notes-input" style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;flex:1;">
                <button type="submit" class="btn btn-danger btn-sm">Request Changes</button>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div style="text-align:center;padding:24px;color:var(--text-muted);">No assets pending review.</div>
      <% end %>
    </div>

    <!-- Landing Page -->
    <% if @landing_page %>
      <div class="card">
        <h3>Landing Page</h3>
        <% if @landing_page.build_requested? %>
          <div style="padding:12px 16px;background:rgba(234,179,8,0.08);border:1px solid rgba(234,179,8,0.2);border-radius:8px;margin-bottom:16px;">
            <div style="font-size:13px;font-weight:600;color:#CA8A04;">Build Requested</div>
            <div class="text-muted" style="font-size:12px;margin-top:2px;">
              <%= @landing_page.build_requested_at ? "#{time_ago_in_words(@landing_page.build_requested_at)} ago" : '' %> by <%= @campaign.author.full_name %>
            </div>
          </div>
        <% end %>
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <span class="status-badge status-<%= @landing_page.published? ? 'live' : 'draft' %>"><%= @landing_page.published? ? 'Published' : 'Draft' %></span>
          <% if @landing_page.has_content? %>
            <span class="text-muted" style="font-size:12px;">Has content</span>
          <% else %>
            <span class="text-muted" style="font-size:12px;">No content yet</span>
          <% end %>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
          <%= link_to builder_manage_campaign_landing_page_path(@campaign), class: 'btn btn-primary btn-sm' do %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            Open Builder
          <% end %>
          <div style="position:relative;display:inline-block;" id="generateDropdown">
            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('generateMenu').style.display = document.getElementById('generateMenu').style.display === 'block' ? 'none' : 'block'">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              Generate Page ▾
            </button>
            <div id="generateMenu" style="display:none;position:absolute;top:100%;left:0;margin-top:4px;background:#fff;border:1px solid var(--border-strong);border-radius:8px;box-shadow:var(--shadow-lg);z-index:20;min-width:220px;padding:4px;">
              <% LandingPageGenerator::TEMPLATES.each do |key, label| %>
                <%= button_to generate_manage_campaign_landing_page_path(@campaign, template: key), method: :patch, form: { style: 'display:block;' }, style: 'display:block;width:100%;text-align:left;padding:8px 12px;font-size:13px;border:none;background:none;cursor:pointer;border-radius:6px;font-family:inherit;color:var(--text-primary);', data: { turbo_confirm: @landing_page.has_content? ? "This will overwrite the current page content with the \"#{label}\" template. Continue?" : nil }, onmouseover: "this.style.background='var(--accent-wash)'", onmouseout: "this.style.background='none'" do %>
                  <%= label %>
                <% end %>
              <% end %>
            </div>
          </div>
          <script>document.addEventListener('click',function(e){if(!document.getElementById('generateDropdown').contains(e.target))document.getElementById('generateMenu').style.display='none';});</script>
          <%= link_to wizard_manage_campaign_landing_page_path(@campaign), class: 'btn btn-secondary btn-sm', style: 'display:inline-flex;align-items:center;gap:4px;' do %>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Page Wizard
          <% end %>
          <% if @landing_page.page_submissions.any? %>
            <%= link_to manage_campaign_page_submissions_path(@campaign), class: 'btn btn-secondary btn-sm' do %>
              Submissions (<%= @landing_page.page_submissions.count %>)
            <% end %>
          <% end %>
        </div>

        <%# Notification toggle %>
        <div style="margin-top:12px;display:flex;align-items:center;gap:8px;">
          <%= button_to toggle_notifications_manage_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-secondary btn-sm', form: { style: 'display:inline' } do %>
            <%= @landing_page.notify_on_submission? ? 'Notifications: ON' : 'Notifications: OFF' %>
          <% end %>
          <span class="text-muted" style="font-size:12px;">Email creator on new form submission</span>
        </div>
      </div>
    <% end %>

    <%# Live Events card %>
    <% live_events = @campaign.live_events.recent.limit(5) %>
    <% if live_events.any? || @campaign.is_live? %>
    <div class="card">
      <h3>Live Events</h3>
      <% if @campaign.is_live? %>
        <div style="padding:12px;background:rgba(233,69,96,0.08);border:1px solid rgba(233,69,96,0.2);border-radius:8px;margin-bottom:12px;">
          <span style="font-size:13px;font-weight:700;color:#e94560;">LIVE NOW — <%= @campaign.current_live_event&.title %></span>
        </div>
      <% end %>
      <% live_events.each do |event| %>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">
          <span style="font-size:14px;"><%= event.title %></span>
          <span class="status-badge status-<%= event.live? ? 'live' : event.ended? ? 'draft' : 'pending' %>"><%= event.status.titleize %></span>
        </div>
      <% end %>
      <%= link_to 'All Events', manage_campaign_live_events_path(@campaign), class: 'btn btn-secondary btn-sm', style: 'margin-top:12px;' %>
    </div>
    <% end %>

    <% approved = @all_assets.where(status: :approved) %>
    <% if approved.any? %>
      <div class="card">
        <h3>Approved Assets (<%= approved.count %>)</h3>
        <% approved.each do |asset| %>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">
            <span style="font-size:14px;"><%= asset.original_filename || asset.asset_type.titleize %></span>
            <span class="status-badge status-approved">Approved</span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Activity Feed ── %>
<div class="card" style="margin-bottom:20px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <h3>Activity Feed</h3>
    <span style="font-size:12px;color:var(--text-muted);"><%= @activities.size %> events</span>
  </div>

  <% if @activities.any? %>
    <div style="max-height:500px;overflow-y:auto;">
      <% @activities.group_by { |a| a.created_at.to_date }.each do |date, day_activities| %>
        <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px;border-bottom:1px solid var(--border);margin-bottom:8px;">
          <%= date == Date.today ? 'Today' : date == Date.yesterday ? 'Yesterday' : date.strftime('%B %d, %Y') %>
        </div>
        <% day_activities.each do |activity| %>
          <div style="display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.04);">
            <div style="width:28px;height:28px;border-radius:50%;background:<%= activity.user&.admin? ? 'var(--accent-wash)' : 'rgba(34,197,94,0.08)' %>;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:<%= activity.user&.admin? ? 'var(--accent)' : '#16A34A' %>;flex-shrink:0;">
              <%= activity.user_initials %>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:13px;color:var(--text-primary);"><%= activity.human_description %></div>
              <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                <%= activity.user&.first_name || 'System' %> &middot; <%= activity.created_at.strftime('%-I:%M %p') %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div style="text-align:center;padding:24px;color:var(--text-muted);font-size:13px;">No activity recorded yet.</div>
  <% end %>
</div>

<%# ── Page Wizard Modal ── %>
<% if @landing_page %>
<div id="wizardOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;overflow-y:auto;padding:40px 16px;">
<div style="max-width:720px;margin:0 auto;background:#fff;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
  <!-- Header -->
  <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
    <div>
      <h2 style="font-size:18px;font-weight:700;margin:0;">Page Wizard</h2>
      <p class="text-muted" style="font-size:12px;margin:2px 0 0;">Step <span id="wizardStepNum">1</span> of 3</p>
    </div>
    <button onclick="closeWizard()" style="background:none;border:none;font-size:24px;cursor:pointer;color:var(--text-muted);line-height:1;">&times;</button>
  </div>

  <!-- Step 1: Choose Template -->
  <div id="wizardStep1" style="padding:24px;">
    <h3 style="font-size:16px;margin-bottom:16px;">Choose a Template</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;">
      <% icons = { 'standard' => '&#128214;', 'personalized_video' => '&#127909;', 'preorder_incentive' => '&#127873;', 'address_capture' => '&#128230;', 'landing_page' => '&#127760;', 'vinyl' => '&#127926;' } %>
      <% descs = { 'standard' => 'Book page with author bio', 'personalized_video' => 'Steps + receipt form + video', 'preorder_incentive' => 'Bonus cards + receipt form', 'address_capture' => 'Shipping address form', 'landing_page' => 'Showcase + email signup', 'vinyl' => 'Dark theme for music' } %>
      <% LandingPageGenerator::TEMPLATES.each do |key, label| %>
        <div class="wizard-tpl-card" data-tpl="<%= key %>" onclick="wizardSelectTemplate('<%= key %>')" style="padding:16px;border:2px solid var(--border);border-radius:10px;cursor:pointer;text-align:center;transition:all 0.15s;">
          <div style="font-size:28px;margin-bottom:8px;"><%= icons[key]&.html_safe %></div>
          <div style="font-size:14px;font-weight:600;"><%= label %></div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:4px;"><%= descs[key] %></div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Step 2: Customize Content -->
  <div id="wizardStep2" style="padding:24px;display:none;max-height:60vh;overflow-y:auto;">
    <h3 style="font-size:16px;margin-bottom:16px;">Customize Content</h3>

    <%# Hero — all templates %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;" id="wiz-section-hero">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Hero</legend>
      <div style="margin-bottom:12px;"><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Headline</label><input type="text" id="wiz-hero-headline" value="<%= h(@campaign.submission.title.presence || 'Your Book Title') %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      <div style="margin-bottom:12px;"><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Subheadline</label><input type="text" id="wiz-hero-subheadline" value="by <%= h(@campaign.author.full_name) %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">CTA Text</label><input type="text" id="wiz-hero-cta-text" value="Order Your Copy" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
        <div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">CTA URL</label><input type="text" id="wiz-hero-cta-url" value="<%= h(@campaign.signed_editions_url.presence || '#') %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      </div>
    </fieldset>

    <%# Book — all templates %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;" id="wiz-section-book">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Book</legend>
      <div style="margin-bottom:12px;"><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Title</label><input type="text" id="wiz-book-title" value="<%= h(@campaign.submission.title.presence || '') %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      <div style="margin-bottom:12px;"><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Description</label><textarea id="wiz-book-description" rows="3" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;resize:vertical;"><%= h(@campaign.submission.description.presence || '') %></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Genre</label><input type="text" id="wiz-book-genre" value="<%= h(@campaign.submission.genre.presence || 'General') %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
        <div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Release Date</label><input type="text" id="wiz-book-release-date" value="<%= @campaign.submission.release_date&.strftime('%B %d, %Y') || 'Coming Soon' %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      </div>
    </fieldset>

    <%# Author — standard, landing_page, address_capture, vinyl %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;" id="wiz-section-author">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Author</legend>
      <div style="margin-bottom:12px;"><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Name</label><input type="text" id="wiz-author-name" value="<%= h(@campaign.author.full_name) %>" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;"></div>
      <div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:3px;">Bio</label><textarea id="wiz-author-bio" rows="3" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;resize:vertical;"><%= h(@campaign.author.description.presence || '') %></textarea></div>
    </fieldset>

    <%# Steps — personalized_video, preorder_incentive %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;display:none;" id="wiz-section-steps">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">How It Works (Steps)</legend>
      <div id="wiz-steps-list">
        <% 4.times do |i| %>
        <div style="display:grid;grid-template-columns:auto 1fr 2fr;gap:8px;align-items:center;margin-bottom:8px;">
          <span style="font-size:12px;font-weight:700;color:var(--text-muted);"><%= i+1 %>.</span>
          <input type="text" class="wiz-step-title" data-idx="<%= i %>" value="" placeholder="Step title" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
          <input type="text" class="wiz-step-desc" data-idx="<%= i %>" value="" placeholder="Description" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
        </div>
        <% end %>
      </div>
    </fieldset>

    <%# Retailers — personalized_video, preorder_incentive, landing_page %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;display:none;" id="wiz-section-retailers">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Retailers</legend>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
        <% [['Amazon','amazon'], ['Barnes & Noble','barnes_noble'], ['Bookshop.org','bookshop'], ['Target','target'], ['Walmart','walmart'], ['Books-A-Million','bam']].each do |name, key| %>
          <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;"><input type="checkbox" class="wiz-retailer" data-name="<%= name %>" checked> <%= name %></label>
        <% end %>
      </div>
    </fieldset>

    <%# Testimonials — personalized_video, landing_page, standard, vinyl %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;" id="wiz-section-testimonials">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Testimonials</legend>
      <div id="wiz-testimonials-list">
        <div class="wiz-testimonial-row" style="display:grid;grid-template-columns:2fr 1fr;gap:8px;margin-bottom:8px;">
          <input type="text" class="wiz-testimonial-quote" placeholder="Quote text..." value="&quot;An absolutely captivating read from start to finish.&quot;" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
          <input type="text" class="wiz-testimonial-attr" placeholder="- Attribution" value="- Reader Review" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
        </div>
      </div>
      <button type="button" onclick="wizardAddTestimonial()" style="font-size:12px;color:var(--accent);background:none;border:none;cursor:pointer;padding:4px 0;">+ Add testimonial</button>
    </fieldset>

    <%# Bonuses — preorder_incentive only %>
    <fieldset style="border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px;display:none;" id="wiz-section-bonuses">
      <legend style="font-size:13px;font-weight:700;padding:0 6px;">Bonus Items</legend>
      <div id="wiz-bonuses-list">
        <% [['&#9997;&#65039;', 'Signed Bookplate', 'A personal signed bookplate from the author'], ['&#128214;', 'Bonus Chapter', 'An exclusive bonus chapter not in the final book'], ['&#127873;', 'Limited Print', 'Exclusive art print (first 500 orders)']].each_with_index do |(emoji, title, desc), i| %>
        <div class="wiz-bonus-row" style="display:grid;grid-template-columns:50px 1fr 2fr;gap:8px;align-items:center;margin-bottom:8px;">
          <input type="text" class="wiz-bonus-emoji" data-idx="<%= i %>" value="<%= emoji %>" style="padding:6px;border:1px solid var(--border);border-radius:6px;font-size:16px;text-align:center;">
          <input type="text" class="wiz-bonus-title" data-idx="<%= i %>" value="<%= title %>" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
          <input type="text" class="wiz-bonus-desc" data-idx="<%= i %>" value="<%= desc %>" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">
        </div>
        <% end %>
      </div>
    </fieldset>
  </div>

  <!-- Step 3: Review & Generate -->
  <div id="wizardStep3" style="padding:24px;display:none;">
    <h3 style="font-size:16px;margin-bottom:16px;">Review & Generate</h3>
    <div style="background:var(--surface-alt,#f8f9fa);border-radius:8px;padding:20px;margin-bottom:20px;">
      <div style="margin-bottom:12px;"><span style="font-size:12px;font-weight:600;color:var(--text-muted);">Template</span><div id="wiz-review-template" style="font-size:15px;font-weight:600;margin-top:2px;">Standard</div></div>
      <div style="margin-bottom:12px;"><span style="font-size:12px;font-weight:600;color:var(--text-muted);">Sections Included</span><div id="wiz-review-sections" style="font-size:13px;margin-top:2px;color:var(--text-primary);">—</div></div>
      <div><span style="font-size:12px;font-weight:600;color:var(--text-muted);">Customized Fields</span><div id="wiz-review-fields" style="font-size:13px;margin-top:2px;color:var(--text-primary);">—</div></div>
    </div>
    <% if @landing_page.has_content? %>
      <p style="font-size:12px;color:#b45309;margin-bottom:12px;">This will overwrite the current page content.</p>
    <% end %>
  </div>

  <!-- Footer -->
  <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;">
    <button type="button" id="wizardBackBtn" onclick="wizardBack()" style="display:none;padding:8px 16px;border:1px solid var(--border);border-radius:6px;background:#fff;font-size:13px;cursor:pointer;">Back</button>
    <div style="margin-left:auto;display:flex;gap:8px;">
      <button type="button" onclick="closeWizard()" style="padding:8px 16px;border:1px solid var(--border);border-radius:6px;background:#fff;font-size:13px;cursor:pointer;">Cancel</button>
      <button type="button" id="wizardNextBtn" onclick="wizardNext()" class="btn btn-primary btn-sm" style="padding:8px 20px;">Next</button>
    </div>
  </div>
</div>
</div>

<style>
  .wizard-tpl-card:hover { border-color: var(--accent) !important; background: var(--accent-wash); }
  .wizard-tpl-card.selected { border-color: var(--accent) !important; background: var(--accent-wash); box-shadow: 0 0 0 1px var(--accent); }
</style>

<script>
(function(){
  var wizardStep = 1;
  var wizardTemplate = 'standard';

  var tplSections = {
    standard:           { hero:true, book:true, author:true, steps:false, retailers:false, testimonials:true, bonuses:false },
    personalized_video: { hero:true, book:true, author:true, steps:true, retailers:true, testimonials:true, bonuses:false },
    preorder_incentive: { hero:true, book:true, author:false, steps:true, retailers:true, testimonials:false, bonuses:true },
    address_capture:    { hero:true, book:true, author:true, steps:false, retailers:false, testimonials:false, bonuses:false },
    landing_page:       { hero:true, book:true, author:true, steps:false, retailers:true, testimonials:true, bonuses:false },
    vinyl:              { hero:true, book:true, author:true, steps:false, retailers:false, testimonials:true, bonuses:false }
  };

  var tplStepDefaults = {
    personalized_video: [
      { title: 'Order the Book', desc: 'Purchase from any retailer below' },
      { title: 'Submit Your Receipt', desc: 'Upload your proof of purchase' },
      { title: 'Get Confirmed', desc: "We'll verify your order" },
      { title: 'Enjoy Your Video', desc: 'Receive a personalized video message' }
    ],
    preorder_incentive: [
      { title: 'Pre-Order the Book', desc: 'Purchase from any retailer below' },
      { title: 'Submit Your Receipt', desc: 'Upload your proof of purchase' },
      { title: 'Get Confirmed', desc: "We'll verify your pre-order" },
      { title: 'Enjoy Your Bonus', desc: 'Receive your exclusive bonus content' }
    ]
  };

  var tplCTADefaults = {
    standard: 'Order Your Copy',
    personalized_video: 'Get Your Personalized Video',
    preorder_incentive: 'Pre-Order Now',
    address_capture: 'Claim Your Signed Copy',
    landing_page: 'Learn More',
    vinyl: 'Order Vinyl'
  };

  var templateNames = <%= raw LandingPageGenerator::TEMPLATES.to_json %>;

  window.openWizard = function() {
    document.getElementById('wizardOverlay').style.display = 'block';
    showStep(1);
    wizardSelectTemplate('standard');
  };

  window.closeWizard = function() {
    document.getElementById('wizardOverlay').style.display = 'none';
  };

  window.wizardSelectTemplate = function(key) {
    wizardTemplate = key;
    document.querySelectorAll('.wizard-tpl-card').forEach(function(el){
      el.classList.toggle('selected', el.dataset.tpl === key);
    });
    document.getElementById('wiz-hero-cta-text').placeholder = tplCTADefaults[key] || 'Order Your Copy';
    if (!document.getElementById('wiz-hero-cta-text')._userEdited) {
      document.getElementById('wiz-hero-cta-text').value = tplCTADefaults[key] || 'Order Your Copy';
    }
    var stepDefaults = tplStepDefaults[key] || tplStepDefaults['personalized_video'];
    document.querySelectorAll('.wiz-step-title').forEach(function(el, i) {
      if (stepDefaults[i] && !el._userEdited) { el.value = stepDefaults[i].title; }
    });
    document.querySelectorAll('.wiz-step-desc').forEach(function(el, i) {
      if (stepDefaults[i] && !el._userEdited) { el.value = stepDefaults[i].desc; }
    });
    wizardUpdateSections();
  };

  function wizardUpdateSections() {
    var vis = tplSections[wizardTemplate] || tplSections.standard;
    ['hero','book','author','steps','retailers','testimonials','bonuses'].forEach(function(s){
      var el = document.getElementById('wiz-section-' + s);
      if (el) el.style.display = vis[s] ? '' : 'none';
    });
  }

  document.addEventListener('input', function(e) {
    if (e.target.id && e.target.id.startsWith('wiz-')) e.target._userEdited = true;
    if (e.target.classList.contains('wiz-step-title') || e.target.classList.contains('wiz-step-desc')) e.target._userEdited = true;
  });

  window.wizardAddTestimonial = function() {
    var list = document.getElementById('wiz-testimonials-list');
    if (list.querySelectorAll('.wiz-testimonial-row').length >= 3) return;
    var row = document.createElement('div');
    row.className = 'wiz-testimonial-row';
    row.style.cssText = 'display:grid;grid-template-columns:2fr 1fr;gap:8px;margin-bottom:8px;';
    row.innerHTML = '<input type="text" class="wiz-testimonial-quote" placeholder="Quote text..." style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">' +
                    '<input type="text" class="wiz-testimonial-attr" placeholder="- Attribution" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:12px;">';
    list.appendChild(row);
  };

  function showStep(n) {
    wizardStep = n;
    document.getElementById('wizardStep1').style.display = n === 1 ? '' : 'none';
    document.getElementById('wizardStep2').style.display = n === 2 ? '' : 'none';
    document.getElementById('wizardStep3').style.display = n === 3 ? '' : 'none';
    document.getElementById('wizardStepNum').textContent = n;
    document.getElementById('wizardBackBtn').style.display = n > 1 ? '' : 'none';
    document.getElementById('wizardNextBtn').textContent = n === 3 ? 'Generate Page' : 'Next';
    if (n === 2) wizardUpdateSections();
    if (n === 3) buildReview();
  }

  function buildReview() {
    document.getElementById('wiz-review-template').textContent = templateNames[wizardTemplate] || wizardTemplate;
    var vis = tplSections[wizardTemplate] || tplSections.standard;
    var secs = [];
    if (vis.hero) secs.push('Hero');
    if (vis.book) secs.push('Book');
    if (vis.author) secs.push('Author');
    if (vis.steps) secs.push('How It Works');
    if (vis.retailers) secs.push('Retailers');
    if (vis.testimonials) secs.push('Testimonials');
    if (vis.bonuses) secs.push('Bonuses');
    secs.push('Footer');
    document.getElementById('wiz-review-sections').textContent = secs.join(', ');
    var total = 0, customized = 0;
    var fieldIds = ['wiz-hero-headline','wiz-hero-subheadline','wiz-hero-cta-text','wiz-hero-cta-url','wiz-book-title','wiz-book-description','wiz-book-genre','wiz-book-release-date','wiz-author-name','wiz-author-bio'];
    fieldIds.forEach(function(id) {
      var el = document.getElementById(id);
      if (el) { total++; if (el.value.trim()) customized++; }
    });
    document.getElementById('wiz-review-fields').textContent = customized + ' of ' + total + ' fields populated';
  }

  window.wizardNext = function() {
    if (wizardStep === 3) { wizardGenerate(); return; }
    showStep(wizardStep + 1);
  };

  window.wizardBack = function() {
    if (wizardStep > 1) showStep(wizardStep - 1);
  };

  function collectWizardData() {
    var vis = tplSections[wizardTemplate] || tplSections.standard;
    var data = { template: wizardTemplate };
    data.hero = {
      headline: document.getElementById('wiz-hero-headline').value,
      subheadline: document.getElementById('wiz-hero-subheadline').value,
      cta_text: document.getElementById('wiz-hero-cta-text').value,
      cta_url: document.getElementById('wiz-hero-cta-url').value
    };
    data.book = {
      description: document.getElementById('wiz-book-description').value,
      genre: document.getElementById('wiz-book-genre').value,
      release_date: document.getElementById('wiz-book-release-date').value
    };
    if (vis.author) {
      data.author = {
        name: document.getElementById('wiz-author-name').value,
        bio: document.getElementById('wiz-author-bio').value
      };
    }
    if (vis.steps) {
      data.steps = [];
      document.querySelectorAll('.wiz-step-title').forEach(function(el, i) {
        var desc = document.querySelectorAll('.wiz-step-desc')[i];
        if (el.value.trim()) {
          data.steps.push({ number: String(i+1), title: el.value, description: desc ? desc.value : '' });
        }
      });
    }
    if (vis.retailers) {
      var defaultUrls = { 'Amazon': 'https://amazon.com', 'Barnes & Noble': 'https://barnesandnoble.com', 'Bookshop.org': 'https://bookshop.org', 'Target': 'https://target.com', 'Walmart': 'https://walmart.com', 'Books-A-Million': 'https://booksamillion.com' };
      var defaultIcons = { 'Amazon': "\uD83D\uDCE6", 'Barnes & Noble': "\uD83D\uDCDA", 'Bookshop.org': "\uD83C\uDFEA", 'Target': "\uD83C\uDFAF", 'Walmart': "\uD83D\uDED2", 'Books-A-Million': "\uD83D\uDCD6" };
      data.retailers = [];
      document.querySelectorAll('.wiz-retailer:checked').forEach(function(el) {
        var name = el.dataset.name;
        data.retailers.push({ name: name, url: defaultUrls[name] || '#', icon: defaultIcons[name] || "\uD83D\uDCDA" });
      });
    }
    if (vis.testimonials) {
      data.testimonials = [];
      document.querySelectorAll('.wiz-testimonial-row').forEach(function(row) {
        var q = row.querySelector('.wiz-testimonial-quote');
        var a = row.querySelector('.wiz-testimonial-attr');
        if (q && q.value.trim()) {
          data.testimonials.push({ quote: q.value, attribution: a ? a.value : '' });
        }
      });
    }
    if (vis.bonuses) {
      data.bonuses = [];
      document.querySelectorAll('.wiz-bonus-row').forEach(function(row) {
        var emoji = row.querySelector('.wiz-bonus-emoji');
        var title = row.querySelector('.wiz-bonus-title');
        var desc = row.querySelector('.wiz-bonus-desc');
        if (title && title.value.trim()) {
          data.bonuses.push({ emoji: emoji ? emoji.value : '', title: title.value, description: desc ? desc.value : '' });
        }
      });
    }
    return data;
  }

  function wizardGenerate() {
    var data = collectWizardData();
    var form = document.createElement('form');
    form.method = 'POST';
    form.action = '<%= wizard_generate_manage_campaign_landing_page_path(@campaign) %>';
    form.style.display = 'none';
    var csrfParam = document.querySelector('meta[name="csrf-param"]');
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    if (csrfParam && csrfToken) {
      var inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = csrfParam.content; inp.value = csrfToken.content;
      form.appendChild(inp);
    }
    var methodInput = document.createElement('input');
    methodInput.type = 'hidden'; methodInput.name = '_method'; methodInput.value = 'patch';
    form.appendChild(methodInput);
    function addField(name, value) {
      var inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = name; inp.value = value;
      form.appendChild(inp);
    }
    function flattenToForm(obj, prefix) {
      for (var key in obj) {
        if (!obj.hasOwnProperty(key)) continue;
        var val = obj[key];
        var fieldName = prefix ? prefix + '[' + key + ']' : key;
        if (Array.isArray(val)) {
          val.forEach(function(item, idx) {
            if (typeof item === 'object' && item !== null) {
              flattenToForm(item, fieldName + '[' + idx + ']');
            } else {
              addField(fieldName + '[]', item);
            }
          });
        } else if (typeof val === 'object' && val !== null) {
          flattenToForm(val, fieldName);
        } else {
          addField(fieldName, val);
        }
      }
    }
    flattenToForm(data, 'wizard_data');
    document.body.appendChild(form);
    form.submit();
  }

  document.getElementById('wizardOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeWizard();
  });
})();
</script>
<% end %>
