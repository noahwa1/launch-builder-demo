<% content_for :page_title, 'New Campaign' %>
<% content_for :page_actions do %>
  <%= link_to 'Back', manage_campaigns_path, class: 'btn btn-secondary' %>
<% end %>

<style>
  .form-section { margin-bottom: 20px; }
  .form-section h3 { margin-bottom: 4px; }
  .form-section .section-desc { font-size: 13px; color: var(--text-secondary); margin-bottom: 16px; }
  .form-section .form-group { margin-bottom: 14px; }
  .form-section label { display: block; font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 5px; }
  .form-section input[type="text"],
  .form-section input[type="email"],
  .form-section input[type="password"],
  .form-section input[type="date"],
  .form-section input[type="url"],
  .form-section select,
  .form-section textarea {
    width: 100%; padding: 9px 12px; border: 1px solid var(--border); border-radius: 8px;
    font-size: 13px; font-family: inherit; background: var(--surface);
  }
  .form-section textarea { resize: vertical; }
  .form-section input:focus, .form-section select:focus, .form-section textarea:focus { outline: none; border-color: var(--accent); }
  .section-divider { height: 1px; background: var(--border); margin: 24px 0; }
</style>

<%= form_tag manage_campaigns_path, method: :post, multipart: true, class: 'max-w-lg' do %>

  <%# ══════ AUTHOR ══════ %>
  <div class="card form-section">
    <h3>Author</h3>
    <div class="d-flex gap-8 mb-16">
      <button type="button" class="btn btn-primary btn-sm" id="btn-new-author" onclick="toggleAuthorMode('new')">New Author</button>
      <button type="button" class="btn btn-secondary btn-sm" id="btn-existing-author" onclick="toggleAuthorMode('existing')">Existing Author</button>
    </div>
    <div id="new-author-fields">
      <div class="grid-2 gap-16">
        <div class="form-group">
          <label for="first_name">First Name *</label>
          <input type="text" name="first_name" id="first_name" placeholder="First name">
        </div>
        <div class="form-group">
          <label for="last_name">Last Name *</label>
          <input type="text" name="last_name" id="last_name" placeholder="Last name">
        </div>
      </div>
      <div class="form-group">
        <label for="description">Bio / Description</label>
        <textarea name="description" id="description" rows="3" placeholder="Author bio..."></textarea>
      </div>
      <div class="form-group">
        <label for="image">Author Photo URL</label>
        <input type="text" name="image" id="image" placeholder="https://...">
      </div>
    </div>
    <div id="existing-author-fields" class="d-none">
      <div class="form-group">
        <label for="existing_author_id">Select Author</label>
        <select name="existing_author_id" id="existing_author_id">
          <option value="">Choose an author...</option>
          <% @authors.each do |author| %>
            <option value="<%= author.id %>" data-has-user="<%= author.user.present? %>"><%= author.full_name %></option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <%# ══════ CREATOR LOGIN ══════ %>
  <div class="card form-section" id="creator-login-card">
    <h3>Creator Login</h3>
    <p class="section-desc">Creates a login the author can use to access the Creator Portal.</p>
    <div class="grid-2 gap-16">
      <div class="form-group">
        <label for="creator_email">Email *</label>
        <input type="email" name="creator_email" id="creator_email" placeholder="author@example.com">
      </div>
      <div class="form-group">
        <label for="creator_password">Password *</label>
        <input type="password" name="creator_password" id="creator_password" placeholder="Min 6 characters">
      </div>
    </div>
  </div>

  <%# ══════ BOOK DETAILS ══════ %>
  <div class="card form-section">
    <h3>Book Details</h3>
    <div class="form-group">
      <label for="title">Title *</label>
      <input type="text" name="title" id="title" required placeholder="Book title">
    </div>
    <div class="grid-2 gap-16">
      <div class="form-group">
        <label for="isbn">ISBN</label>
        <input type="text" name="isbn" id="isbn" placeholder="978-...">
      </div>
      <div class="form-group">
        <label for="genre">Genre</label>
        <select name="genre" id="genre">
          <option value="">Select genre...</option>
          <% %w[Romance Thriller Fantasy Sci-Fi Mystery Non-Fiction Business Memoir Self-Help Children's YA Political Other].each do |g| %>
            <option value="<%= g %>"><%= g %></option>
          <% end %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label for="book_description">Description</label>
      <textarea name="book_description" id="book_description" rows="4" placeholder="Book description..."></textarea>
    </div>
    <div class="grid-2 gap-16">
      <div class="form-group">
        <label for="release_date">Release Date</label>
        <input type="date" name="release_date" id="release_date">
      </div>
      <div class="form-group">
        <label for="cover">Cover Image</label>
        <input type="file" name="cover" id="cover" accept="image/*">
      </div>
    </div>
    <div class="form-group">
      <label for="book_id">Link Existing Book</label>
      <select name="book_id" id="book_id">
        <option value="">None — create from details above</option>
        <% @books.each do |book| %>
          <option value="<%= book.id %>"
            data-title="<%= book.title %>"
            data-isbn="<%= book.isbn %>"
            data-description="<%= book.description&.truncate(2000) %>"
            data-release-date="<%= book.release_date&.strftime('%Y-%m-%d') %>"
            data-genre="<%= book.try(:genre) %>"
          ><%= book.title %><%= " (#{book.isbn})" if book.isbn.present? %></option>
        <% end %>
      </select>
      <p id="book-autofill-note" class="d-none text-sm fw-500" style="color:#16A34A;margin-top:6px;"></p>
    </div>
  </div>

  <%# ══════ BRIEF & DATES ══════ %>
  <div class="card form-section">
    <h3>Brief & Key Dates</h3>
    <p class="section-desc">The campaign brief is shown to the creator. Key dates drive the timeline and phase system.</p>
    <div class="form-group">
      <label for="brief">Campaign Brief</label>
      <textarea name="brief" id="brief" rows="5" placeholder="Here's what we're doing, the timeline, and what we need from you..."></textarea>
    </div>
    <div class="grid-3 gap-16">
      <div class="form-group">
        <label for="launch_date">Launch Date</label>
        <input type="date" name="launch_date" id="launch_date">
      </div>
      <div class="form-group">
        <label for="content_deadline">Content Deadline</label>
        <input type="date" name="content_deadline" id="content_deadline">
      </div>
      <div class="form-group">
        <label for="review_deadline">Review Deadline</label>
        <input type="date" name="review_deadline" id="review_deadline">
      </div>
    </div>
  </div>

  <%# ══════ LINKS & RETAILERS ══════ %>
  <div class="card form-section">
    <h3>Links & Retailers</h3>
    <p class="section-desc">Pre-fill retailer links and the signed editions URL so the creator doesn't have to hunt them down.</p>
    <div class="form-group">
      <label for="signed_editions_url">Signed Editions URL</label>
      <input type="url" name="signed_editions_url" id="signed_editions_url" placeholder="https://...">
    </div>
  </div>

  <%# ══════ AD ACCESS ══════ %>
  <div class="card form-section">
    <h3>Ad Access</h3>
    <p class="section-desc">Instructions for the creator on granting ad access to their social accounts.</p>
    <div class="form-group">
      <label for="ad_access_notes">Ad Access Instructions</label>
      <textarea name="ad_access_notes" id="ad_access_notes" rows="4" placeholder="We need access to your Facebook page at facebook.com/authorname — here's how to grant it..."></textarea>
    </div>
  </div>

  <%# ══════ LOGISTICS ══════ %>
  <div class="card form-section">
    <h3>Logistics</h3>
    <p class="section-desc">Shipping and management contact info for bookplate fulfillment.</p>
    <div class="form-group">
      <label for="bookplate_address">Bookplate Shipping Address</label>
      <textarea name="bookplate_address" id="bookplate_address" rows="3" placeholder="123 Main St&#10;City, State, Zip"></textarea>
    </div>
    <div class="grid-2 gap-16">
      <div class="form-group">
        <label for="management_emails">Management Emails</label>
        <input type="text" name="management_emails" id="management_emails" placeholder="manager@example.com, agent@example.com">
        <p class="text-muted text-xs" style="margin-top:4px;">Comma-separated email addresses.</p>
      </div>
      <div class="form-group">
        <label for="bookplate_design">Bookplate Design</label>
        <input type="file" name="bookplate_design" id="bookplate_design" accept="image/*,.pdf">
      </div>
    </div>
  </div>

  <%# ══════ CAMPAIGN TYPE & SETTINGS ══════ %>
  <div class="card form-section">
    <h3>Campaign Type & Features</h3>
    <p class="section-desc">Choose a preset to start, then toggle individual features as needed.</p>

    <div class="form-group">
      <label for="campaign_type">Campaign Type</label>
      <select name="campaign_type" id="campaign_type" onchange="applyCampaignType(this.value)" style="max-width:340px;">
        <% Campaign::CAMPAIGN_TYPES.each do |key, config| %>
          <option value="<%= key %>" <%= 'selected' if key == 'full' %>><%= config[:label] %> — <%= config[:description] %></option>
        <% end %>
      </select>
    </div>

    <div class="border-top mt-8" style="padding-top:16px;">
      <label class="text-sm fw-600 text-muted" style="margin-bottom:10px;display:block;">FEATURE TOGGLES</label>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="landing_page_enabled" value="0">
          <input type="checkbox" name="landing_page_enabled" value="1" id="flag_landing_page" checked style="width:auto;">
          Landing Page
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="asset_uploads_enabled" value="0">
          <input type="checkbox" name="asset_uploads_enabled" value="1" id="flag_asset_uploads" checked style="width:auto;">
          Asset Uploads
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="deliverables_enabled" value="0">
          <input type="checkbox" name="deliverables_enabled" value="1" id="flag_deliverables" checked style="width:auto;">
          Deliverables Review
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="live_events_enabled" value="0">
          <input type="checkbox" name="live_events_enabled" value="1" id="flag_live_events" checked style="width:auto;">
          Live Events / Studio
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="personal_videos_enabled" value="0">
          <input type="checkbox" name="personal_videos_enabled" value="1" id="flag_personal_videos" checked style="width:auto;">
          Personal Videos
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="social_tools_enabled" value="0">
          <input type="checkbox" name="social_tools_enabled" value="1" id="flag_social_tools" checked style="width:auto;">
          Social Tools
        </label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-primary);padding:8px;border:1px solid var(--border);border-radius:8px;">
          <input type="hidden" name="royalties_enabled" value="0">
          <input type="checkbox" name="royalties_enabled" value="1" id="flag_royalties" checked style="width:auto;">
          Royalties
        </label>
      </div>
    </div>

    <div style="border-top:1px solid var(--border);padding-top:16px;margin-top:16px;">
      <div class="form-group">
        <label for="example_category">Example Category</label>
        <select name="example_category" id="example_category" style="max-width:240px;">
          <option value="">None (default)</option>
          <% Campaign::EXAMPLE_CATEGORIES.each do |cat| %>
            <option value="<%= cat %>"><%= cat.titleize %></option>
          <% end %>
        </select>
        <p class="text-muted" style="font-size:11px;margin-top:4px;">Which examples the creator sees during onboarding.</p>
      </div>
    </div>
  </div>

  <div style="display:flex;gap:12px;">
    <button type="submit" class="btn btn-primary">Create Campaign</button>
    <%= link_to 'Cancel', manage_campaigns_path, class: 'btn btn-secondary' %>
  </div>
<% end %>

<script>
  function toggleAuthorMode(mode) {
    var newFields = document.getElementById('new-author-fields');
    var existingFields = document.getElementById('existing-author-fields');
    var btnNew = document.getElementById('btn-new-author');
    var btnExisting = document.getElementById('btn-existing-author');
    var loginCard = document.getElementById('creator-login-card');

    if (mode === 'new') {
      newFields.style.display = '';
      existingFields.style.display = 'none';
      btnNew.className = 'btn btn-primary btn-sm';
      btnExisting.className = 'btn btn-secondary btn-sm';
      document.getElementById('existing_author_id').value = '';
      loginCard.style.display = '';
    } else {
      newFields.style.display = 'none';
      existingFields.style.display = '';
      btnNew.className = 'btn btn-secondary btn-sm';
      btnExisting.className = 'btn btn-primary btn-sm';
      document.getElementById('first_name').value = '';
      document.getElementById('last_name').value = '';
      checkExistingAuthorUser();
    }
  }

  document.getElementById('existing_author_id').addEventListener('change', checkExistingAuthorUser);

  function checkExistingAuthorUser() {
    var select = document.getElementById('existing_author_id');
    var loginCard = document.getElementById('creator-login-card');
    var selected = select.options[select.selectedIndex];
    if (selected && selected.dataset.hasUser === 'true') {
      loginCard.style.display = 'none';
    } else {
      loginCard.style.display = '';
    }
  }

  // Campaign type preset switcher
  var campaignTypes = <%= raw Campaign::CAMPAIGN_TYPES.to_json %>;
  function applyCampaignType(typeKey) {
    var config = campaignTypes[typeKey];
    if (!config) return;
    var flags = config.flags;
    for (var key in flags) {
      var cleanKey = key.replace('_enabled', '');
      var checkbox = document.getElementById('flag_' + cleanKey);
      if (checkbox) checkbox.checked = flags[key];
    }
  }
  window.applyCampaignType = applyCampaignType;
  // Apply default on load
  applyCampaignType('full');

  document.getElementById('book_id').addEventListener('change', function() {
    var selected = this.options[this.selectedIndex];
    var note = document.getElementById('book-autofill-note');
    if (this.value && selected.dataset.title) {
      document.getElementById('title').value = selected.dataset.title || '';
      document.getElementById('isbn').value = selected.dataset.isbn || '';
      document.getElementById('book_description').value = selected.dataset.description || '';
      document.getElementById('release_date').value = selected.dataset.releaseDate || '';
      var genreSelect = document.getElementById('genre');
      var genreVal = selected.dataset.genre || '';
      for (var i = 0; i < genreSelect.options.length; i++) {
        if (genreSelect.options[i].value === genreVal) { genreSelect.selectedIndex = i; break; }
      }
      note.textContent = 'Auto-filled from "' + selected.dataset.title + '"';
      note.style.display = '';
    } else {
      note.style.display = 'none';
    }
  });
</script>
