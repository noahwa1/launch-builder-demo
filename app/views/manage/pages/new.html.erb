<% content_for :page_title, 'New Page' %>
<% content_for :page_actions do %>
  <%= link_to 'All Pages', manage_pages_path, class: 'btn btn-secondary btn-sm' %>
<% end %>

<div class="card" style="max-width:640px;">
  <p class="text-secondary" style="font-size:13px;margin-bottom:20px;line-height:1.6;">
    Create a standalone landing page not tied to any campaign. After creating, you'll be taken to the page builder.
  </p>

  <%= form_with url: manage_pages_path, method: :post do |f| %>
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" name="title" id="title" placeholder="Page title" required>
    </div>
    <div class="form-group">
      <label for="slug">Slug (optional — auto-generated from title)</label>
      <input type="text" name="slug" id="slug" placeholder="my-page-slug">
    </div>
    <div class="form-group">
      <label for="author_id">Author (optional)</label>
      <select name="author_id" id="author_id">
        <option value="">None</option>
        <% @authors.each do |author| %>
          <option value="<%= author.id %>"><%= author.full_name %></option>
        <% end %>
      </select>
    </div>

    <hr style="margin:24px 0;border:none;border-top:1px solid var(--border);">
    <h4 style="margin-bottom:12px;">Auto-Generate Content <span class="text-muted" style="font-weight:400;font-size:12px;">(optional)</span></h4>
    <p class="text-secondary" style="font-size:12px;margin-bottom:16px;">Select a book and optionally a company to auto-fill the page with a landing page template.</p>

    <div class="form-group">
      <label for="book_id">Book</label>
      <select name="book_id" id="book_id">
        <option value="">None</option>
        <% @books.each do |book| %>
          <option value="<%= book.id %>" data-author-id="<%= book.author_id %>"><%= book.display_title %> — <%= book.author.full_name %></option>
        <% end %>
      </select>
    </div>
    <div class="form-group">
      <label for="company_name">Company Name <span class="text-muted" style="font-weight:400;font-size:12px;">(for corporate partner pages)</span></label>
      <input type="text" name="company_name" id="company_name" placeholder="e.g. United Airlines">
    </div>
    <div class="form-group">
      <label for="company_email">Company Contact Email</label>
      <input type="email" name="company_email" id="company_email" placeholder="e.g. orders@united.com">
    </div>

    <div style="display:flex;gap:10px;margin-top:24px;">
      <button type="submit" class="btn btn-primary">Create & Open Builder</button>
      <button type="submit" name="generate_page" value="1" class="btn btn-success">Create & Generate Page</button>
      <%= link_to 'Cancel', manage_pages_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
