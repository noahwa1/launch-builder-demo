<% content_for :page_title, "Submissions" %>

<div class="filter-bar">
  <%= link_to 'All', manage_submissions_path, class: "#{params[:status].blank? ? 'active' : ''}" %>
  <% Submission.statuses.keys.each do |status| %>
    <%= link_to status.titleize, manage_submissions_path(status: status), class: "#{params[:status] == status ? 'active' : ''}" %>
  <% end %>
</div>

<div class="card">
  <% if @submissions.any? %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Genre</th>
            <th>Status</th>
            <th>Submitted</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @submissions.each do |sub| %>
            <tr>
              <td><%= link_to sub.title, manage_submission_path(sub), style: 'color: #0071e3; text-decoration: none; font-weight: 500;' %></td>
              <td><%= sub.author.full_name %></td>
              <td><%= sub.genre || '—' %></td>
              <td><span class="status-badge status-<%= sub.status %>"><%= sub.status.titleize %></span></td>
              <td style="color: #86868b; font-size: 13px;"><%= sub.submitted_at&.strftime('%b %d, %Y') || '—' %></td>
              <td>
                <%= link_to 'Review', manage_submission_path(sub), class: 'btn btn-secondary btn-sm' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= paginate @submissions %>
  <% else %>
    <div style="text-align: center; padding: 48px; color: #86868b;">
      <p>No submissions found.</p>
    </div>
  <% end %>
</div>
