<% content_for :page_title, @submission.title %>
<% content_for :page_actions do %>
  <%= link_to 'Back', manage_submissions_path, class: 'btn btn-secondary' %>
<% end %>

<div class="two-col">
  <div>
    <div class="card">
      <h3>Submission Details</h3>
      <div style="display: grid; gap: 16px;">
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">Author</div>
          <div style="font-weight: 500;"><%= @submission.author.full_name %></div>
        </div>
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">Status</div>
          <span class="status-badge status-<%= @submission.status %>"><%= @submission.status.titleize %></span>
        </div>
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">ISBN</div>
          <div><%= @submission.isbn || 'Not assigned' %></div>
        </div>
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">Genre</div>
          <div><%= @submission.genre || '—' %></div>
        </div>
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">Release Date</div>
          <div><%= @submission.release_date&.strftime('%B %d, %Y') || 'TBD' %></div>
        </div>
        <div>
          <div style="font-size: 12px; color: #86868b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">Description</div>
          <div style="line-height: 1.6;"><%= @submission.description || 'None' %></div>
        </div>
      </div>
    </div>

    <div class="card">
      <h3>Actions</h3>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <% if @submission.submitted? %>
          <%= link_to 'Mark In Review', mark_in_review_manage_submission_path(@submission), method: :patch, class: 'btn btn-primary' %>
        <% end %>
        <% if @submission.submitted? || @submission.in_review? %>
          <%= link_to 'Approve', approve_manage_submission_path(@submission), method: :patch, class: 'btn btn-success', data: { confirm: 'Approve this submission?' } %>
        <% end %>
        <% unless @submission.rejected? || @submission.approved? || @submission.live? %>
          <button class="btn btn-danger" onclick="document.getElementById('reject-form').style.display='block'; this.style.display='none';">Reject</button>
        <% end %>
      </div>

      <div id="reject-form" style="display: none; margin-top: 16px;">
        <%= form_tag reject_manage_submission_path(@submission), method: :patch do %>
          <div class="form-group">
            <label>Rejection Notes (sent to creator)</label>
            <%= text_area_tag :admin_notes, nil, placeholder: 'Explain why this submission is being rejected...', rows: 3 %>
          </div>
          <%= submit_tag 'Confirm Rejection', class: 'btn btn-danger' %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card">
    <h3>Messages</h3>
    <% if @messages.any? %>
      <div class="message-list">
        <% @messages.each do |msg| %>
          <div class="message-item <%= 'from-creator' if msg.sender.creator? %>">
            <div class="meta">
              <span class="sender"><%= msg.sender.full_name %> (<%= msg.sender.role %>)</span>
              <span><%= msg.created_at.strftime('%b %d, %I:%M %p') %></span>
            </div>
            <div class="body"><%= msg.body %></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color: #86868b; font-size: 14px;">No messages yet.</p>
    <% end %>

    <%= form_tag reply_manage_submission_path(@submission), method: :post, style: 'margin-top: 16px; border-top: 1px solid #e5e5e7; padding-top: 16px;' do %>
      <div class="form-group" style="margin-bottom: 8px;">
        <%= text_area_tag :body, nil, placeholder: 'Reply to the creator...', rows: 3 %>
      </div>
      <%= submit_tag 'Send Reply', class: 'btn btn-primary btn-sm' %>
    <% end %>
  </div>
</div>
