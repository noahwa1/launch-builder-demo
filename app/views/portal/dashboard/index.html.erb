<% content_for :page_title, "Dashboard" %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="label">Published Books</div>
    <div class="value"><%= @books_count %></div>
  </div>
  <div class="stat-card">
    <div class="label">Total Submissions</div>
    <div class="value"><%= current_author.submissions.count %></div>
    <div class="sub">
      <% @submissions_by_status.each do |status, count| %>
        <span class="status-badge status-<%= status %>"><%= count %> <%= status %></span>
      <% end %>
    </div>
  </div>
  <div class="stat-card">
    <div class="label">Unread Messages</div>
    <div class="value"><%= @unread_messages %></div>
  </div>
  <div class="stat-card">
    <div class="label">Total Royalties Earned</div>
    <div class="value">$<%= number_with_delimiter(current_author.royalty_payments.where(status: :paid).sum(:amount), precision: 2) %></div>
  </div>
</div>

<div class="two-col">
  <div class="card">
    <h3>Recent Submissions</h3>
    <% if @submissions.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% @submissions.each do |sub| %>
              <tr>
                <td style="font-weight: 500;"><%= sub.title %></td>
                <td><span class="status-badge status-<%= sub.status %>"><%= sub.status.titleize %></span></td>
                <td style="color: #86868b; font-size: 13px;"><%= sub.created_at.strftime('%b %d, %Y') %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No submissions yet.</p>
      </div>
    <% end %>
  </div>

  <div class="card">
    <h3>Recent Payments</h3>
    <% if @recent_payments.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Period</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_payments.each do |payment| %>
              <tr>
                <td><%= link_to payment.period_label, portal_royalty_path(payment), style: 'color: #0071e3; text-decoration: none; font-weight: 500;' %></td>
                <td style="font-weight: 600;">$<%= number_with_precision(payment.amount, precision: 2) %></td>
                <td><span class="status-badge status-<%= payment.status %>"><%= payment.status.titleize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No payments yet.</p>
      </div>
    <% end %>
  </div>
</div>
