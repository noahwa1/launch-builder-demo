<div class="onboard-overlay" id="onboardOverlay">
  <div class="onboard-modal">
    <button class="ob-close" onclick="closeOnboarding()" title="Skip">&times;</button>

    <%# ── Step 1: Welcome Video ── %>
    <div class="ob-video-step" id="obStep1">
      <h2>Welcome to Launch</h2>
      <div class="ob-sub">A quick message from our CEO about how we'll help you launch your book.</div>

      <div class="ob-video-placeholder">
        <div class="play-circle" onclick="playVideo()">
          <svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg>
        </div>
        <div class="vid-label">CEO Welcome Video</div>
      </div>

      <div class="ob-footer">
        <div class="ob-steps-dots">
          <div class="ob-dot active"></div>
          <div class="ob-dot"></div>
        </div>
        <button class="ob-next-btn" onclick="goToStep2()">Next</button>
      </div>
    </div>

    <%# ── Step 2: Campaign Examples ── %>
    <div class="ob-examples-step" id="obStep2" style="display:none;">
      <h2>Set up your campaign like...</h2>
      <div class="ob-sub">Here are some successful campaigns similar to yours. Pick one that inspires you, or skip to start from scratch.</div>

      <div class="example-grid">
        <% examples.each_with_index do |ex, i| %>
          <div class="example-card" onclick="selectExample(this)" data-idx="<%= i %>">
            <div class="ex-cover">Campaign Preview</div>
            <div class="ex-title"><%= ex[:title] %></div>
            <div class="ex-desc"><%= ex[:desc] %></div>
            <div class="ex-tag"><%= ex[:tag] %></div>
          </div>
        <% end %>
      </div>

      <div class="ob-footer">
        <div class="ob-steps-dots">
          <div class="ob-dot"></div>
          <div class="ob-dot active"></div>
        </div>
        <div style="display:flex;gap:10px;">
          <button class="ob-next-btn" style="background:var(--surface);color:var(--text-primary);border:1px solid var(--border-strong);box-shadow:var(--shadow-sm);" onclick="closeOnboarding()">Skip</button>
          <%= button_to complete_onboarding_portal_campaign_path(@campaign), method: :patch, class: 'ob-next-btn', form: { style: 'display:inline', id: 'onboardForm' } do %>
            Get Started
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  window.goToStep2 = function() {
    document.getElementById('obStep1').style.display = 'none';
    document.getElementById('obStep2').style.display = '';
  };

  window.selectExample = function(card) {
    document.querySelectorAll('.example-card').forEach(function(c) { c.classList.remove('selected'); });
    card.classList.add('selected');
  };

  window.playVideo = function() {
    // Placeholder — will eventually load actual video
    var placeholder = document.querySelector('.ob-video-placeholder');
    placeholder.innerHTML = '<div style="color:rgba(255,255,255,0.5);font-size:14px;z-index:1;">Video player will be embedded here</div>';
  };

  window.closeOnboarding = function() {
    var overlay = document.getElementById('onboardOverlay');
    overlay.style.opacity = '0';
    overlay.style.transition = 'opacity 0.2s ease';
    setTimeout(function() { overlay.remove(); }, 200);
    // Mark onboarding complete via AJAX
    var form = document.getElementById('onboardForm');
    if (form) {
      fetch(form.action, {
        method: 'PATCH',
        headers: {
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Accept': 'text/html'
        }
      });
    }
  };
})();
</script>
<% end %>
