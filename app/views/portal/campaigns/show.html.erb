            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'brief'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="brief">
                <textarea name="notes" rows="2" placeholder="Describe what needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes</button>
