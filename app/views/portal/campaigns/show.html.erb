            <span class="team-label">Set by your team</span>
          </h4>
          <% if links_ok %><span class="confirm-status st-confirmed">Confirmed</span>
          <% elsif links_chg %><span class="confirm-status st-changes">Changes Requested</span>
          <% else %><span class="confirm-status st-pending">Needs Review</span><% end %>
