            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="brief">
                <textarea name="notes" rows="2" placeholder="Describe what still needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes Again</button>
              <% end %>
            </div>
          </div>
        <% else %>
