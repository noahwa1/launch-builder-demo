        <div class="confirm-data">
          <div class="data-label">Signed Editions URL</div>
          <div class="data-value"><a href="<%= @campaign.signed_editions_url %>" target="_blank" class="text-accent" style="word-break:break-all;"><%= @campaign.signed_editions_url %></a></div>
        </div>
        <% if links_ok %>
          <div class="confirm-meta">Confirmed by you on <%= links_conf.confirmed_at.strftime('%b %d, %Y') %></div>
        <% elsif links_chg %>
          <div class="confirm-note"><div class="note-label">Your change request</div><%= links_conf.notes %></div>
          <div class="confirm-meta">Submitted <%= time_ago_in_words(links_conf.confirmed_at) %> ago</div>
          <div class="confirm-actions" style="margin-top:12px;">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'links'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="links">
                <textarea name="notes" rows="2" placeholder="Describe what still needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes Again</button>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="confirm-actions">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'links'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="links">
                <textarea name="notes" rows="2" placeholder="e.g. Can you change it to the paperback edition link?" required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Ad Access ── %>
    <% if @campaign.ad_access_notes.present? || @campaign.facebook_access? || @campaign.instagram_access? || @campaign.tiktok_access? %>
      <% ad_conf = @confirmations['ad_access'] %>
      <% ad_ok = ad_conf&.persisted? && !ad_conf&.has_changes_requested? %>
      <% ad_chg = ad_conf&.has_changes_requested? %>
      <div class="confirm-section <%= ad_ok ? 'confirmed' : (ad_chg ? 'changes-requested' : 'needs-review') %>">
        <div class="confirm-header">
          <h4>
            <% if ad_ok %><svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><% end %>
            Ad Access
            <span class="team-label">Set by your team</span>
          </h4>
          <% if ad_ok %><span class="confirm-status st-confirmed">Confirmed</span>
          <% elsif ad_chg %><span class="confirm-status st-changes">Changes Requested</span>
          <% else %><span class="confirm-status st-pending">Needs Review</span><% end %>
        </div>
        <div class="confirm-data">
          <div class="d-flex gap-8 flex-wrap mb-8">
            <% if @campaign.facebook_access? %><span class="text-sm fw-600 rounded" style="padding:4px 10px;background:rgba(59,89,152,0.08);color:#3B5998;">Facebook</span><% end %>
            <% if @campaign.instagram_access? %><span class="text-sm fw-600 rounded" style="padding:4px 10px;background:rgba(225,48,108,0.08);color:#E1306C;">Instagram</span><% end %>
            <% if @campaign.tiktok_access? %><span class="text-sm fw-600 rounded" style="padding:4px 10px;background:rgba(0,0,0,0.06);color:#000;">TikTok</span><% end %>
          </div>
          <% if @campaign.ad_access_notes.present? %>
            <div class="data-label">Instructions from your team</div>
            <div class="data-value" style="white-space:pre-wrap"><%= @campaign.ad_access_notes %></div>
          <% end %>
        </div>
        <% if ad_ok %>
          <div class="confirm-meta">Confirmed by you on <%= ad_conf.confirmed_at.strftime('%b %d, %Y') %></div>
        <% elsif ad_chg %>
          <div class="confirm-note"><div class="note-label">Your change request</div><%= ad_conf.notes %></div>
          <div class="confirm-meta">Submitted <%= time_ago_in_words(ad_conf.confirmed_at) %> ago</div>
          <div class="confirm-actions" style="margin-top:12px;">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'ad_access'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="ad_access">
                <textarea name="notes" rows="2" placeholder="Describe what still needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes Again</button>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="confirm-actions">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'ad_access'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="ad_access">
                <textarea name="notes" rows="2" placeholder="Describe what needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Logistics ── %>
    <% if @campaign.bookplate_address.present? || @campaign.management_emails.present? || @campaign.bookplate_design.present? %>
      <% log_conf = @confirmations['logistics'] %>
      <% log_ok = log_conf&.persisted? && !log_conf&.has_changes_requested? %>
      <% log_chg = log_conf&.has_changes_requested? %>
      <div class="confirm-section <%= log_ok ? 'confirmed' : (log_chg ? 'changes-requested' : 'needs-review') %>">
        <div class="confirm-header">
          <h4>
            <% if log_ok %><svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><% end %>
            Logistics
            <span class="team-label">Set by your team</span>
          </h4>
          <% if log_ok %><span class="confirm-status st-confirmed">Confirmed</span>
          <% elsif log_chg %><span class="confirm-status st-changes">Changes Requested</span>
          <% else %><span class="confirm-status st-pending">Needs Review</span><% end %>
        </div>
        <div class="confirm-data">
          <div class="grid-2" style="gap:12px;">
            <% if @campaign.bookplate_address.present? %><div><div class="data-label">Shipping Address</div><div class="data-value" style="white-space:pre-wrap"><%= @campaign.bookplate_address %></div></div><% end %>
            <% if @campaign.management_emails.present? %><div><div class="data-label">Management Emails</div><div class="data-value"><%= @campaign.management_emails %></div></div><% end %>
          </div>
          <% if @campaign.bookplate_design.present? %><div class="mt-8"><div class="data-label">Bookplate Design</div><div class="data-value">Uploaded</div></div><% end %>
        </div>
        <% if log_ok %>
          <div class="confirm-meta">Confirmed by you on <%= log_conf.confirmed_at.strftime('%b %d, %Y') %></div>
        <% elsif log_chg %>
          <div class="confirm-note"><div class="note-label">Your change request</div><%= log_conf.notes %></div>
          <div class="confirm-meta">Submitted <%= time_ago_in_words(log_conf.confirmed_at) %> ago</div>
          <div class="confirm-actions" style="margin-top:12px;">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'logistics'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="logistics">
                <textarea name="notes" rows="2" placeholder="Describe what still needs to change..." required></textarea>
                <button type="submit" class="confirm-btn request">Request Changes Again</button>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="confirm-actions">
            <%= button_to 'Confirm', portal_campaign_confirmations_path(@campaign, section: 'logistics'), method: :post, class: 'confirm-btn approve', form: { class: 'd-inline' } %>
            <div class="confirm-changes-form">
              <%= form_tag portal_campaign_confirmations_path(@campaign), method: :post do %>
                <input type="hidden" name="section" value="logistics">
