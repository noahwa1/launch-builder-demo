<% content_for :page_title, @campaign.title %>
<% content_for :page_actions do %>
  <span class="status-badge status-<%= @campaign.status %>"><%= @campaign.status.titleize %></span>
<% end %>

<style>
  .progress-bar-wrap { background: var(--border); border-radius: 20px; height: 8px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 20px; background: linear-gradient(90deg, var(--accent), var(--accent-light)); transition: width 0.6s ease; }
  .checklist-category { margin-bottom: 24px; }
  .checklist-category h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  .checklist-category h4 .cat-badge { background: var(--accent-glow); color: var(--accent); padding: 2px 8px; border-radius: 6px; font-size: 11px; }
  .checklist-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border-radius: 10px; transition: background 0.1s; }
  .checklist-row:hover { background: var(--accent-wash); }
  .check-icon { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border-strong); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .check-icon.complete { background: #22C55E; border-color: #22C55E; color: #fff; }
  .check-icon.in_progress { background: var(--accent-glow); border-color: var(--accent); color: var(--accent); }
  .check-icon svg { width: 12px; height: 12px; }
  .checklist-title { font-size: 14px; flex: 1; }
  .checklist-title.complete { text-decoration: line-through; color: var(--text-muted); }
  .optional-tag { font-size: 10px; background: rgba(0,0,0,0.04); color: var(--text-muted); padding: 2px 6px; border-radius: 4px; }
  .quick-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
  .whats-next-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px; color: var(--text-secondary); }
  .whats-next-item:last-child { border-bottom: none; }
  .whats-next-num { width: 24px; height: 24px; border-radius: 50%; background: var(--accent-glow); color: var(--accent); font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
</style>

<!-- Stats Grid -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="label">Progress</div>
    <div class="value"><%= @progress %>%</div>
    <div style="margin-top: 8px;">
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width: <%= @progress %>%"></div></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="label">Items Complete</div>
    <div class="value"><%= @campaign.checklist_items.where(status: :complete).count %><span style="font-size:16px;color:var(--text-muted)"> / <%= @campaign.checklist_items.count %></span></div>
  </div>
  <div class="stat-card">
    <div class="label">Assets Uploaded</div>
    <div class="value"><%= @assets_count %></div>
    <% if @pending_assets > 0 %>
      <div class="sub"><%= @pending_assets %> pending review</div>
    <% end %>
  </div>
  <div class="stat-card">
    <div class="label">Landing Page</div>
    <div class="value" style="font-size:16px; margin-top:12px;">
      <% if @campaign.landing_page&.published? %>
        <span class="status-badge status-live">Published</span>
      <% else %>
        <span class="status-badge status-draft">Draft</span>
      <% end %>
    </div>
  </div>
</div>

<div class="two-col">
  <!-- What's Next -->
  <div class="card">
    <h3>What's Next</h3>
    <% if @incomplete_items.any? %>
      <% @incomplete_items.each_with_index do |item, i| %>
        <div class="whats-next-item">
          <span class="whats-next-num"><%= i + 1 %></span>
          <%= item.title %>
        </div>
      <% end %>
    <% else %>
      <div style="text-align:center;padding:24px;color:var(--text-muted);">All items complete!</div>
    <% end %>
    <div class="quick-actions">
      <%= link_to 'Links', links_portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Content', portal_campaign_campaign_assets_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Ad Access', ad_access_portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Logistics', logistics_portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Landing Page', portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Social Posts', portal_campaign_social_posts_path(@campaign), class: 'btn btn-secondary btn-sm' %>
    </div>
  </div>

  <!-- Recent Assets -->
  <div class="card">
    <h3>Recent Assets</h3>
    <% if @recent_assets.any? %>
      <% @recent_assets.each do |asset| %>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);">
          <span style="font-size:14px;flex:1;"><%= asset.original_filename || asset.asset_type.titleize %></span>
          <span class="status-badge status-<%= asset.status == 'pending_review' ? 'pending' : asset.status %>"><%= asset.status.titleize %></span>
        </div>
      <% end %>
    <% else %>
      <div style="text-align:center;padding:24px;color:var(--text-muted);">No assets uploaded yet.</div>
    <% end %>
    <%= link_to 'Upload Content', portal_campaign_campaign_assets_path(@campaign), class: 'btn btn-primary btn-sm', style: 'margin-top:12px;' %>
  </div>
</div>

<!-- Go Live -->
<div class="card" style="margin-top:4px;">
  <h3>Go Live</h3>
  <% current_event = @campaign.current_live_event %>
  <% if current_event %>
    <div style="padding:16px;background:rgba(233,69,96,0.06);border:1px solid rgba(233,69,96,0.2);border-radius:10px;margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
        <span style="display:inline-block;width:10px;height:10px;background:#e94560;border-radius:50%;animation:liveDot 1.5s ease-in-out infinite;"></span>
        <span style="font-size:14px;font-weight:700;color:#e94560;">LIVE NOW</span>
      </div>
      <div style="font-size:15px;font-weight:600;"><%= current_event.title %></div>
      <div class="text-muted" style="font-size:13px;margin-top:2px;">Started <%= time_ago_in_words(current_event.started_at) %> ago</div>
      <div style="margin-top:12px;">
        <%= button_to 'End Stream', end_stream_portal_campaign_live_event_path(@campaign, current_event), method: :patch, class: 'btn btn-danger btn-sm', form: { style: 'display:inline' }, data: { confirm: 'End the live stream?' } %>
      </div>
    </div>
    <style>@keyframes liveDot { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }</style>
  <% end %>

  <% upcoming = @campaign.live_events.upcoming.limit(3) %>
  <% if upcoming.any? %>
    <div style="margin-bottom:16px;">
      <div class="detail-label" style="margin-bottom:8px;">Upcoming Events</div>
      <% upcoming.each do |event| %>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);">
          <div>
            <div style="font-size:14px;font-weight:600;"><%= event.title %></div>
            <div class="text-muted" style="font-size:12px;"><%= event.scheduled_at&.strftime('%b %d at %l:%M %p') %> — <%= event.stream_platform&.capitalize || 'TBD' %></div>
          </div>
          <div style="display:flex;gap:6px;">
            <%= button_to 'Go Live', go_live_portal_campaign_live_event_path(@campaign, event), method: :patch, class: 'btn btn-primary btn-sm', form: { style: 'display:inline' }, data: { confirm: 'Go live now?' } %>
            <%= link_to 'Edit', edit_portal_campaign_live_event_path(@campaign, event), class: 'btn btn-secondary btn-sm' %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if current_event.nil? && upcoming.empty? %>
    <p class="text-secondary" style="font-size:14px;margin-bottom:16px;">No events scheduled. Set up a live stream for your campaign.</p>
  <% end %>

  <%= link_to new_portal_campaign_live_event_path(@campaign), class: 'btn btn-secondary btn-sm' do %>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
    Schedule Event
  <% end %>
</div>

<!-- Checklist by Category -->
<div class="card" style="margin-top:4px;">
  <h3>Campaign Checklist</h3>
  <% Campaign::CATEGORIES.each do |cat| %>
    <% items = @items_by_category[cat] || [] %>
    <% next if items.empty? %>
    <div class="checklist-category">
      <h4>
        <%= cat.titleize.gsub('Ad Access', 'Ad Access') %>
        <span class="cat-badge"><%= items.count(&:complete?) %>/<%= items.size %></span>
      </h4>
      <% items.each do |item| %>
        <div class="checklist-row">
          <div class="check-icon <%= item.status %>">
            <% if item.complete? %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            <% elsif item.in_progress? %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 6v6l4 2"/></svg>
            <% end %>
          </div>
          <span class="checklist-title <%= item.status %>"><%= item.title %></span>
          <% if item.optional? %><span class="optional-tag">Optional</span><% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
