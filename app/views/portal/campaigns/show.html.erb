                <button type="submit" class="confirm-btn request">Request Changes</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE: CONTENT (current) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% elsif @campaign.content? %>
  <%# From Your Team — Deliverables %>
  <% if @campaign.deliverables_enabled? && @pending_deliverables&.any? %>
    <div class="card content-section">
      <h4>
        <svg viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        From Your Team
        <span class="text-xs fw-700 bg-warning-light" style="padding:2px 8px;border-radius:10px;color:#D97706;"><%= @pending_deliverables.count %></span>
      </h4>
      <p class="text-md text-muted mb-12">Review and approve these items from your team.</p>
      <% @pending_deliverables.each do |del| %>
        <%= link_to portal_campaign_deliverable_path(@campaign, del), class: 'del-row' do %>
          <div class="del-row-icon" style="background:rgba(217,119,6,0.08);color:#D97706;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="del-row-info">
            <h5><%= del.title %></h5>
            <div class="meta"><%= del.category_label %> · <%= time_ago_in_words(del.created_at) %> ago</div>
          </div>
          <span class="text-xs fw-700 text-upper rounded bg-warning-light" style="padding:4px 10px;color:#D97706;"><%= del.revised? ? 'Revised' : 'Review' %></span>
        <% end %>
      <% end %>
      <%= link_to 'View All Deliverables', portal_campaign_deliverables_path(@campaign), class: 'text-md text-accent d-inline-block mt-8' %>
    </div>
  <% end %>

  <%# Content uploads — soft ask %>
  <% if @campaign.asset_uploads_enabled? %>
    <% completed_count = @content_items&.count(&:complete?) || 0 %>
    <% total_count = @content_items&.size || 0 %>
    <div class="card content-section">
      <h4>
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" width="18" height="18"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        Your Content
        <% if completed_count > 0 %>
          <span class="text-xs fw-700 bg-success-light rounded-lg" style="padding:2px 8px;color:#16A34A;"><%= completed_count %>/<%= total_count %></span>
        <% end %>
      </h4>
      <p class="text-md text-muted mb-12">Upload whatever you have ready — every piece helps your campaign. You can always add more later.</p>
      <% if @content_items&.any? %>
        <% @content_items.each do |item| %>
          <div class="checklist-mini-row">
            <div class="check-dot <%= 'done' if item.complete? %>">
              <% if item.complete? %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><% end %>
            </div>
            <span class="flex-1" style="color:<%= item.complete? ? 'var(--text-muted)' : 'var(--text-primary)' %>;<%= 'text-decoration:line-through;' if item.complete? %>"><%= item.title %></span>
            <% unless item.complete? %><span class="text-xs text-muted">Optional</span><% end %>
          </div>
        <% end %>
      <% end %>
      <div class="mt-12 d-flex items-center gap-12">
        <%= link_to portal_campaign_campaign_assets_path(@campaign), class: 'btn btn-primary btn-sm' do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          Upload Assets
        <% end %>
      </div>
    </div>
  <% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE: REVIEW (current) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% elsif @campaign.review? %>
  <%# Outstanding Items %>
  <% if @all_incomplete.any? %>
    <div class="card mb-16">
      <h4 class="subheading d-flex items-center gap-8">
        Remaining Items
        <span class="text-xs fw-700 bg-warning-light" style="padding:2px 8px;border-radius:10px;color:#D97706;"><%= @all_incomplete.count %></span>
      </h4>
      <% @all_incomplete.group_by(&:category).each do |cat, items| %>
        <div class="label-upper fw-700" style="margin:10px 0 6px;"><%= cat.titleize %></div>
        <% items.each do |item| %>
          <div class="checklist-mini-row">
            <div class="check-dot"></div>
            <span class="flex-1"><%= item.title %></span>
            <% if item.optional? %><span class="text-muted rounded-sm" style="font-size:10px;background:rgba(0,0,0,0.04);padding:2px 6px;"><%= "Optional" %></span><% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Deliverables in revision %>
  <% if @campaign.deliverables_enabled? && @revision_deliverables&.any? %>
    <div class="card mb-16" style="border-left:3px solid #EF4444;">
      <h4 class="subheading">Deliverables Needing Revision</h4>
      <% @revision_deliverables.each do |del| %>
        <%= link_to portal_campaign_deliverable_path(@campaign, del), class: 'del-row' do %>
          <div class="del-row-icon" style="background:rgba(239,68,68,0.08);color:#EF4444;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <div class="del-row-info">
            <h5><%= del.title %></h5>
            <div class="meta">Revision requested · <%= time_ago_in_words(del.updated_at) %> ago</div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Landing Page %>
  <% if @campaign.landing_page_enabled? && @landing_page %>
    <div class="card mb-16">
      <div class="section-header">
        <h4 class="text-base fw-700">Landing Page</h4>
        <% if @landing_page.published? %>
          <span class="text-xs fw-700 text-upper rounded bg-success-light" style="padding:4px 10px;color:#16A34A;">Published</span>
        <% else %>
          <span class="text-xs fw-700 text-upper rounded bg-warning-light" style="padding:4px 10px;color:#D97706;">Draft</span>
        <% end %>
      </div>
      <div class="d-flex gap-8">
        <%= link_to portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary btn-sm' do %>Preview<% end %>
        <% if @landing_page.published? %>
          <%= link_to public_page_path(@landing_page.slug), target: '_blank', class: 'btn btn-secondary btn-sm' do %>View Live<% end %>
        <% else %>
          <%= link_to builder_portal_campaign_landing_page_path(@campaign), class: 'btn btn-primary btn-sm' do %>Open Builder<% end %>
        <% end %>
      </div>
    </div>
  <% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE: LIVE (current) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% elsif @campaign.live? %>
  <%# Stats %>
  <div class="live-stats">
    <% if @campaign.landing_page_enabled? %>
      <div class="live-stat"><div class="ls-num"><%= @submission_count %></div><div class="ls-label">Submissions</div></div>
    <% end %>
    <div class="live-stat"><div class="ls-num"><%= @assets_count %></div><div class="ls-label">Assets</div></div>
    <div class="live-stat"><div class="ls-num"><%= @campaign.live_events.where(status: :ended).count %></div><div class="ls-label">Streams</div></div>
    <% if @campaign.personal_videos_enabled? %>
      <div class="live-stat"><div class="ls-num"><%= @personal_video_count %>/<%= @personal_video_total %></div><div class="ls-label">Videos Sent</div></div>
    <% end %>
  </div>

  <%# Quick Tools %>
  <div class="card mb-16">
    <h4 class="subheading">Your Tools</h4>
    <% if @campaign.landing_page_enabled? && @landing_page %>
      <%= link_to portal_campaign_landing_page_path(@campaign), class: 'toolkit-row' do %>
        <div class="tk-icon" style="background:rgba(79,70,229,0.1);color:var(--accent);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg></div>
        <span class="tk-title">Landing Page</span>
        <% if @landing_page.published? %><span class="text-xs fw-600 text-success">Live</span><% end %>
        <svg class="tk-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    <% end %>
    <% if @campaign.live_events_enabled? %>
      <%= link_to studio_portal_campaign_live_events_path(@campaign), class: 'toolkit-row' do %>
        <div class="tk-icon" style="background:rgba(233,69,96,0.1);color:#e94560;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg></div>
        <span class="tk-title">Go Live Studio</span>
        <svg class="tk-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    <% end %>
    <% if @campaign.social_tools_enabled? %>
      <%= link_to portal_campaign_social_posts_path(@campaign), class: 'toolkit-row' do %>
        <div class="tk-icon" style="background:rgba(59,130,246,0.1);color:#3B82F6;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg></div>
        <span class="tk-title">Social Posts</span>
        <svg class="tk-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    <% end %>
    <% if @campaign.asset_uploads_enabled? %>
      <%= link_to portal_campaign_campaign_assets_path(@campaign), class: 'toolkit-row' do %>
        <div class="tk-icon" style="background:rgba(34,197,94,0.1);color:#22C55E;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
        <span class="tk-title">Content & Assets</span>
        <svg class="tk-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    <% end %>
    <% if @campaign.personal_videos_enabled? %>
      <%= link_to recorder_portal_campaign_live_events_path(@campaign), class: 'toolkit-row' do %>
        <div class="tk-icon" style="background:rgba(168,85,247,0.1);color:#A855F7;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg></div>
        <span class="tk-title">Personal Videos</span>
        <span class="text-xs text-muted"><%= @personal_video_count %>/<%= @personal_video_total %></span>
        <svg class="tk-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <% end %>
    <% end %>
  </div>

  <%# Recent Submissions %>
  <% if @campaign.landing_page_enabled? && @recent_submissions.any? %>
    <div class="card mb-16">
      <h4 class="subheading">Recent Submissions</h4>
      <% @recent_submissions.each do |sub| %>
        <div class="list-row" style="padding:8px 0;">
          <div>
            <div class="text-md fw-600"><%= sub.email %></div>
            <div class="text-xs text-muted"><%= time_ago_in_words(sub.created_at) %> ago</div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE: WRAP UP (current) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% elsif @campaign.wrap_up? %>
  <div class="card mb-16">
    <div class="centered-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="48" height="48" class="mb-12"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <h3 class="text-2xl fw-700 mb-6">Campaign Complete</h3>
      <p class="text-base text-secondary">Great work! Here's a summary of your campaign.</p>
    </div>
    <div class="mt-16" style="display:grid;grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));gap:12px;">
      <div class="live-stat"><div class="ls-num"><%= @submission_count %></div><div class="ls-label">Total Leads</div></div>
      <div class="live-stat"><div class="ls-num"><%= @assets_count %></div><div class="ls-label">Assets Created</div></div>
      <div class="live-stat"><div class="ls-num"><%= @campaign.live_events.where(status: :ended).count %></div><div class="ls-label">Live Events</div></div>
      <% if @campaign.personal_videos_enabled? %>
        <div class="live-stat"><div class="ls-num"><%= @personal_video_count %></div><div class="ls-label">Videos Sent</div></div>
      <% end %>
    </div>
  </div>

  <% if @campaign.royalties_enabled? %>
    <div class="card mb-16">
      <h4 class="subheading" style="margin-bottom:8px;">Royalties</h4>
      <p class="text-md text-secondary mb-12">View your earnings and payment history.</p>
      <%= link_to 'View Royalties', portal_royalties_path, class: 'btn btn-primary btn-sm' %>
    </div>
  <% end %>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE ADVANCEMENT BAR ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% unless %w[live wrap_up].include?(@campaign.phase) %>
  <% if @campaign.can_advance? %>
    <% next_phase_name = Campaign.phases.key(Campaign.phases[@campaign.phase] + 1)&.titleize %>
    <div class="advance-bar ready">
      <div>
        <div class="text-base fw-600 text-success">All clear — ready to advance</div>
        <div class="text-sm text-muted mt-2">Move to the <%= next_phase_name %> phase</div>
      </div>
      <%= button_to "Move to #{next_phase_name}", advance_phase_portal_campaign_path(@campaign), method: :patch, class: 'advance-btn' %>
    </div>
  <% elsif @blockers.any? %>
    <div class="advance-bar blocked">
      <div>
        <div class="text-base fw-600 text-warning"><%= @blockers.count %> item<%= 's' if @blockers.count != 1 %> remaining</div>
        <ul style="margin:4px 0 0;padding-left:18px;">
          <% @blockers.each do |b| %>
            <li class="text-sm text-secondary" style="margin-bottom:1px;"><%= b %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── COMPLETED PHASES (collapsed) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% Campaign.phases.each do |name, idx| %>
  <% next unless idx < @current_phase_idx %>
  <details class="phase-card mb-8">
    <summary class="phase-card-header" style="list-style:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <h3><%= name.titleize %></h3>
      <span class="phase-badge bg-success-light text-success">Complete</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" class="ml-auto"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div class="phase-card-body">
      <% case name %>
      <% when 'setup' %>
        <% @campaign.confirmable_sections.each do |s| %>
          <div class="d-flex items-center gap-8 text-md" style="padding:6px 0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="14" height="14"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span><%= s.titleize %> — confirmed</span>
          </div>
        <% end %>
      <% when 'content' %>
        <div class="text-md text-muted">Content phase complete. Deliverables reviewed.</div>
      <% when 'review' %>
        <div class="text-md text-muted">All items approved and landing page published.</div>
      <% end %>
    </div>
  </details>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── FUTURE PHASES (preview) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% Campaign.phases.each do |name, idx| %>
  <% next unless idx > @current_phase_idx %>
  <% preview = phase_previews[name] %>
  <% next unless preview %>
  <div class="future-preview">
    <div class="lock-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    </div>
    <div>
      <div class="text-md fw-600 text-secondary"><%= name.titleize %></div>
      <div class="text-sm text-muted"><%= preview %></div>
    </div>
  </div>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── FULL CHECKLIST (collapsed) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<details class="card mt-16" style="cursor:pointer;">
  <summary class="detail-label d-flex items-center justify-between" style="list-style:none;">
    Full Campaign Checklist
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
  </summary>
  <div class="mt-16">
    <% Campaign::CATEGORIES.each do |cat| %>
      <% items = @items_by_category[cat] || [] %>
      <% next if items.empty? %>
      <div class="mb-16">
        <div class="detail-label fw-700 mb-8"><%= cat.titleize %></div>
        <% items.each do |item| %>
          <div class="checklist-mini-row">
            <div class="check-dot <%= 'done' if item.complete? %>">
              <% if item.complete? %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><% end %>
            </div>
            <span class="flex-1" style="color:<%= item.complete? ? 'var(--text-muted)' : 'var(--text-primary)' %>;<%= 'text-decoration:line-through;' if item.complete? %>"><%= item.title %></span>
            <% if item.optional? %><span class="text-muted rounded-sm" style="font-size:10px;background:rgba(0,0,0,0.04);padding:2px 6px;">Optional</span><% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</details>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── ACTIVITY TIMELINE ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% if @activities.any? %>
<details class="card mt-16" style="cursor:pointer;">
  <summary class="detail-label d-flex items-center justify-between" style="list-style:none;">
    Recent Activity
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
  </summary>
  <div class="mt-16" style="max-height:400px;overflow-y:auto;">
    <% @activities.group_by { |a| a.created_at.to_date }.each do |date, day_activities| %>
      <div class="detail-label border-bottom mb-6" style="padding:6px 0 4px;">
        <%= date == Date.today ? 'Today' : date == Date.yesterday ? 'Yesterday' : date.strftime('%B %d, %Y') %>
      </div>
      <% day_activities.each do |activity| %>
        <div class="d-flex gap-10 items-start" style="padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.04);">
          <div class="d-flex items-center justify-center fw-700 rounded-full" style="width:26px;height:26px;background:var(--accent-wash);font-size:10px;color:var(--accent);flex-shrink:0;">
            <%= activity.user_initials %>
          </div>
          <div class="flex-1" style="min-width:0;">
            <div class="text-md text-primary"><%= activity.human_description %></div>
            <div class="text-xs text-muted mt-2">
              <%= activity.user&.first_name || 'System' %> &middot; <%= activity.created_at.strftime('%-I:%M %p') %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</details>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── ONBOARDING POPUP (first-time only) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% unless @campaign.onboarding_completed? %>
<style>
  .onboard-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: obFadeIn 0.3s ease; }
  @keyframes obFadeIn { from { opacity: 0; } to { opacity: 1; } }
  .onboard-modal { background: #fff; border-radius: 20px; width: 680px; max-width: 94vw; max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 80px rgba(0,0,0,0.25); animation: obSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1); position: relative; }
  @keyframes obSlideUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .onboard-modal .ob-close { position: absolute; top: 16px; right: 16px; width: 32px; height: 32px; border-radius: 50%; border: none; background: rgba(0,0,0,0.05); color: var(--text-muted); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; z-index: 2; }
  .onboard-modal .ob-close:hover { background: rgba(0,0,0,0.1); color: var(--text-primary); }
  .ob-video-step { padding: 40px 40px 32px; text-align: center; }
  .ob-video-step h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 8px; }
  .ob-video-step .ob-sub { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.5; }
  .ob-video-placeholder { width: 100%; aspect-ratio: 16/9; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-direction: column; color: rgba(255,255,255,0.5); margin-bottom: 24px; position: relative; overflow: hidden; }
  .ob-video-placeholder::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(79,70,229,0.15), transparent 70%); }
  .ob-video-placeholder .play-circle { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.15); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; z-index: 1; transition: all 0.2s; cursor: pointer; }
  .ob-video-placeholder .play-circle:hover { background: rgba(255,255,255,0.25); transform: scale(1.05); }
  .ob-video-placeholder .play-circle svg { width: 24px; height: 24px; fill: #fff; margin-left: 3px; }
  .ob-video-placeholder .vid-label { font-size: 13px; z-index: 1; }
  .ob-next-btn { padding: 12px 32px; background: linear-gradient(135deg, var(--accent), var(--accent-light)); color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all 0.15s; box-shadow: 0 2px 12px rgba(79,70,229,0.3); }
  .ob-next-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 18px rgba(79,70,229,0.4); }
  .ob-examples-step { padding: 40px 40px 32px; }
  .ob-examples-step h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 6px; }
  .ob-examples-step .ob-sub { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; line-height: 1.5; }
  .example-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 28px; }
  .example-card { border: 2px solid var(--border); border-radius: 14px; padding: 20px; cursor: pointer; transition: all 0.2s; position: relative; }
  .example-card:hover { border-color: rgba(79,70,229,0.3); background: var(--accent-wash); }
  .example-card.selected { border-color: var(--accent); background: rgba(79,70,229,0.04); }
  .example-card.selected::after { content: ''; position: absolute; top: 10px; right: 10px; width: 22px; height: 22px; border-radius: 50%; background: var(--accent); background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolyline points='20 6 9 17 4 12'/%3E%3C/svg%3E"); background-size: 12px; background-repeat: no-repeat; background-position: center; }
  .example-card .ex-cover { width: 100%; aspect-ratio: 3/2; background: linear-gradient(135deg, #f0f0f0, #e5e5e5); border-radius: 8px; margin-bottom: 12px; display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 12px; }
  .example-card .ex-title { font-size: 15px; font-weight: 700; margin-bottom: 3px; }
  .example-card .ex-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.4; }
  .example-card .ex-tag { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--accent); margin-top: 6px; }
  .ob-footer { display: flex; align-items: center; justify-content: space-between; }
  .ob-steps-dots { display: flex; gap: 6px; }
  .ob-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border-strong); transition: all 0.3s; }
  .ob-dot.active { background: var(--accent); width: 24px; border-radius: 4px; }
  @media (max-width: 768px) { .example-grid { grid-template-columns: 1fr; } .ob-video-step, .ob-examples-step { padding: 24px 20px; } .ob-video-step h2, .ob-examples-step h2 { font-size: 20px; } }
</style>

<%
  cat = @campaign.example_category.presence || 'general'
  examples = case cat
  when 'political'
    [{ title: 'Democracy Reborn', desc: 'Targeted voter outreach with signed editions for donors and townhall live events.', tag: 'Political Non-Fiction' }, { title: "The Senator's Playbook", desc: 'Pre-order campaign with bundled merch and rally-style live signings.', tag: 'Political Memoir' }, { title: 'Red State, Blue State', desc: 'Bi-partisan book club with social media blitz and retail push.', tag: 'Political Analysis' }, { title: 'Campaign Trail Diaries', desc: 'Behind-the-scenes launch with exclusive signed first editions.', tag: 'Political Memoir' }]
  when 'romance'
    [{ title: 'Summer Hearts', desc: 'BookTok-first launch with aesthetic content, AR bookmarks, and live reading.', tag: 'Contemporary Romance' }, { title: "The Duke's Secret", desc: 'Historical romance with period-themed signing events and box sets.', tag: 'Historical Romance' }, { title: 'Tangled Tides', desc: 'Dark romance with exclusive annotated editions and midnight release.', tag: 'Dark Romance' }, { title: 'Love in Bloom', desc: 'Cozy romance with bookstore partnerships and floral-themed branding.', tag: 'Cozy Romance' }]
  when 'thriller'
    [{ title: 'The Last Witness', desc: 'Mystery-box unboxing campaign with clue-based social teasers.', tag: 'Psychological Thriller' }, { title: 'Blackout Protocol', desc: 'Tech thriller with countdown launch, encrypted ARG, and live Q&A.', tag: 'Tech Thriller' }, { title: 'Cold Trail', desc: 'True crime crossover with podcast tie-ins and evidence-style merch.', tag: 'Crime Thriller' }, { title: 'The Vanishing', desc: 'Suspense launch with chapter-a-day reveals and exclusive signed editions.', tag: 'Suspense' }]
  when 'fantasy'
    [{ title: 'Throne of Embers', desc: 'Epic fantasy with map poster bundles, character art reveals, and cosplay events.', tag: 'Epic Fantasy' }, { title: 'The Fae Accord', desc: 'Romantasy with exclusive sprayed edges, fairy light signing events.', tag: 'Romantasy' }, { title: 'Starforge', desc: 'Sci-fi fantasy with holographic covers and virtual launch party.', tag: 'Science Fantasy' }, { title: 'Grimwood Rising', desc: 'Dark fantasy with hand-signed bookplates and lore-based social content.', tag: 'Dark Fantasy' }]
  when 'nonfiction'
    [{ title: 'The Resilience Code', desc: 'Self-help launch with keynote-style live events and workbook bundles.', tag: 'Self-Help' }, { title: 'Untold America', desc: 'History book with museum partnerships and documentary-style social content.', tag: 'History' }, { title: 'Kitchen Roots', desc: 'Cookbook with live cooking demos, recipe card bundles, and grocery collabs.', tag: 'Food & Cooking' }, { title: 'Mind Over Market', desc: 'Business book with LinkedIn blitz, webinar series, and executive bundles.', tag: 'Business' }]
  when 'business'
    [{ title: 'Scale or Fail', desc: 'Startup launch with conference keynotes, bulk corporate orders, and podcast tour.', tag: 'Entrepreneurship' }, { title: 'The Leadership Shift', desc: 'Executive book with LinkedIn campaign, signed CEO editions, and webinar.', tag: 'Leadership' }, { title: 'Data-Driven', desc: 'Tech business with product hunt launch, newsletter partnerships, and bulk deals.', tag: 'Technology' }, { title: 'The Funding Playbook', desc: 'VC/startup with investor dinner events and exclusive audiobook early access.', tag: 'Finance' }]
  when 'children'
    [{ title: 'Captain Sparkle', desc: 'Kids book with school visits, coloring sheet downloads, and storytime lives.', tag: 'Picture Book' }, { title: 'The Magic Treehouse Club', desc: 'Middle grade with scavenger hunt launch, bookmarks, and library events.', tag: 'Middle Grade' }, { title: 'Dino Detectives', desc: 'Activity book with dinosaur-themed events, stamp-signed copies, and class sets.', tag: 'Activity Book' }, { title: 'Starlight Stories', desc: 'Bedtime stories with lullaby playlist, glow-in-dark cover, and pajama party event.', tag: 'Bedtime' }]
  when 'ya'
    [{ title: 'Neon Hearts', desc: 'YA contemporary with BookTok campaign, annotated editions, and Discord server.', tag: 'YA Contemporary' }, { title: 'The Uprising', desc: 'YA dystopia with resistance-themed merch and countdown social campaign.', tag: 'YA Dystopia' }, { title: 'Hex Academy', desc: 'YA fantasy with house-sorting quiz, exclusive pins, and midnight release.', tag: 'YA Fantasy' }, { title: 'Last Summer Before', desc: 'YA romance with playlist collab, aesthetic reels, and beach-themed signing.', tag: 'YA Romance' }]
  else
    [{ title: 'Bestseller Blueprint', desc: 'Full-funnel launch with landing page, signed editions, and social blitz.', tag: 'General Fiction' }, { title: "The Author's Edge", desc: 'Multi-platform campaign with live events, retailer push, and ad creative.', tag: 'Non-Fiction' }, { title: 'Readers First', desc: 'Community-driven launch with ARC readers, book clubs, and pre-order incentives.', tag: 'Any Genre' }, { title: 'Launch & Scale', desc: 'Data-driven campaign with A/B tested ads, landing page optimization, and retargeting.', tag: 'Any Genre' }]
  end
%>

<div class="onboard-overlay" id="onboardOverlay">
  <div class="onboard-modal">
    <button class="ob-close" onclick="closeOnboarding()" title="Skip">&times;</button>
    <div class="ob-video-step" id="obStep1">
      <h2>Welcome to Launch</h2>
      <div class="ob-sub">A quick message from our CEO about how we'll help you launch your book.</div>
      <div class="ob-video-placeholder">
        <div class="play-circle" onclick="playVideo()"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg></div>
        <div class="vid-label">CEO Welcome Video</div>
      </div>
      <div class="ob-footer">
        <div class="ob-steps-dots"><div class="ob-dot active"></div><div class="ob-dot"></div></div>
        <button class="ob-next-btn" onclick="goToStep2()">Next</button>
      </div>
    </div>
    <div class="ob-examples-step d-none" id="obStep2">
      <h2>Set up your campaign like...</h2>
      <div class="ob-sub">Here are some successful campaigns similar to yours. Pick one that inspires you, or skip to start from scratch.</div>
      <div class="example-grid">
        <% examples.each_with_index do |ex, i| %>
          <div class="example-card" onclick="selectExample(this)" data-idx="<%= i %>">
            <div class="ex-cover">Campaign Preview</div>
            <div class="ex-title"><%= ex[:title] %></div>
            <div class="ex-desc"><%= ex[:desc] %></div>
            <div class="ex-tag"><%= ex[:tag] %></div>
          </div>
        <% end %>
      </div>
      <div class="ob-footer">
        <div class="ob-steps-dots"><div class="ob-dot"></div><div class="ob-dot active"></div></div>
        <div class="d-flex gap-10">
          <button class="ob-next-btn" style="background:var(--surface);color:var(--text-primary);border:1px solid var(--border-strong);box-shadow:var(--shadow-sm);" onclick="closeOnboarding()">Skip</button>
          <%= button_to complete_onboarding_portal_campaign_path(@campaign), method: :patch, class: 'ob-next-btn', form: { class: 'd-inline', id: 'onboardForm' } do %>Get Started<% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  window.goToStep2 = function() { document.getElementById('obStep1').classList.add('d-none'); document.getElementById('obStep2').classList.remove('d-none'); };
  window.selectExample = function(card) { document.querySelectorAll('.example-card').forEach(function(c) { c.classList.remove('selected'); }); card.classList.add('selected'); };
  window.playVideo = function() { var p = document.querySelector('.ob-video-placeholder'); p.innerHTML = '<div style="color:rgba(255,255,255,0.5);font-size:14px;z-index:1;">Video player will be embedded here</div>'; };
  window.closeOnboarding = function() { var o = document.getElementById('onboardOverlay'); o.style.opacity = '0'; o.style.transition = 'opacity 0.2s ease'; setTimeout(function() { o.remove(); }, 200); var f = document.getElementById('onboardForm'); if (f) { fetch(f.action, { method: 'PATCH', headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content, 'Accept': 'text/html' } }); } };
})();
</script>
<% end %>
