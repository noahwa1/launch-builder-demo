<% content_for :page_title, 'Marketing Hub' %>

<%
  phase_descriptions = {
    'setup'   => 'Review and confirm the details your team has prepared for you.',
    'content' => 'Upload your photos and videos, and review the creative your team has built.',
    'review'  => 'Final review — approve remaining items so we can go live.',
    'live'    => "Your campaign is live! Here's how it's performing.",
    'wrap_up' => "Campaign complete. Here's your summary and earnings."
  }
  phase_icons = {
    'setup'   => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>',
    'content' => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>',
    'review'  => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
    'live'    => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg>',
    'wrap_up' => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
  }
  # Previews for future phases (only shown if the phase will have content)
  phase_previews = {
    'content' => (@campaign.asset_uploads_enabled? || @campaign.deliverables_enabled?) ? "You'll upload your photos and review creative from your team." : nil,
    'review'  => "Final checks — approve everything so we can go live.",
    'live'    => "Your campaign goes public. Track performance and engage fans.",
    'wrap_up' => (@campaign.royalties_enabled?) ? "Campaign results, royalty info, and downloadable recap." : "Campaign results and recap."
  }
  confirmed_count = @campaign.confirmable_sections.count { |s| c = @confirmations[s]; c&.persisted? && !c&.has_changes_requested? }
%>

<style>
  /* ── Hero Banner ── */
  .hero-banner { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: var(--radius-lg); padding: 32px 36px; color: #fff; display: flex; align-items: center; gap: 28px; margin-bottom: 20px; position: relative; overflow: hidden; }
  .hero-banner::before { content: ''; position: absolute; top: -50%; right: -20%; width: 60%; height: 200%; background: radial-gradient(ellipse, rgba(79,70,229,0.15), transparent 70%); pointer-events: none; }
  .hero-cover { flex-shrink: 0; position: relative; z-index: 1; }
  .hero-cover img { width: 90px; height: 135px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); }
  .hero-cover .cover-placeholder { width: 90px; height: 135px; background: rgba(255,255,255,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.3); font-size: 12px; }
  .hero-info { flex: 1; position: relative; z-index: 1; }
  .hero-info .greeting { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 2px; }
  .hero-info h2 { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 4px; }
  .hero-info .book-title { font-size: 14px; color: rgba(255,255,255,0.6); }
  .hero-stats { display: flex; gap: 20px; margin-top: 12px; }
  .hero-stat { text-align: center; }
  .hero-stat .num { font-size: 20px; font-weight: 700; }
  .hero-stat .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.4); margin-top: 2px; }

  /* ── Phase Stepper ── */
  .phase-stepper { display: flex; gap: 4px; margin-bottom: 6px; }
  .phase-step { flex: 1; text-align: center; position: relative; }
  .phase-step .step-bar { height: 6px; border-radius: 3px; margin-bottom: 8px; transition: background 0.3s; }
  .phase-step .step-bar.past { background: #16A34A; }
  .phase-step .step-bar.current { background: var(--accent); }
  .phase-step .step-bar.future { background: var(--border); }
  .phase-step .step-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; display: flex; align-items: center; justify-content: center; gap: 4px; }
  .phase-step .step-label.past { color: #16A34A; }
  .phase-step .step-label.current { color: var(--accent); }
  .phase-step .step-label.future { color: var(--text-muted); }

  /* ── Phase Status Bar ── */
  .phase-status-bar { padding: 14px 20px; border-radius: 10px; margin-bottom: 20px; display: flex; align-items: center; gap: 12px; }
  .phase-status-bar.setup { background: rgba(79,70,229,0.04); border: 1px solid rgba(79,70,229,0.12); }
  .phase-status-bar.content { background: rgba(34,197,94,0.04); border: 1px solid rgba(34,197,94,0.12); }
  .phase-status-bar.review { background: rgba(245,158,11,0.04); border: 1px solid rgba(245,158,11,0.12); }
  .phase-status-bar.live { background: rgba(233,69,96,0.04); border: 1px solid rgba(233,69,96,0.12); }
  .phase-status-bar.wrap_up { background: rgba(139,92,246,0.04); border: 1px solid rgba(139,92,246,0.12); }
  .phase-status-bar .status-text { font-size: 14px; color: var(--text-secondary); flex: 1; }

  /* ── Key Dates ── */
  .key-dates { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
  .key-date { flex: 1; min-width: 140px; padding: 12px 14px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; }
  .key-date .kd-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3px; }
  .key-date .kd-value { font-size: 14px; font-weight: 700; margin-top: 3px; }
  .key-date .kd-countdown { font-size: 11px; margin-top: 2px; }

  /* ── Confirm Sections ── */
  .confirm-section { border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; margin-bottom: 12px; transition: all 0.15s; }
  .confirm-section.confirmed { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.02); }
  .confirm-section.changes-requested { border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.02); }
  .confirm-section.needs-review { border-color: rgba(217,119,6,0.3); }
  .confirm-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .confirm-header h4 { font-size: 15px; font-weight: 700; display: flex; align-items: center; gap: 6px; }
  .confirm-status { padding: 4px 12px; border-radius: 6px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }
  .confirm-status.st-confirmed { background: rgba(34,197,94,0.08); color: #16A34A; }
  .confirm-status.st-changes { background: rgba(245,158,11,0.08); color: #D97706; }
  .confirm-status.st-pending { background: rgba(217,119,6,0.08); color: #D97706; }
  .confirm-data { font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 14px; }
  .confirm-data .data-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 2px; }
  .confirm-data .data-value { margin-bottom: 10px; }
  .confirm-actions { display: flex; gap: 8px; align-items: flex-start; }
  .confirm-btn { padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; border: none; cursor: pointer; font-family: inherit; transition: all 0.15s; text-decoration: none; display: inline-block; }
  .confirm-btn.approve { background: #16A34A; color: #fff; }
  .confirm-btn.approve:hover { background: #15803d; }
  .confirm-changes-form { flex: 1; }
  .confirm-changes-form textarea { width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; font-family: inherit; resize: vertical; margin-bottom: 8px; }
  .confirm-btn.request { background: rgba(245,158,11,0.06); color: #D97706; border: 1px solid rgba(245,158,11,0.2); }
  .confirm-btn.request:hover { background: rgba(245,158,11,0.12); }
  .confirm-note { margin-top: 8px; padding: 10px 14px; background: rgba(245,158,11,0.04); border-left: 3px solid #D97706; border-radius: 0 8px 8px 0; font-size: 13px; }
  .confirm-note .note-label { font-size: 11px; font-weight: 600; color: #D97706; text-transform: uppercase; margin-bottom: 4px; }
  .confirm-meta { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
  .team-label { font-size: 10px; font-weight: 600; color: var(--accent); background: var(--accent-wash); padding: 2px 8px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.3px; }

  /* ── Phase Card / Accordion ── */
  .phase-card { border: 1px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 12px; overflow: hidden; }
  .phase-card.active-phase { border-color: var(--accent); box-shadow: 0 2px 12px rgba(79,70,229,0.08); }
  .phase-card-header { padding: 16px 20px; display: flex; align-items: center; gap: 12px; cursor: pointer; }
  .phase-card-header h3 { font-size: 15px; font-weight: 700; flex: 1; margin: 0; }
  .phase-card-body { padding: 0 20px 20px; }
  .phase-badge { padding: 3px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; text-transform: uppercase; }

  /* ── Advance Button ── */
  .advance-bar { padding: 16px 20px; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
  .advance-bar.ready { background: rgba(34,197,94,0.04); border: 1px solid rgba(34,197,94,0.2); }
  .advance-bar.blocked { background: rgba(245,158,11,0.04); border: 1px solid rgba(245,158,11,0.15); }
  .advance-btn { padding: 10px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; border: none; cursor: pointer; font-family: inherit; background: #16A34A; color: #fff; transition: all 0.15s; }
  .advance-btn:hover { background: #15803d; transform: translateY(-1px); }

  /* ── Future Phase Preview ── */
  .future-preview { padding: 16px 20px; border: 1px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 10px; opacity: 0.6; display: flex; align-items: center; gap: 12px; }
  .future-preview .lock-icon { width: 28px; height: 28px; border-radius: 8px; background: rgba(0,0,0,0.04); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--text-muted); }

  /* ── Content Phase Cards ── */
  .content-section { margin-bottom: 16px; }
  .content-section h4 { font-size: 14px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
  .del-row { display: flex; align-items: center; gap: 14px; padding: 12px 14px; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; transition: background 0.1s; }
  .del-row:hover { background: var(--accent-wash); }
  .del-row:last-child { border-bottom: none; }
  .del-row-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .del-row-info { flex: 1; }
  .del-row-info h5 { font-size: 13px; font-weight: 600; margin: 0; }
  .del-row-info .meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* ── Checklist Rows ── */
  .checklist-mini-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
  .checklist-mini-row:last-child { border-bottom: none; }
  .check-dot { width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--border-strong); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .check-dot.done { background: #22C55E; border-color: #22C55E; color: #fff; }
  .check-dot.done svg { width: 10px; height: 10px; }

  /* ── Live Stats ── */
  .live-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .live-stat { padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; text-align: center; }
  .live-stat .ls-num { font-size: 28px; font-weight: 700; }
  .live-stat .ls-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.3px; color: var(--text-muted); margin-top: 2px; }

  /* ── Toolkit Links ── */
  .toolkit-row { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border: 1px solid var(--border); border-radius: 10px; text-decoration: none; color: inherit; transition: all 0.15s; margin-bottom: 8px; }
  .toolkit-row:hover { border-color: var(--accent); background: var(--accent-wash); }
  .toolkit-row .tk-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .toolkit-row .tk-title { font-size: 14px; font-weight: 600; flex: 1; }
  .toolkit-row .tk-arrow { color: var(--text-muted); }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero-banner { flex-direction: column; text-align: center; padding: 24px 20px; gap: 14px; }
    .hero-info h2 { font-size: 20px; }
    .hero-stats { justify-content: center; gap: 14px; }
    .key-dates { flex-direction: column; }

    /* Phase stepper: compact horizontal with shorter labels */
    .phase-stepper { gap: 2px; }
    .phase-step .step-label { font-size: 9px; letter-spacing: 0; }
    .phase-step .step-label svg { display: none; }

    /* Confirmation buttons: full-width tap targets */
    .confirm-actions { flex-direction: column; }
    .confirm-btn { width: 100%; text-align: center; padding: 12px 20px; min-height: 44px; }
    .confirm-changes-form { width: 100%; }
    .confirm-section { padding: 16px; }

    /* Deliverable review cards: clear tap actions */
    .del-row { padding: 14px 12px; min-height: 54px; }
    .del-row-icon { width: 32px; height: 32px; }

    /* Live stats responsive */
    .live-stats { grid-template-columns: 1fr 1fr; }

    /* Toolkit links: stack vertically */
    .toolkit-row { padding: 14px 16px; min-height: 52px; }

    /* Activity feed: clean vertical timeline */
    .phase-card-header { padding: 14px 16px; }
    .phase-card-body { padding: 0 16px 16px; }

    /* Advance bar: stack on mobile */
    .advance-bar { flex-direction: column; gap: 10px; text-align: center; }
    .advance-btn { width: 100%; }

    /* Future previews */
    .future-preview { padding: 14px 16px; }
  }

  @media (max-width: 480px) {
    .phase-stepper { flex-wrap: wrap; gap: 2px; }
    .phase-step { min-width: 0; flex: 1 1 18%; }
    .phase-step .step-label { font-size: 8px; }
    .live-stats { grid-template-columns: 1fr; }
    .hero-stats { flex-wrap: wrap; }
  }
</style>

<%# ── LIVE NOW BAR ── %>
<% if @current_live_event %>
  <div class="d-flex items-center justify-between mb-16 text-white rounded-md" style="background:linear-gradient(90deg,#e94560,#c0392b);padding:14px 24px;">
    <div class="d-flex items-center gap-12 fw-700">
      <span style="width:10px;height:10px;background:#fff;border-radius:50%;animation:dotBlink 1.5s ease-in-out infinite;"></span>
      LIVE NOW — <%= @current_live_event.title %>
    </div>
    <%= link_to 'Enter Studio', studio_portal_campaign_live_events_path(@campaign), class: 'btn btn-sm', style: 'background:rgba(255,255,255,0.2);color:#fff;border:none;' %>
  </div>
  <style>@keyframes dotBlink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }</style>
<% end %>

<%# ── HERO BANNER ── %>
<div class="hero-banner">
  <div class="hero-cover">
    <% if @submission.cover.present? && @submission.cover.url.present? %>
      <img src="<%= @submission.cover.url %>" alt="<%= @submission.title %>">
    <% else %>
      <div class="cover-placeholder">No Cover</div>
    <% end %>
  </div>
  <div class="hero-info">
    <div class="greeting">Welcome back,</div>
    <h2><%= @campaign.author.full_name %></h2>
    <div class="book-title"><%= @submission.title %></div>
    <div class="hero-stats">
      <div class="hero-stat"><div class="num"><%= @progress %>%</div><div class="lbl">Ready</div></div>
      <div class="hero-stat"><div class="num"><%= @submission_count %></div><div class="lbl">Leads</div></div>
      <div class="hero-stat"><div class="num"><%= @assets_count %></div><div class="lbl">Assets</div></div>
    </div>
  </div>
</div>

<%# ── PHASE STEPPER ── %>
<div class="phase-stepper">
  <% Campaign.phases.each do |name, idx| %>
    <% state = idx < @current_phase_idx ? 'past' : (idx == @current_phase_idx ? 'current' : 'future') %>
    <div class="phase-step">
      <div class="step-bar <%= state %>"></div>
      <div class="step-label <%= state %>">
        <% if state == 'past' %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="12" height="12"><polyline points="20 6 9 17 4 12"/></svg>
        <% end %>
        <%= name.titleize %>
      </div>
    </div>
  <% end %>
</div>

<%# ── PHASE STATUS BAR ── %>
<div class="phase-status-bar <%= @campaign.phase %>">
  <div><%= phase_icons[@campaign.phase]&.html_safe %></div>
  <div class="status-text"><strong><%= @campaign.phase_label %>:</strong> <%= phase_descriptions[@campaign.phase] %></div>
</div>

<%# ── CAMPAIGN BRIEF (always visible) ── %>
<% if @campaign.brief.present? %>
  <div class="card mb-16">
    <h3 class="subheading" style="margin-bottom:8px;">Campaign Brief</h3>
    <div class="text-base text-secondary lh-relaxed" style="white-space:pre-wrap;"><%= @campaign.brief %></div>
  </div>
<% end %>

<%# ── KEY DATES BAR ── %>
<% if @campaign.launch_date.present? || @campaign.content_deadline.present? || @campaign.review_deadline.present? %>
  <div class="key-dates">
    <% if @campaign.launch_date.present? %>
      <% days = (@campaign.launch_date - Date.today).to_i %>
      <div class="key-date" style="border-left:3px solid var(--accent);">
        <div class="kd-label">Launch Date</div>
        <div class="kd-value"><%= @campaign.launch_date.strftime('%b %d, %Y') %></div>
        <div class="kd-countdown" style="color:<%= days > 14 ? '#16A34A' : (days > 0 ? '#D97706' : 'var(--text-muted)') %>;"><%= days > 0 ? "#{days} days away" : (days == 0 ? 'Today!' : "#{days.abs} days ago") %></div>
      </div>
    <% end %>
    <% if @campaign.content_deadline.present? %>
      <% days_cd = (@campaign.content_deadline - Date.today).to_i %>
      <div class="key-date" style="border-left:3px solid #F59E0B;">
        <div class="kd-label">Content Deadline</div>
        <div class="kd-value"><%= @campaign.content_deadline.strftime('%b %d, %Y') %></div>
        <div class="kd-countdown" style="color:<%= days_cd > 7 ? '#16A34A' : (days_cd > 0 ? '#D97706' : '#EF4444') %>;"><%= days_cd > 0 ? "#{days_cd} days left" : (days_cd == 0 ? 'Due today' : "#{days_cd.abs} days overdue") %></div>
      </div>
    <% end %>
    <% if @campaign.review_deadline.present? %>
      <% days_rd = (@campaign.review_deadline - Date.today).to_i %>
      <div class="key-date" style="border-left:3px solid #8B5CF6;">
        <div class="kd-label">Review Deadline</div>
        <div class="kd-value"><%= @campaign.review_deadline.strftime('%b %d, %Y') %></div>
        <div class="kd-countdown" style="color:<%= days_rd > 7 ? '#16A34A' : (days_rd > 0 ? '#D97706' : '#EF4444') %>;"><%= days_rd > 0 ? "#{days_rd} days left" : (days_rd == 0 ? 'Due today' : "#{days_rd.abs} days overdue") %></div>
      </div>
    <% end %>
  </div>
<% end %>

<%# ══════════════════════════════════════════════════════════════ %>
<%# ── PHASE: SETUP (current) ── %>
<%# ══════════════════════════════════════════════════════════════ %>
<% if @campaign.setup? %>
  <div class="card mb-16">
    <div class="section-header" style="margin-bottom:16px;">
      <h3 class="mt-0 mb-0">Review & Confirm</h3>
      <span class="text-md fw-600 text-muted"><%= confirmed_count %>/<%= @campaign.confirmable_sections.size %> confirmed</span>
    </div>

    <%# ── Brief ── %>
    <% if @campaign.brief.present? || @campaign.launch_date.present? %>
      <% brief_conf = @confirmations['brief'] %>
      <% brief_confirmed = brief_conf&.persisted? && !brief_conf&.has_changes_requested? %>
      <% brief_changes = brief_conf&.has_changes_requested? %>
      <div class="confirm-section <%= brief_confirmed ? 'confirmed' : (brief_changes ? 'changes-requested' : 'needs-review') %>">
        <div class="confirm-header">
          <h4>
            <% if brief_confirmed %><svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><% end %>
            Campaign Brief
            <span class="team-label">Set by your team</span>
          </h4>
          <% if brief_confirmed %>
            <span class="confirm-status st-confirmed">Confirmed</span>
