<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <title>Record Studio — <%= @campaign.title %></title>
  <script src="https://unpkg.com/@ffmpeg/ffmpeg@0.12.10/dist/umd/ffmpeg.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@ffmpeg/util@0.12.1/dist/umd/util.js" crossorigin="anonymous"></script>
<style>
  :root {
    --bg-primary: #111119;
    --bg-secondary: #1a1a24;
    --bg-tertiary: #22222e;
    --bg-hover: #2a2a38;
    --border: #2d2d3d;
    --text-primary: #e8e8ef;
    --text-secondary: #8888a0;
    --text-muted: #55556a;
    --accent: #003262;
    --accent-hover: #1a4a7a;
    --accent-soft: rgba(0,50,98,0.12);
    --danger: #e94560;
    --success: #219653;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif; background: var(--bg-primary); color: var(--text-primary); height: 100vh; display: flex; flex-direction: column; }

  /* ── Top Bar ── */
  .top-bar {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg-secondary); padding: 0 16px; height: 48px;
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .top-bar-left { display: flex; align-items: center; gap: 12px; }
  .logo { font-size: 14px; font-weight: 700; letter-spacing: 1.5px; white-space: nowrap; }
  .logo span { color: var(--accent); }
  .mode-pills { display: inline-flex; background: var(--bg-tertiary); border-radius: 8px; padding: 2px; gap: 2px; }
  .mode-pill {
    padding: 5px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
    text-decoration: none; color: var(--text-secondary); transition: all 0.15s;
  }
  .mode-pill:hover { color: var(--text-primary); }
  .mode-pill.active { background: var(--accent); color: #fff; }
  .top-bar-right { display: flex; align-items: center; gap: 8px; }
  .tb-btn {
    padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
    border: 1px solid var(--border); background: var(--bg-tertiary); color: var(--text-secondary);
    cursor: pointer; text-decoration: none; transition: all 0.15s;
  }
  .tb-btn:hover { border-color: var(--accent); color: var(--accent); }
  .tb-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .tb-btn.primary:hover { background: var(--accent-hover); }
  .tb-btn.danger { background: var(--danger); border-color: var(--danger); color: #fff; }
  .tb-btn:disabled { opacity: 0.4; cursor: default; }

  /* ── Main Layout ── */
  .main-area { display: flex; flex: 1; min-height: 0; }
  .canvas-col { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .sidebar { width: 280px; background: var(--bg-secondary); border-left: 1px solid var(--border); display: flex; flex-direction: column; overflow-y: auto; flex-shrink: 0; }

  /* ── Aspect Ratio Toggle ── */
  .aspect-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 16px; background: var(--bg-secondary); border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .aspect-switcher {
    display: inline-flex; background: var(--bg-primary); border-radius: 6px; padding: 2px; gap: 2px;
  }
  .aspect-btn {
    display: flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 4px;
    border: none; background: none; font-size: 11px; font-weight: 600; font-family: inherit;
    color: var(--text-muted); cursor: pointer; transition: all 0.15s;
  }
  .aspect-btn:hover { color: var(--text-secondary); }
  .aspect-btn.active { background: var(--accent); color: #fff; }
  .aspect-btn svg { width: 14px; height: 14px; }
  .aspect-label { font-size: 11px; color: var(--text-muted); font-weight: 500; }

  /* ── Canvas ── */
  .canvas-wrap {
    flex: 1; display: flex; align-items: center; justify-content: center;
    background: #0a0a0f; position: relative; min-height: 0; padding: 12px;
    transition: all 0.3s ease;
  }
  .canvas-wrap.portrait { max-width: 380px; margin: 0 auto; width: 100%; }
  #recorderCanvas {
    max-width: 100%; max-height: 100%; border-radius: 8px;
    background: #000; display: block; transition: all 0.3s ease;
  }
  /* Safe zone guide for portrait */
  .canvas-safe-zone {
    display: none; position: absolute; z-index: 4; pointer-events: none;
    border: 1px dashed rgba(255,255,255,0.12); border-radius: 6px;
  }
  .canvas-wrap.portrait .canvas-safe-zone { display: block; }
  .canvas-safe-zone::after {
    content: 'Safe Zone'; position: absolute; top: 4px; right: 6px;
    font-size: 8px; color: rgba(255,255,255,0.18); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .canvas-badge {
    position: absolute; top: 20px; left: 20px; padding: 5px 12px; border-radius: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 1px; display: none; z-index: 5;
  }
  .canvas-badge.recording { background: var(--danger); color: #fff; display: flex; align-items: center; gap: 6px; }
  .canvas-badge.recording .dot { width: 8px; height: 8px; background: #fff; border-radius: 50%; animation: blink 1.2s ease-in-out infinite; }
  .canvas-badge.paused { background: #F59E0B; color: #000; display: block; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .canvas-time {
    position: absolute; top: 20px; right: 20px; background: rgba(0,0,0,0.6);
    backdrop-filter: blur(6px); padding: 5px 12px; border-radius: 6px;
    font-size: 13px; font-weight: 600; font-variant-numeric: tabular-nums;
    display: none; z-index: 5;
  }

  /* ── Controls Bar ── */
  .controls-bar {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    padding: 10px 16px; background: var(--bg-secondary); border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .ctrl-btn {
    width: 42px; height: 42px; border-radius: 50%; border: 2px solid var(--border);
    background: var(--bg-tertiary); color: var(--text-secondary); display: flex;
    align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s;
  }
  .ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }
  .ctrl-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .ctrl-btn.rec { border-color: var(--danger); color: var(--danger); }
  .ctrl-btn.rec:hover { background: var(--danger); color: #fff; }
  .ctrl-btn.rec.active { background: var(--danger); color: #fff; animation: recPulse 2s ease-in-out infinite; }
  @keyframes recPulse { 0%,100%{box-shadow:0 0 0 0 rgba(233,69,96,0.4)} 50%{box-shadow:0 0 12px 4px rgba(233,69,96,0.2)} }
  .ctrl-btn.stop { border-color: #F59E0B; color: #F59E0B; }
  .ctrl-btn.stop:hover { background: #F59E0B; color: #000; }
  .ctrl-btn svg { width: 18px; height: 18px; }
  .ctrl-sep { width: 1px; height: 28px; background: var(--border); margin: 0 4px; }

  /* ── Timeline ── */
  .timeline {
    height: 200px; background: var(--bg-secondary); border-top: 1px solid var(--border);
    flex-shrink: 0; display: flex; flex-direction: column; overflow: hidden;
  }
  .timeline-header {
    display: flex; align-items: center; padding: 6px 12px; gap: 8px;
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .timeline-header span { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .timeline-ruler {
    height: 20px; background: var(--bg-tertiary); border-bottom: 1px solid var(--border);
    position: relative; flex-shrink: 0; overflow: hidden;
  }
  .timeline-tracks { flex: 1; overflow-y: auto; position: relative; }
  .timeline-track {
    display: flex; align-items: center; height: 36px;
    border-bottom: 1px solid rgba(45,45,61,0.5); position: relative;
  }
  .track-label {
    width: 80px; padding: 0 10px; font-size: 10px; font-weight: 600;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;
    flex-shrink: 0; background: var(--bg-secondary); z-index: 2;
  }
  .track-lane { flex: 1; height: 100%; position: relative; overflow: hidden; }
  .track-clip {
    position: absolute; top: 4px; bottom: 4px; border-radius: 4px;
    font-size: 10px; font-weight: 600; color: #fff; display: flex;
    align-items: center; padding: 0 8px; cursor: grab; min-width: 20px;
    overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
  }
  .track-clip.video { background: rgba(108,92,231,0.6); border: 1px solid rgba(108,92,231,0.8); }
  .track-clip.text { background: rgba(34,197,94,0.5); border: 1px solid rgba(34,197,94,0.7); }
  .track-clip.image { background: rgba(59,130,246,0.5); border: 1px solid rgba(59,130,246,0.7); }
  .track-clip.audio { background: rgba(245,158,11,0.5); border: 1px solid rgba(245,158,11,0.7); }
  .trim-handle {
    position: absolute; top: 0; bottom: 0; width: 8px; cursor: ew-resize; z-index: 3;
    transition: background 0.1s;
  }
  .trim-handle.left { left: -2px; border-radius: 4px 0 0 4px; background: rgba(255,255,255,0.12); }
  .trim-handle.right { right: -2px; border-radius: 0 4px 4px 0; background: rgba(255,255,255,0.12); }
  .trim-handle:hover { background: rgba(255,255,255,0.35); }
  .track-clip:hover .trim-handle { background: rgba(255,255,255,0.25); }
  .track-clip.selected, .track-clip:active { outline: 1px solid var(--accent); outline-offset: -1px; z-index: 5; }
  .playhead {
    position: absolute; top: 0; bottom: 0; width: 2px; background: var(--danger);
    z-index: 10; pointer-events: none;
  }
  .playhead::before {
    content: ''; position: absolute; top: -4px; left: -5px;
    width: 12px; height: 8px; background: var(--danger);
    clip-path: polygon(0 0, 100% 0, 50% 100%);
  }

  /* ── Sidebar Tabs ── */
  .sidebar-tabs {
    display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .sidebar-tab {
    flex: 1; padding: 10px; text-align: center; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);
    cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s;
  }
  .sidebar-tab:hover { color: var(--text-secondary); }
  .sidebar-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .sidebar-panel { display: none; padding: 16px; flex: 1; overflow-y: auto; }
  .sidebar-panel.active { display: block; }
  .sb-group { margin-bottom: 16px; }
  .sb-label { display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .sb-input, .sb-select {
    width: 100%; padding: 7px 10px; border: 1px solid var(--border); border-radius: 6px;
    font-size: 12px; font-family: inherit; background: var(--bg-tertiary); color: var(--text-primary);
  }
  .sb-input:focus, .sb-select:focus { outline: none; border-color: var(--accent); }
  .sb-btn {
    width: 100%; padding: 8px; border-radius: 6px; font-size: 12px; font-weight: 600;
    font-family: inherit; border: 1px solid var(--border); background: var(--bg-tertiary);
    color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
  }
  .sb-btn:hover { border-color: var(--accent); color: var(--accent); }
  .sb-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .sb-row { display: flex; gap: 8px; }
  .sb-row > * { flex: 1; }
  .sb-range { width: 100%; accent-color: var(--accent); }

  /* ── Countdown Overlay ── */
  .countdown-overlay {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    z-index: 6; pointer-events: none;
  }
  .countdown-overlay .countdown-num {
    font-size: 200px; font-weight: 900; color: #fff;
    text-shadow: 0 0 60px rgba(0,0,0,0.8), 0 4px 20px rgba(0,0,0,0.5);
    animation: countPop 0.6s ease-out;
  }
  @keyframes countPop { 0%{transform:scale(1.6);opacity:0.3} 100%{transform:scale(1);opacity:1} }

  /* ── Trim Time Labels ── */
  .trim-time-label {
    font-size: 10px; color: var(--text-muted); font-variant-numeric: tabular-nums;
    margin-left: 4px;
  }
  .trim-active .trim-handle { background: rgba(233,69,96,0.4); }
  .trim-active .trim-handle:hover { background: rgba(233,69,96,0.6); }
  .ctrl-btn.trim-on { border-color: var(--danger); color: var(--danger); }

  /* ── Time Remaining ── */
  .time-remaining { font-variant-numeric: tabular-nums; }
  .time-remaining.warning { color: #F59E0B; }
  .time-remaining.critical { color: var(--danger); animation: blink 0.8s ease-in-out infinite; }

  /* ── Teleprompter ── */
  #teleprompter {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 4;
  }
  #prompterText {
    position: absolute; bottom: 0; left: 10%; right: 10%;
    font-size: 28px; line-height: 1.6; color: rgba(255,255,255,0.85);
    text-shadow: 0 2px 8px rgba(0,0,0,0.8); text-align: center;
  }
  #teleprompter.mirrored { transform: scaleX(-1); }

  /* ── Canvas Drag Handles ── */
  .canvas-wrap { cursor: default; }
  .canvas-wrap.dragging { cursor: grabbing; }
  .overlay-handle {
    position: absolute; border: 2px dashed rgba(255,255,255,0.6); border-radius: 4px;
    cursor: grab; z-index: 3; pointer-events: auto;
    display: flex; align-items: flex-start; justify-content: flex-end;
  }
  .overlay-handle:hover { border-color: var(--accent); }
  .overlay-handle.selected { border-color: var(--accent); border-style: solid; }
  .overlay-handle .handle-label {
    font-size: 9px; background: var(--accent); color: #fff; padding: 1px 5px;
    border-radius: 0 0 0 4px; pointer-events: none;
  }

  /* ── Lower Third ── */
  .lower-third-preview {
    display: flex; align-items: center; gap: 8px; padding: 6px 8px;
    background: var(--bg-tertiary); border-radius: 6px; border: 1px solid var(--border);
    margin-top: 6px;
  }
  .lower-third-preview img { height: 32px; border-radius: 3px; }
  .lower-third-preview .name { flex: 1; font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .overlay-item {
    display: flex; align-items: center; gap: 8px; padding: 8px; margin-bottom: 6px;
    background: var(--bg-tertiary); border-radius: 6px; border: 1px solid var(--border);
  }
  .overlay-item .name { flex: 1; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .overlay-item .del {
    width: 20px; height: 20px; border: none; background: none; color: var(--text-muted);
    cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center;
  }
  .overlay-item .del:hover { color: var(--danger); }

  /* ── Export Modal ── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100;
    display: none; align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px;
    padding: 28px; width: 420px; max-width: 90vw;
  }
  .modal-box h3 { font-size: 16px; margin-bottom: 16px; }
  .progress-bar { height: 8px; background: var(--bg-tertiary); border-radius: 4px; overflow: hidden; margin: 12px 0; }
  .progress-bar .fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.3s; width: 0; }
  .progress-text { font-size: 12px; color: var(--text-secondary); }

  /* ── Queue Mode ── */
  .sub-mode-pills { display: inline-flex; background: var(--bg-primary); border-radius: 6px; padding: 2px; gap: 2px; margin-left: 4px; }
  .sub-mode-pill {
    padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 600;
    color: var(--text-muted); cursor: pointer; transition: all 0.15s; border: none; background: none;
  }
  .sub-mode-pill:hover { color: var(--text-secondary); }
  .sub-mode-pill.active { background: var(--bg-tertiary); color: var(--text-primary); }

  .queue-sidebar { display: none; flex-direction: column; height: 100%; }
  .queue-sidebar.active { display: flex; }
  .queue-header { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .queue-header h3 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 8px; }
  .queue-progress { height: 6px; background: var(--bg-tertiary); border-radius: 3px; overflow: hidden; margin-bottom: 6px; }
  .queue-progress .fill { height: 100%; background: var(--success); border-radius: 3px; transition: width 0.3s; }
  .queue-progress-text { font-size: 11px; color: var(--text-muted); }

  .queue-section { padding: 8px 16px; }
  .queue-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); margin-bottom: 6px; }

  .queue-current { padding: 12px 16px; background: var(--accent-soft); border-left: 3px solid var(--accent); margin: 0 8px; border-radius: 0 6px 6px 0; }
  .queue-current .buyer-name { font-size: 16px; font-weight: 700; color: var(--text-primary); }
  .queue-current .buyer-location { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }

  .queue-list { list-style: none; padding: 0; margin: 0; flex: 1; overflow-y: auto; }
  .queue-list li { padding: 6px 16px; font-size: 13px; color: var(--text-secondary); display: flex; align-items: center; gap: 8px; }
  .queue-list li .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted); flex-shrink: 0; }

  .queue-done-list { list-style: none; padding: 0; margin: 0; max-height: 200px; overflow-y: auto; }
  .queue-done-list li { padding: 5px 16px; font-size: 12px; color: var(--success); display: flex; align-items: center; gap: 8px; }
  .queue-done-list .check { flex-shrink: 0; }
  .queue-done-list .redo-btn {
    margin-left: auto; font-size: 10px; color: var(--text-muted); cursor: pointer;
    background: none; border: 1px solid var(--border); border-radius: 4px; padding: 2px 8px;
  }
  .queue-done-list .redo-btn:hover { color: var(--accent); border-color: var(--accent); }

  .queue-controls { padding: 12px 16px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
  .queue-controls .q-btn {
    flex: 1; padding: 8px; border-radius: 6px; font-size: 12px; font-weight: 600;
    border: 1px solid var(--border); background: var(--bg-tertiary); color: var(--text-secondary);
    cursor: pointer; text-align: center; transition: all 0.15s;
  }
  .queue-controls .q-btn:hover { border-color: var(--accent); color: var(--accent); }
  .queue-controls .q-btn:disabled { opacity: 0.4; cursor: default; }

  .queue-uploading { display: inline-block; width: 12px; height: 12px; border: 2px solid var(--text-muted); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: auto; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .queue-empty { padding: 24px 16px; text-align: center; color: var(--text-muted); font-size: 13px; }

  /* ═══════════════════════════════════════
     MOBILE — Social-style Record Experience
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    body { overflow: auto; }

    .top-bar { padding: 0 10px; height: 44px; }
    .logo { font-size: 12px; }
    .mode-pills { display: none; }
    .sub-mode-pills { display: none; }
    .top-bar-right { gap: 4px; }
    .top-bar-right .tb-btn { padding: 5px 10px; font-size: 11px; }
    /* Hide desktop-only top bar buttons on mobile */
    #btnDownloadRaw, #btnExport, #btnSaveContent { display: none !important; }

    .main-area { flex-direction: column; min-height: calc(100vh - 44px); }

    /* Hide desktop sidebar, timeline, aspect bar */
    .sidebar { display: none !important; }
    .timeline { display: none !important; }
    .aspect-bar { display: none !important; }

    /* Canvas fills the screen */
    .canvas-col { flex: 1; min-height: 0; }
    .canvas-wrap {
      flex: 1; padding: 0; border-radius: 0;
      max-width: 100% !important; margin: 0 !important;
      touch-action: none;
    }
    .canvas-wrap.portrait { max-width: 100% !important; }
    #recorderCanvas { border-radius: 0; width: 100%; height: 100%; object-fit: cover; }

    /* Controls bar — fixed bottom, social-style */
    .controls-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 20;
      padding: 12px 20px 28px; gap: 16px;
      background: linear-gradient(transparent, rgba(0,0,0,0.85));
      border: none;
    }
    .ctrl-btn { width: 48px; height: 48px; }
    .ctrl-btn.rec { width: 64px; height: 64px; border-width: 3px; }
    .ctrl-btn.rec svg { width: 28px; height: 28px; }
    .ctrl-btn svg { width: 20px; height: 20px; }
    .ctrl-sep { display: none; }
    /* Hide play/trim on mobile */
    #btnPlay, #btnTrim { display: none !important; }

    .canvas-badge { top: 10px; left: 10px; font-size: 10px; padding: 4px 10px; }
    .canvas-time { top: 10px; right: 10px; font-size: 12px; padding: 4px 10px; }

    /* Hide safe zone on mobile */
    .canvas-safe-zone { display: none !important; }
  }

  /* ── Mobile Review Screen (shown after recording) ── */
  .mobile-review {
    display: none; position: fixed; inset: 0; z-index: 50;
    background: var(--bg-primary); flex-direction: column;
  }
  .mobile-review.open { display: flex; }
  .mobile-review-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .mobile-review-header h3 { font-size: 15px; font-weight: 700; }
  .mr-close {
    background: none; border: none; color: var(--text-secondary); font-size: 20px;
    cursor: pointer; padding: 4px 8px;
  }
  .mobile-review-video {
    flex: 1; display: flex; align-items: center; justify-content: center;
    background: #000; min-height: 0; position: relative;
  }
  .mobile-review-video video {
    width: 100%; height: 100%; object-fit: contain;
  }
  .mr-duration {
    position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); padding: 4px 14px;
    border-radius: 20px; font-size: 12px; font-weight: 600; color: #fff;
    font-variant-numeric: tabular-nums;
  }
  .mobile-review-actions {
    padding: 16px; display: flex; flex-direction: column; gap: 10px; flex-shrink: 0;
    background: var(--bg-secondary); border-top: 1px solid var(--border);
  }
  .mr-btn-row { display: flex; gap: 10px; }
  .mr-btn {
    flex: 1; padding: 14px; border-radius: 12px; font-size: 14px; font-weight: 600;
    font-family: inherit; cursor: pointer; text-align: center; border: none;
    transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .mr-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
  .mr-btn-save { background: var(--success); color: #fff; }
  .mr-btn-save:hover { filter: brightness(1.1); }
  .mr-btn-redo { background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border); }
  .mr-btn-redo:hover { border-color: var(--danger); color: var(--danger); }
  .mr-btn-export { background: var(--accent); color: #fff; }
  .mr-btn-export:hover { filter: brightness(1.15); }
  .mr-btn-download { background: var(--bg-tertiary); color: var(--text-secondary); border: 1px solid var(--border); }
  .mr-btn-download:hover { border-color: var(--accent); color: var(--accent); }
  .mr-saving { font-size: 13px; color: var(--text-muted); text-align: center; padding: 8px; }
  .mr-saved { font-size: 13px; color: var(--success); text-align: center; padding: 8px; font-weight: 600; }

  /* ── Save to Content button (desktop + mobile) ── */
  .save-content-btn {
    padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
    border: 1px solid var(--success); background: rgba(33,150,83,0.1); color: var(--success);
    cursor: pointer; transition: all 0.15s; font-family: inherit;
  }
  .save-content-btn:hover { background: var(--success); color: #fff; }
  .save-content-btn:disabled { opacity: 0.4; cursor: default; }
  .save-content-btn.saved { background: rgba(33,150,83,0.1); color: var(--success); border-color: var(--success); cursor: default; }
</style>
</head>
<body>

<!-- ── Top Bar ── -->
<div class="top-bar">
  <div class="top-bar-left">
    <div class="logo">PREMIERE <span>STUDIO</span></div>
    <div class="mode-pills">
      <a href="<%= studio_portal_campaign_live_events_path(@campaign) %>" class="mode-pill">Live</a>
      <span class="mode-pill active">Record</span>
    </div>
    <div class="sub-mode-pills">
      <button class="sub-mode-pill active" id="pillStudio" onclick="R.switchToStudio()">Studio</button>
      <% if @campaign.personal_videos_enabled? %>
        <button class="sub-mode-pill" id="pillQueue" onclick="R.switchToQueue()">Queue</button>
      <% end %>
    </div>
  </div>
  <div class="top-bar-right">
    <button class="tb-btn" id="btnLaunchRecorder" onclick="R.launchRecorder()">Launch Recorder</button>
    <a href="<%= studio_portal_campaign_live_events_path(@campaign) %>" class="tb-btn">Back to Studio</a>
    <button class="tb-btn" id="btnDownloadRaw" onclick="R.downloadRaw()" style="display:none;">Download Raw</button>
    <button class="save-content-btn" id="btnSaveContent" onclick="R.saveToContent()" style="display:none;">Save to Content</button>
    <button class="tb-btn primary" id="btnExport" onclick="R.startExport()" disabled>Export MP4</button>
  </div>
</div>

<!-- ── Main ── -->
<div class="main-area">
  <div class="canvas-col">
    <!-- Aspect Ratio Toggle -->
    <div class="aspect-bar">
      <div class="aspect-switcher">
        <button class="aspect-btn active" onclick="R.setAspect('landscape',this)" title="Landscape (16:9)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="3"/></svg>
          16:9
        </button>
        <button class="aspect-btn" onclick="R.setAspect('portrait',this)" title="Portrait (9:16) — Social Media">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="3"/></svg>
          9:16
        </button>
      </div>
      <span class="aspect-label" id="recAspectLabel">Landscape (16:9)</span>
    </div>
    <!-- Canvas -->
    <div class="canvas-wrap" id="canvasWrap">
      <canvas id="recorderCanvas" width="1920" height="1080"></canvas>
      <div class="canvas-safe-zone" id="canvasSafeZone"></div>
      <div class="canvas-badge" id="badge"></div>
      <div class="canvas-time" id="canvasTime">00:00</div>
      <div id="teleprompter" style="display:none;">
        <div id="prompterText"></div>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls-bar">
      <button class="ctrl-btn" id="btnCamera" onclick="R.toggleCamera()" title="Camera">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg>
      </button>
      <button class="ctrl-btn" id="btnMic" onclick="R.toggleMic()" title="Microphone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
      </button>
      <div class="ctrl-sep"></div>
      <button class="ctrl-btn rec" id="btnRec" onclick="R.toggleRecord()" title="Record">
        <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="8"/></svg>
      </button>
      <button class="ctrl-btn" id="btnPause" onclick="R.togglePause()" title="Pause" style="display:none;">
        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
      </button>
      <button class="ctrl-btn stop" id="btnStop" onclick="R.stopRecord()" title="Stop" style="display:none;">
        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
      </button>
      <div class="ctrl-sep"></div>
      <button class="ctrl-btn" id="btnPlay" onclick="R.togglePlayback()" title="Play">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <button class="ctrl-btn" id="btnTrim" onclick="R.toggleTrim()" title="Trim">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
      </button>
    </div>

    <!-- Timeline -->
    <div class="timeline">
      <div class="timeline-header">
        <span>Timeline</span>
        <span id="tlDuration" style="margin-left:auto;">0:00</span>
      </div>
      <div class="timeline-ruler" id="timelineRuler" onclick="R.scrub(event)"></div>
      <div class="timeline-tracks" id="timelineTracks">
        <div class="playhead" id="playhead" style="left:80px;"></div>
        <div class="timeline-track">
          <div class="track-label">Video</div>
          <div class="track-lane" id="trackVideo"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Text</div>
          <div class="track-lane" id="trackText"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Image</div>
          <div class="track-lane" id="trackImage"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Audio</div>
          <div class="track-lane" id="trackAudio"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Sidebar ── -->
  <div class="sidebar">
    <div class="sidebar-tabs">
      <div class="sidebar-tab active" onclick="R.switchTab('text')">Text</div>
      <div class="sidebar-tab" onclick="R.switchTab('image')">Image</div>
      <div class="sidebar-tab" onclick="R.switchTab('music')">Music</div>
      <div class="sidebar-tab" onclick="R.switchTab('prompter')">Prompter</div>
      <div class="sidebar-tab" onclick="R.switchTab('settings')">Settings</div>
    </div>

    <!-- Text Panel -->
    <div class="sidebar-panel active" id="panelText">
      <div class="sb-group">
        <label class="sb-label">Add Text Overlay</label>
        <input type="text" class="sb-input" id="textContent" placeholder="Enter text...">
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Font</label>
          <select class="sb-select" id="textFont">
            <option value="sans-serif">Sans-serif</option>
            <option value="serif">Serif</option>
            <option value="monospace">Monospace</option>
            <option value="Georgia">Georgia</option>
            <option value="Impact">Impact</option>
          </select>
        </div>
        <div>
          <label class="sb-label">Size</label>
          <input type="number" class="sb-input" id="textSize" value="48" min="12" max="200">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Color</label>
          <input type="color" class="sb-input" id="textColor" value="#ffffff" style="padding:2px;height:32px;">
        </div>
        <div>
          <label class="sb-label">Stroke</label>
          <input type="color" class="sb-input" id="textStroke" value="#000000" style="padding:2px;height:32px;">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Start (s)</label>
          <input type="number" class="sb-input" id="textStart" value="0" min="0" step="0.5">
        </div>
        <div>
          <label class="sb-label">Duration (s)</label>
          <input type="number" class="sb-input" id="textDuration" value="5" min="0.5" step="0.5">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Fade In (s)</label>
          <input type="number" class="sb-input" id="textFadeIn" value="0.5" min="0" max="5" step="0.1">
        </div>
        <div>
          <label class="sb-label">Fade Out (s)</label>
          <input type="number" class="sb-input" id="textFadeOut" value="0.5" min="0" max="5" step="0.1">
        </div>
      </div>
      <div class="sb-group">
        <label class="sb-label">Position</label>
        <select class="sb-select" id="textPosition" onchange="R.setTextPositionPreset(this.value)">
          <option value="center">Center</option>
          <option value="top">Top Center</option>
          <option value="bottom">Bottom Center</option>
          <option value="lower-third">Lower Third</option>
          <option value="top-left">Top Left</option>
          <option value="top-right">Top Right</option>
          <option value="custom">Custom (drag on canvas)</option>
        </select>
      </div>
      <div class="sb-group sb-row" id="textCustomPos" style="display:none;">
        <div>
          <label class="sb-label">X</label>
          <input type="number" class="sb-input" id="textPosX" value="960" min="0" max="3840">
        </div>
        <div>
          <label class="sb-label">Y</label>
          <input type="number" class="sb-input" id="textPosY" value="540" min="0" max="2160">
        </div>
      </div>
      <button class="sb-btn primary" onclick="R.addTextOverlay()">Add Text</button>
      <div style="margin-top:8px;font-size:10px;color:var(--text-muted);">Tip: After adding, drag text directly on the canvas to reposition.</div>
      <div id="textOverlaysList" style="margin-top:12px;"></div>
    </div>

    <!-- Image Panel -->
    <div class="sidebar-panel" id="panelImage">
      <div class="sb-group">
        <label class="sb-label">Upload Image Overlay</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose File
          <input type="file" accept="image/*" style="display:none;" onchange="R.addImageOverlay(this)">
        </label>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">X Position</label>
          <input type="number" class="sb-input" id="imgX" value="50" min="0" max="1920">
        </div>
        <div>
          <label class="sb-label">Y Position</label>
          <input type="number" class="sb-input" id="imgY" value="50" min="0" max="1080">
        </div>
      </div>
      <div class="sb-group">
        <label class="sb-label">Scale: <span id="imgScaleLabel">50%</span></label>
        <input type="range" class="sb-range" id="imgScale" min="5" max="100" value="50" oninput="document.getElementById('imgScaleLabel').textContent=this.value+'%'">
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Start (s)</label>
          <input type="number" class="sb-input" id="imgStart" value="0" min="0" step="0.5">
        </div>
        <div>
          <label class="sb-label">Duration (s)</label>
          <input type="number" class="sb-input" id="imgDuration" value="5" min="0.5" step="0.5">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Fade In (s)</label>
          <input type="number" class="sb-input" id="imgFadeIn" value="0.5" min="0" max="5" step="0.1">
        </div>
        <div>
          <label class="sb-label">Fade Out (s)</label>
          <input type="number" class="sb-input" id="imgFadeOut" value="0.5" min="0" max="5" step="0.1">
        </div>
      </div>
      <div id="imageOverlaysList" style="margin-top:12px;"></div>

      <div style="border-top:1px solid var(--border);padding-top:16px;margin-top:16px;">
        <div class="sb-group">
          <label class="sb-label">Lower Third Bar</label>
          <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
            Upload Lower Third
            <input type="file" accept="image/*" style="display:none;" onchange="R.addLowerThird(this)">
          </label>
          <div style="margin-top:4px;font-size:10px;color:var(--text-muted);">PNG with transparency recommended. Auto-positioned at bottom of canvas.</div>
        </div>
        <div class="sb-group sb-row">
          <div>
            <label class="sb-label">Start (s)</label>
            <input type="number" class="sb-input" id="ltStart" value="0" min="0" step="0.5">
          </div>
          <div>
            <label class="sb-label">Duration (s)</label>
            <input type="number" class="sb-input" id="ltDuration" value="10" min="0.5" step="0.5">
          </div>
        </div>
        <div class="sb-group">
          <label class="sb-label">Scale: <span id="ltScaleLabel">100%</span></label>
          <input type="range" class="sb-range" id="ltScale" min="20" max="100" value="100" oninput="document.getElementById('ltScaleLabel').textContent=this.value+'%'">
        </div>
        <div id="lowerThirdsList" style="margin-top:8px;"></div>
      </div>
    </div>

    <!-- Music Panel -->
    <div class="sidebar-panel" id="panelMusic">
      <div class="sb-group">
        <label class="sb-label">Upload Music Track</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose Audio File
          <input type="file" accept="audio/*" style="display:none;" onchange="R.addMusic(this)">
        </label>
      </div>
      <div class="sb-group">
        <label class="sb-label">Music Volume: <span id="musicVolLabel">50%</span></label>
        <input type="range" class="sb-range" id="musicVolume" min="0" max="100" value="50" oninput="R.setMusicVolume(this.value)">
      </div>
      <div id="musicInfo" style="display:none;">
        <div class="overlay-item">
          <span class="name" id="musicName"></span>
          <button class="del" onclick="R.removeMusic()">&times;</button>
        </div>
      </div>
    </div>

    <!-- Prompter Panel -->
    <div class="sidebar-panel" id="panelPrompter">
      <div class="sb-group">
        <label class="sb-label">Script</label>
        <textarea class="sb-input" id="prompterScript" rows="12" placeholder="Paste or type your script here..." style="resize:vertical;"></textarea>
      </div>
      <div class="sb-group">
        <label class="sb-label">Font Size: <span id="prompterSizeLabel">28px</span></label>
        <input type="range" class="sb-range" id="prompterSize" min="16" max="60" value="28" oninput="R.setPrompterSize(this.value)">
      </div>
      <div class="sb-group">
        <label class="sb-label">Scroll Speed: <span id="prompterSpeedLabel">3</span></label>
        <input type="range" class="sb-range" id="prompterSpeed" min="1" max="10" value="3" oninput="R.setPrompterSpeed(this.value)">
      </div>
      <div class="sb-group">
        <label class="sb-label">Opacity: <span id="prompterOpacityLabel">85%</span></label>
        <input type="range" class="sb-range" id="prompterOpacity" min="10" max="100" value="85" oninput="R.setPrompterOpacity(this.value)">
      </div>
      <div class="sb-group">
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);cursor:pointer;">
          <input type="checkbox" id="prompterMirror" onchange="R.togglePrompterMirror()"> Mirror text
        </label>
      </div>
      <button class="sb-btn primary" id="btnPrompter" onclick="R.togglePrompter()">Start Prompter</button>
    </div>

    <!-- Settings Panel -->
    <div class="sidebar-panel" id="panelSettings">
      <div class="sb-group">
        <label class="sb-label">Resolution</label>
        <select class="sb-select" id="resSel" onchange="R.changeResolution(this.value)">
          <option value="1280x720">720p (1280×720)</option>
          <option value="1920x1080" selected>1080p (1920×1080)</option>
          <option value="3840x2160">4K (3840×2160)</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Frame Rate</label>
        <select class="sb-select" id="fpsSel" onchange="R.changeFps(this.value)">
          <option value="24">24 FPS</option>
          <option value="30" selected>30 FPS</option>
          <option value="60">60 FPS</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Quality</label>
        <select class="sb-select" id="qualSel" onchange="R.changeBitrate(this.value)">
          <option value="2000000">Standard (2 Mbps)</option>
          <option value="4000000" selected>High (4 Mbps)</option>
          <option value="8000000">Ultra (8 Mbps)</option>
        </select>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Camera</label>
        <select class="sb-select" id="cameraSel" onchange="R.switchDevice()">
          <option value="">Default Camera</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Microphone</label>
        <select class="sb-select" id="micSel" onchange="R.switchDevice()">
          <option value="">Default Microphone</option>
        </select>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Layout</label>
        <select class="sb-select" id="layoutSel" onchange="R.setLayout(this.value)">
          <option value="full">Full (Camera fills canvas)</option>
          <option value="pip">PiP (Camera bottom-right)</option>
          <option value="split">Split Screen (50/50)</option>
          <option value="cover">Camera + Cover (60/40)</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Cover Image (for PiP / Split / Cover)</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose Cover Image
          <input type="file" accept="image/*" style="display:none;" onchange="R.loadCoverImage(this)">
        </label>
        <div id="coverInfo" style="display:none;margin-top:6px;">
          <div class="overlay-item">
            <span class="name" id="coverName"></span>
            <button class="del" onclick="R.removeCoverImage()">&times;</button>
          </div>
        </div>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Recording Time Limit</label>
        <select class="sb-select" id="timeLimitSel" onchange="R.setTimeLimit(this.value)">
          <option value="0">None</option>
          <option value="60">1 minute</option>
          <option value="120">2 minutes</option>
          <option value="300">5 minutes</option>
          <option value="600">10 minutes</option>
          <option value="1800">30 minutes</option>
          <option value="3600">60 minutes</option>
        </select>
      </div>
    </div>

    <!-- Queue Sidebar (hidden by default, shown in Queue mode) -->
    <div class="queue-sidebar" id="queueSidebar">
      <div class="queue-header">
        <h3>Recording Queue</h3>
        <div class="queue-progress"><div class="fill" id="queueProgressBar" style="width:0%"></div></div>
        <div class="queue-progress-text" id="queueProgressText">0/0</div>
      </div>

      <div class="queue-section">
        <div class="queue-section-label">Now</div>
      </div>
      <div class="queue-current" id="queueCurrent" style="display:none;">
        <div class="buyer-name" id="queueBuyerName"></div>
        <div class="buyer-location" id="queueBuyerLocation"></div>
      </div>

      <div class="queue-section" style="margin-top:12px;">
        <div class="queue-section-label">Up Next</div>
      </div>
      <ul class="queue-list" id="queueUpNext"></ul>

      <div class="queue-section" style="margin-top:12px;">
        <div class="queue-section-label">Done (<span id="queueDoneCount">0</span>)</div>
      </div>
      <ul class="queue-done-list" id="queueDoneList"></ul>

      <div class="queue-section" style="margin-top:12px;border-top:1px solid var(--border);padding-top:12px;">
        <div class="queue-section-label">Lower Third Design</div>
      </div>
      <div style="padding:0 16px;">
        <div style="margin-bottom:8px;">
          <label style="font-size:10px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;">Text Template</label>
          <input type="text" class="sb-input" id="queueLtText" value="For {name}" placeholder="Use {name} for buyer name" oninput="R.updateQueueLtPreview()">
          <div style="font-size:9px;color:var(--text-muted);margin-top:2px;">{name} = buyer's name</div>
        </div>
        <div style="display:flex;gap:6px;margin-bottom:8px;">
          <div style="flex:1;">
            <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Font Size</label>
            <input type="number" class="sb-input" id="queueLtFontSize" value="36" min="16" max="120" oninput="R.updateQueueLtPreview()">
          </div>
          <div style="flex:1;">
            <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Color</label>
            <input type="color" class="sb-input" id="queueLtColor" value="#ffffff" style="padding:2px;height:32px;" oninput="R.updateQueueLtPreview()">
          </div>
          <div style="flex:1;">
            <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Stroke</label>
            <input type="color" class="sb-input" id="queueLtStroke" value="#000000" style="padding:2px;height:32px;" oninput="R.updateQueueLtPreview()">
          </div>
        </div>
        <div style="display:flex;gap:6px;margin-bottom:8px;">
          <div style="flex:1;">
            <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Font</label>
            <select class="sb-select" id="queueLtFont" onchange="R.updateQueueLtPreview()">
              <option value="-apple-system, sans-serif">System</option>
              <option value="Georgia, serif">Georgia</option>
              <option value="'Courier New', monospace">Monospace</option>
              <option value="Impact, sans-serif">Impact</option>
              <option value="'Brush Script MT', cursive">Script</option>
            </select>
          </div>
          <div style="flex:1;">
            <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Position</label>
            <select class="sb-select" id="queueLtPosition" onchange="R.updateQueueLtPreview()">
              <option value="bottom">Bottom</option>
              <option value="top">Top</option>
              <option value="center">Center</option>
            </select>
          </div>
        </div>
        <div style="margin-bottom:8px;">
          <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Custom Design (PNG)</label>
          <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;font-size:11px;">
            Upload Graphic
            <input type="file" accept="image/*" style="display:none;" onchange="R.loadQueueLtDesign(this)">
          </label>
          <div style="font-size:9px;color:var(--text-muted);margin-top:2px;">PNG with transparency. Name text renders on top.</div>
          <div id="queueLtDesignInfo" style="display:none;margin-top:6px;">
            <div class="overlay-item">
              <span class="name" id="queueLtDesignName" style="flex:1;font-size:11px;"></span>
              <button class="del" onclick="R.removeQueueLtDesign()" style="font-size:14px;">&times;</button>
            </div>
          </div>
        </div>
        <div style="margin-bottom:8px;">
          <label style="font-size:10px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:4px;">Bar Opacity</label>
          <input type="range" class="sb-range" id="queueLtBarOpacity" min="0" max="100" value="65" oninput="R.updateQueueLtPreview()">
        </div>
        <div id="queueLtPreview" style="background:var(--bg-tertiary);border:1px solid var(--border);border-radius:6px;padding:6px;text-align:center;min-height:40px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
          <span style="font-size:11px;color:var(--text-muted);">Preview will show here</span>
        </div>
      </div>

      <div class="queue-controls">
        <button class="q-btn" id="queueSkipBtn" onclick="R.skipBuyer()" disabled>Skip</button>
      </div>
    </div>
  </div>
</div>

