<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <title>Record Studio — <%= @campaign.title %></title>
  <script src="https://unpkg.com/@ffmpeg/ffmpeg@0.12.10/dist/umd/ffmpeg.js" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@ffmpeg/util@0.12.1/dist/umd/util.js" crossorigin="anonymous"></script>
<style>
  :root {
    --bg-primary: #111119;
    --bg-secondary: #1a1a24;
    --bg-tertiary: #22222e;
    --bg-hover: #2a2a38;
    --border: #2d2d3d;
    --text-primary: #e8e8ef;
    --text-secondary: #8888a0;
    --text-muted: #55556a;
    --accent: #003262;
    --accent-hover: #1a4a7a;
    --accent-soft: rgba(0,50,98,0.12);
    --danger: #e94560;
    --success: #219653;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif; background: var(--bg-primary); color: var(--text-primary); height: 100vh; display: flex; flex-direction: column; }

  /* ── Top Bar ── */
  .top-bar {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg-secondary); padding: 0 16px; height: 48px;
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .top-bar-left { display: flex; align-items: center; gap: 12px; }
  .logo { font-size: 14px; font-weight: 700; letter-spacing: 1.5px; white-space: nowrap; }
  .logo span { color: var(--accent); }
  .mode-pills { display: inline-flex; background: var(--bg-tertiary); border-radius: 8px; padding: 2px; gap: 2px; }
  .mode-pill {
    padding: 5px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
    text-decoration: none; color: var(--text-secondary); transition: all 0.15s;
  }
  .mode-pill:hover { color: var(--text-primary); }
  .mode-pill.active { background: var(--accent); color: #fff; }
  .top-bar-right { display: flex; align-items: center; gap: 8px; }
  .tb-btn {
    padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
    border: 1px solid var(--border); background: var(--bg-tertiary); color: var(--text-secondary);
    cursor: pointer; text-decoration: none; transition: all 0.15s;
  }
  .tb-btn:hover { border-color: var(--accent); color: var(--accent); }
  .tb-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .tb-btn.primary:hover { background: var(--accent-hover); }
  .tb-btn.danger { background: var(--danger); border-color: var(--danger); color: #fff; }
  .tb-btn:disabled { opacity: 0.4; cursor: default; }

  /* ── Main Layout ── */
  .main-area { display: flex; flex: 1; min-height: 0; }
  .canvas-col { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .sidebar { width: 280px; background: var(--bg-secondary); border-left: 1px solid var(--border); display: flex; flex-direction: column; overflow-y: auto; flex-shrink: 0; }

  /* ── Canvas ── */
  .canvas-wrap {
    flex: 1; display: flex; align-items: center; justify-content: center;
    background: #0a0a0f; position: relative; min-height: 0; padding: 12px;
  }
  #recorderCanvas {
    max-width: 100%; max-height: 100%; border-radius: 8px;
    background: #000; display: block;
  }
  .canvas-badge {
    position: absolute; top: 20px; left: 20px; padding: 5px 12px; border-radius: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 1px; display: none; z-index: 5;
  }
  .canvas-badge.recording { background: var(--danger); color: #fff; display: flex; align-items: center; gap: 6px; }
  .canvas-badge.recording .dot { width: 8px; height: 8px; background: #fff; border-radius: 50%; animation: blink 1.2s ease-in-out infinite; }
  .canvas-badge.paused { background: #F59E0B; color: #000; display: block; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .canvas-time {
    position: absolute; top: 20px; right: 20px; background: rgba(0,0,0,0.6);
    backdrop-filter: blur(6px); padding: 5px 12px; border-radius: 6px;
    font-size: 13px; font-weight: 600; font-variant-numeric: tabular-nums;
    display: none; z-index: 5;
  }

  /* ── Controls Bar ── */
  .controls-bar {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    padding: 10px 16px; background: var(--bg-secondary); border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .ctrl-btn {
    width: 42px; height: 42px; border-radius: 50%; border: 2px solid var(--border);
    background: var(--bg-tertiary); color: var(--text-secondary); display: flex;
    align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s;
  }
  .ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }
  .ctrl-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .ctrl-btn.rec { border-color: var(--danger); color: var(--danger); }
  .ctrl-btn.rec:hover { background: var(--danger); color: #fff; }
  .ctrl-btn.rec.active { background: var(--danger); color: #fff; animation: recPulse 2s ease-in-out infinite; }
  @keyframes recPulse { 0%,100%{box-shadow:0 0 0 0 rgba(233,69,96,0.4)} 50%{box-shadow:0 0 12px 4px rgba(233,69,96,0.2)} }
  .ctrl-btn.stop { border-color: #F59E0B; color: #F59E0B; }
  .ctrl-btn.stop:hover { background: #F59E0B; color: #000; }
  .ctrl-btn svg { width: 18px; height: 18px; }
  .ctrl-sep { width: 1px; height: 28px; background: var(--border); margin: 0 4px; }

  /* ── Timeline ── */
  .timeline {
    height: 200px; background: var(--bg-secondary); border-top: 1px solid var(--border);
    flex-shrink: 0; display: flex; flex-direction: column; overflow: hidden;
  }
  .timeline-header {
    display: flex; align-items: center; padding: 6px 12px; gap: 8px;
    border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .timeline-header span { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .timeline-ruler {
    height: 20px; background: var(--bg-tertiary); border-bottom: 1px solid var(--border);
    position: relative; flex-shrink: 0; overflow: hidden;
  }
  .timeline-tracks { flex: 1; overflow-y: auto; position: relative; }
  .timeline-track {
    display: flex; align-items: center; height: 36px;
    border-bottom: 1px solid rgba(45,45,61,0.5); position: relative;
  }
  .track-label {
    width: 80px; padding: 0 10px; font-size: 10px; font-weight: 600;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;
    flex-shrink: 0; background: var(--bg-secondary); z-index: 2;
  }
  .track-lane { flex: 1; height: 100%; position: relative; overflow: hidden; }
  .track-clip {
    position: absolute; top: 4px; bottom: 4px; border-radius: 4px;
    font-size: 10px; font-weight: 600; color: #fff; display: flex;
    align-items: center; padding: 0 8px; cursor: grab; min-width: 20px;
    overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
  }
  .track-clip.video { background: rgba(108,92,231,0.6); border: 1px solid rgba(108,92,231,0.8); }
  .track-clip.text { background: rgba(34,197,94,0.5); border: 1px solid rgba(34,197,94,0.7); }
  .track-clip.image { background: rgba(59,130,246,0.5); border: 1px solid rgba(59,130,246,0.7); }
  .track-clip.audio { background: rgba(245,158,11,0.5); border: 1px solid rgba(245,158,11,0.7); }
  .trim-handle {
    position: absolute; top: 0; bottom: 0; width: 6px; cursor: ew-resize; z-index: 3;
  }
  .trim-handle.left { left: 0; border-radius: 4px 0 0 4px; background: rgba(255,255,255,0.15); }
  .trim-handle.right { right: 0; border-radius: 0 4px 4px 0; background: rgba(255,255,255,0.15); }
  .trim-handle:hover { background: rgba(255,255,255,0.3); }
  .playhead {
    position: absolute; top: 0; bottom: 0; width: 2px; background: var(--danger);
    z-index: 10; pointer-events: none;
  }
  .playhead::before {
    content: ''; position: absolute; top: -4px; left: -5px;
    width: 12px; height: 8px; background: var(--danger);
    clip-path: polygon(0 0, 100% 0, 50% 100%);
  }

  /* ── Sidebar Tabs ── */
  .sidebar-tabs {
    display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .sidebar-tab {
    flex: 1; padding: 10px; text-align: center; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);
    cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s;
  }
  .sidebar-tab:hover { color: var(--text-secondary); }
  .sidebar-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .sidebar-panel { display: none; padding: 16px; flex: 1; overflow-y: auto; }
  .sidebar-panel.active { display: block; }
  .sb-group { margin-bottom: 16px; }
  .sb-label { display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .sb-input, .sb-select {
    width: 100%; padding: 7px 10px; border: 1px solid var(--border); border-radius: 6px;
    font-size: 12px; font-family: inherit; background: var(--bg-tertiary); color: var(--text-primary);
  }
  .sb-input:focus, .sb-select:focus { outline: none; border-color: var(--accent); }
  .sb-btn {
    width: 100%; padding: 8px; border-radius: 6px; font-size: 12px; font-weight: 600;
    font-family: inherit; border: 1px solid var(--border); background: var(--bg-tertiary);
    color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
  }
  .sb-btn:hover { border-color: var(--accent); color: var(--accent); }
  .sb-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .sb-row { display: flex; gap: 8px; }
  .sb-row > * { flex: 1; }
  .sb-range { width: 100%; accent-color: var(--accent); }

  /* ── Countdown Overlay ── */
  .countdown-overlay {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    z-index: 6; pointer-events: none;
  }
  .countdown-overlay .countdown-num {
    font-size: 200px; font-weight: 900; color: #fff;
    text-shadow: 0 0 60px rgba(0,0,0,0.8), 0 4px 20px rgba(0,0,0,0.5);
    animation: countPop 0.6s ease-out;
  }
  @keyframes countPop { 0%{transform:scale(1.6);opacity:0.3} 100%{transform:scale(1);opacity:1} }

  /* ── Trim Time Labels ── */
  .trim-time-label {
    font-size: 10px; color: var(--text-muted); font-variant-numeric: tabular-nums;
    margin-left: 4px;
  }
  .trim-active .trim-handle { background: rgba(233,69,96,0.4); }
  .trim-active .trim-handle:hover { background: rgba(233,69,96,0.6); }
  .ctrl-btn.trim-on { border-color: var(--danger); color: var(--danger); }

  /* ── Time Remaining ── */
  .time-remaining { font-variant-numeric: tabular-nums; }
  .time-remaining.warning { color: #F59E0B; }
  .time-remaining.critical { color: var(--danger); animation: blink 0.8s ease-in-out infinite; }

  /* ── Teleprompter ── */
  #teleprompter {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 4;
  }
  #prompterText {
    position: absolute; bottom: 0; left: 10%; right: 10%;
    font-size: 28px; line-height: 1.6; color: rgba(255,255,255,0.85);
    text-shadow: 0 2px 8px rgba(0,0,0,0.8); text-align: center;
  }
  #teleprompter.mirrored { transform: scaleX(-1); }

  .overlay-item {
    display: flex; align-items: center; gap: 8px; padding: 8px; margin-bottom: 6px;
    background: var(--bg-tertiary); border-radius: 6px; border: 1px solid var(--border);
  }
  .overlay-item .name { flex: 1; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .overlay-item .del {
    width: 20px; height: 20px; border: none; background: none; color: var(--text-muted);
    cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center;
  }
  .overlay-item .del:hover { color: var(--danger); }

  /* ── Export Modal ── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100;
    display: none; align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px;
    padding: 28px; width: 420px; max-width: 90vw;
  }
  .modal-box h3 { font-size: 16px; margin-bottom: 16px; }
  .progress-bar { height: 8px; background: var(--bg-tertiary); border-radius: 4px; overflow: hidden; margin: 12px 0; }
  .progress-bar .fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.3s; width: 0; }
  .progress-text { font-size: 12px; color: var(--text-secondary); }
</style>
</head>
<body>

<!-- ── Top Bar ── -->
<div class="top-bar">
  <div class="top-bar-left">
    <div class="logo">PREMIERE <span>STUDIO</span></div>
    <div class="mode-pills">
      <a href="<%= studio_portal_campaign_live_events_path(@campaign) %>" class="mode-pill">Live</a>
      <span class="mode-pill active">Record</span>
    </div>
  </div>
  <div class="top-bar-right">
    <button class="tb-btn" id="btnLaunchRecorder" onclick="R.launchRecorder()">Launch Recorder</button>
    <a href="<%= studio_portal_campaign_live_events_path(@campaign) %>" class="tb-btn">Back to Studio</a>
    <button class="tb-btn" id="btnDownloadRaw" onclick="R.downloadRaw()" style="display:none;">Download Raw</button>
    <button class="tb-btn primary" id="btnExport" onclick="R.startExport()" disabled>Export MP4</button>
  </div>
</div>

<!-- ── Main ── -->
<div class="main-area">
  <div class="canvas-col">
    <!-- Canvas -->
    <div class="canvas-wrap">
      <canvas id="recorderCanvas" width="1920" height="1080"></canvas>
      <div class="canvas-badge" id="badge"></div>
      <div class="canvas-time" id="canvasTime">00:00</div>
      <div id="teleprompter" style="display:none;">
        <div id="prompterText"></div>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls-bar">
      <button class="ctrl-btn" id="btnCamera" onclick="R.toggleCamera()" title="Camera">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15.5 10-5 3V7l5 3Z"/><rect x="2" y="4" width="20" height="16" rx="4"/></svg>
      </button>
      <button class="ctrl-btn" id="btnMic" onclick="R.toggleMic()" title="Microphone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
      </button>
      <div class="ctrl-sep"></div>
      <button class="ctrl-btn rec" id="btnRec" onclick="R.toggleRecord()" title="Record">
        <svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="8"/></svg>
      </button>
      <button class="ctrl-btn" id="btnPause" onclick="R.togglePause()" title="Pause" style="display:none;">
        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>
      </button>
      <button class="ctrl-btn stop" id="btnStop" onclick="R.stopRecord()" title="Stop" style="display:none;">
        <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
      </button>
      <div class="ctrl-sep"></div>
      <button class="ctrl-btn" id="btnPlay" onclick="R.togglePlayback()" title="Play">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <button class="ctrl-btn" id="btnTrim" onclick="R.toggleTrim()" title="Trim">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
      </button>
    </div>

    <!-- Timeline -->
    <div class="timeline">
      <div class="timeline-header">
        <span>Timeline</span>
        <span id="tlDuration" style="margin-left:auto;">0:00</span>
      </div>
      <div class="timeline-ruler" id="timelineRuler" onclick="R.scrub(event)"></div>
      <div class="timeline-tracks" id="timelineTracks">
        <div class="playhead" id="playhead" style="left:80px;"></div>
        <div class="timeline-track">
          <div class="track-label">Video</div>
          <div class="track-lane" id="trackVideo"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Text</div>
          <div class="track-lane" id="trackText"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Image</div>
          <div class="track-lane" id="trackImage"></div>
        </div>
        <div class="timeline-track">
          <div class="track-label">Audio</div>
          <div class="track-lane" id="trackAudio"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Sidebar ── -->
  <div class="sidebar">
    <div class="sidebar-tabs">
      <div class="sidebar-tab active" onclick="R.switchTab('text')">Text</div>
      <div class="sidebar-tab" onclick="R.switchTab('image')">Image</div>
      <div class="sidebar-tab" onclick="R.switchTab('music')">Music</div>
      <div class="sidebar-tab" onclick="R.switchTab('prompter')">Prompter</div>
      <div class="sidebar-tab" onclick="R.switchTab('settings')">Settings</div>
    </div>

    <!-- Text Panel -->
    <div class="sidebar-panel active" id="panelText">
      <div class="sb-group">
        <label class="sb-label">Add Text Overlay</label>
        <input type="text" class="sb-input" id="textContent" placeholder="Enter text...">
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Font</label>
          <select class="sb-select" id="textFont">
            <option value="sans-serif">Sans-serif</option>
            <option value="serif">Serif</option>
            <option value="monospace">Monospace</option>
            <option value="Georgia">Georgia</option>
            <option value="Impact">Impact</option>
          </select>
        </div>
        <div>
          <label class="sb-label">Size</label>
          <input type="number" class="sb-input" id="textSize" value="48" min="12" max="200">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Color</label>
          <input type="color" class="sb-input" id="textColor" value="#ffffff" style="padding:2px;height:32px;">
        </div>
        <div>
          <label class="sb-label">Stroke</label>
          <input type="color" class="sb-input" id="textStroke" value="#000000" style="padding:2px;height:32px;">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Start (s)</label>
          <input type="number" class="sb-input" id="textStart" value="0" min="0" step="0.5">
        </div>
        <div>
          <label class="sb-label">Duration (s)</label>
          <input type="number" class="sb-input" id="textDuration" value="5" min="0.5" step="0.5">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Fade In (s)</label>
          <input type="number" class="sb-input" id="textFadeIn" value="0.5" min="0" max="5" step="0.1">
        </div>
        <div>
          <label class="sb-label">Fade Out (s)</label>
          <input type="number" class="sb-input" id="textFadeOut" value="0.5" min="0" max="5" step="0.1">
        </div>
      </div>
      <button class="sb-btn primary" onclick="R.addTextOverlay()">Add Text</button>
      <div id="textOverlaysList" style="margin-top:12px;"></div>
    </div>

    <!-- Image Panel -->
    <div class="sidebar-panel" id="panelImage">
      <div class="sb-group">
        <label class="sb-label">Upload Image Overlay</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose File
          <input type="file" accept="image/*" style="display:none;" onchange="R.addImageOverlay(this)">
        </label>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">X Position</label>
          <input type="number" class="sb-input" id="imgX" value="50" min="0" max="1920">
        </div>
        <div>
          <label class="sb-label">Y Position</label>
          <input type="number" class="sb-input" id="imgY" value="50" min="0" max="1080">
        </div>
      </div>
      <div class="sb-group">
        <label class="sb-label">Scale: <span id="imgScaleLabel">50%</span></label>
        <input type="range" class="sb-range" id="imgScale" min="5" max="100" value="50" oninput="document.getElementById('imgScaleLabel').textContent=this.value+'%'">
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Start (s)</label>
          <input type="number" class="sb-input" id="imgStart" value="0" min="0" step="0.5">
        </div>
        <div>
          <label class="sb-label">Duration (s)</label>
          <input type="number" class="sb-input" id="imgDuration" value="5" min="0.5" step="0.5">
        </div>
      </div>
      <div class="sb-group sb-row">
        <div>
          <label class="sb-label">Fade In (s)</label>
          <input type="number" class="sb-input" id="imgFadeIn" value="0.5" min="0" max="5" step="0.1">
        </div>
        <div>
          <label class="sb-label">Fade Out (s)</label>
          <input type="number" class="sb-input" id="imgFadeOut" value="0.5" min="0" max="5" step="0.1">
        </div>
      </div>
      <div id="imageOverlaysList" style="margin-top:12px;"></div>
    </div>

    <!-- Music Panel -->
    <div class="sidebar-panel" id="panelMusic">
      <div class="sb-group">
        <label class="sb-label">Upload Music Track</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose Audio File
          <input type="file" accept="audio/*" style="display:none;" onchange="R.addMusic(this)">
        </label>
      </div>
      <div class="sb-group">
        <label class="sb-label">Music Volume: <span id="musicVolLabel">50%</span></label>
        <input type="range" class="sb-range" id="musicVolume" min="0" max="100" value="50" oninput="R.setMusicVolume(this.value)">
      </div>
      <div id="musicInfo" style="display:none;">
        <div class="overlay-item">
          <span class="name" id="musicName"></span>
          <button class="del" onclick="R.removeMusic()">&times;</button>
        </div>
      </div>
    </div>

    <!-- Prompter Panel -->
    <div class="sidebar-panel" id="panelPrompter">
      <div class="sb-group">
        <label class="sb-label">Script</label>
        <textarea class="sb-input" id="prompterScript" rows="12" placeholder="Paste or type your script here..." style="resize:vertical;"></textarea>
      </div>
      <div class="sb-group">
        <label class="sb-label">Font Size: <span id="prompterSizeLabel">28px</span></label>
        <input type="range" class="sb-range" id="prompterSize" min="16" max="60" value="28" oninput="R.setPrompterSize(this.value)">
      </div>
      <div class="sb-group">
        <label class="sb-label">Scroll Speed: <span id="prompterSpeedLabel">3</span></label>
        <input type="range" class="sb-range" id="prompterSpeed" min="1" max="10" value="3" oninput="R.setPrompterSpeed(this.value)">
      </div>
      <div class="sb-group">
        <label class="sb-label">Opacity: <span id="prompterOpacityLabel">85%</span></label>
        <input type="range" class="sb-range" id="prompterOpacity" min="10" max="100" value="85" oninput="R.setPrompterOpacity(this.value)">
      </div>
      <div class="sb-group">
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);cursor:pointer;">
          <input type="checkbox" id="prompterMirror" onchange="R.togglePrompterMirror()"> Mirror text
        </label>
      </div>
      <button class="sb-btn primary" id="btnPrompter" onclick="R.togglePrompter()">Start Prompter</button>
    </div>

    <!-- Settings Panel -->
    <div class="sidebar-panel" id="panelSettings">
      <div class="sb-group">
        <label class="sb-label">Resolution</label>
        <select class="sb-select" id="resSel" onchange="R.changeResolution(this.value)">
          <option value="1280x720">720p (1280×720)</option>
          <option value="1920x1080" selected>1080p (1920×1080)</option>
          <option value="3840x2160">4K (3840×2160)</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Frame Rate</label>
        <select class="sb-select" id="fpsSel" onchange="R.changeFps(this.value)">
          <option value="24">24 FPS</option>
          <option value="30" selected>30 FPS</option>
          <option value="60">60 FPS</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Quality</label>
        <select class="sb-select" id="qualSel" onchange="R.changeBitrate(this.value)">
          <option value="2000000">Standard (2 Mbps)</option>
          <option value="4000000" selected>High (4 Mbps)</option>
          <option value="8000000">Ultra (8 Mbps)</option>
        </select>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Camera</label>
        <select class="sb-select" id="cameraSel" onchange="R.switchDevice()">
          <option value="">Default Camera</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Microphone</label>
        <select class="sb-select" id="micSel" onchange="R.switchDevice()">
          <option value="">Default Microphone</option>
        </select>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Layout</label>
        <select class="sb-select" id="layoutSel" onchange="R.setLayout(this.value)">
          <option value="full">Full (Camera fills canvas)</option>
          <option value="pip">PiP (Camera bottom-right)</option>
          <option value="split">Split Screen (50/50)</option>
          <option value="cover">Camera + Cover (60/40)</option>
        </select>
      </div>
      <div class="sb-group">
        <label class="sb-label">Cover Image (for PiP / Split / Cover)</label>
        <label class="sb-btn" style="cursor:pointer;text-align:center;display:block;">
          Choose Cover Image
          <input type="file" accept="image/*" style="display:none;" onchange="R.loadCoverImage(this)">
        </label>
        <div id="coverInfo" style="display:none;margin-top:6px;">
          <div class="overlay-item">
            <span class="name" id="coverName"></span>
            <button class="del" onclick="R.removeCoverImage()">&times;</button>
          </div>
        </div>
      </div>
      <div class="sb-group" style="border-top:1px solid var(--border);padding-top:16px;margin-top:8px;">
        <label class="sb-label">Recording Time Limit</label>
        <select class="sb-select" id="timeLimitSel" onchange="R.setTimeLimit(this.value)">
          <option value="0">None</option>
          <option value="60">1 minute</option>
          <option value="120">2 minutes</option>
          <option value="300">5 minutes</option>
          <option value="600">10 minutes</option>
          <option value="1800">30 minutes</option>
          <option value="3600">60 minutes</option>
        </select>
      </div>
    </div>
  </div>
</div>

<!-- Export Modal -->
<div class="modal-overlay" id="exportModal">
  <div class="modal-box">
    <h3 id="exportTitle">Exporting MP4...</h3>
    <div class="progress-bar"><div class="fill" id="exportProgress"></div></div>
    <div class="progress-text" id="exportStatus">Loading FFmpeg core (this may take a moment)...</div>
    <div style="margin-top:16px;text-align:right;">
      <button class="tb-btn" id="exportCloseBtn" onclick="R.closeExportModal()" style="display:none;">Close</button>
    </div>
  </div>
</div>

<script>
var R = (function() {
  'use strict';

  // ── State ──
  var canvas = document.getElementById('recorderCanvas');
  var ctx = canvas.getContext('2d');
  var cameraStream = null;
  var cameraVideo = null;
  var cameraOn = false;
  var micOn = false;

  var mediaRecorder = null;
  var recordedChunks = [];
  var isRecording = false;
  var isPaused = false;
  var recordStartTime = 0;
  var recordElapsed = 0;
  var pauseStart = 0;
  var totalPaused = 0;

  var recordedBlob = null;
  var recordedUrl = null;
  var playbackVideo = null;
  var isPlaying = false;
  var playStartTime = 0;

  var textOverlays = [];
  var imageOverlays = [];
  var musicFile = null;
  var musicBuffer = null;
  var musicAudioEl = null;

  var audioCtx = null;
  var micSource = null;
  var musicSource = null;
  var musicGain = null;
  var audioDest = null;
  var musicPendingConnect = false;

  var timelineDuration = 0;
  var animFrame = null;

  // ── Settings / Quality ──
  var resolution = { w: 1920, h: 1080, label: '1080p' };
  var targetFps = 30;
  var targetBitrate = 4000000;

  // ── Layout ──
  var layout = 'full';
  var coverImage = null;

  // ── Countdown ──
  var countdownValue = 0;

  // ── Time Limit ──
  var timeLimit = 0;
  var timeLimitTimer = null;
  var timeLimitRemaining = 0;

  // ── Teleprompter ──
  var prompterActive = false;
  var prompterAnimFrame = null;
  var prompterScrollPos = 0;

  // ── Trim ──
  var trimIn = 0;
  var trimOut = 0;
  var trimActive = false;

  // ── Camera ──
  function launchRecorder() {
    var videoConstraints = { width: { ideal: resolution.w }, height: { ideal: resolution.h } };
    var audioConstraints = true;
    var selCam = document.getElementById('cameraSel').value;
    var selMic = document.getElementById('micSel').value;
    if (selCam) videoConstraints.deviceId = { exact: selCam };
    if (selMic) audioConstraints = { deviceId: { exact: selMic } };

    navigator.mediaDevices.getUserMedia({
      video: videoConstraints,
      audio: audioConstraints
    }).then(function(stream) {
      cameraStream = stream;
      cameraVideo = document.createElement('video');
      cameraVideo.srcObject = stream;
      cameraVideo.muted = true;
      cameraVideo.playsInline = true;
      cameraVideo.play();
      cameraOn = true;
      micOn = true;
      document.getElementById('btnCamera').classList.add('active');
      document.getElementById('btnMic').classList.add('active');
      document.getElementById('btnLaunchRecorder').textContent = 'Recorder Active';
      document.getElementById('btnLaunchRecorder').disabled = true;
      setupAudio(stream);
      enumerateDeviceLists();
      startCompositor();
    }).catch(function(err) {
      alert('Camera/mic access denied: ' + err.message);
    });
  }

  function toggleCamera() {
    if (!cameraStream) return launchRecorder();
    var tracks = cameraStream.getVideoTracks();
    if (tracks.length === 0) return;
    cameraOn = !cameraOn;
    tracks[0].enabled = cameraOn;
    document.getElementById('btnCamera').classList.toggle('active', cameraOn);
  }

  function toggleMic() {
    if (!cameraStream) return;
    var tracks = cameraStream.getAudioTracks();
    if (tracks.length === 0) return;
    micOn = !micOn;
    tracks[0].enabled = micOn;
    document.getElementById('btnMic').classList.toggle('active', micOn);
  }

  // ── Audio Mixing ──
  function setupAudio(stream) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    audioDest = audioCtx.createMediaStreamDestination();
    micSource = audioCtx.createMediaStreamSource(stream);
    micSource.connect(audioDest);
    musicGain = audioCtx.createGain();
    musicGain.gain.value = 0.5;
    musicGain.connect(audioDest);

    // Connect pending music if it was added before camera launch
    if (musicPendingConnect && musicAudioEl) {
      musicSource = audioCtx.createMediaElementSource(musicAudioEl);
      musicSource.connect(musicGain);
      musicPendingConnect = false;
    }
  }

  // ── Compositor ──
  function startCompositor() {
    function draw() {
      animFrame = requestAnimationFrame(draw);
      var cw = canvas.width;
      var ch = canvas.height;
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, cw, ch);

      // Draw camera with layout
      if (cameraOn && cameraVideo && cameraVideo.readyState >= 2) {
        drawLayout(ctx, cameraVideo, cw, ch);
      } else if (coverImage && layout !== 'full') {
        drawCoverFull(ctx, coverImage, cw, ch);
      }

      // Draw countdown number on canvas
      if (countdownValue > 0) {
        ctx.save();
        ctx.font = 'bold 200px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 8;
        ctx.strokeText(countdownValue, cw / 2, ch / 2);
        ctx.fillStyle = '#fff';
        ctx.fillText(countdownValue, cw / 2, ch / 2);
        ctx.restore();
      }

      // Current time relative to recording
      var now = getCurrentTime();

      // Draw image overlays
      for (var i = 0; i < imageOverlays.length; i++) {
        var io = imageOverlays[i];
        var opacity = getOverlayOpacity(io, now);
        if (opacity <= 0) continue;
        ctx.globalAlpha = opacity;
        var w = io.img.naturalWidth * (io.scale / 100);
        var h = io.img.naturalHeight * (io.scale / 100);
        ctx.drawImage(io.img, io.x, io.y, w, h);
        ctx.globalAlpha = 1;
      }

      // Draw text overlays
      for (var j = 0; j < textOverlays.length; j++) {
        var to = textOverlays[j];
        var textOpacity = getOverlayOpacity(to, now);
        if (textOpacity <= 0) continue;
        ctx.globalAlpha = textOpacity;
        ctx.font = to.size + 'px ' + to.font;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        if (to.stroke) {
          ctx.strokeStyle = to.stroke;
          ctx.lineWidth = Math.max(2, to.size / 12);
          ctx.strokeText(to.text, to.x, to.y);
        }
        ctx.fillStyle = to.color;
        ctx.fillText(to.text, to.x, to.y);
        ctx.globalAlpha = 1;
      }

      // Update timer
      if (isRecording && !isPaused) {
        updateTimerDisplay(now);
      }
    }
    draw();
  }

  function getCurrentTime() {
    if (isPlaying && playbackVideo) {
      return playbackVideo.currentTime;
    }
    if (isRecording) {
      if (isPaused) return (pauseStart - recordStartTime - totalPaused) / 1000;
      return (performance.now() - recordStartTime - totalPaused) / 1000;
    }
    return 0;
  }

  function getOverlayOpacity(overlay, time) {
    if (time < overlay.start || time > overlay.start + overlay.duration) return 0;
    var elapsed = time - overlay.start;
    var remaining = overlay.start + overlay.duration - time;
    var opacity = 1;
    if (overlay.fadeIn > 0 && elapsed < overlay.fadeIn) {
      opacity = elapsed / overlay.fadeIn;
    }
    if (overlay.fadeOut > 0 && remaining < overlay.fadeOut) {
      opacity = Math.min(opacity, remaining / overlay.fadeOut);
    }
    return Math.max(0, Math.min(1, opacity));
  }

  function updateTimerDisplay(seconds) {
    var m = Math.floor(seconds / 60);
    var s = Math.floor(seconds % 60);
    var str = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    var el = document.getElementById('canvasTime');
    if (timeLimit > 0 && isRecording) {
      var remaining = timeLimit - seconds;
      var rm = Math.floor(Math.max(0, remaining) / 60);
      var rs = Math.floor(Math.max(0, remaining) % 60);
      str += ' / -' + String(rm).padStart(2, '0') + ':' + String(rs).padStart(2, '0');
      el.className = 'canvas-time time-remaining' + (remaining < 10 ? ' critical' : remaining < 30 ? ' warning' : '');
    } else {
      el.className = 'canvas-time';
    }
    el.textContent = str;
  }

  // ── Recording ──
  function toggleRecord() {
    if (isRecording) {
      togglePause();
      return;
    }
    if (!cameraStream) {
      alert('Launch the recorder first (camera + mic access required).');
      return;
    }
    startCountdown();
  }

  function startRecording() {
    recordedChunks = [];
    recordedBlob = null;
    if (recordedUrl) { URL.revokeObjectURL(recordedUrl); recordedUrl = null; }

    // Canvas stream + mixed audio
    var canvasStream = canvas.captureStream(targetFps);
    var combined = new MediaStream();
    canvasStream.getVideoTracks().forEach(function(t) { combined.addTrack(t); });
    audioDest.stream.getAudioTracks().forEach(function(t) { combined.addTrack(t); });

    // Codec detection
    var mimeType = '';
    var codecs = ['video/webm;codecs=vp9,opus', 'video/webm;codecs=vp8,opus', 'video/webm', 'video/mp4'];
    for (var i = 0; i < codecs.length; i++) {
      if (MediaRecorder.isTypeSupported(codecs[i])) { mimeType = codecs[i]; break; }
    }

    var options = { videoBitsPerSecond: targetBitrate };
    if (mimeType) options.mimeType = mimeType;

    mediaRecorder = new MediaRecorder(combined, options);
    mediaRecorder.ondataavailable = function(e) {
      if (e.data && e.data.size > 0) recordedChunks.push(e.data);
    };
    mediaRecorder.onstop = function() {
      recordedBlob = new Blob(recordedChunks, { type: mimeType || 'video/webm' });
      recordedUrl = URL.createObjectURL(recordedBlob);
      timelineDuration = recordElapsed;
      document.getElementById('btnExport').disabled = false;
      updateTimeline();
      setupPlayback();
    };

    mediaRecorder.start(1000);
    isRecording = true;
    isPaused = false;
    recordStartTime = performance.now();
    totalPaused = 0;

    // Start music playback if loaded
    if (musicAudioEl) {
      musicAudioEl.currentTime = 0;
      musicAudioEl.play();
    }

    // UI
    document.getElementById('btnRec').classList.add('active');
    document.getElementById('btnPause').style.display = '';
    document.getElementById('btnStop').style.display = '';
    document.getElementById('canvasTime').style.display = '';
    var badge = document.getElementById('badge');
    badge.className = 'canvas-badge recording';
    badge.innerHTML = '<span class="dot"></span> REC';

    // Disable settings while recording
    setSettingsDisabled(true);

    // Start time limit timer
    if (timeLimit > 0) {
      timeLimitRemaining = timeLimit;
      timeLimitTimer = setTimeout(function() { stopRecord(); }, timeLimit * 1000);
    }
  }

  function togglePause() {
    if (!isRecording) return;
    if (isPaused) {
      totalPaused += performance.now() - pauseStart;
      mediaRecorder.resume();
      isPaused = false;
      if (musicAudioEl) musicAudioEl.play();
      document.getElementById('badge').className = 'canvas-badge recording';
      document.getElementById('badge').innerHTML = '<span class="dot"></span> REC';
      // Resume time limit timer
      if (timeLimit > 0 && timeLimitRemaining > 0) {
        var elapsed = getCurrentTime();
        var remaining = timeLimit - elapsed;
        if (remaining > 0) {
          timeLimitTimer = setTimeout(function() { stopRecord(); }, remaining * 1000);
        }
      }
    } else {
      pauseStart = performance.now();
      mediaRecorder.pause();
      isPaused = true;
      if (musicAudioEl) musicAudioEl.pause();
      document.getElementById('badge').className = 'canvas-badge paused';
      document.getElementById('badge').textContent = 'PAUSED';
      // Pause time limit timer
      if (timeLimitTimer) { clearTimeout(timeLimitTimer); timeLimitTimer = null; }
    }
  }

  function stopRecord() {
    if (!isRecording) return;
    recordElapsed = getCurrentTime();
    isRecording = false;
    isPaused = false;
    mediaRecorder.stop();
    if (musicAudioEl) { musicAudioEl.pause(); musicAudioEl.currentTime = 0; }

    // Clear time limit timer
    if (timeLimitTimer) { clearTimeout(timeLimitTimer); timeLimitTimer = null; }

    // Re-enable settings
    setSettingsDisabled(false);

    // Reset trim points
    trimIn = 0;
    trimOut = 0;

    // UI
    document.getElementById('btnRec').classList.remove('active');
    document.getElementById('btnPause').style.display = 'none';
    document.getElementById('btnStop').style.display = 'none';
    document.getElementById('badge').className = 'canvas-badge';
    document.getElementById('badge').style.display = 'none';
  }

  // ── Playback ──
  function setupPlayback() {
    if (playbackVideo) { playbackVideo.pause(); playbackVideo.remove(); }
    playbackVideo = document.createElement('video');
    playbackVideo.src = recordedUrl;
    playbackVideo.muted = false;
    playbackVideo.playsInline = true;
    playbackVideo.addEventListener('ended', function() {
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      // Restart compositor for live camera if still connected
      if (cameraStream) { cameraOn = true; document.getElementById('btnCamera').classList.add('active'); startCompositor(); }
    });
    // Show download button
    document.getElementById('btnDownloadRaw').style.display = '';
  }

  function togglePlayback() {
    if (!recordedUrl) return;
    if (isPlaying) {
      playbackVideo.pause();
      if (musicAudioEl) musicAudioEl.pause();
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      // Restart compositor for live camera if still connected
      if (cameraStream && cameraOn) startCompositor();
    } else {
      // Cancel the compositor loop before starting playback loop
      if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
      cameraOn = false;
      document.getElementById('btnCamera').classList.remove('active');
      // Respect trim in point
      if (trimIn > 0) playbackVideo.currentTime = trimIn;
      playbackVideo.play();
      if (musicAudioEl) { musicAudioEl.currentTime = playbackVideo.currentTime; musicAudioEl.play(); }
      isPlaying = true;
      document.getElementById('btnPlay').classList.add('active');
      drawPlayback();
    }
  }

  function drawPlayback() {
    if (!isPlaying) return;
    animFrame = requestAnimationFrame(drawPlayback);

    // Check trim out point
    var effectiveTrimOut = trimOut > 0 ? trimOut : timelineDuration;
    if (trimOut > 0 && playbackVideo.currentTime >= trimOut) {
      playbackVideo.pause();
      if (musicAudioEl) musicAudioEl.pause();
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      if (cameraStream) { cameraOn = true; document.getElementById('btnCamera').classList.add('active'); startCompositor(); }
      return;
    }

    var cw = canvas.width;
    var ch = canvas.height;
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, cw, ch);

    if (playbackVideo.readyState >= 2) {
      var vw = playbackVideo.videoWidth || cw;
      var vh = playbackVideo.videoHeight || ch;
      var scale = Math.max(cw / vw, ch / vh);
      ctx.drawImage(playbackVideo, (cw - vw * scale) / 2, (ch - vh * scale) / 2, vw * scale, vh * scale);
    }

    // Draw overlays during playback
    var now = playbackVideo.currentTime;
    for (var i = 0; i < imageOverlays.length; i++) {
      var io = imageOverlays[i];
      var opacity = getOverlayOpacity(io, now);
      if (opacity <= 0) continue;
      ctx.globalAlpha = opacity;
      var w = io.img.naturalWidth * (io.scale / 100);
      var h = io.img.naturalHeight * (io.scale / 100);
      ctx.drawImage(io.img, io.x, io.y, w, h);
      ctx.globalAlpha = 1;
    }
    for (var j = 0; j < textOverlays.length; j++) {
      var to = textOverlays[j];
      var textOpacity = getOverlayOpacity(to, now);
      if (textOpacity <= 0) continue;
      ctx.globalAlpha = textOpacity;
      ctx.font = to.size + 'px ' + to.font;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      if (to.stroke) {
        ctx.strokeStyle = to.stroke;
        ctx.lineWidth = Math.max(2, to.size / 12);
        ctx.strokeText(to.text, to.x, to.y);
      }
      ctx.fillStyle = to.color;
      ctx.fillText(to.text, to.x, to.y);
      ctx.globalAlpha = 1;
    }

    // Update playhead
    if (timelineDuration > 0) {
      var pct = (playbackVideo.currentTime / timelineDuration) * 100;
      document.getElementById('playhead').style.left = (80 + pct * (document.getElementById('trackVideo').offsetWidth) / 100) + 'px';
    }

    updateTimerDisplay(playbackVideo.currentTime);
  }

  // ── Text Overlays ──
  function addTextOverlay() {
    var text = document.getElementById('textContent').value.trim();
    if (!text) return;
    textOverlays.push({
      id: Date.now(),
      type: 'text',
      text: text,
      font: document.getElementById('textFont').value,
      size: parseInt(document.getElementById('textSize').value) || 48,
      color: document.getElementById('textColor').value,
      stroke: document.getElementById('textStroke').value,
      x: 960,
      y: 540,
      start: parseFloat(document.getElementById('textStart').value) || 0,
      duration: parseFloat(document.getElementById('textDuration').value) || 5,
      fadeIn: parseFloat(document.getElementById('textFadeIn').value) || 0.5,
      fadeOut: parseFloat(document.getElementById('textFadeOut').value) || 0.5
    });
    document.getElementById('textContent').value = '';
    renderTextList();
    updateTimeline();
  }

  function renderTextList() {
    var el = document.getElementById('textOverlaysList');
    el.innerHTML = '';
    textOverlays.forEach(function(o) {
      var div = document.createElement('div');
      div.className = 'overlay-item';
      div.innerHTML = '<span class="name">' + escHtml(o.text) + '</span>' +
        '<button class="del" onclick="R.removeTextOverlay(' + o.id + ')">&times;</button>';
      el.appendChild(div);
    });
  }

  function removeTextOverlay(id) {
    textOverlays = textOverlays.filter(function(o) { return o.id !== id; });
    renderTextList();
    updateTimeline();
  }

  // ── Image Overlays ──
  function addImageOverlay(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      imageOverlays.push({
        id: Date.now(),
        type: 'image',
        name: file.name,
        img: img,
        x: parseInt(document.getElementById('imgX').value) || 50,
        y: parseInt(document.getElementById('imgY').value) || 50,
        scale: parseInt(document.getElementById('imgScale').value) || 50,
        start: parseFloat(document.getElementById('imgStart').value) || 0,
        duration: parseFloat(document.getElementById('imgDuration').value) || 5,
        fadeIn: parseFloat(document.getElementById('imgFadeIn').value) || 0.5,
        fadeOut: parseFloat(document.getElementById('imgFadeOut').value) || 0.5
      });
      renderImageList();
      updateTimeline();
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function renderImageList() {
    var el = document.getElementById('imageOverlaysList');
    el.innerHTML = '';
    imageOverlays.forEach(function(o) {
      var div = document.createElement('div');
      div.className = 'overlay-item';
      div.innerHTML = '<span class="name">' + escHtml(o.name) + '</span>' +
        '<button class="del" onclick="R.removeImageOverlay(' + o.id + ')">&times;</button>';
      el.appendChild(div);
    });
  }

  function removeImageOverlay(id) {
    imageOverlays = imageOverlays.filter(function(o) { return o.id !== id; });
    renderImageList();
    updateTimeline();
  }

  // ── Music ──
  function addMusic(input) {
    if (!input.files || !input.files[0]) return;
    musicFile = input.files[0];
    document.getElementById('musicName').textContent = musicFile.name;
    document.getElementById('musicInfo').style.display = '';

    // Disconnect old music source to prevent leaks
    if (musicSource) { try { musicSource.disconnect(); } catch(e) {} musicSource = null; }
    if (musicAudioEl) { musicAudioEl.pause(); }

    // Create fresh audio element
    musicAudioEl = new Audio();
    musicAudioEl.src = URL.createObjectURL(musicFile);
    musicAudioEl.loop = true;

    // Connect to audio mixer if available, otherwise flag for later
    if (audioCtx && musicGain) {
      musicSource = audioCtx.createMediaElementSource(musicAudioEl);
      musicSource.connect(musicGain);
      musicPendingConnect = false;
    } else {
      musicPendingConnect = true;
    }

    updateTimeline();
    input.value = '';
  }

  function setMusicVolume(val) {
    var vol = parseInt(val) / 100;
    document.getElementById('musicVolLabel').textContent = val + '%';
    if (musicGain) musicGain.gain.value = vol;
    if (musicAudioEl) musicAudioEl.volume = vol;
  }

  function removeMusic() {
    if (musicAudioEl) { musicAudioEl.pause(); musicAudioEl = null; }
    musicFile = null;
    document.getElementById('musicInfo').style.display = 'none';
    updateTimeline();
  }

  // ── Timeline ──
  function updateTimeline() {
    var dur = timelineDuration || 30;
    document.getElementById('tlDuration').textContent = formatTime(dur);

    // Video track
    var trackVideo = document.getElementById('trackVideo');
    trackVideo.innerHTML = '';
    if (timelineDuration > 0) {
      var clipHtml = '<div class="track-clip video' + (trimActive ? ' trim-active' : '') + '" style="left:0;width:100%;">Recording';
      clipHtml += '<div class="trim-handle left" data-trim="in"></div>';
      clipHtml += '<div class="trim-handle right" data-trim="out"></div>';
      clipHtml += '</div>';
      trackVideo.innerHTML = clipHtml;
      // Show trim labels
      if (trimIn > 0 || trimOut > 0) {
        var labelHtml = '<span class="trim-time-label" style="position:absolute;bottom:-14px;left:0;font-size:9px;">In: ' + formatTime(trimIn) + '</span>';
        if (trimOut > 0) labelHtml += '<span class="trim-time-label" style="position:absolute;bottom:-14px;right:0;font-size:9px;">Out: ' + formatTime(trimOut) + '</span>';
        trackVideo.innerHTML += labelHtml;
      }
      setupTrimHandles();
    }

    // Text track
    var trackText = document.getElementById('trackText');
    trackText.innerHTML = '';
    textOverlays.forEach(function(o) {
      var left = (o.start / dur) * 100;
      var width = (o.duration / dur) * 100;
      var clip = document.createElement('div');
      clip.className = 'track-clip text';
      clip.style.left = left + '%';
      clip.style.width = Math.max(width, 1) + '%';
      clip.textContent = o.text;
      clip.innerHTML += '<div class="trim-handle left"></div><div class="trim-handle right"></div>';
      trackText.appendChild(clip);
    });

    // Image track
    var trackImage = document.getElementById('trackImage');
    trackImage.innerHTML = '';
    imageOverlays.forEach(function(o) {
      var left = (o.start / dur) * 100;
      var width = (o.duration / dur) * 100;
      var clip = document.createElement('div');
      clip.className = 'track-clip image';
      clip.style.left = left + '%';
      clip.style.width = Math.max(width, 1) + '%';
      clip.textContent = o.name;
      clip.innerHTML += '<div class="trim-handle left"></div><div class="trim-handle right"></div>';
      trackImage.appendChild(clip);
    });

    // Audio track
    var trackAudio = document.getElementById('trackAudio');
    trackAudio.innerHTML = '';
    if (musicFile) {
      trackAudio.innerHTML = '<div class="track-clip audio" style="left:0;width:100%;">' + escHtml(musicFile.name) + '</div>';
    }

    // Ruler ticks
    drawRuler(dur);
  }

  function drawRuler(dur) {
    var ruler = document.getElementById('timelineRuler');
    ruler.innerHTML = '';
    var w = ruler.offsetWidth;
    var interval = dur <= 30 ? 5 : dur <= 120 ? 10 : 30;
    for (var t = 0; t <= dur; t += interval) {
      var pct = (t / dur) * 100;
      var tick = document.createElement('div');
      tick.style.cssText = 'position:absolute;left:' + pct + '%;top:0;height:100%;border-left:1px solid rgba(255,255,255,0.1);';
      var label = document.createElement('span');
      label.style.cssText = 'position:absolute;left:3px;top:3px;font-size:9px;color:rgba(255,255,255,0.3);';
      label.textContent = formatTime(t);
      tick.appendChild(label);
      ruler.appendChild(tick);
    }
  }

  function scrub(e) {
    if (!playbackVideo || !timelineDuration) return;
    var ruler = document.getElementById('timelineRuler');
    var rect = ruler.getBoundingClientRect();
    var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    var seekTime = pct * timelineDuration;
    // Clamp to trim range
    var lo = trimIn;
    var hi = trimOut > 0 ? trimOut : timelineDuration;
    seekTime = Math.max(lo, Math.min(hi, seekTime));
    playbackVideo.currentTime = seekTime;
    if (musicAudioEl) musicAudioEl.currentTime = playbackVideo.currentTime;
  }

  // ── Sidebar Tabs ──
  function switchTab(tab) {
    document.querySelectorAll('.sidebar-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.sidebar-panel').forEach(function(p) { p.classList.remove('active'); });
    var idx = {text:1,image:2,music:3,prompter:4,settings:5}[tab];
    document.querySelector('.sidebar-tab:nth-child(' + idx + ')').classList.add('active');
    document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
  }

  // ── Export ──
  function startExport() {
    if (!recordedBlob) return;
    var modal = document.getElementById('exportModal');
    modal.classList.add('show');
    document.getElementById('exportProgress').style.width = '0%';
    document.getElementById('exportStatus').textContent = 'Loading FFmpeg core (this may take a moment)...';
    document.getElementById('exportTitle').textContent = 'Exporting MP4...';
    document.getElementById('exportCloseBtn').style.display = 'none';

    doExport();
  }

  async function doExport() {
    try {
      var FFmpeg = FFmpegWASM.FFmpeg;
      var fetchFile = FFmpegUtil.fetchFile;
      var ffmpeg = new FFmpeg();

      ffmpeg.on('progress', function(p) {
        var pct = Math.round(p.progress * 100);
        document.getElementById('exportProgress').style.width = pct + '%';
        document.getElementById('exportStatus').textContent = 'Processing... ' + pct + '%';
      });

      await ffmpeg.load({
        coreURL: 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.js',
        wasmURL: 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.wasm'
      });

      document.getElementById('exportStatus').textContent = 'Writing video data...';
      document.getElementById('exportProgress').style.width = '10%';

      await ffmpeg.writeFile('input.webm', await fetchFile(recordedBlob));

      // Build trim args
      var trimArgs = [];
      if (trimIn > 0) trimArgs.push('-ss', trimIn.toFixed(2));
      if (trimOut > 0) trimArgs.push('-to', trimOut.toFixed(2));

      if (musicFile) {
        document.getElementById('exportStatus').textContent = 'Writing audio data...';
        await ffmpeg.writeFile('music.mp3', await fetchFile(musicFile));

        // Mix music into video
        var vol = (parseInt(document.getElementById('musicVolume').value) || 50) / 100;
        var args = trimArgs.concat([
          '-i', 'input.webm',
          '-i', 'music.mp3',
          '-filter_complex', '[0:a]volume=1[mic];[1:a]volume=' + vol + '[music];[mic][music]amix=inputs=2:duration=shortest[aout]',
          '-map', '0:v',
          '-map', '[aout]',
          '-c:v', 'libx264',
          '-preset', 'fast',
          '-crf', '23',
          '-c:a', 'aac',
          '-b:a', '128k',
          '-movflags', '+faststart',
          'output.mp4'
        ]);
        await ffmpeg.exec(args);
      } else {
        var args = trimArgs.concat([
          '-i', 'input.webm',
          '-c:v', 'libx264',
          '-preset', 'fast',
          '-crf', '23',
          '-c:a', 'aac',
          '-b:a', '128k',
          '-movflags', '+faststart',
          'output.mp4'
        ]);
        await ffmpeg.exec(args);
      }

      document.getElementById('exportStatus').textContent = 'Reading output...';
      document.getElementById('exportProgress').style.width = '90%';

      var data = await ffmpeg.readFile('output.mp4');
      var mp4Blob = new Blob([data.buffer], { type: 'video/mp4' });

      document.getElementById('exportProgress').style.width = '95%';
      document.getElementById('exportStatus').textContent = 'Uploading to campaign assets...';

      // Upload
      var formData = new FormData();
      formData.append('campaign_asset[asset_type]', 'video_recording');
      formData.append('campaign_asset[file]', mp4Blob, 'recording-' + Date.now() + '.mp4');

      var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      var uploadUrl = '<%= portal_campaign_campaign_assets_path(@campaign) %>';

      var resp = await fetch(uploadUrl, {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrfToken },
        body: formData
      });

      if (resp.ok || resp.status === 302) {
        document.getElementById('exportProgress').style.width = '100%';
        document.getElementById('exportTitle').textContent = 'Export Complete!';
        document.getElementById('exportStatus').textContent = 'MP4 uploaded as a campaign asset.';
      } else {
        // Still offer the download even if upload fails
        document.getElementById('exportTitle').textContent = 'Upload failed — downloading instead';
        document.getElementById('exportStatus').textContent = 'Status: ' + resp.status;
        downloadBlob(mp4Blob);
      }

      document.getElementById('exportCloseBtn').style.display = '';

      // Cleanup
      await ffmpeg.deleteFile('input.webm');
      if (musicFile) await ffmpeg.deleteFile('music.mp3');
      await ffmpeg.deleteFile('output.mp4');
    } catch(err) {
      document.getElementById('exportTitle').textContent = 'Export Error';
      document.getElementById('exportStatus').textContent = err.message;
      document.getElementById('exportCloseBtn').style.display = '';

      // Fallback: download raw WebM
      if (recordedBlob) {
        document.getElementById('exportStatus').textContent = err.message + ' — Downloading raw recording instead.';
        downloadBlob(recordedBlob, 'recording.webm');
      }
    }
  }

  function downloadBlob(blob, name) {
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = name || 'recording-' + Date.now() + '.mp4';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  function closeExportModal() {
    document.getElementById('exportModal').classList.remove('show');
  }

  function downloadRaw() {
    if (!recordedBlob) return;
    downloadBlob(recordedBlob, 'recording.webm');
  }

  // ── Helpers ──
  function formatTime(s) {
    var m = Math.floor(s / 60);
    var sec = Math.floor(s % 60);
    return m + ':' + String(sec).padStart(2, '0');
  }

  function escHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ── Settings / Quality ──
  function changeResolution(val) {
    var parts = val.split('x');
    resolution.w = parseInt(parts[0]);
    resolution.h = parseInt(parts[1]);
    canvas.width = resolution.w;
    canvas.height = resolution.h;
    if (cameraStream && cameraOn) {
      var track = cameraStream.getVideoTracks()[0];
      if (track) track.applyConstraints({ width: { ideal: resolution.w }, height: { ideal: resolution.h } });
    }
  }

  function changeFps(val) {
    targetFps = parseInt(val);
  }

  function changeBitrate(val) {
    targetBitrate = parseInt(val);
  }

  function setSettingsDisabled(disabled) {
    ['resSel', 'fpsSel', 'qualSel', 'cameraSel', 'micSel'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.disabled = disabled;
    });
  }

  // ── Device Picker ──
  function enumerateDeviceLists() {
    navigator.mediaDevices.enumerateDevices().then(function(devices) {
      var cameraSel = document.getElementById('cameraSel');
      var micSel = document.getElementById('micSel');
      var curCam = cameraSel.value;
      var curMic = micSel.value;
      cameraSel.innerHTML = '<option value="">Default Camera</option>';
      micSel.innerHTML = '<option value="">Default Microphone</option>';
      devices.forEach(function(d) {
        if (d.kind === 'videoinput') {
          var opt = document.createElement('option');
          opt.value = d.deviceId;
          opt.textContent = d.label || ('Camera ' + (cameraSel.options.length));
          cameraSel.appendChild(opt);
        } else if (d.kind === 'audioinput') {
          var opt = document.createElement('option');
          opt.value = d.deviceId;
          opt.textContent = d.label || ('Mic ' + (micSel.options.length));
          micSel.appendChild(opt);
        }
      });
      if (curCam) cameraSel.value = curCam;
      if (curMic) micSel.value = curMic;
    });
  }

  function switchDevice() {
    if (!cameraStream) return;
    // Stop existing tracks
    cameraStream.getTracks().forEach(function(t) { t.stop(); });
    if (musicSource) { try { musicSource.disconnect(); } catch(e) {} musicSource = null; }
    if (micSource) { try { micSource.disconnect(); } catch(e) {} micSource = null; }
    // Re-launch with new device
    launchRecorder();
  }

  // ── Countdown ──
  function startCountdown() {
    countdownValue = 3;
    var badge = document.getElementById('badge');
    badge.className = 'canvas-badge recording';
    badge.style.display = 'flex';
    badge.textContent = '3';

    function tick() {
      if (countdownValue > 0) {
        badge.textContent = countdownValue;
        countdownValue--;
        setTimeout(tick, 1000);
      } else {
        badge.textContent = '';
        countdownValue = 0;
        startRecording();
      }
    }
    tick();
  }

  // ── Time Limit ──
  function setTimeLimit(val) {
    timeLimit = parseInt(val) || 0;
  }

  // ── Layout ──
  function drawLayout(ctx, video, cw, ch) {
    var vw = video.videoWidth;
    var vh = video.videoHeight;
    if (!vw || !vh) return;

    switch (layout) {
      case 'pip':
        // Draw cover or black background
        if (coverImage) {
          drawCoverFull(ctx, coverImage, cw, ch);
        }
        // Camera in small rounded rect bottom-right
        var pipW = Math.round(cw * 0.2);
        var pipH = Math.round(ch * 0.2);
        var pipX = cw - pipW - 20;
        var pipY = ch - pipH - 20;
        ctx.save();
        ctx.beginPath();
        ctx.roundRect(pipX, pipY, pipW, pipH, 12);
        ctx.clip();
        var pipScale = Math.max(pipW / vw, pipH / vh);
        ctx.drawImage(video, pipX + (pipW - vw * pipScale) / 2, pipY + (pipH - vh * pipScale) / 2, vw * pipScale, vh * pipScale);
        ctx.restore();
        // PiP border
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.roundRect(pipX, pipY, pipW, pipH, 12);
        ctx.stroke();
        break;

      case 'split':
        // Left half: camera
        var halfW = Math.round(cw / 2);
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, halfW, ch);
        ctx.clip();
        var splitScale = Math.max(halfW / vw, ch / vh);
        ctx.drawImage(video, (halfW - vw * splitScale) / 2, (ch - vh * splitScale) / 2, vw * splitScale, vh * splitScale);
        ctx.restore();
        // Right half: cover or gradient
        if (coverImage) {
          ctx.save();
          ctx.beginPath();
          ctx.rect(halfW, 0, cw - halfW, ch);
          ctx.clip();
          drawCoverFit(ctx, coverImage, halfW, 0, cw - halfW, ch);
          ctx.restore();
        } else {
          var grad = ctx.createLinearGradient(halfW, 0, cw, ch);
          grad.addColorStop(0, '#1a1a2e');
          grad.addColorStop(1, '#16213e');
          ctx.fillStyle = grad;
          ctx.fillRect(halfW, 0, cw - halfW, ch);
        }
        // Divider line
        ctx.strokeStyle = 'rgba(255,255,255,0.15)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(halfW, 0);
        ctx.lineTo(halfW, ch);
        ctx.stroke();
        break;

      case 'cover':
        // Left 60%: camera
        var camW = Math.round(cw * 0.6);
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, camW, ch);
        ctx.clip();
        var coverScale = Math.max(camW / vw, ch / vh);
        ctx.drawImage(video, (camW - vw * coverScale) / 2, (ch - vh * coverScale) / 2, vw * coverScale, vh * coverScale);
        ctx.restore();
        // Right 40%: cover image
        var rightW = cw - camW;
        if (coverImage) {
          ctx.save();
          ctx.beginPath();
          ctx.rect(camW, 0, rightW, ch);
          ctx.clip();
          drawCoverFit(ctx, coverImage, camW, 0, rightW, ch);
          ctx.restore();
        } else {
          var grad = ctx.createLinearGradient(camW, 0, cw, ch);
          grad.addColorStop(0, '#1a1a2e');
          grad.addColorStop(1, '#16213e');
          ctx.fillStyle = grad;
          ctx.fillRect(camW, 0, rightW, ch);
        }
        break;

      default: // 'full'
        var fullScale = Math.max(cw / vw, ch / vh);
        var sw = vw * fullScale;
        var sh = vh * fullScale;
        ctx.drawImage(video, (cw - sw) / 2, (ch - sh) / 2, sw, sh);
        break;
    }
  }

  function drawCoverFull(ctx, img, cw, ch) {
    var scale = Math.max(cw / img.naturalWidth, ch / img.naturalHeight);
    var w = img.naturalWidth * scale;
    var h = img.naturalHeight * scale;
    ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
  }

  function drawCoverFit(ctx, img, x, y, w, h) {
    var scale = Math.min(w / img.naturalWidth, h / img.naturalHeight);
    var iw = img.naturalWidth * scale;
    var ih = img.naturalHeight * scale;
    ctx.drawImage(img, x + (w - iw) / 2, y + (h - ih) / 2, iw, ih);
  }

  function setLayout(val) {
    layout = val;
  }

  function loadCoverImage(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      coverImage = img;
      document.getElementById('coverName').textContent = file.name;
      document.getElementById('coverInfo').style.display = '';
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function removeCoverImage() {
    coverImage = null;
    document.getElementById('coverInfo').style.display = 'none';
  }

  // ── Teleprompter ──
  function togglePrompter() {
    var el = document.getElementById('teleprompter');
    var btn = document.getElementById('btnPrompter');
    if (prompterActive) {
      prompterActive = false;
      el.style.display = 'none';
      if (prompterAnimFrame) { cancelAnimationFrame(prompterAnimFrame); prompterAnimFrame = null; }
      btn.textContent = 'Start Prompter';
      btn.classList.remove('primary');
      return;
    }
    var script = document.getElementById('prompterScript').value.trim();
    if (!script) { alert('Enter a script first.'); return; }
    var textEl = document.getElementById('prompterText');
    textEl.innerHTML = script.replace(/\n/g, '<br>');
    prompterScrollPos = 0;
    textEl.style.transform = 'translateY(0px)';
    el.style.display = '';
    prompterActive = true;
    btn.textContent = 'Stop Prompter';
    btn.classList.add('primary');
    scrollPrompter();
  }

  function scrollPrompter() {
    if (!prompterActive) return;
    prompterAnimFrame = requestAnimationFrame(scrollPrompter);
    var speed = parseInt(document.getElementById('prompterSpeed').value) || 3;
    prompterScrollPos += speed * 0.5;
    var textEl = document.getElementById('prompterText');
    textEl.style.transform = 'translateY(-' + prompterScrollPos + 'px)';
    // Stop when fully scrolled past
    var container = document.getElementById('teleprompter');
    if (prompterScrollPos > textEl.offsetHeight + container.offsetHeight) {
      prompterActive = false;
      container.style.display = 'none';
      if (prompterAnimFrame) { cancelAnimationFrame(prompterAnimFrame); prompterAnimFrame = null; }
      document.getElementById('btnPrompter').textContent = 'Start Prompter';
      document.getElementById('btnPrompter').classList.remove('primary');
    }
  }

  function setPrompterSize(val) {
    document.getElementById('prompterSizeLabel').textContent = val + 'px';
    document.getElementById('prompterText').style.fontSize = val + 'px';
  }

  function setPrompterSpeed(val) {
    document.getElementById('prompterSpeedLabel').textContent = val;
  }

  function setPrompterOpacity(val) {
    document.getElementById('prompterOpacityLabel').textContent = val + '%';
    document.getElementById('prompterText').style.color = 'rgba(255,255,255,' + (val / 100) + ')';
  }

  function togglePrompterMirror() {
    var el = document.getElementById('teleprompter');
    el.classList.toggle('mirrored', document.getElementById('prompterMirror').checked);
  }

  // ── Trim ──
  function toggleTrim() {
    trimActive = !trimActive;
    document.getElementById('btnTrim').classList.toggle('trim-on', trimActive);
    updateTimeline();
  }

  function setupTrimHandles() {
    var handles = document.querySelectorAll('#trackVideo .trim-handle');
    handles.forEach(function(handle) {
      handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var which = handle.getAttribute('data-trim');
        var tracks = document.getElementById('timelineTracks');
        var lane = document.getElementById('trackVideo');
        var laneRect = lane.getBoundingClientRect();

        function onMove(ev) {
          var pct = Math.max(0, Math.min(1, (ev.clientX - laneRect.left) / laneRect.width));
          var time = pct * timelineDuration;
          if (which === 'in') {
            trimIn = Math.max(0, Math.min(time, (trimOut > 0 ? trimOut : timelineDuration) - 0.1));
          } else {
            trimOut = Math.max(trimIn + 0.1, Math.min(time, timelineDuration));
          }
          updateTimeline();
        }

        function onUp() {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  // ── Enumerate devices on load ──
  if (navigator.mediaDevices) {
    enumerateDeviceLists();
  }

  // ── Public API ──
  return {
    launchRecorder: launchRecorder,
    toggleCamera: toggleCamera,
    toggleMic: toggleMic,
    toggleRecord: toggleRecord,
    togglePause: togglePause,
    stopRecord: stopRecord,
    togglePlayback: togglePlayback,
    addTextOverlay: addTextOverlay,
    removeTextOverlay: removeTextOverlay,
    addImageOverlay: addImageOverlay,
    removeImageOverlay: removeImageOverlay,
    addMusic: addMusic,
    setMusicVolume: setMusicVolume,
    removeMusic: removeMusic,
    switchTab: switchTab,
    startExport: startExport,
    closeExportModal: closeExportModal,
    downloadRaw: downloadRaw,
    scrub: scrub,
    changeResolution: changeResolution,
    changeFps: changeFps,
    changeBitrate: changeBitrate,
    setLayout: setLayout,
    loadCoverImage: loadCoverImage,
    removeCoverImage: removeCoverImage,
    togglePrompter: togglePrompter,
    setPrompterSize: setPrompterSize,
    setPrompterSpeed: setPrompterSpeed,
    setPrompterOpacity: setPrompterOpacity,
    togglePrompterMirror: togglePrompterMirror,
    switchDevice: switchDevice,
    setTimeLimit: setTimeLimit,
    toggleTrim: toggleTrim
  };
})();
</script>
