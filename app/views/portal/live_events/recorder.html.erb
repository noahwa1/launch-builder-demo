<script>
var R = (function() {
  'use strict';

  // ── State ──
  var canvas = document.getElementById('recorderCanvas');
  var ctx = canvas.getContext('2d');
  var cameraStream = null;
  var cameraVideo = null;
  var cameraOn = false;
  var micOn = false;

  var mediaRecorder = null;
  var recordedChunks = [];
  var isRecording = false;
  var isPaused = false;
  var recordStartTime = 0;
  var recordElapsed = 0;
  var pauseStart = 0;
  var totalPaused = 0;

  var recordedBlob = null;
  var recordedUrl = null;
  var playbackVideo = null;
  var isPlaying = false;
  var playStartTime = 0;

  var textOverlays = [];
  var imageOverlays = [];
  var musicFile = null;
  var musicBuffer = null;
  var musicAudioEl = null;

  var audioCtx = null;
  var micSource = null;
  var musicSource = null;
  var musicGain = null;
  var audioDest = null;
  var musicPendingConnect = false;

  var timelineDuration = 0;
  var animFrame = null;

  // ── Settings / Quality ──
  var resolution = { w: 1920, h: 1080, label: '1080p' };
  var targetFps = 30;
  var targetBitrate = 4000000;

  // ── Layout ──
  var layout = 'full';
  var coverImage = null;

  // ── Countdown ──
  var countdownValue = 0;

  // ── Time Limit ──
  var timeLimit = 0;
  var timeLimitTimer = null;
  var timeLimitRemaining = 0;

  // ── Queue Mode ──
  var queueMode = false;
  var queueData = [];
  var queueIndex = 0;
  var queueUploading = {};
  var campaignId = <%= @campaign.id %>;
  var queueDataUrl = '<%= queue_data_portal_campaign_personal_videos_path(@campaign, format: :json) %>';
  var queueCreateUrl = '<%= portal_campaign_personal_videos_path(@campaign) %>';
  var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

  // ── Teleprompter ──
  var prompterActive = false;
  var prompterAnimFrame = null;
  var prompterScrollPos = 0;

  // ── Trim ──
  var trimIn = 0;
  var trimOut = 0;
  var trimActive = false;

  // ── Canvas Drag ──
  var dragTarget = null;  // overlay being dragged
  var dragOffsetX = 0;
  var dragOffsetY = 0;
  var selectedOverlay = null;

  // ── Lower Thirds ──
  var lowerThirds = [];

  // ── Preview Mode ──
  var previewTime = 0; // virtual time for previewing overlays before recording

  // ── Camera ──
  function launchRecorder() {
    var videoConstraints = { width: { ideal: resolution.w }, height: { ideal: resolution.h } };
    var audioConstraints = true;
    var selCam = document.getElementById('cameraSel').value;
    var selMic = document.getElementById('micSel').value;
    if (selCam) videoConstraints.deviceId = { exact: selCam };
    if (selMic) audioConstraints = { deviceId: { exact: selMic } };

    navigator.mediaDevices.getUserMedia({
      video: videoConstraints,
      audio: audioConstraints
    }).then(function(stream) {
      cameraStream = stream;
      cameraVideo = document.createElement('video');
      cameraVideo.srcObject = stream;
      cameraVideo.muted = true;
      cameraVideo.playsInline = true;
      cameraVideo.play();
      cameraOn = true;
      micOn = true;
      document.getElementById('btnCamera').classList.add('active');
      document.getElementById('btnMic').classList.add('active');
      document.getElementById('btnLaunchRecorder').textContent = 'Recorder Active';
      document.getElementById('btnLaunchRecorder').disabled = true;
      setupAudio(stream);
      enumerateDeviceLists();
      startCompositor();
    }).catch(function(err) {
      alert('Camera/mic access denied: ' + err.message);
    });
  }

  function toggleCamera() {
    if (!cameraStream) return launchRecorder();
    var tracks = cameraStream.getVideoTracks();
    if (tracks.length === 0) return;
    cameraOn = !cameraOn;
    tracks[0].enabled = cameraOn;
    document.getElementById('btnCamera').classList.toggle('active', cameraOn);
  }

  function toggleMic() {
    if (!cameraStream) return;
    var tracks = cameraStream.getAudioTracks();
    if (tracks.length === 0) return;
    micOn = !micOn;
    tracks[0].enabled = micOn;
    document.getElementById('btnMic').classList.toggle('active', micOn);
  }

  // ── Audio Mixing ──
  function setupAudio(stream) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    audioDest = audioCtx.createMediaStreamDestination();
    micSource = audioCtx.createMediaStreamSource(stream);
    micSource.connect(audioDest);
    musicGain = audioCtx.createGain();
    musicGain.gain.value = 0.5;
    musicGain.connect(audioDest);

    // Connect pending music if it was added before camera launch
    if (musicPendingConnect && musicAudioEl) {
      musicSource = audioCtx.createMediaElementSource(musicAudioEl);
      musicSource.connect(musicGain);
      musicPendingConnect = false;
    }
  }

  // ── Compositor ──
  var compositorRunning = false;

  function startCompositor() {
    if (compositorRunning) return;
    compositorRunning = true;
    function draw() {
      animFrame = requestAnimationFrame(draw);
      var cw = canvas.width;
      var ch = canvas.height;
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, cw, ch);

      // Draw camera with layout
      if (cameraOn && cameraVideo && cameraVideo.readyState >= 2) {
        drawLayout(ctx, cameraVideo, cw, ch);
      } else if (coverImage && layout !== 'full') {
        drawCoverFull(ctx, coverImage, cw, ch);
      }

      // Draw countdown number on canvas
      if (countdownValue > 0) {
        ctx.save();
        ctx.font = 'bold 200px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 8;
        ctx.strokeText(countdownValue, cw / 2, ch / 2);
        ctx.fillStyle = '#fff';
        ctx.fillText(countdownValue, cw / 2, ch / 2);
        ctx.restore();
      }

      // Current time relative to recording
      var now = getCurrentTime();

      // Draw image overlays
      for (var i = 0; i < imageOverlays.length; i++) {
        var io = imageOverlays[i];
        var opacity = getOverlayOpacity(io, now);
        if (opacity <= 0) continue;
        ctx.globalAlpha = opacity;
        var w = io.img.naturalWidth * (io.scale / 100);
        var h = io.img.naturalHeight * (io.scale / 100);
        ctx.drawImage(io.img, io.x, io.y, w, h);
        ctx.globalAlpha = 1;
      }

      // Draw text overlays
      for (var j = 0; j < textOverlays.length; j++) {
        var to = textOverlays[j];
        var textOpacity = getOverlayOpacity(to, now);
        if (textOpacity <= 0) continue;
        ctx.globalAlpha = textOpacity;
        ctx.font = to.size + 'px ' + to.font;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        if (to.stroke) {
          ctx.strokeStyle = to.stroke;
          ctx.lineWidth = Math.max(2, to.size / 12);
          ctx.strokeText(to.text, to.x, to.y);
        }
        ctx.fillStyle = to.color;
        ctx.fillText(to.text, to.x, to.y);
        ctx.globalAlpha = 1;
      }

      // Draw lower thirds
      for (var k = 0; k < lowerThirds.length; k++) {
        var lt = lowerThirds[k];
        var ltOpacity = getOverlayOpacity(lt, now);
        if (ltOpacity <= 0) continue;
        ctx.globalAlpha = ltOpacity;
        var ltW = lt.img.naturalWidth * (lt.scale / 100);
        var ltH = lt.img.naturalHeight * (lt.scale / 100);
        ctx.drawImage(lt.img, lt.x, lt.y, ltW, ltH);
        ctx.globalAlpha = 1;
      }

      // Draw queue auto lower-third
      drawQueueLowerThird();

      // Update timer
      if (isRecording && !isPaused) {
        updateTimerDisplay(now);
      }
    }
    draw();
  }

  function getCurrentTime() {
    if (isPlaying && playbackVideo) {
      return playbackVideo.currentTime;
    }
    if (isRecording) {
      if (isPaused) return (pauseStart - recordStartTime - totalPaused) / 1000;
      return (performance.now() - recordStartTime - totalPaused) / 1000;
    }
    // Preview mode: show overlays at previewTime when not recording
    return previewTime;
  }

  function getOverlayOpacity(overlay, time) {
    if (time < overlay.start || time > overlay.start + overlay.duration) return 0;
    var elapsed = time - overlay.start;
    var remaining = overlay.start + overlay.duration - time;
    var opacity = 1;
    if (overlay.fadeIn > 0 && elapsed < overlay.fadeIn) {
      opacity = elapsed / overlay.fadeIn;
    }
    if (overlay.fadeOut > 0 && remaining < overlay.fadeOut) {
      opacity = Math.min(opacity, remaining / overlay.fadeOut);
    }
    return Math.max(0, Math.min(1, opacity));
  }

  function updateTimerDisplay(seconds) {
    var m = Math.floor(seconds / 60);
    var s = Math.floor(seconds % 60);
    var str = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    var el = document.getElementById('canvasTime');
    if (timeLimit > 0 && isRecording) {
      var remaining = timeLimit - seconds;
      var rm = Math.floor(Math.max(0, remaining) / 60);
      var rs = Math.floor(Math.max(0, remaining) % 60);
      str += ' / -' + String(rm).padStart(2, '0') + ':' + String(rs).padStart(2, '0');
      el.className = 'canvas-time time-remaining' + (remaining < 10 ? ' critical' : remaining < 30 ? ' warning' : '');
    } else {
      el.className = 'canvas-time';
    }
    el.textContent = str;
  }

  // ── Recording ──
  function toggleRecord() {
    if (isRecording) {
      togglePause();
      return;
    }
    if (!cameraStream) {
      alert('Launch the recorder first (camera + mic access required).');
      return;
    }
    startCountdown();
  }

  function startRecording() {
    recordedChunks = [];
    recordedBlob = null;
    if (recordedUrl) { URL.revokeObjectURL(recordedUrl); recordedUrl = null; }

    // Canvas stream + mixed audio
    var canvasStream = canvas.captureStream(targetFps);
    var combined = new MediaStream();
    canvasStream.getVideoTracks().forEach(function(t) { combined.addTrack(t); });
    audioDest.stream.getAudioTracks().forEach(function(t) { combined.addTrack(t); });

    // Codec detection
    var mimeType = '';
    var codecs = ['video/webm;codecs=vp9,opus', 'video/webm;codecs=vp8,opus', 'video/webm', 'video/mp4'];
    for (var i = 0; i < codecs.length; i++) {
      if (MediaRecorder.isTypeSupported(codecs[i])) { mimeType = codecs[i]; break; }
    }

    var options = { videoBitsPerSecond: targetBitrate };
    if (mimeType) options.mimeType = mimeType;

    mediaRecorder = new MediaRecorder(combined, options);
    mediaRecorder.ondataavailable = function(e) {
      if (e.data && e.data.size > 0) recordedChunks.push(e.data);
    };
    mediaRecorder.onstop = function() {
      recordedBlob = new Blob(recordedChunks, { type: mimeType || 'video/webm' });
      recordedUrl = URL.createObjectURL(recordedBlob);
      timelineDuration = recordElapsed;
      document.getElementById('btnExport').disabled = false;
      updateTimeline();
      setupPlayback();
    };

    mediaRecorder.start(1000);
    isRecording = true;
    isPaused = false;
    recordStartTime = performance.now();
    totalPaused = 0;

    // Start music playback if loaded
    if (musicAudioEl) {
      musicAudioEl.currentTime = 0;
      musicAudioEl.play();
    }

    // UI
    document.getElementById('btnRec').classList.add('active');
    document.getElementById('btnPause').style.display = '';
    document.getElementById('btnStop').style.display = '';
    document.getElementById('canvasTime').style.display = '';
    var badge = document.getElementById('badge');
    badge.className = 'canvas-badge recording';
    badge.innerHTML = '<span class="dot"></span> REC';

    // Disable settings while recording
    setSettingsDisabled(true);

    // Start time limit timer
    if (timeLimit > 0) {
      timeLimitRemaining = timeLimit;
      timeLimitTimer = setTimeout(function() { stopRecord(); }, timeLimit * 1000);
    }
  }

  function togglePause() {
    if (!isRecording) return;
    if (isPaused) {
      totalPaused += performance.now() - pauseStart;
      mediaRecorder.resume();
      isPaused = false;
      if (musicAudioEl) musicAudioEl.play();
      document.getElementById('badge').className = 'canvas-badge recording';
      document.getElementById('badge').innerHTML = '<span class="dot"></span> REC';
      // Resume time limit timer
      if (timeLimit > 0 && timeLimitRemaining > 0) {
        var elapsed = getCurrentTime();
        var remaining = timeLimit - elapsed;
        if (remaining > 0) {
          timeLimitTimer = setTimeout(function() { stopRecord(); }, remaining * 1000);
        }
      }
    } else {
      pauseStart = performance.now();
      mediaRecorder.pause();
      isPaused = true;
      if (musicAudioEl) musicAudioEl.pause();
      document.getElementById('badge').className = 'canvas-badge paused';
      document.getElementById('badge').textContent = 'PAUSED';
      // Pause time limit timer
      if (timeLimitTimer) { clearTimeout(timeLimitTimer); timeLimitTimer = null; }
    }
  }

  function stopRecord() {
    if (!isRecording) return;
    recordElapsed = getCurrentTime();
    isRecording = false;
    isPaused = false;
    mediaRecorder.stop();
    if (musicAudioEl) { musicAudioEl.pause(); musicAudioEl.currentTime = 0; }

    // Clear time limit timer
    if (timeLimitTimer) { clearTimeout(timeLimitTimer); timeLimitTimer = null; }

    // Re-enable settings
    setSettingsDisabled(false);

    // Reset trim points
    trimIn = 0;
    trimOut = 0;

    // UI
    document.getElementById('btnRec').classList.remove('active');
    document.getElementById('btnPause').style.display = 'none';
    document.getElementById('btnStop').style.display = 'none';
    document.getElementById('badge').className = 'canvas-badge';
    document.getElementById('badge').style.display = 'none';
  }

  // ── Playback ──
  function setupPlayback() {
    if (playbackVideo) { playbackVideo.pause(); playbackVideo.remove(); }
    playbackVideo = document.createElement('video');
    playbackVideo.src = recordedUrl;
    playbackVideo.muted = false;
    playbackVideo.playsInline = true;
    playbackVideo.addEventListener('ended', function() {
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      // Restart compositor for live camera if still connected
      if (cameraStream) { cameraOn = true; document.getElementById('btnCamera').classList.add('active'); startCompositor(); }
    });
    // Show download + save buttons
    document.getElementById('btnDownloadRaw').style.display = '';
    document.getElementById('btnSaveContent').style.display = '';

    // On mobile, show the review screen automatically
    if (window.innerWidth <= 768) {
      showMobileReview();
    }
  }

  function togglePlayback() {
    if (!recordedUrl) return;
    if (isPlaying) {
      playbackVideo.pause();
      if (musicAudioEl) musicAudioEl.pause();
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      // Restart compositor for live camera if still connected
      if (cameraStream && cameraOn) startCompositor();
    } else {
      // Cancel the compositor loop before starting playback loop
      if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
      cameraOn = false;
      document.getElementById('btnCamera').classList.remove('active');
      // Respect trim in point
      if (trimIn > 0) playbackVideo.currentTime = trimIn;
      playbackVideo.play();
      if (musicAudioEl) { musicAudioEl.currentTime = playbackVideo.currentTime; musicAudioEl.play(); }
      isPlaying = true;
      document.getElementById('btnPlay').classList.add('active');
      drawPlayback();
    }
  }

  function drawPlayback() {
    if (!isPlaying) return;
    animFrame = requestAnimationFrame(drawPlayback);

    // Check trim out point
    var effectiveTrimOut = trimOut > 0 ? trimOut : timelineDuration;
    if (trimOut > 0 && playbackVideo.currentTime >= trimOut) {
      playbackVideo.pause();
      if (musicAudioEl) musicAudioEl.pause();
      isPlaying = false;
      document.getElementById('btnPlay').classList.remove('active');
      if (cameraStream) { cameraOn = true; document.getElementById('btnCamera').classList.add('active'); startCompositor(); }
      return;
    }

    var cw = canvas.width;
    var ch = canvas.height;
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, cw, ch);

    if (playbackVideo.readyState >= 2) {
      var vw = playbackVideo.videoWidth || cw;
      var vh = playbackVideo.videoHeight || ch;
      var scale = Math.max(cw / vw, ch / vh);
      ctx.drawImage(playbackVideo, (cw - vw * scale) / 2, (ch - vh * scale) / 2, vw * scale, vh * scale);
    }

    // Draw overlays during playback
    var now = playbackVideo.currentTime;
    for (var i = 0; i < imageOverlays.length; i++) {
      var io = imageOverlays[i];
      var opacity = getOverlayOpacity(io, now);
      if (opacity <= 0) continue;
      ctx.globalAlpha = opacity;
      var w = io.img.naturalWidth * (io.scale / 100);
      var h = io.img.naturalHeight * (io.scale / 100);
      ctx.drawImage(io.img, io.x, io.y, w, h);
      ctx.globalAlpha = 1;
    }
    for (var j = 0; j < textOverlays.length; j++) {
      var to = textOverlays[j];
      var textOpacity = getOverlayOpacity(to, now);
      if (textOpacity <= 0) continue;
      ctx.globalAlpha = textOpacity;
      ctx.font = to.size + 'px ' + to.font;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      if (to.stroke) {
        ctx.strokeStyle = to.stroke;
        ctx.lineWidth = Math.max(2, to.size / 12);
        ctx.strokeText(to.text, to.x, to.y);
      }
      ctx.fillStyle = to.color;
      ctx.fillText(to.text, to.x, to.y);
      ctx.globalAlpha = 1;
    }

    // Draw lower thirds during playback
    for (var k = 0; k < lowerThirds.length; k++) {
      var lt = lowerThirds[k];
      var ltOpacity = getOverlayOpacity(lt, now);
      if (ltOpacity <= 0) continue;
      ctx.globalAlpha = ltOpacity;
      var ltW = lt.img.naturalWidth * (lt.scale / 100);
      var ltH = lt.img.naturalHeight * (lt.scale / 100);
      ctx.drawImage(lt.img, lt.x, lt.y, ltW, ltH);
      ctx.globalAlpha = 1;
    }

    // Update playhead
    if (timelineDuration > 0) {
      var pct = (playbackVideo.currentTime / timelineDuration) * 100;
      document.getElementById('playhead').style.left = (80 + pct * (document.getElementById('trackVideo').offsetWidth) / 100) + 'px';
    }

    updateTimerDisplay(playbackVideo.currentTime);
  }

  // ── Text Overlays ──
  function addTextOverlay() {
    var text = document.getElementById('textContent').value.trim();
    if (!text) return;
    var pos = getTextPosition();
    var overlay = {
      id: Date.now(),
      type: 'text',
      text: text,
      font: document.getElementById('textFont').value,
      size: parseInt(document.getElementById('textSize').value) || 48,
      color: document.getElementById('textColor').value,
      stroke: document.getElementById('textStroke').value,
      x: pos.x,
      y: pos.y,
      start: parseFloat(document.getElementById('textStart').value) || 0,
      duration: parseFloat(document.getElementById('textDuration').value) || 5,
      fadeIn: parseFloat(document.getElementById('textFadeIn').value) || 0.5,
      fadeOut: parseFloat(document.getElementById('textFadeOut').value) || 0.5
    };
    textOverlays.push(overlay);
    document.getElementById('textContent').value = '';
    // Set preview time so the new overlay is visible (offset past fade-in)
    previewTime = overlay.start + Math.min(overlay.fadeIn, overlay.duration * 0.5) + 0.01;
    renderTextList();
    updateTimeline();
  }

  function renderTextList() {
    var el = document.getElementById('textOverlaysList');
    el.innerHTML = '';
    textOverlays.forEach(function(o, i) {
      var div = document.createElement('div');
      div.className = 'overlay-item';
      div.style.cursor = 'pointer';
      div.innerHTML = '<span class="name" style="flex:1;">' + escHtml(o.text) + '</span>' +
        '<span style="font-size:10px;color:var(--text-muted);margin-right:4px;">' + o.start.toFixed(1) + 's / ' + o.duration.toFixed(1) + 's</span>' +
        '<button class="del" onclick="event.stopPropagation();R.removeTextOverlay(' + o.id + ')">&times;</button>';
      div.addEventListener('click', function() {
        previewTime = o.start + 0.01;
      });
      el.appendChild(div);
    });
  }

  function removeTextOverlay(id) {
    textOverlays = textOverlays.filter(function(o) { return o.id !== id; });
    renderTextList();
    updateTimeline();
  }

  // ── Image Overlays ──
  function addImageOverlay(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      var overlay = {
        id: Date.now(),
        type: 'image',
        name: file.name,
        img: img,
        x: parseInt(document.getElementById('imgX').value) || 50,
        y: parseInt(document.getElementById('imgY').value) || 50,
        scale: parseInt(document.getElementById('imgScale').value) || 50,
        start: parseFloat(document.getElementById('imgStart').value) || 0,
        duration: parseFloat(document.getElementById('imgDuration').value) || 5,
        fadeIn: parseFloat(document.getElementById('imgFadeIn').value) || 0.5,
        fadeOut: parseFloat(document.getElementById('imgFadeOut').value) || 0.5
      };
      imageOverlays.push(overlay);
      previewTime = overlay.start + Math.min(overlay.fadeIn, overlay.duration * 0.5) + 0.01;
      renderImageList();
      updateTimeline();
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function renderImageList() {
    var el = document.getElementById('imageOverlaysList');
    el.innerHTML = '';
    imageOverlays.forEach(function(o, i) {
      var div = document.createElement('div');
      div.className = 'overlay-item';
      div.style.cursor = 'pointer';
      div.innerHTML = '<span class="name" style="flex:1;">' + escHtml(o.name) + '</span>' +
        '<span style="font-size:10px;color:var(--text-muted);margin-right:4px;">' + o.start.toFixed(1) + 's / ' + o.duration.toFixed(1) + 's</span>' +
        '<button class="del" onclick="event.stopPropagation();R.removeImageOverlay(' + o.id + ')">&times;</button>';
      div.addEventListener('click', function() {
        previewTime = o.start + 0.01;
      });
      el.appendChild(div);
    });
  }

  function removeImageOverlay(id) {
    imageOverlays = imageOverlays.filter(function(o) { return o.id !== id; });
    renderImageList();
    updateTimeline();
  }

  // ── Music ──
  function addMusic(input) {
    if (!input.files || !input.files[0]) return;
    musicFile = input.files[0];
    document.getElementById('musicName').textContent = musicFile.name;
    document.getElementById('musicInfo').style.display = '';

    // Disconnect old music source to prevent leaks
    if (musicSource) { try { musicSource.disconnect(); } catch(e) {} musicSource = null; }
    if (musicAudioEl) { musicAudioEl.pause(); }

    // Create fresh audio element
    musicAudioEl = new Audio();
    musicAudioEl.src = URL.createObjectURL(musicFile);
    musicAudioEl.loop = true;

    // Connect to audio mixer if available, otherwise flag for later
    if (audioCtx && musicGain) {
      musicSource = audioCtx.createMediaElementSource(musicAudioEl);
      musicSource.connect(musicGain);
      musicPendingConnect = false;
    } else {
      musicPendingConnect = true;
    }

    updateTimeline();
    input.value = '';
  }

  function setMusicVolume(val) {
    var vol = parseInt(val) / 100;
    document.getElementById('musicVolLabel').textContent = val + '%';
    if (musicGain) musicGain.gain.value = vol;
    if (musicAudioEl) musicAudioEl.volume = vol;
  }

  function removeMusic() {
    if (musicAudioEl) { musicAudioEl.pause(); musicAudioEl = null; }
    musicFile = null;
    document.getElementById('musicInfo').style.display = 'none';
    updateTimeline();
  }

  // ── Timeline ──
  function updateTimeline() {
    var dur = timelineDuration || 30;
    document.getElementById('tlDuration').textContent = formatTime(dur);

    // Video track
    var trackVideo = document.getElementById('trackVideo');
    trackVideo.innerHTML = '';
    if (timelineDuration > 0) {
      var clipHtml = '<div class="track-clip video' + (trimActive ? ' trim-active' : '') + '" style="left:0;width:100%;">Recording';
      clipHtml += '<div class="trim-handle left" data-trim="in"></div>';
      clipHtml += '<div class="trim-handle right" data-trim="out"></div>';
      clipHtml += '</div>';
      trackVideo.innerHTML = clipHtml;
      // Show trim labels
      if (trimIn > 0 || trimOut > 0) {
        var labelHtml = '<span class="trim-time-label" style="position:absolute;bottom:-14px;left:0;font-size:9px;">In: ' + formatTime(trimIn) + '</span>';
        if (trimOut > 0) labelHtml += '<span class="trim-time-label" style="position:absolute;bottom:-14px;right:0;font-size:9px;">Out: ' + formatTime(trimOut) + '</span>';
        trackVideo.innerHTML += labelHtml;
      }
      setupTrimHandles();
    }

    // Text track
    var trackText = document.getElementById('trackText');
    trackText.innerHTML = '';
    textOverlays.forEach(function(o) {
      var left = (o.start / dur) * 100;
      var width = (o.duration / dur) * 100;
      var clip = document.createElement('div');
      clip.className = 'track-clip text';
      clip.style.left = left + '%';
      clip.style.width = Math.max(width, 1) + '%';
      clip.textContent = o.text;
      clip.innerHTML += '<div class="trim-handle left"></div><div class="trim-handle right"></div>';
      trackText.appendChild(clip);
    });

    // Image track
    var trackImage = document.getElementById('trackImage');
    trackImage.innerHTML = '';
    imageOverlays.forEach(function(o) {
      var left = (o.start / dur) * 100;
      var width = (o.duration / dur) * 100;
      var clip = document.createElement('div');
      clip.className = 'track-clip image';
      clip.style.left = left + '%';
      clip.style.width = Math.max(width, 1) + '%';
      clip.textContent = o.name;
      clip.innerHTML += '<div class="trim-handle left"></div><div class="trim-handle right"></div>';
      trackImage.appendChild(clip);
    });

    // Audio track
    var trackAudio = document.getElementById('trackAudio');
    trackAudio.innerHTML = '';
    if (musicFile) {
      trackAudio.innerHTML = '<div class="track-clip audio" style="left:0;width:100%;">' + escHtml(musicFile.name) + '</div>';
    }

    // Lower third track (share image track lane)
    for (var li = 0; li < lowerThirds.length; li++) {
      var lt = lowerThirds[li];
      var ltLeft = (lt.start / dur) * 100;
      var ltWidth = (lt.duration / dur) * 100;
      var ltClip = document.createElement('div');
      ltClip.className = 'track-clip image';
      ltClip.style.left = ltLeft + '%';
      ltClip.style.width = Math.max(ltWidth, 1) + '%';
      ltClip.style.background = 'rgba(168,85,247,0.5)';
      ltClip.style.borderColor = 'rgba(168,85,247,0.7)';
      ltClip.textContent = lt.name;
      trackImage.appendChild(ltClip);
    }

    // Ruler ticks
    drawRuler(dur);

    // Setup timeline clip dragging
    setupTimelineClipDrag();
  }

  function drawRuler(dur) {
    var ruler = document.getElementById('timelineRuler');
    ruler.innerHTML = '';
    var w = ruler.offsetWidth;
    var interval = dur <= 30 ? 5 : dur <= 120 ? 10 : 30;
    for (var t = 0; t <= dur; t += interval) {
      var pct = (t / dur) * 100;
      var tick = document.createElement('div');
      tick.style.cssText = 'position:absolute;left:' + pct + '%;top:0;height:100%;border-left:1px solid rgba(255,255,255,0.1);';
      var label = document.createElement('span');
      label.style.cssText = 'position:absolute;left:3px;top:3px;font-size:9px;color:rgba(255,255,255,0.3);';
      label.textContent = formatTime(t);
      tick.appendChild(label);
      ruler.appendChild(tick);
    }
  }

  function scrub(e) {
    if (!playbackVideo || !timelineDuration) return;
    var ruler = document.getElementById('timelineRuler');
    var rect = ruler.getBoundingClientRect();
    var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    var seekTime = pct * timelineDuration;
    // Clamp to trim range
    var lo = trimIn;
    var hi = trimOut > 0 ? trimOut : timelineDuration;
    seekTime = Math.max(lo, Math.min(hi, seekTime));
    playbackVideo.currentTime = seekTime;
    if (musicAudioEl) musicAudioEl.currentTime = playbackVideo.currentTime;
  }

  // ── Sidebar Tabs ──
  function switchTab(tab) {
    document.querySelectorAll('.sidebar-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.sidebar-panel').forEach(function(p) { p.classList.remove('active'); });
    var idx = {text:1,image:2,music:3,prompter:4,settings:5}[tab];
    document.querySelector('.sidebar-tab:nth-child(' + idx + ')').classList.add('active');
    document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
  }

  // ── Export ──
  function startExport() {
    if (!recordedBlob) return;
    var modal = document.getElementById('exportModal');
    modal.classList.add('show');
    document.getElementById('exportProgress').style.width = '0%';
    document.getElementById('exportStatus').textContent = 'Loading FFmpeg core (this may take a moment)...';
    document.getElementById('exportTitle').textContent = 'Exporting MP4...';
    document.getElementById('exportCloseBtn').style.display = 'none';

    doExport();
  }

  async function doExport() {
    try {
      var FFmpeg = FFmpegWASM.FFmpeg;
      var fetchFile = FFmpegUtil.fetchFile;
      var ffmpeg = new FFmpeg();

      ffmpeg.on('progress', function(p) {
        var pct = Math.round(p.progress * 100);
        document.getElementById('exportProgress').style.width = pct + '%';
        document.getElementById('exportStatus').textContent = 'Processing... ' + pct + '%';
      });

      await ffmpeg.load({
        coreURL: 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.js',
        wasmURL: 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.wasm'
      });

      document.getElementById('exportStatus').textContent = 'Writing video data...';
      document.getElementById('exportProgress').style.width = '10%';

      await ffmpeg.writeFile('input.webm', await fetchFile(recordedBlob));

      // Build trim args
      var trimArgs = [];
      if (trimIn > 0) trimArgs.push('-ss', trimIn.toFixed(2));
      if (trimOut > 0) trimArgs.push('-to', trimOut.toFixed(2));

      if (musicFile) {
        document.getElementById('exportStatus').textContent = 'Writing audio data...';
        await ffmpeg.writeFile('music.mp3', await fetchFile(musicFile));

        // Mix music into video
        var vol = (parseInt(document.getElementById('musicVolume').value) || 50) / 100;
        var args = trimArgs.concat([
          '-i', 'input.webm',
          '-i', 'music.mp3',
          '-filter_complex', '[0:a]volume=1[mic];[1:a]volume=' + vol + '[music];[mic][music]amix=inputs=2:duration=shortest[aout]',
          '-map', '0:v',
          '-map', '[aout]',
          '-c:v', 'libx264',
          '-preset', 'fast',
          '-crf', '23',
          '-c:a', 'aac',
          '-b:a', '128k',
          '-movflags', '+faststart',
          'output.mp4'
        ]);
        await ffmpeg.exec(args);
      } else {
        var args = trimArgs.concat([
          '-i', 'input.webm',
          '-c:v', 'libx264',
          '-preset', 'fast',
          '-crf', '23',
          '-c:a', 'aac',
          '-b:a', '128k',
          '-movflags', '+faststart',
          'output.mp4'
        ]);
        await ffmpeg.exec(args);
      }

      document.getElementById('exportStatus').textContent = 'Reading output...';
      document.getElementById('exportProgress').style.width = '90%';

      var data = await ffmpeg.readFile('output.mp4');
      var mp4Blob = new Blob([data.buffer], { type: 'video/mp4' });

      document.getElementById('exportProgress').style.width = '95%';
      document.getElementById('exportStatus').textContent = 'Uploading to campaign assets...';

      // Upload
      var formData = new FormData();
      formData.append('campaign_asset[asset_type]', 'video_recording');
      formData.append('campaign_asset[file]', mp4Blob, 'recording-' + Date.now() + '.mp4');

      var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      var uploadUrl = '<%= portal_campaign_campaign_assets_path(@campaign) %>';

      var resp = await fetch(uploadUrl, {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrfToken },
        body: formData
      });

      if (resp.ok || resp.status === 302) {
        document.getElementById('exportProgress').style.width = '100%';
        document.getElementById('exportTitle').textContent = 'Export Complete!';
        document.getElementById('exportStatus').textContent = 'MP4 uploaded as a campaign asset.';
      } else {
        // Still offer the download even if upload fails
        document.getElementById('exportTitle').textContent = 'Upload failed — downloading instead';
        document.getElementById('exportStatus').textContent = 'Status: ' + resp.status;
        downloadBlob(mp4Blob);
      }

      document.getElementById('exportCloseBtn').style.display = '';

      // Cleanup
      await ffmpeg.deleteFile('input.webm');
      if (musicFile) await ffmpeg.deleteFile('music.mp3');
      await ffmpeg.deleteFile('output.mp4');
    } catch(err) {
      document.getElementById('exportTitle').textContent = 'Export Error';
      document.getElementById('exportStatus').textContent = err.message;
      document.getElementById('exportCloseBtn').style.display = '';

      // Fallback: download raw WebM
      if (recordedBlob) {
        document.getElementById('exportStatus').textContent = err.message + ' — Downloading raw recording instead.';
        downloadBlob(recordedBlob, 'recording.webm');
      }
    }
  }

  function downloadBlob(blob, name) {
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = name || 'recording-' + Date.now() + '.mp4';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  function closeExportModal() {
    document.getElementById('exportModal').classList.remove('show');
  }

  function downloadRaw() {
    if (!recordedBlob) return;
    downloadBlob(recordedBlob, 'recording.webm');
  }

  // ── Helpers ──
  function formatTime(s) {
    if (!isFinite(s) || isNaN(s)) s = 0;
    var m = Math.floor(s / 60);
    var sec = Math.floor(s % 60);
    return m + ':' + String(sec).padStart(2, '0');
  }

  function escHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ── Settings / Quality ──
  function changeResolution(val) {
    var parts = val.split('x');
    resolution.w = parseInt(parts[0]);
    resolution.h = parseInt(parts[1]);
    canvas.width = resolution.w;
    canvas.height = resolution.h;
    if (cameraStream && cameraOn) {
      var track = cameraStream.getVideoTracks()[0];
      if (track) track.applyConstraints({ width: { ideal: resolution.w }, height: { ideal: resolution.h } });
    }
  }

  function changeFps(val) {
    targetFps = parseInt(val);
  }

  function changeBitrate(val) {
    targetBitrate = parseInt(val);
  }

  function setSettingsDisabled(disabled) {
    ['resSel', 'fpsSel', 'qualSel', 'cameraSel', 'micSel'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.disabled = disabled;
    });
  }

  // ── Device Picker ──
  function enumerateDeviceLists() {
    navigator.mediaDevices.enumerateDevices().then(function(devices) {
      var cameraSel = document.getElementById('cameraSel');
      var micSel = document.getElementById('micSel');
      var curCam = cameraSel.value;
      var curMic = micSel.value;
      cameraSel.innerHTML = '<option value="">Default Camera</option>';
      micSel.innerHTML = '<option value="">Default Microphone</option>';
      devices.forEach(function(d) {
        if (d.kind === 'videoinput') {
          var opt = document.createElement('option');
          opt.value = d.deviceId;
          opt.textContent = d.label || ('Camera ' + (cameraSel.options.length));
          cameraSel.appendChild(opt);
        } else if (d.kind === 'audioinput') {
          var opt = document.createElement('option');
          opt.value = d.deviceId;
          opt.textContent = d.label || ('Mic ' + (micSel.options.length));
          micSel.appendChild(opt);
        }
      });
      if (curCam) cameraSel.value = curCam;
      if (curMic) micSel.value = curMic;
    });
  }

  function switchDevice() {
    if (!cameraStream) return;
    // Stop existing tracks
    cameraStream.getTracks().forEach(function(t) { t.stop(); });
    if (musicSource) { try { musicSource.disconnect(); } catch(e) {} musicSource = null; }
    if (micSource) { try { micSource.disconnect(); } catch(e) {} micSource = null; }
    // Re-launch with new device
    launchRecorder();
  }

  // ── Countdown ──
  function startCountdown() {
    countdownValue = 3;
    var badge = document.getElementById('badge');
    badge.className = 'canvas-badge recording';
    badge.style.display = 'flex';
    badge.textContent = '3';

    function tick() {
      if (countdownValue > 0) {
        badge.textContent = countdownValue;
        countdownValue--;
        setTimeout(tick, 1000);
      } else {
        badge.textContent = '';
        countdownValue = 0;
        startRecording();
      }
    }
    tick();
  }

  // ── Time Limit ──
  function setTimeLimit(val) {
    timeLimit = parseInt(val) || 0;
  }

  // ── Layout ──
  function drawLayout(ctx, video, cw, ch) {
    var vw = video.videoWidth;
    var vh = video.videoHeight;
    if (!vw || !vh) return;

    switch (layout) {
      case 'pip':
        // Draw cover or black background
        if (coverImage) {
          drawCoverFull(ctx, coverImage, cw, ch);
        }
        // Camera in small rounded rect bottom-right
        var pipW = Math.round(cw * 0.2);
        var pipH = Math.round(ch * 0.2);
        var pipX = cw - pipW - 20;
        var pipY = ch - pipH - 20;
        ctx.save();
        ctx.beginPath();
        ctx.roundRect(pipX, pipY, pipW, pipH, 12);
        ctx.clip();
        var pipScale = Math.max(pipW / vw, pipH / vh);
        ctx.drawImage(video, pipX + (pipW - vw * pipScale) / 2, pipY + (pipH - vh * pipScale) / 2, vw * pipScale, vh * pipScale);
        ctx.restore();
        // PiP border
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.roundRect(pipX, pipY, pipW, pipH, 12);
        ctx.stroke();
        break;

      case 'split':
        // Left half: camera
        var halfW = Math.round(cw / 2);
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, halfW, ch);
        ctx.clip();
        var splitScale = Math.max(halfW / vw, ch / vh);
        ctx.drawImage(video, (halfW - vw * splitScale) / 2, (ch - vh * splitScale) / 2, vw * splitScale, vh * splitScale);
        ctx.restore();
        // Right half: cover or gradient
        if (coverImage) {
          ctx.save();
          ctx.beginPath();
          ctx.rect(halfW, 0, cw - halfW, ch);
          ctx.clip();
          drawCoverFit(ctx, coverImage, halfW, 0, cw - halfW, ch);
          ctx.restore();
        } else {
          var grad = ctx.createLinearGradient(halfW, 0, cw, ch);
          grad.addColorStop(0, '#1a1a2e');
          grad.addColorStop(1, '#16213e');
          ctx.fillStyle = grad;
          ctx.fillRect(halfW, 0, cw - halfW, ch);
        }
        // Divider line
        ctx.strokeStyle = 'rgba(255,255,255,0.15)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(halfW, 0);
        ctx.lineTo(halfW, ch);
        ctx.stroke();
        break;

      case 'cover':
        // Left 60%: camera
        var camW = Math.round(cw * 0.6);
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, camW, ch);
        ctx.clip();
        var coverScale = Math.max(camW / vw, ch / vh);
        ctx.drawImage(video, (camW - vw * coverScale) / 2, (ch - vh * coverScale) / 2, vw * coverScale, vh * coverScale);
        ctx.restore();
        // Right 40%: cover image
        var rightW = cw - camW;
        if (coverImage) {
          ctx.save();
          ctx.beginPath();
          ctx.rect(camW, 0, rightW, ch);
          ctx.clip();
          drawCoverFit(ctx, coverImage, camW, 0, rightW, ch);
          ctx.restore();
        } else {
          var grad = ctx.createLinearGradient(camW, 0, cw, ch);
          grad.addColorStop(0, '#1a1a2e');
          grad.addColorStop(1, '#16213e');
          ctx.fillStyle = grad;
          ctx.fillRect(camW, 0, rightW, ch);
        }
        break;

      default: // 'full'
        var fullScale = Math.max(cw / vw, ch / vh);
        var sw = vw * fullScale;
        var sh = vh * fullScale;
        ctx.drawImage(video, (cw - sw) / 2, (ch - sh) / 2, sw, sh);
        break;
    }
  }

  function drawCoverFull(ctx, img, cw, ch) {
    var scale = Math.max(cw / img.naturalWidth, ch / img.naturalHeight);
    var w = img.naturalWidth * scale;
    var h = img.naturalHeight * scale;
    ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
  }

  function drawCoverFit(ctx, img, x, y, w, h) {
    var scale = Math.min(w / img.naturalWidth, h / img.naturalHeight);
    var iw = img.naturalWidth * scale;
    var ih = img.naturalHeight * scale;
    ctx.drawImage(img, x + (w - iw) / 2, y + (h - ih) / 2, iw, ih);
  }

  function setLayout(val) {
    layout = val;
  }

  function loadCoverImage(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      coverImage = img;
      document.getElementById('coverName').textContent = file.name;
      document.getElementById('coverInfo').style.display = '';
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function removeCoverImage() {
    coverImage = null;
    document.getElementById('coverInfo').style.display = 'none';
  }

  // ── Teleprompter ──
  function togglePrompter() {
    var el = document.getElementById('teleprompter');
    var btn = document.getElementById('btnPrompter');
    if (prompterActive) {
      prompterActive = false;
      el.style.display = 'none';
      if (prompterAnimFrame) { cancelAnimationFrame(prompterAnimFrame); prompterAnimFrame = null; }
      btn.textContent = 'Start Prompter';
      btn.classList.remove('primary');
      return;
    }
    var script = document.getElementById('prompterScript').value.trim();
    if (!script) { alert('Enter a script first.'); return; }
    var textEl = document.getElementById('prompterText');
    textEl.innerHTML = script.replace(/\n/g, '<br>');
    prompterScrollPos = 0;
    textEl.style.transform = 'translateY(0px)';
    el.style.display = '';
    prompterActive = true;
    btn.textContent = 'Stop Prompter';
    btn.classList.add('primary');
    scrollPrompter();
  }

  function scrollPrompter() {
    if (!prompterActive) return;
    prompterAnimFrame = requestAnimationFrame(scrollPrompter);
    var speed = parseInt(document.getElementById('prompterSpeed').value) || 3;
    prompterScrollPos += speed * 0.5;
    var textEl = document.getElementById('prompterText');
    textEl.style.transform = 'translateY(-' + prompterScrollPos + 'px)';
    // Stop when fully scrolled past
    var container = document.getElementById('teleprompter');
    if (prompterScrollPos > textEl.offsetHeight + container.offsetHeight) {
      prompterActive = false;
      container.style.display = 'none';
      if (prompterAnimFrame) { cancelAnimationFrame(prompterAnimFrame); prompterAnimFrame = null; }
      document.getElementById('btnPrompter').textContent = 'Start Prompter';
      document.getElementById('btnPrompter').classList.remove('primary');
    }
  }

  function setPrompterSize(val) {
    document.getElementById('prompterSizeLabel').textContent = val + 'px';
    document.getElementById('prompterText').style.fontSize = val + 'px';
  }

  function setPrompterSpeed(val) {
    document.getElementById('prompterSpeedLabel').textContent = val;
  }

  function setPrompterOpacity(val) {
    document.getElementById('prompterOpacityLabel').textContent = val + '%';
    document.getElementById('prompterText').style.color = 'rgba(255,255,255,' + (val / 100) + ')';
  }

  function togglePrompterMirror() {
    var el = document.getElementById('teleprompter');
    el.classList.toggle('mirrored', document.getElementById('prompterMirror').checked);
  }

  // ── Trim ──
  function toggleTrim() {
    trimActive = !trimActive;
    document.getElementById('btnTrim').classList.toggle('trim-on', trimActive);
    updateTimeline();
  }

  function setupTrimHandles() {
    var handles = document.querySelectorAll('#trackVideo .trim-handle');
    handles.forEach(function(handle) {
      handle.addEventListener('mousedown', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var which = handle.getAttribute('data-trim');
        var tracks = document.getElementById('timelineTracks');
        var lane = document.getElementById('trackVideo');
        var laneRect = lane.getBoundingClientRect();

        function onMove(ev) {
          var pct = Math.max(0, Math.min(1, (ev.clientX - laneRect.left) / laneRect.width));
          var time = pct * timelineDuration;
          if (which === 'in') {
            trimIn = Math.max(0, Math.min(time, (trimOut > 0 ? trimOut : timelineDuration) - 0.1));
          } else {
            trimOut = Math.max(trimIn + 0.1, Math.min(time, timelineDuration));
          }
          updateTimeline();
        }

        function onUp() {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  // ── Text Position Presets ──
  function getTextPosition() {
    var preset = document.getElementById('textPosition').value;
    var cw = canvas.width;
    var ch = canvas.height;
    switch (preset) {
      case 'top':         return { x: cw / 2, y: ch * 0.1 };
      case 'bottom':      return { x: cw / 2, y: ch * 0.9 };
      case 'lower-third': return { x: cw / 2, y: ch * 0.82 };
      case 'top-left':    return { x: cw * 0.15, y: ch * 0.1 };
      case 'top-right':   return { x: cw * 0.85, y: ch * 0.1 };
      case 'custom':
        return {
          x: parseInt(document.getElementById('textPosX').value) || cw / 2,
          y: parseInt(document.getElementById('textPosY').value) || ch / 2
        };
      default: return { x: cw / 2, y: ch / 2 };
    }
  }

  function setTextPositionPreset(val) {
    document.getElementById('textCustomPos').style.display = val === 'custom' ? '' : 'none';
  }

  // ── Canvas Drag-to-Reposition ──
  (function initCanvasDrag() {
    var wrap = document.querySelector('.canvas-wrap');

    wrap.addEventListener('mousedown', function(e) {
      if (isRecording || isPlaying) return;
      var canvasRect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / canvasRect.width;
      var scaleY = canvas.height / canvasRect.height;
      var mx = (e.clientX - canvasRect.left) * scaleX;
      var my = (e.clientY - canvasRect.top) * scaleY;

      // Check text overlays (reverse order = top first)
      for (var i = textOverlays.length - 1; i >= 0; i--) {
        var to = textOverlays[i];
        var tw = to.size * to.text.length * 0.5;
        var th = to.size;
        if (mx >= to.x - tw / 2 && mx <= to.x + tw / 2 &&
            my >= to.y - th / 2 && my <= to.y + th / 2) {
          dragTarget = to;
          dragOffsetX = mx - to.x;
          dragOffsetY = my - to.y;
          selectedOverlay = to;
          wrap.classList.add('dragging');
          e.preventDefault();
          return;
        }
      }

      // Check image overlays
      for (var j = imageOverlays.length - 1; j >= 0; j--) {
        var io = imageOverlays[j];
        var iw = io.img.naturalWidth * (io.scale / 100);
        var ih = io.img.naturalHeight * (io.scale / 100);
        if (mx >= io.x && mx <= io.x + iw && my >= io.y && my <= io.y + ih) {
          dragTarget = io;
          dragOffsetX = mx - io.x;
          dragOffsetY = my - io.y;
          selectedOverlay = io;
          wrap.classList.add('dragging');
          e.preventDefault();
          return;
        }
      }

      // Check lower thirds
      for (var k = lowerThirds.length - 1; k >= 0; k--) {
        var lt = lowerThirds[k];
        var ltw = lt.img.naturalWidth * (lt.scale / 100);
        var lth = lt.img.naturalHeight * (lt.scale / 100);
        if (mx >= lt.x && mx <= lt.x + ltw && my >= lt.y && my <= lt.y + lth) {
          dragTarget = lt;
          dragOffsetX = mx - lt.x;
          dragOffsetY = my - lt.y;
          selectedOverlay = lt;
          wrap.classList.add('dragging');
          e.preventDefault();
          return;
        }
      }

      selectedOverlay = null;
    });

    document.addEventListener('mousemove', function(e) {
      if (!dragTarget) return;
      var canvasRect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / canvasRect.width;
      var scaleY = canvas.height / canvasRect.height;
      var mx = (e.clientX - canvasRect.left) * scaleX;
      var my = (e.clientY - canvasRect.top) * scaleY;

      if (dragTarget.type === 'text') {
        dragTarget.x = mx - dragOffsetX;
        dragTarget.y = my - dragOffsetY;
      } else {
        dragTarget.x = mx - dragOffsetX;
        dragTarget.y = my - dragOffsetY;
      }
    });

    document.addEventListener('mouseup', function() {
      if (dragTarget) {
        dragTarget = null;
        document.querySelector('.canvas-wrap').classList.remove('dragging');
      }
    });
  })();

  // ── Lower Thirds ──
  function addLowerThird(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      var scale = parseInt(document.getElementById('ltScale').value) || 100;
      var ltW = img.naturalWidth * (scale / 100);
      var ltH = img.naturalHeight * (scale / 100);
      var lt = {
        id: Date.now(),
        type: 'lower-third',
        name: file.name,
        img: img,
        x: (canvas.width - ltW) / 2,
        y: canvas.height - ltH - 40,
        scale: scale,
        start: parseFloat(document.getElementById('ltStart').value) || 0,
        duration: parseFloat(document.getElementById('ltDuration').value) || 10,
        fadeIn: 0.5,
        fadeOut: 0.5
      };
      lowerThirds.push(lt);
      previewTime = lt.start + 0.01;
      renderLowerThirdsList();
      updateTimeline();
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function renderLowerThirdsList() {
    var el = document.getElementById('lowerThirdsList');
    el.innerHTML = '';
    lowerThirds.forEach(function(lt) {
      var div = document.createElement('div');
      div.className = 'lower-third-preview';
      div.innerHTML = '<img src="' + lt.img.src + '">' +
        '<span class="name">' + escHtml(lt.name) + '</span>' +
        '<button class="del" onclick="R.removeLowerThird(' + lt.id + ')">&times;</button>';
      el.appendChild(div);
    });
  }

  function removeLowerThird(id) {
    lowerThirds = lowerThirds.filter(function(lt) { return lt.id !== id; });
    renderLowerThirdsList();
    updateTimeline();
  }

  // ── Timeline Clip Dragging ──
  function setupTimelineClipDrag() {
    var tracks = document.getElementById('timelineTracks');
    var clips = tracks.querySelectorAll('.track-clip.text, .track-clip.image');
    clips.forEach(function(clip) {
      var lane = clip.parentElement;
      var isText = clip.classList.contains('text');
      // Lower thirds use .image class but are in the image track after image overlays
      var isLowerThird = !isText && clip.style.background && clip.style.background.indexOf('168,85,247') !== -1;

      var overlayArr, overlayIdx;
      if (isLowerThird) {
        overlayArr = lowerThirds;
        // Count lower-third clips before this one
        var ltClips = lane.querySelectorAll('.track-clip');
        var ltIdx = 0;
        for (var s = 0; s < ltClips.length; s++) {
          if (ltClips[s] === clip) { ltIdx = s - imageOverlays.length; break; }
        }
        overlayIdx = Math.max(0, ltIdx);
      } else if (isText) {
        overlayArr = textOverlays;
        var siblings = lane.querySelectorAll('.track-clip.text');
        overlayIdx = 0;
        for (var s = 0; s < siblings.length; s++) {
          if (siblings[s] === clip) { overlayIdx = s; break; }
        }
      } else {
        overlayArr = imageOverlays;
        var siblings = lane.querySelectorAll('.track-clip.image');
        overlayIdx = 0;
        for (var s = 0; s < siblings.length; s++) {
          if (siblings[s] === clip) { overlayIdx = s; break; }
        }
      }
      if (!overlayArr[overlayIdx]) return;

      // Trim handles on overlay clips — resize start/duration
      clip.querySelectorAll('.trim-handle').forEach(function(handle) {
        handle.addEventListener('mousedown', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var side = handle.classList.contains('left') ? 'left' : 'right';
          var laneRect = lane.getBoundingClientRect();
          var dur = timelineDuration || 30;
          var origStart = overlayArr[overlayIdx].start;
          var origDuration = overlayArr[overlayIdx].duration;

          function onTrimMove(ev) {
            var pct = Math.max(0, Math.min(1, (ev.clientX - laneRect.left) / laneRect.width));
            var time = pct * dur;
            if (side === 'left') {
              var maxStart = origStart + origDuration - 0.5;
              var newStart = Math.max(0, Math.min(time, maxStart));
              var delta = newStart - origStart;
              overlayArr[overlayIdx].start = newStart;
              overlayArr[overlayIdx].duration = origDuration - delta;
            } else {
              var newEnd = Math.max(overlayArr[overlayIdx].start + 0.5, time);
              overlayArr[overlayIdx].duration = newEnd - overlayArr[overlayIdx].start;
            }
            previewTime = overlayArr[overlayIdx].start + 0.01;
            // Visually update clip
            clip.style.left = (overlayArr[overlayIdx].start / dur * 100) + '%';
            clip.style.width = Math.max(overlayArr[overlayIdx].duration / dur * 100, 1) + '%';
          }

          function onTrimUp() {
            document.removeEventListener('mousemove', onTrimMove);
            document.removeEventListener('mouseup', onTrimUp);
            updateTimeline();
          }

          document.addEventListener('mousemove', onTrimMove);
          document.addEventListener('mouseup', onTrimUp);
        });
      });

      // Drag clip to move start time
      clip.addEventListener('mousedown', function(e) {
        if (e.target.classList.contains('trim-handle')) return;
        e.preventDefault();
        var laneRect = lane.getBoundingClientRect();
        var dur = timelineDuration || 30;
        var startPct = parseFloat(clip.style.left) / 100;
        var startX = e.clientX;

        // Highlight selected clip
        tracks.querySelectorAll('.track-clip').forEach(function(c) { c.classList.remove('selected'); });
        clip.classList.add('selected');
        clip.style.outline = '1px solid var(--accent)';

        function onDrag(ev) {
          var dx = ev.clientX - startX;
          var dPct = dx / laneRect.width;
          var newPct = Math.max(0, Math.min(1, startPct + dPct));
          clip.style.left = (newPct * 100) + '%';
          overlayArr[overlayIdx].start = newPct * dur;
          previewTime = overlayArr[overlayIdx].start + 0.01;
        }

        function onUp() {
          document.removeEventListener('mousemove', onDrag);
          document.removeEventListener('mouseup', onUp);
          clip.style.outline = '';
          previewTime = overlayArr[overlayIdx].start + 0.01;
          updateTimeline();
        }

        document.addEventListener('mousemove', onDrag);
        document.addEventListener('mouseup', onUp);
      });
    });
  }

  // ── Queue Mode Functions ──

  function switchToQueue() {
    queueMode = true;
    document.getElementById('pillStudio').classList.remove('active');
    document.getElementById('pillQueue').classList.add('active');

    // Hide studio sidebar tabs/panels, show queue sidebar
    document.querySelector('.sidebar-tabs').style.display = 'none';
    var panels = document.querySelectorAll('.sidebar-panel');
    for (var i = 0; i < panels.length; i++) panels[i].style.display = 'none';
    document.getElementById('queueSidebar').classList.add('active');

    // Hide timeline
    document.querySelector('.timeline').style.display = 'none';

    // Hide studio-only controls
    document.getElementById('btnPause').style.display = 'none';
    document.getElementById('btnPlay').style.display = 'none';
    document.getElementById('btnTrim').style.display = 'none';
    document.getElementById('btnExport').style.display = 'none';
    document.getElementById('btnDownloadRaw').style.display = 'none';

    // Enable skip
    document.getElementById('queueSkipBtn').disabled = false;

    loadQueueData();
  }

  function switchToStudio() {
    queueMode = false;
    document.getElementById('pillQueue')?.classList.remove('active');
    document.getElementById('pillStudio').classList.add('active');

    // Restore studio sidebar
    document.querySelector('.sidebar-tabs').style.display = '';
    document.getElementById('queueSidebar').classList.remove('active');
    // Clear inline display:none that switchToQueue set on panels
    var panels = document.querySelectorAll('.sidebar-panel');
    for (var i = 0; i < panels.length; i++) panels[i].style.display = '';
    // Re-show active panel
    var activeTab = document.querySelector('.sidebar-tab.active');
    if (activeTab) activeTab.click();

    // Restore timeline
    document.querySelector('.timeline').style.display = '';

    // Restore studio controls
    document.getElementById('btnPlay').style.display = '';
    document.getElementById('btnTrim').style.display = '';
    document.getElementById('btnExport').style.display = '';
  }

  function loadQueueData() {
    fetch(queueDataUrl, { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        queueData = data.queue || [];
        renderQueueSidebar();
        // Load first pending buyer
        var firstPending = findNextPendingIndex(0);
        if (firstPending >= 0) loadBuyer(firstPending);
      });
  }

  function findNextPendingIndex(fromIndex) {
    for (var i = fromIndex; i < queueData.length; i++) {
      if (queueData[i].status === 'pending') return i;
    }
    return -1;
  }

  function loadBuyer(index) {
    if (index < 0 || index >= queueData.length) {
      document.getElementById('queueCurrent').style.display = 'none';
      return;
    }
    queueIndex = index;
    var buyer = queueData[index];
    var el = document.getElementById('queueCurrent');
    el.style.display = '';
    // Rebuild inner HTML in case review step replaced it
    el.innerHTML = '<div class="buyer-name" id="queueBuyerName"></div>' +
      '<div class="buyer-location" id="queueBuyerLocation"></div>';
    document.getElementById('queueBuyerName').textContent = buyer.name || 'Unknown';
    var loc = [buyer.city, buyer.state].filter(Boolean).join(', ');
    document.getElementById('queueBuyerLocation').textContent = loc || '';
    renderQueueSidebar();
  }

  function queueRecord() {
    if (!cameraStream) {
      alert('Launch the recorder first (camera + mic access required).');
      return;
    }
    // Instant start — no countdown in Queue mode
    startRecording();
  }

  function queueStop() {
    if (!isRecording) return;
    recordElapsed = getCurrentTime();
    isRecording = false;
    isPaused = false;
    mediaRecorder.stop();

    // Clear time limit timer
    if (timeLimitTimer) { clearTimeout(timeLimitTimer); timeLimitTimer = null; }
    setSettingsDisabled(false);

    // UI reset
    document.getElementById('btnRec').classList.remove('active');
    document.getElementById('btnStop').style.display = 'none';
    document.getElementById('badge').className = 'canvas-badge';
    document.getElementById('badge').style.display = 'none';

    // Wait for blob, then show review controls
    var waitForBlob = setInterval(function() {
      if (recordedBlob) {
        clearInterval(waitForBlob);
        showQueueReview();
      }
    }, 100);
  }

  function showQueueReview() {
    var buyer = queueData[queueIndex];
    // Set up playback so they can review
    setupPlayback();

    // Show review overlay in the queue current area
    var el = document.getElementById('queueCurrent');
    el.innerHTML = '<div class="buyer-name">' + escHtml(buyer.name || 'Unknown') + '</div>' +
      '<div class="buyer-location" style="margin-bottom:10px;">' + escHtml([buyer.city, buyer.state].filter(Boolean).join(', ') || '') + '</div>' +
      '<div style="font-size:12px;color:var(--success);font-weight:600;margin-bottom:10px;">Recording complete — ' + formatTime(recordElapsed) + '</div>' +
      '<div style="display:flex;gap:8px;">' +
        '<button class="q-btn" onclick="R.queuePlayReview()" style="flex:1;" id="queuePlayBtn">Play</button>' +
      '</div>' +
      '<div style="display:flex;gap:8px;margin-top:8px;">' +
        '<button class="q-btn" onclick="R.queueRedo()" style="flex:1;border-color:var(--danger);color:var(--danger);">Redo</button>' +
        '<button class="q-btn" onclick="R.queueSend()" style="flex:1;background:var(--success);border-color:var(--success);color:#fff;">Send</button>' +
      '</div>';

    // Disable skip while reviewing
    document.getElementById('queueSkipBtn').disabled = true;
  }

  function queuePlayReview() {
    if (!recordedUrl) return;
    if (isPlaying) {
      playbackVideo.pause();
      isPlaying = false;
      document.getElementById('queuePlayBtn').textContent = 'Play';
      if (cameraStream && cameraOn) startCompositor();
    } else {
      if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; compositorRunning = false; }
      playbackVideo.currentTime = 0;
      playbackVideo.play();
      isPlaying = true;
      document.getElementById('queuePlayBtn').textContent = 'Pause';
      // When playback ends, re-enable camera preview
      playbackVideo.onended = function() {
        isPlaying = false;
        document.getElementById('queuePlayBtn').textContent = 'Play';
        if (cameraStream) { cameraOn = true; startCompositor(); }
      };
      startCompositor();
    }
  }

  function queueRedo() {
    // Stop any playback
    if (isPlaying && playbackVideo) { playbackVideo.pause(); isPlaying = false; }
    // Clear the recorded blob
    recordedBlob = null;
    if (recordedUrl) { URL.revokeObjectURL(recordedUrl); recordedUrl = null; }
    recordedChunks = [];
    // Restore the buyer display
    var buyer = queueData[queueIndex];
    var el = document.getElementById('queueCurrent');
    el.innerHTML = '<div class="buyer-name" id="queueBuyerName">' + escHtml(buyer.name || 'Unknown') + '</div>' +
      '<div class="buyer-location" id="queueBuyerLocation">' + escHtml([buyer.city, buyer.state].filter(Boolean).join(', ') || '') + '</div>';
    // Re-enable skip
    document.getElementById('queueSkipBtn').disabled = false;
    // Restart camera preview
    if (cameraStream) { cameraOn = true; startCompositor(); }
  }

  function queueSend() {
    // Stop any playback
    if (isPlaying && playbackVideo) { playbackVideo.pause(); isPlaying = false; }
    var buyer = queueData[queueIndex];
    // Mark as sent immediately so advanceQueue skips this buyer
    queueData[queueIndex].status = 'sent';
    uploadPersonalVideo(recordedBlob, buyer.id, queueIndex);
    advanceQueue();
    // Re-enable skip
    document.getElementById('queueSkipBtn').disabled = false;
    // Restart camera preview
    if (cameraStream) { cameraOn = true; startCompositor(); }
  }

  function uploadPersonalVideo(blob, submissionId, buyerIndex) {
    queueUploading[buyerIndex] = true;
    renderQueueSidebar();

    var formData = new FormData();
    formData.append('file', blob, 'personal_video_' + submissionId + '.webm');
    formData.append('page_submission_id', submissionId);

    fetch(queueCreateUrl, {
      method: 'POST',
      headers: { 'X-CSRF-Token': csrfToken },
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      delete queueUploading[buyerIndex];
      if (data.success) {
        queueData[buyerIndex].status = 'recorded';
        queueData[buyerIndex].personal_video_id = data.personal_video_id;
      }
      renderQueueSidebar();
    })
    .catch(function() {
      delete queueUploading[buyerIndex];
      queueData[buyerIndex].status = 'failed';
      renderQueueSidebar();
    });
  }

  function advanceQueue() {
    // Look for next pending after current, then wrap around from start
    var next = findNextPendingIndex(queueIndex + 1);
    if (next < 0) next = findNextPendingIndex(0);
    if (next >= 0) {
      loadBuyer(next);
    } else {
      document.getElementById('queueCurrent').style.display = 'none';
      document.getElementById('queueBuyerName').textContent = 'All done!';
    }
    // Reset recording state for next take
    recordedBlob = null;
    if (recordedUrl) { URL.revokeObjectURL(recordedUrl); recordedUrl = null; }
    recordedChunks = [];
  }

  function skipBuyer() {
    if (isRecording) return;
    advanceQueue();
  }

  function retakeBuyer(index) {
    // Mark as pending again so it shows up
    queueData[index].status = 'pending';
    loadBuyer(index);
    renderQueueSidebar();
  }

  function renderQueueSidebar() {
    var total = queueData.length;
    var done = 0;
    var pending = [];
    var completed = [];

    for (var i = 0; i < queueData.length; i++) {
      if (queueData[i].status === 'recorded' || queueData[i].status === 'sent') {
        done++;
        completed.push(i);
      } else if (queueData[i].status === 'pending' && i !== queueIndex) {
        pending.push(i);
      }
    }

    // Progress
    var pct = total > 0 ? Math.round(done / total * 100) : 0;
    document.getElementById('queueProgressBar').style.width = pct + '%';
    document.getElementById('queueProgressText').textContent = done + '/' + total;

    // Up next
    var upNextEl = document.getElementById('queueUpNext');
    var upNextHtml = '';
    var shown = 0;
    for (var j = 0; j < pending.length && shown < 5; j++) {
      var idx = pending[j];
      var b = queueData[idx];
      upNextHtml += '<li><span class="dot"></span>' + escHtml(b.name || 'Unknown') + '</li>';
      shown++;
    }
    if (pending.length > 5) {
      upNextHtml += '<li style="color:var(--text-muted);font-size:11px;padding-left:30px;">... ' + (pending.length - 5) + ' more</li>';
    }
    if (pending.length === 0) {
      upNextHtml = '<li style="color:var(--text-muted);font-style:italic;">No more buyers</li>';
    }
    upNextEl.innerHTML = upNextHtml;

    // Done
    document.getElementById('queueDoneCount').textContent = done;
    var doneEl = document.getElementById('queueDoneList');
    var doneHtml = '';
    for (var k = completed.length - 1; k >= 0 && k >= completed.length - 10; k--) {
      var di = completed[k];
      var db = queueData[di];
      var uploading = queueUploading[di];
      doneHtml += '<li>';
      if (uploading) {
        doneHtml += '<span class="queue-uploading"></span>';
      } else {
        doneHtml += '<span class="check">&#10003;</span>';
      }
      doneHtml += escHtml(db.name || 'Unknown');
      if (!uploading) {
        doneHtml += '<button class="redo-btn" onclick="R.retakeBuyer(' + di + ')">redo</button>';
      }
      doneHtml += '</li>';
    }
    doneEl.innerHTML = doneHtml;
  }

  function escHtml(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  // Override toggleRecord and stopRecord in queue mode
  var originalToggleRecord = toggleRecord;
  var originalStopRecord = stopRecord;

  toggleRecord = function() {
    if (queueMode && !isRecording) {
      queueRecord();
    } else if (queueMode && isRecording) {
      // In queue mode, clicking record while recording does nothing (use stop)
      return;
    } else {
      originalToggleRecord();
    }
  };

  stopRecord = function() {
    if (queueMode) {
      queueStop();
    } else {
      originalStopRecord();
    }
  };

  // ── Queue Lower Third Customization ──
  var queueLtDesign = null; // custom design Image object
  var queueLtDesignLoaded = false;

  function getQueueLtSettings() {
    return {
      text: (document.getElementById('queueLtText')?.value || 'For {name}'),
      fontSize: parseInt(document.getElementById('queueLtFontSize')?.value) || 36,
      color: document.getElementById('queueLtColor')?.value || '#ffffff',
      stroke: document.getElementById('queueLtStroke')?.value || '#000000',
      font: document.getElementById('queueLtFont')?.value || '-apple-system, sans-serif',
      position: document.getElementById('queueLtPosition')?.value || 'bottom',
      barOpacity: (parseInt(document.getElementById('queueLtBarOpacity')?.value) || 65) / 100
    };
  }

  function drawQueueLowerThird() {
    if (!queueMode || queueIndex < 0 || queueIndex >= queueData.length) return;
    var buyer = queueData[queueIndex];
    if (!buyer || !buyer.name) return;

    var s = getQueueLtSettings();
    var displayText = s.text.replace(/\{name\}/gi, buyer.name);
    var cw = canvas.width;
    var ch = canvas.height;

    // Calculate bar position
    var barH = Math.max(80, s.fontSize * 2.2);
    var barY;
    if (s.position === 'top') barY = 40;
    else if (s.position === 'center') barY = (ch - barH) / 2;
    else barY = ch - barH - 40; // bottom

    if (queueLtDesign && queueLtDesignLoaded) {
      // Draw custom design image scaled to full width
      var imgAspect = queueLtDesign.naturalWidth / queueLtDesign.naturalHeight;
      var drawW = cw;
      var drawH = drawW / imgAspect;
      var drawY;
      if (s.position === 'top') drawY = 0;
      else if (s.position === 'center') drawY = (ch - drawH) / 2;
      else drawY = ch - drawH;

      ctx.drawImage(queueLtDesign, 0, drawY, drawW, drawH);

      // Draw text on top of the design
      ctx.font = 'bold ' + s.fontSize + 'px ' + s.font;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      var textY = drawY + drawH / 2;
      // Stroke for readability
      if (s.stroke) {
        ctx.strokeStyle = s.stroke;
        ctx.lineWidth = Math.max(2, s.fontSize / 10);
        ctx.strokeText(displayText, cw / 2, textY);
      }
      ctx.fillStyle = s.color;
      ctx.fillText(displayText, cw / 2, textY);
    } else {
      // Default: semi-transparent bar with text
      ctx.fillStyle = 'rgba(0, 0, 0, ' + s.barOpacity + ')';
      ctx.fillRect(0, barY, cw, barH);

      ctx.font = 'bold ' + s.fontSize + 'px ' + s.font;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      if (s.stroke && s.stroke !== s.color) {
        ctx.strokeStyle = s.stroke;
        ctx.lineWidth = Math.max(2, s.fontSize / 12);
        ctx.strokeText(displayText, cw / 2, barY + barH / 2);
      }
      ctx.fillStyle = s.color;
      ctx.fillText(displayText, cw / 2, barY + barH / 2);
    }
  }

  function loadQueueLtDesign(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var img = new Image();
    img.onload = function() {
      queueLtDesign = img;
      queueLtDesignLoaded = true;
      document.getElementById('queueLtDesignName').textContent = file.name;
      document.getElementById('queueLtDesignInfo').style.display = '';
      updateQueueLtPreview();
    };
    img.src = URL.createObjectURL(file);
    input.value = '';
  }

  function removeQueueLtDesign() {
    queueLtDesign = null;
    queueLtDesignLoaded = false;
    document.getElementById('queueLtDesignInfo').style.display = 'none';
    updateQueueLtPreview();
  }

  function updateQueueLtPreview() {
    var previewEl = document.getElementById('queueLtPreview');
    if (!previewEl) return;
    var s = getQueueLtSettings();
    var sampleName = (queueData.length > 0 && queueData[queueIndex]) ? queueData[queueIndex].name : 'Jane Smith';
    var displayText = s.text.replace(/\{name\}/gi, sampleName || 'Jane Smith');
    var previewFontSize = Math.min(s.fontSize, 18);

    if (queueLtDesign && queueLtDesignLoaded) {
      previewEl.innerHTML = '<div style="position:relative;width:100%;min-height:40px;">' +
        '<img src="' + queueLtDesign.src + '" style="width:100%;display:block;border-radius:4px;">' +
        '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">' +
        '<span style="font:bold ' + previewFontSize + 'px ' + s.font + ';color:' + s.color + ';' +
        'text-shadow: -1px -1px 0 ' + s.stroke + ', 1px -1px 0 ' + s.stroke + ', -1px 1px 0 ' + s.stroke + ', 1px 1px 0 ' + s.stroke + ';">' +
        escHtml(displayText) + '</span></div></div>';
    } else {
      previewEl.innerHTML = '<div style="background:rgba(0,0,0,' + s.barOpacity + ');padding:8px 16px;border-radius:4px;width:100%;">' +
        '<span style="font:bold ' + previewFontSize + 'px ' + s.font + ';color:' + s.color + ';' +
        'text-shadow: -1px -1px 0 ' + s.stroke + ', 1px -1px 0 ' + s.stroke + ', -1px 1px 0 ' + s.stroke + ', 1px 1px 0 ' + s.stroke + ';">' +
        escHtml(displayText) + '</span></div>';
    }
  }

  // ── Enumerate devices on load ──
  if (navigator.mediaDevices) {
    enumerateDeviceLists();
  }

  // ── Save to Content ──
  function saveToContent() {
    if (!recordedBlob) return;
    var saveBtn = document.getElementById('btnSaveContent');
    var mrSaveBtn = document.getElementById('mrSaveBtn');
    var mrSaving = document.getElementById('mrSaving');
    var mrSaved = document.getElementById('mrSaved');

    // Disable buttons and show saving state
    if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = 'Saving...'; }
    if (mrSaveBtn) { mrSaveBtn.disabled = true; mrSaveBtn.innerHTML = '<span class="queue-uploading"></span> Saving...'; }
    if (mrSaving) mrSaving.style.display = '';

    var formData = new FormData();
    formData.append('campaign_asset[asset_type]', 'video_recording');
    formData.append('campaign_asset[file]', recordedBlob, 'recording-' + Date.now() + '.webm');

    var token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    var uploadUrl = '<%= portal_campaign_campaign_assets_path(@campaign) %>';

    fetch(uploadUrl, {
      method: 'POST',
      headers: { 'X-CSRF-Token': token },
      body: formData
    })
    .then(function(resp) {
      if (resp.ok || resp.status === 302) {
        if (saveBtn) { saveBtn.textContent = 'Saved!'; saveBtn.classList.add('saved'); }
        if (mrSaving) mrSaving.style.display = 'none';
        if (mrSaved) mrSaved.style.display = '';
        if (mrSaveBtn) { mrSaveBtn.disabled = true; mrSaveBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Saved!'; }
      } else {
        if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save Failed — Retry'; }
        if (mrSaving) mrSaving.style.display = 'none';
        if (mrSaveBtn) { mrSaveBtn.disabled = false; mrSaveBtn.innerHTML = 'Save Failed — Tap to Retry'; }
      }
    })
    .catch(function() {
      if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save Failed — Retry'; }
      if (mrSaving) mrSaving.style.display = 'none';
      if (mrSaveBtn) { mrSaveBtn.disabled = false; mrSaveBtn.innerHTML = 'Save Failed — Tap to Retry'; }
    });
  }

  // ── Mobile Review Screen ──
  function showMobileReview() {
    var review = document.getElementById('mobileReview');
    var video = document.getElementById('mobileReviewVideo');
    if (!recordedUrl || !review) return;

    video.src = recordedUrl;
    video.play();
    // Use recordElapsed (tracked during recording) since WebM blobs often lack duration metadata
    document.getElementById('mrDuration').textContent = formatTime(recordElapsed || 0);

    // Reset save state
    document.getElementById('mrSaving').style.display = 'none';
    document.getElementById('mrSaved').style.display = 'none';
    var mrSaveBtn = document.getElementById('mrSaveBtn');
    mrSaveBtn.disabled = false;
    mrSaveBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save to Content';

    review.classList.add('open');
  }

  function closeMobileReview() {
    var review = document.getElementById('mobileReview');
    var video = document.getElementById('mobileReviewVideo');
    if (video) { video.pause(); video.src = ''; }
    review.classList.remove('open');
  }

  function mobileRedo() {
    closeMobileReview();
    // Clear recorded data
    recordedBlob = null;
    if (recordedUrl) { URL.revokeObjectURL(recordedUrl); recordedUrl = null; }
    recordedChunks = [];
    document.getElementById('btnExport').disabled = true;
    document.getElementById('btnDownloadRaw').style.display = 'none';
    document.getElementById('btnSaveContent').style.display = 'none';
    // Restart camera
    if (cameraStream) { cameraOn = true; startCompositor(); }
  }

  // ── Aspect Ratio Toggle ──
  var currentAspect = 'landscape';

  function setAspect(mode, btn) {
    if (mode === currentAspect) return;
    currentAspect = mode;

    var wrap = document.getElementById('canvasWrap');
    var label = document.getElementById('recAspectLabel');
    var safeZone = document.getElementById('canvasSafeZone');
    document.querySelectorAll('.aspect-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');

    if (mode === 'portrait') {
      canvas.width = 1080;
      canvas.height = 1920;
      wrap.classList.add('portrait');
      label.textContent = 'Portrait 9:16 (TikTok, Reels, Shorts)';
      // Position safe zone guide
      safeZone.style.top = '8%';
      safeZone.style.left = '8%';
      safeZone.style.right = '8%';
      safeZone.style.bottom = '20%';
    } else {
      canvas.width = 1920;
      canvas.height = 1080;
      wrap.classList.remove('portrait');
      label.textContent = 'Landscape (16:9)';
    }
    // Ensure compositor is running to render the change
    startCompositor();
  }

  // ── Auto-start compositor so overlays preview immediately ──
  startCompositor();

  // ── Public API ──
  return {
    launchRecorder: launchRecorder,
    toggleCamera: toggleCamera,
    toggleMic: toggleMic,
    toggleRecord: toggleRecord,
    togglePause: togglePause,
    stopRecord: stopRecord,
    togglePlayback: togglePlayback,
    addTextOverlay: addTextOverlay,
    removeTextOverlay: removeTextOverlay,
    addImageOverlay: addImageOverlay,
    removeImageOverlay: removeImageOverlay,
    addMusic: addMusic,
    setMusicVolume: setMusicVolume,
    removeMusic: removeMusic,
    switchTab: switchTab,
    startExport: startExport,
    closeExportModal: closeExportModal,
    downloadRaw: downloadRaw,
    scrub: scrub,
    changeResolution: changeResolution,
    changeFps: changeFps,
    changeBitrate: changeBitrate,
    setLayout: setLayout,
    loadCoverImage: loadCoverImage,
    removeCoverImage: removeCoverImage,
    togglePrompter: togglePrompter,
    setPrompterSize: setPrompterSize,
    setPrompterSpeed: setPrompterSpeed,
    setPrompterOpacity: setPrompterOpacity,
    togglePrompterMirror: togglePrompterMirror,
    switchDevice: switchDevice,
    setTimeLimit: setTimeLimit,
    toggleTrim: toggleTrim,
    setTextPositionPreset: setTextPositionPreset,
    addLowerThird: addLowerThird,
    removeLowerThird: removeLowerThird,
    switchToQueue: switchToQueue,
    switchToStudio: switchToStudio,
    skipBuyer: skipBuyer,
    retakeBuyer: retakeBuyer,
    queuePlayReview: queuePlayReview,
    queueRedo: queueRedo,
    queueSend: queueSend,
    loadQueueLtDesign: loadQueueLtDesign,
    removeQueueLtDesign: removeQueueLtDesign,
    updateQueueLtPreview: updateQueueLtPreview,
    setAspect: setAspect,
    saveToContent: saveToContent,
    showMobileReview: showMobileReview,
    closeMobileReview: closeMobileReview,
    mobileRedo: mobileRedo
  };
})();
</script>
</body>
</html>
