<%= form_with model: live_event, url: url, method: method do |f| %>
  <% if live_event.errors.any? %>
    <div style="padding:12px 16px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:8px;margin-bottom:16px;">
      <% live_event.errors.full_messages.each do |msg| %>
        <div style="font-size:13px;color:#DC2626;"><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, 'Event Title', class: 'detail-label' %>
    <%= f.text_field :title, placeholder: 'Live Book Signing', style: 'width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;margin-top:4px;background:var(--bg-secondary);color:var(--text-primary);' %>
  </div>

  <div class="form-group">
    <%= f.label :description, 'Description', class: 'detail-label' %>
    <%= f.text_area :description, rows: 3, placeholder: 'What will happen during the event?', style: 'width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;margin-top:4px;resize:vertical;background:var(--bg-secondary);color:var(--text-primary);' %>
  </div>

  <div class="form-group">
    <%= f.label :stream_platform, 'Platform', class: 'detail-label' %>
    <%= f.select :stream_platform, options_for_select([['YouTube', 'youtube'], ['Twitch', 'twitch'], ['Restream', 'restream'], ['StreamYard', 'streamyard'], ['Custom', 'custom']], live_event.stream_platform), { include_blank: 'Select platform...' }, style: 'width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;margin-top:4px;background:var(--bg-secondary);color:var(--text-primary);' %>
  </div>

  <div class="form-group">
    <%= f.label :embed_url, 'Embed URL', class: 'detail-label' %>
    <%= f.url_field :embed_url, placeholder: 'https://youtube.com/live/...', style: 'width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;margin-top:4px;background:var(--bg-secondary);color:var(--text-primary);' %>
    <div class="text-muted" style="font-size:12px;margin-top:4px;">Paste the embed or live URL from YouTube, Twitch, Restream, or StreamYard</div>
  </div>

  <div class="form-group">
    <%= f.label :scheduled_at, 'Scheduled Date & Time', class: 'detail-label' %>
    <%= f.datetime_local_field :scheduled_at, style: 'width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;margin-top:4px;background:var(--bg-secondary);color:var(--text-primary);' %>
  </div>

  <div style="margin-top:20px;">
    <%= f.submit 'Save Event', class: 'btn btn-primary', style: 'padding:12px 28px;font-size:14px;' %>
    <%= link_to 'Cancel', portal_campaign_path(@campaign), class: 'btn btn-secondary', style: 'padding:12px 28px;font-size:14px;margin-left:8px;' %>
  </div>
<% end %>
