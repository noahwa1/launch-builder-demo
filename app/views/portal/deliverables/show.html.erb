<% content_for :page_title, @deliverable.title %>
<% content_for :page_actions do %>
  <%= link_to '← All Deliverables', portal_campaign_deliverables_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<style>
  .del-detail { display: grid; grid-template-columns: 1fr 320px; gap: 16px; }
  @media (max-width: 900px) { .del-detail { grid-template-columns: 1fr; } }
  .note-thread { margin-top: 4px; }
  .note-item {
    display: flex; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--border);
  }
  .note-avatar {
    width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center;
    justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0;
  }
  .note-avatar.admin { background: var(--accent); color: #fff; }
  .note-avatar.creator { background: #F59E0B; color: #fff; }
  .note-body { flex: 1; }
  .note-body .header { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .note-body .header strong { color: var(--text-primary); }
  .note-body .text { font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
</style>

<div class="del-detail">
  <!-- Main Column -->
  <div>
    <div class="card">
      <div class="d-flex items-start justify-between mb-16">
        <div>
          <span class="fw-600 text-muted text-upper rounded-sm" style="padding:2px 8px;font-size:10px;background:rgba(0,0,0,0.04);"><%= @deliverable.category_label %></span>
          <% if @deliverable.revision_count > 0 %>
            <span class="fw-600 rounded-sm" style="padding:2px 8px;font-size:10px;background:rgba(99,102,241,0.08);color:#6366F1;margin-left:4px;">v<%= @deliverable.revision_count + 1 %></span>
          <% end %>
        </div>
        <span class="text-xs fw-700 text-upper rounded" style="padding:4px 12px;color:<%= @deliverable.status_color %>;background:rgba(0,0,0,0.04);">
          <%= @deliverable.status.titleize %>
        </span>
      </div>

      <h2 class="text-2xl fw-700 mb-8"><%= @deliverable.title %></h2>

      <% if @deliverable.description.present? %>
        <div class="text-base text-secondary mb-16" style="line-height:1.7;white-space:pre-wrap;"><%= @deliverable.description %></div>
      <% end %>

      <% if @deliverable.file.present? %>
        <div class="p-16 bg-page border mb-16" style="border-radius:var(--radius-sm);">
          <div class="d-flex items-center gap-10">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="color:var(--accent);flex-shrink:0;"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            <div class="flex-1 text-md fw-600"><%= File.basename(@deliverable.file.url) rescue 'Attached file' %></div>
            <a href="<%= @deliverable.file.url %>" target="_blank" class="btn btn-secondary btn-sm">Download</a>
          </div>
          <% ext = File.extname(@deliverable.file.url).downcase rescue '' %>
          <% if %w[.jpg .jpeg .png .gif .webp].include?(ext) %>
            <img src="<%= @deliverable.file.url %>" class="rounded-md mt-12" style="max-width:100%;">
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Notes Thread -->
    <div class="card note-thread">
      <h3 class="subheading">Notes & Conversation</h3>
      <% if @notes.any? %>
        <% @notes.each do |note| %>
          <div class="note-item">
            <div class="note-avatar <%= note.user.admin? ? 'admin' : 'creator' %>"><%= note.user.initials %></div>
            <div class="note-body">
              <div class="header"><strong><%= note.user.full_name %></strong> · <%= time_ago_in_words(note.created_at) %> ago</div>
              <div class="text"><%= note.body %></div>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Add Note -->
      <%= form_tag add_note_portal_campaign_deliverable_path(@campaign, @deliverable), class: 'd-flex gap-8 mt-16', style: 'padding-top:16px;border-top:1px solid var(--border);' do %>
        <input type="text" name="body" placeholder="Add a note..." required class="flex-1 text-md rounded-md border" style="padding:8px 12px;font-family:inherit;">
        <button type="submit" class="btn btn-secondary btn-sm">Send</button>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div>
    <!-- Actions -->
    <% if @deliverable.needs_attention? %>
      <div class="card" style="border:1px solid rgba(217,119,6,0.2);">
        <h4 class="text-md fw-700 mb-12">Your Review</h4>

        <div class="d-flex gap-8 mb-16">
          <%= link_to approve_portal_campaign_deliverable_path(@campaign, @deliverable), method: :patch, class: 'btn btn-sm flex-1 text-md fw-600 text-center text-white rounded-md d-block', style: 'background:#16A34A;border:none;padding:10px;text-decoration:none;' do %>
            Approve
          <% end %>
        </div>

        <div style="border-top:1px solid var(--border);padding-top:12px;">
          <p class="text-sm text-muted mb-8">Or request changes:</p>
          <%= form_tag request_revision_portal_campaign_deliverable_path(@campaign, @deliverable), method: :patch do %>
            <textarea name="creator_notes" rows="3" placeholder="What needs to change? Be specific so we can get it right..." required class="w-full text-md rounded-md border mb-8" style="padding:8px 10px;font-family:inherit;resize:vertical;"></textarea>
            <button type="submit" class="btn btn-sm w-full fw-600" style="background:rgba(239,68,68,0.06);color:#EF4444;border:1px solid rgba(239,68,68,0.2);">Request Revision</button>
          <% end %>
        </div>
      </div>
    <% elsif @deliverable.approved? %>
      <div class="card" style="border:1px solid rgba(34,197,94,0.2);background:rgba(34,197,94,0.02);">
        <div class="text-center p-12">
          <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" width="32" height="32" class="mb-8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div class="fw-700" style="font-size:15px;color:#16A34A;">Approved</div>
          <div class="text-sm text-muted mt-4">You've approved this deliverable.</div>
        </div>
      </div>
    <% elsif @deliverable.revision_requested? %>
      <div class="card" style="border:1px solid rgba(239,68,68,0.2);">
        <div class="text-center p-12">
          <div class="fw-700" style="font-size:15px;color:#EF4444;">Revision Requested</div>
          <div class="text-sm text-muted mt-4">The team is working on your revisions.</div>
        </div>
      </div>
    <% end %>

    <!-- Info -->
    <div class="card mt-4">
      <h4 class="text-md fw-700 mb-12">Details</h4>
      <div class="text-md d-flex flex-col gap-10">
        <div>
          <div class="text-xs text-muted fw-600">From</div>
          <div><%= @deliverable.creator&.full_name %></div>
        </div>
        <div>
          <div class="text-xs text-muted fw-600">Sent</div>
          <div><%= @deliverable.created_at.strftime('%b %d, %Y') %></div>
        </div>
        <% if @deliverable.due_date.present? %>
          <div>
            <div class="text-xs text-muted fw-600">Feedback due</div>
            <div class="fw-600" style="color:<%= @deliverable.due_date < Date.today ? '#EF4444' : 'var(--text-primary)' %>;"><%= @deliverable.due_date.strftime('%b %d, %Y') %></div>
          </div>
        <% end %>
        <div>
          <div class="text-xs text-muted fw-600">Revisions</div>
          <div><%= @deliverable.revision_count %></div>
        </div>
      </div>
    </div>
  </div>
</div>
