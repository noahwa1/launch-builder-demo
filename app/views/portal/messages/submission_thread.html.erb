<% content_for :page_title, "Messages: #{@submission.title}" %>
<% content_for :page_actions do %>
  <%= link_to 'View Submission', portal_submission_path(@submission), class: 'btn btn-secondary' %>
  <%= link_to 'All Messages', portal_messages_path, class: 'btn btn-secondary' %>
<% end %>

<div class="card">
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
    <span class="status-badge status-<%= @submission.status %>"><%= @submission.status.titleize %></span>
    <span style="font-size: 13px; color: #86868b;">Submission #<%= @submission.id %></span>
  </div>

  <% if @messages.any? %>
    <div class="message-list">
      <% @messages.reverse.each do |msg| %>
        <div class="message-item <%= 'from-admin' if msg.sender.admin? %>">
          <div class="meta">
            <span class="sender"><%= msg.sender.full_name %></span>
            <span><%= msg.created_at.strftime('%b %d, %Y at %I:%M %p') %></span>
          </div>
          <div class="body"><%= msg.body %></div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color: #86868b; font-size: 14px;">No messages in this thread yet.</p>
  <% end %>

  <%= form_for PortalMessage.new, url: portal_messages_path, style: 'margin-top: 20px; border-top: 1px solid #e5e5e7; padding-top: 16px;' do |f| %>
    <%= f.hidden_field :submission_id, value: @submission.id %>
    <div class="form-group" style="margin-bottom: 8px;">
      <%= f.text_area :body, placeholder: 'Reply...', rows: 3 %>
    </div>
    <%= f.submit 'Send', class: 'btn btn-primary' %>
  <% end %>
</div>
