<% content_for :page_title, 'Social Performance' %>
<% content_for :page_actions do %>
  <%= link_to 'Back to Hub', portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<style>
  .perf-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
  .perf-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md);
    padding: 18px; text-align: center; transition: box-shadow 0.15s;
  }
  .perf-card:hover { box-shadow: var(--shadow-md); }
  .perf-card .perf-val { font-size: 28px; font-weight: 300; margin: 6px 0 2px; letter-spacing: -0.5px; }
  .perf-card .perf-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .perf-card .perf-change { font-size: 12px; font-weight: 600; margin-top: 4px; }
  .perf-card .perf-change.up { color: #16A34A; }
  .perf-card .perf-change.down { color: #DC2626; }

  .platform-row {
    display: flex; align-items: center; gap: 14px; padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .platform-row:last-child { border-bottom: none; }
  .plat-icon {
    width: 40px; height: 40px; border-radius: 10px; display: flex;
    align-items: center; justify-content: center; font-size: 16px; font-weight: 800; flex-shrink: 0;
  }
  .plat-info { flex: 1; min-width: 0; }
  .plat-name { font-size: 14px; font-weight: 600; }
  .plat-handle { font-size: 12px; color: var(--text-muted); }
  .plat-stats { display: flex; gap: 20px; text-align: center; }
  .plat-stat-val { font-size: 16px; font-weight: 600; }
  .plat-stat-lbl { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3px; }

  .chart-placeholder {
    height: 200px; background: var(--page-bg); border-radius: 10px; display: flex;
    align-items: center; justify-content: center; color: var(--text-muted); font-size: 13px;
    border: 1px dashed var(--border);
  }

  .top-post {
    display: flex; gap: 14px; padding: 14px; border: 1px solid var(--border);
    border-radius: var(--radius-md); margin-bottom: 10px; transition: box-shadow 0.15s;
  }
  .top-post:hover { box-shadow: var(--shadow-md); }
  .top-post .post-thumb {
    width: 60px; height: 60px; border-radius: 8px; background: var(--page-bg);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    font-size: 24px;
  }
  .top-post .post-info { flex: 1; min-width: 0; }
  .top-post .post-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .top-post .post-meta { font-size: 11px; color: var(--text-muted); }
  .top-post .post-engagement { text-align: right; white-space: nowrap; }
  .top-post .post-engagement .eng-val { font-size: 16px; font-weight: 700; color: var(--text-primary); }
  .top-post .post-engagement .eng-lbl { font-size: 10px; color: var(--text-muted); text-transform: uppercase; }

  @media (max-width: 768px) {
    .perf-grid { grid-template-columns: 1fr 1fr; }
    .plat-stats { gap: 12px; }
    .plat-stat-val { font-size: 14px; }
  }
  @media (max-width: 480px) {
    .perf-grid { grid-template-columns: 1fr; }
    .platform-row { flex-wrap: wrap; }
    .plat-stats { width: 100%; justify-content: space-around; padding-top: 8px; }
  }
</style>

<%# ── Overview Stats ── %>
<div class="perf-grid">
  <div class="perf-card">
    <div class="perf-label">Total Reach</div>
    <div class="perf-val">24.8K</div>
    <div class="perf-change up">+12.3% vs last week</div>
  </div>
  <div class="perf-card">
    <div class="perf-label">Engagements</div>
    <div class="perf-val">1,847</div>
    <div class="perf-change up">+8.7% vs last week</div>
  </div>
  <div class="perf-card">
    <div class="perf-label">Link Clicks</div>
    <div class="perf-val">342</div>
    <div class="perf-change up">+22.1% vs last week</div>
  </div>
  <div class="perf-card">
    <div class="perf-label">Engagement Rate</div>
    <div class="perf-val">7.4%</div>
    <div class="perf-change down">-0.8% vs last week</div>
  </div>
</div>

<%# ── Engagement Over Time ── %>
<div class="card">
  <h3>Engagement Over Time</h3>
  <div class="bar-chart" style="height:180px;margin-top:8px;">
    <% [65, 42, 78, 55, 90, 72, 85, 48, 95, 60, 82, 70, 88, 50].each_with_index do |val, i| %>
      <div class="bar-group">
        <div class="bar" style="height:<%= val %>%;"></div>
        <div class="bar-label"><%= (Date.today - 13 + i).strftime('%-m/%d') %></div>
      </div>
    <% end %>
  </div>
</div>

