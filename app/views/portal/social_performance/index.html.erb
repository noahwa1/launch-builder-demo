  </div>

  <%# ── Top Posts ── %>
  <div class="card">
    <h3>Top Performing Posts</h3>
    <div class="top-post">
      <div class="post-thumb" style="background:rgba(225,48,108,0.08);color:#E1306C;">IG</div>
      <div class="post-info">
        <div class="post-title">Cover reveal carousel with behind-the-scenes shots</div>
