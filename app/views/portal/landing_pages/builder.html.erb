document.body.appendChild(hiddenDiv);

// ════════════════════════════════════════════════════════
// CUSTOM BLOCK SIDEBAR
// ════════════════════════════════════════════════════════
function buildBlocksSidebar() {
  var container = document.getElementById('custom-blocks');
  container.innerHTML = '';
  blockDefs.forEach(function(cat) {
    var section = document.createElement('div');
    section.className = 'block-category';
    section.innerHTML = '<div class="block-category-title" onclick="this.parentElement.classList.toggle(\'collapsed\')">' + cat.cat + ' <i class="fas fa-chevron-down chevron"></i></div>';
    var grid = document.createElement('div');
    grid.className = 'block-grid' + (cat.cat === 'Page Sections' || cat.cat === 'Forms' ? ' single-col' : '');
    cat.blocks.forEach(function(b) {
      var item = document.createElement('div');
      item.className = 'block-item';
      item.innerHTML = '<i class="fas ' + b.icon + '"></i><span>' + b.label + '</span>';
      item.addEventListener('click', function() {
        if (b.content === 'CUSTOM_HTML_PROMPT') { handleCustomHtmlBlock(); return; }
        if (typeof b.content === 'string') { editor.addComponents(b.content); }
        else { editor.addComponents([b.content]); }
      });
      grid.appendChild(item);
    });
    section.appendChild(grid);
    container.appendChild(section);
  });
}

// ════════════════════════════════════════════════════════
// LINK MANAGEMENT
// ════════════════════════════════════════════════════════
function applyLink() {
  var url = document.getElementById('link-url-input').value.trim();
  if (!url) return;
  var sel = editor.getSelected();
  if (!sel) return;
  var parent = sel.parent();
  if (parent && parent.get('tagName') === 'a') {
    parent.addAttributes({ href: url, target: '_blank' });
  } else {
    var wrapper = editor.DomComponents.addComponent({
      tagName: 'a', attributes: { href: url, target: '_blank' },
      style: { display: 'inline-block' },
      components: [sel.clone()],
    });
    sel.replaceWith(wrapper);
    editor.select(wrapper);
  }
}

function removeLink() {
  var sel = editor.getSelected();
  if (!sel) return;
  var comp = sel.get('tagName') === 'a' ? sel : sel.parent();
  if (comp && comp.get('tagName') === 'a') {
    var children = comp.components().models.map(function(c) { return c.clone(); });
    children.forEach(function(c) { comp.parent().append(c); });
    comp.remove();
    if (children.length) editor.select(children[0]);
  }
}

// ════════════════════════════════════════════════════════
// EDITOR EVENTS
// ════════════════════════════════════════════════════════
function injectCSS() {
  var doc = editor.Canvas.getDocument();
  if (!doc) return;
  var el = doc.getElementById('launch-css');
  if (el) el.remove();
  var style = doc.createElement('style');
  style.id = 'launch-css';
  style.innerHTML = launchCSS;
  doc.head.appendChild(style);
  // Inject editor-only resize handle CSS (separate so it's never exported)
  if (!doc.getElementById('resize-handle-css')) {
    var rStyle = doc.createElement('style');
    rStyle.id = 'resize-handle-css';
    rStyle.innerHTML = resizeHandleCSS;
    doc.head.appendChild(rStyle);
  }
  // Inject AOS CSS into canvas for scroll animation previews
  if (!doc.getElementById('aos-css')) {
    var aosLink = doc.createElement('link');
    aosLink.id = 'aos-css';
    aosLink.rel = 'stylesheet';
    aosLink.href = 'https://unpkg.com/aos@2.3.4/dist/aos.css';
    doc.head.appendChild(aosLink);
  }
  // Inject AOS JS into canvas and initialize
  if (!doc.getElementById('aos-js')) {
    var aosScript = doc.createElement('script');
    aosScript.id = 'aos-js';
    aosScript.src = 'https://unpkg.com/aos@2.3.4/dist/aos.js';
    aosScript.onload = function() {
      if (doc.defaultView && doc.defaultView.AOS) {
        doc.defaultView.AOS.init({ once: true, duration: 800 });
      }
    };
    doc.body.appendChild(aosScript);
  }
}

function refreshAOS() {
  var doc = editor.Canvas.getDocument();
  if (doc && doc.defaultView && doc.defaultView.AOS) {
    doc.defaultView.AOS.refreshHard();
  }
}

editor.on('load', function() {
  injectCSS();
  buildBlocksSidebar();

  // Load saved project from server or localStorage
  var loaded = false;

  if (typeof CAMPAIGN_ID !== 'undefined' && CAMPAIGN_ID) {
    // Load from DB via API
    fetch(SAVE_URL, { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.html_content && data.html_content.trim().length > 0) {
          editor.setComponents(data.html_content);
          if (data.css_content) editor.setStyle(data.css_content);
          document.getElementById('saved-builder-html').value = data.html_content;
          document.getElementById('saved-builder-css').value = data.css_content || '';
        }
      }).catch(function() {});
  }

  var savedHtml = document.getElementById('saved-builder-html').value || localStorage.getItem('launch-builder-html') || '';
  var savedCss = document.getElementById('saved-builder-css').value || localStorage.getItem('launch-builder-css') || '';

  if (!CAMPAIGN_ID && savedHtml && savedHtml.trim().length > 0) {
    editor.setComponents(savedHtml);
    if (savedCss) editor.setStyle(savedCss);
    loaded = true;
    setTimeout(function() { injectCSS(); markUploadPlaceholders(); }, 150);
  }

  if (!loaded && editor.DomComponents.getComponents().length === 0) {
    openTemplates();
  }
});

var markTimeout;
editor.on('component:add', function() {
  injectCSS();
  clearTimeout(markTimeout);
  markTimeout = setTimeout(markUploadPlaceholders, 300);
});

