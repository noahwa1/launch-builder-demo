// RESIZE HANDLES
// ════════════════════════════════════════════════════════
var resizeState = { active: false, type: null, startY: 0, startX: 0, startH: 0, startW: 0, el: null, comp: null };

function addResizeHandles(component) {
  removeResizeHandles();
  var doc = editor.Canvas.getDocument();
  if (!doc) return;
  var el = component.getEl();
  if (!el) return;

  // Make sure element has relative/absolute/sticky positioning for handle placement
  var iframeWin = doc.defaultView || window;
  var pos = iframeWin.getComputedStyle(el).position;
  if (pos === 'static') {
    el.style.position = 'relative';
    el.setAttribute('data-gjs-was-static', '1');
  }

  // Bottom handle (height resize)
  var bottomHandle = doc.createElement('div');
  bottomHandle.className = 'gjs-resize-handle';
  bottomHandle.setAttribute('data-resize', 'bottom');
  el.appendChild(bottomHandle);

  // Right handle (width resize)
  var rightHandle = doc.createElement('div');
  rightHandle.className = 'gjs-resize-handle-side';
  rightHandle.setAttribute('data-resize', 'right');
  el.appendChild(rightHandle);

  // Bottom handle drag
  bottomHandle.addEventListener('mousedown', function(e) {
    e.preventDefault(); e.stopPropagation();
    resizeState = { active: true, type: 'height', startY: e.clientY, startH: el.offsetHeight, el: el, comp: component, startX: 0, startW: 0 };
  });

  // Right handle drag
  rightHandle.addEventListener('mousedown', function(e) {
    e.preventDefault(); e.stopPropagation();
    resizeState = { active: true, type: 'width', startX: e.clientX, startW: el.offsetWidth, el: el, comp: component, startY: 0, startH: 0 };
  });
}

function removeResizeHandles() {
  var doc = editor.Canvas.getDocument();
  if (!doc) return;
  // Restore position on elements that were originally static
  doc.querySelectorAll('[data-gjs-was-static]').forEach(function(el) {
    el.style.position = '';
    el.removeAttribute('data-gjs-was-static');
  });
  doc.querySelectorAll('.gjs-resize-handle, .gjs-resize-handle-side').forEach(function(h) { h.remove(); });
}

// Listen for mousemove/mouseup on the canvas iframe
editor.on('load', function() {
  var canvasDoc = editor.Canvas.getDocument();
  if (!canvasDoc) return;

  canvasDoc.addEventListener('mousemove', function(e) {
    if (!resizeState.active) return;
    if (resizeState.type === 'height') {
      var newH = Math.max(20, resizeState.startH + (e.clientY - resizeState.startY));
      resizeState.el.style.height = newH + 'px';
      resizeState.el.style.minHeight = newH + 'px';
      resizeState.el.style.maxHeight = 'none';
      // Neutralize flex column sizing if parent is a column flex
      resizeState.el.style.flexShrink = '0';
      resizeState.el.style.flexBasis = 'auto';
    } else if (resizeState.type === 'width') {
      var newW = Math.max(40, resizeState.startW + (e.clientX - resizeState.startX));
      resizeState.el.style.width = newW + 'px';
      resizeState.el.style.minWidth = newW + 'px';
      resizeState.el.style.maxWidth = 'none';
      // Neutralize flex so explicit width is respected
      resizeState.el.style.flex = 'none';
    }
  });

  canvasDoc.addEventListener('mouseup', function() {
    if (!resizeState.active) return;
    // Sync only the essential properties to the GrapesJS component model
    // Clean up temporary DOM overrides that shouldn't persist
    if (resizeState.comp) {
      if (resizeState.type === 'height') {
        var h = resizeState.el.style.height;
        // Clean up DOM-only overrides
        resizeState.el.style.maxHeight = '';
        resizeState.el.style.flexShrink = '';
        resizeState.el.style.flexBasis = '';
        // Sync to model — only height and min-height
        resizeState.comp.addStyle({
          'height': h,
          'min-height': h
        });
      } else if (resizeState.type === 'width') {
        var w = resizeState.el.style.width;
        // Clean up DOM-only overrides
        resizeState.el.style.maxWidth = '';
        resizeState.el.style.minWidth = '';
        // Sync to model — width + flex:none so flex layout doesn't override
        resizeState.comp.addStyle({
          'width': w,
          'flex': 'none'
        });
      }
    }
    resizeState.active = false;
    resizeState.el = null;
    resizeState.comp = null;
  });
});

// Template CSS classes — must never be used as CSS rule targets by GrapesJS
var templateClasses = new Set([
  'section-wrapper','section-intro','project-header','steps-section','step-card','steps-row',
  'two-col','col-left','col-right','book-section','book-row','book-cover','book-detail',
  'author-section','author-row','author-image','author-detail','testimonials-section',
  'testimonial-card','launch-footer','container','retailer-grid','retailer-card','retailer-name',
  'bg-form','field-group','name-row','nav-links','btn-submit','btn-order','order-btn',
  'bg-launch-blue1','bg-launch-green','bg-launch-dark','bg-launch-yellow',
  'text-white','text-launch-darkblue','page-headline','page-headline2','text-shadow',
  'ff-montserrat','ff-opensans','step-number','step-caption','step-desc',
  'order-step-number','order-caption','book-headline1','book-headline2','book-desc',
  'author-headline1','author-desc','sticky-nav','btn','btn-submit',
  'hover-lift','hover-scale','hover-glow','hover-brighten','hover-shadow','hover-darken',
  'overlay-darken','overlay-lighten','overlay-gradient-dark','overlay-gradient-color',
  'upload-placeholder'
]);

editor.on('component:selected', function(component) {
  // Protect template classes — deactivate them so GrapesJS creates unique per-element selectors
  component.getSelectors().each(function(sel) {
    if (templateClasses.has(sel.get('name'))) {
      sel.set('private', true);
    }
  });

  showPanel('styles', document.querySelector('.sidebar-tabs button:nth-child(2)'));
  document.getElementById('img-actions').style.display = '';
  document.getElementById('align-actions').style.display = '';
  var tag = component.get('tagName');
  var isImg = component.is('image') || tag === 'img';
  var isLink = tag === 'a';
  document.getElementById('link-actions').style.display = (isImg || isLink) ? '' : 'none';
  var linkInput = document.getElementById('link-url-input');
  if (isLink) {
    linkInput.value = component.getAttributes().href || '';
  } else if (component.parent() && component.parent().get('tagName') === 'a') {
    linkInput.value = component.parent().getAttributes().href || '';
  } else {
    linkInput.value = '';
  }

  // Add resize handles + floating toolbar (skip if RTE text editing is active)
  setTimeout(function() {
    if (!rteActive) {
      addResizeHandles(component);
      showElementToolbar(component);
    }
    showEffectsPanel(component);
  }, 50);
});

editor.on('component:deselected', function() {
  showPanel('blocks', document.querySelector('.sidebar-tabs button:first-child'));
  document.getElementById('img-actions').style.display = 'none';
  document.getElementById('link-actions').style.display = 'none';
  document.getElementById('align-actions').style.display = 'none';
  removeResizeHandles();
  hideElementToolbar();
  hideEffectsPanel();
});

// Hide element toolbar when RTE (inline text editor) is active to prevent overlap
var rteActive = false;
editor.on('rte:enable', function() {
  rteActive = true;
  hideElementToolbar();
  removeResizeHandles();
});
editor.on('rte:disable', function() {
  rteActive = false;
  var sel = editor.getSelected();
  if (sel) {
    showElementToolbar(sel);
    addResizeHandles(sel);
  }
});

editor.DomComponents.addType('link', {
  isComponent: function(el) { return el.tagName === 'A'; },
  model: {
    defaults: {
      traits: [
        { type: 'text', name: 'href', label: 'URL' },
        { type: 'select', name: 'target', label: 'Open in', options: [{ id:'', name:'Same tab' },{ id:'_blank', name:'New tab' }] },
      ],
    },
  },
});

// ════════════════════════════════════════════════════════
// UI FUNCTIONS
// ════════════════════════════════════════════════════════
function doUndo() { editor.UndoManager.undo(); }
function doRedo() { editor.UndoManager.redo(); }

function toggleStickyNav(btn) {
  var doc = editor.Canvas.getDocument();
  if (!doc) return;
  var navs = doc.querySelectorAll('.project-header');
  if (!navs.length) { alert('No nav bar on the page to toggle.'); return; }
  var isSticky = navs[0].classList.contains('sticky-nav');
  navs.forEach(function(nav) { nav.classList.toggle('sticky-nav'); });
  btn.classList.toggle('active');
  var components = editor.DomComponents.getComponents();
  function findNavs(comps) {
    comps.forEach(function(c) {
      if ((c.getClasses() || []).includes('project-header')) {
        if (isSticky) c.removeClass('sticky-nav');
        else c.addClass('sticky-nav');
      }
      if (c.components().length) findNavs(c.components().models);
    });
  }
  findNavs(components.models);
}

function setDevice(device, btn) {
  editor.setDevice(device);
  document.querySelectorAll('.device-btn').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
}

function togglePreview() {
  editor.runCommand('preview');
  var hint = document.createElement('div');
  hint.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.85);color:#fff;padding:10px 24px;border-radius:10px;font-size:13px;z-index:99999;pointer-events:none;transition:opacity 0.5s;font-family:-apple-system,sans-serif;';
  hint.textContent = 'Press Escape to exit preview';
  document.body.appendChild(hint);
  setTimeout(function() { hint.style.opacity = '0'; }, 2000);
  setTimeout(function() { hint.remove(); }, 2500);
}

function showPanel(name, btn) {
  document.querySelectorAll('.sidebar-panel').forEach(function(p) { p.classList.remove('active'); });
  document.getElementById('panel-' + name).classList.add('active');
  document.querySelectorAll('.sidebar-tabs button').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  else { var tabs = document.querySelectorAll('.sidebar-tabs button');
    var map = { blocks: 0, styles: 1, layers: 2 };
    if (tabs[map[name]]) tabs[map[name]].classList.add('active');
  }
}

function quickAlign(position) {
  var sel = editor.getSelected();
  if (!sel) return;
  var tag = sel.get('tagName');
  var isInline = sel.is('image') || tag === 'img' || tag === 'a';
  if (position === 'center') {
    if (isInline) { sel.addStyle({ display: 'block', 'margin-left': 'auto', 'margin-right': 'auto' }); }
    else { sel.addStyle({ 'text-align': 'center' }); }
  } else if (position === 'left') {
    if (isInline) { sel.addStyle({ display: 'block', 'margin-left': '0', 'margin-right': 'auto' }); }
    else { sel.addStyle({ 'text-align': 'left' }); }
  } else if (position === 'right') {
    if (isInline) { sel.addStyle({ display: 'block', 'margin-left': 'auto', 'margin-right': '0' }); }
    else { sel.addStyle({ 'text-align': 'right' }); }
  }
}

function applyUploadedBg(input) {
  var file = input.files[0]; if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var sel = editor.getSelected();
    if (sel) sel.addStyle({ 'background-image': 'url(' + ev.target.result + ')', 'background-size': 'cover', 'background-position': 'center center', 'background-repeat': 'no-repeat' });
    else alert('Select an element first.');
    input.value = '';
  };
  reader.readAsDataURL(file);
}

function insertUploadedImg(input) {
  var file = input.files[0]; if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var sel = editor.getSelected();
    if (sel) sel.append('<img src="' + ev.target.result + '" style="max-width:100%;height:auto;" />');
    else editor.addComponents('<img src="' + ev.target.result + '" style="max-width:100%;height:auto;" />');
    editor.AssetManager.add([{ src: ev.target.result, name: file.name, type: 'image' }]);
    input.value = '';
  };
  reader.readAsDataURL(file);
}

function openTemplates() {
  var grid = document.getElementById('templateGrid');
  grid.innerHTML = '';
  templates.forEach(function(t, i) {
    var card = document.createElement('div');
    card.className = 'template-card';
    card.innerHTML = '<div class="preview">' + t.icon + (t.badge ? '<span class="badge">' + t.badge + '</span>' : '') + '</div><div class="info"><h3>' + t.name + '</h3><p>' + t.desc + '</p></div>';
    card.onclick = function() { loadTemplate(i); };
    grid.appendChild(card);
  });
  document.getElementById('templateModal').classList.add('active');
}
function closeTemplates() { document.getElementById('templateModal').classList.remove('active'); }

function loadTemplate(i) {
  if (editor.DomComponents.getComponents().length > 0 && !confirm('Replace current page with this template?')) return;
  editor.DomComponents.clear(); editor.CssComposer.clear();
  editor.setComponents(templates[i].html);
  injectCSS(); setTimeout(function() { injectCSS(); markUploadPlaceholders(); }, 150);
  closeTemplates();
}

// Strip editor-only artifacts from components before export/save
function cleanForExport() {
  removeResizeHandles();
  var wrapper = editor.DomComponents.getWrapper();
  if (!wrapper) return;
  // Remove upload-placeholder class (dashed borders are editor-only)
  wrapper.find('.upload-placeholder').forEach(function(comp) {
    comp.removeClass('upload-placeholder');
  });
  // Remove data-gjs-was-static attribute if somehow still present
  var doc = editor.Canvas.getDocument();
  if (doc) {
    doc.querySelectorAll('[data-gjs-was-static]').forEach(function(el) {
      el.removeAttribute('data-gjs-was-static');
    });
  }
}

// Re-add editor-only artifacts after export/save
function restoreAfterExport() {
  markUploadPlaceholders();
  var sel = editor.getSelected();
  if (sel) addResizeHandles(sel);
}

function openCode() {
  cleanForExport();
  // Check if any elements use AOS
  var html = editor.getHtml();
  var hasAOS = html.indexOf('data-aos') !== -1;
  var aosHead = hasAOS ? '\n  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css">' : '';
  var aosFoot = hasAOS ? '\n  <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"><\/script>\n  <script>AOS.init({once:true,duration:800});<\/script>' : '';
  var full = '<!DOCTYPE html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8">\n  <meta name="viewport" content="width=device-width, initial-scale=1.0">\n  <title>Launch Page</title>' + aosHead + '\n  <style>\n' + launchCSS + '\n' + editor.getCss() + '\n  </style>\n</head>\n<body>\n' + html + aosFoot + '\n</body>\n</html>';
  restoreAfterExport();
  document.getElementById('codeOutput').value = full;
  document.getElementById('codeModal').classList.add('active');
}
function closeCode() { document.getElementById('codeModal').classList.remove('active'); }
function copyCode() {
  var ta = document.getElementById('codeOutput'); ta.select();
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(ta.value)
      .then(function() { showToast('Copied!', 'success'); })
      .catch(function() { document.execCommand('copy'); showToast('Copied!', 'success'); });
  } else {
    document.execCommand('copy');
    showToast('Copied!', 'success');
  }
}

// ════════════════════════════════════════════════════════
// HTML EDITOR
// ════════════════════════════════════════════════════════
function openHtmlEditor() {
  cleanForExport();
  var ta = document.getElementById('htmlEditorOutput');
  ta.value = editor.getHtml();
  restoreAfterExport();
  ta.readOnly = false;
  document.getElementById('htmlEditorModal').classList.add('active');
  setTimeout(function() { ta.focus(); }, 100);
}
function closeHtmlEditor() { document.getElementById('htmlEditorModal').classList.remove('active'); }

function applyHtmlEdit() {
  var html = document.getElementById('htmlEditorOutput').value;
  if (!html.trim()) { showToast('HTML is empty', 'error'); return; }
  if (!confirm('This will replace the entire page with your edited HTML. Continue?')) return;
  editor.DomComponents.clear();
  editor.CssComposer.clear();
  editor.setComponents(html);
  injectCSS();
  setTimeout(injectCSS, 150);
  closeHtmlEditor();
  showToast('HTML applied!', 'success');
}

function pasteHtmlSnippet() {
  var ta = document.getElementById('htmlEditorOutput');
  var snippet = prompt('Paste your HTML snippet:');
  if (!snippet) return;
  // Insert at cursor position in the textarea
  var start = ta.selectionStart;
  var end = ta.selectionEnd;
  var text = ta.value;
  ta.value = text.substring(0, start) + snippet + text.substring(end);
  ta.selectionStart = ta.selectionEnd = start + snippet.length;
  ta.focus();
}

// Custom HTML block — prompts for HTML when dropped
function handleCustomHtmlBlock() {
  var html = prompt('Paste your HTML:');
  if (html && html.trim()) {
    editor.addComponents(html);
    injectCSS();
  }
}

// ════════════════════════════════════════════════════════
// SAVE TO SERVER
// ════════════════════════════════════════════════════════
function showToast(msg, type) {
  var toast = document.createElement('div');
  toast.className = 'save-toast ' + (type || 'success');
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(function() { toast.style.opacity = '0'; }, 2000);
  setTimeout(function() { toast.remove(); }, 2500);
}

function saveToServer() {
  cleanForExport();
  var btn = document.querySelector('.actions .btn-success');
  var origHTML = btn.innerHTML;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
  btn.disabled = true;

  var html = editor.getHtml();
  var css = launchCSS + '\n' + editor.getCss();
  restoreAfterExport();

  var formData = new FormData();
  formData.append('builder_html', html);
  formData.append('builder_css', css);

  if (typeof CAMPAIGN_ID !== 'undefined' && CAMPAIGN_ID) {
    fetch(SAVE_URL, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({ landing_page: { html_content: html, css_content: css } })
    }).then(function(r) { return r.json(); }).then(function(data) {
      btn.innerHTML = origHTML;
      btn.disabled = false;
      if (data.success) {
        document.getElementById('saved-builder-html').value = html;
        document.getElementById('saved-builder-css').value = css;
        showToast('Saved!', 'success');
      } else {
        showToast('Save failed — ' + (data.errors || []).join(', '), 'error');
      }
    }).catch(function(e) {
      btn.innerHTML = origHTML;
      btn.disabled = false;
      showToast('Save failed — ' + e.message, 'error');
    });
  } else {
    // Fallback: localStorage for standalone testing
    try {
      localStorage.setItem('launch-builder-html', html);
      localStorage.setItem('launch-builder-css', css);
      document.getElementById('saved-builder-html').value = html;
      document.getElementById('saved-builder-css').value = css;
      setTimeout(function() {
        btn.innerHTML = origHTML;
        btn.disabled = false;
        showToast('Saved! (localStorage)', 'success');
      }, 300);
    } catch(e) {
      btn.innerHTML = origHTML;
      btn.disabled = false;
      showToast('Save failed — ' + e.message, 'error');
    }
  }
}

// ════════════════════════════════════════════════════════
// EFFECTS PANEL
// ════════════════════════════════════════════════════════
var hoverClasses = ['hover-lift','hover-scale','hover-glow','hover-brighten','hover-shadow','hover-darken'];
var overlayClasses = ['overlay-darken','overlay-lighten','overlay-gradient-dark','overlay-gradient-color'];
var shadowPresets = {
  'none': 'none',
  'subtle': '0 2px 8px rgba(0,0,0,0.08)',
  'medium': '0 4px 16px rgba(0,0,0,0.12)',
  'heavy': '0 10px 40px rgba(0,0,0,0.2)',
  'glow': '0 0 30px rgba(108,92,231,0.35)',
  'warm': '0 0 30px rgba(255,160,50,0.3)',
};

function showEffectsPanel(component) {
  var panel = document.getElementById('effects-panel');
  panel.classList.add('visible');

  // Update hover button states
  var classes = component.getClasses() || [];
  document.querySelectorAll('.fx-btn[data-hover]').forEach(function(btn) {
    btn.classList.toggle('active', classes.indexOf(btn.getAttribute('data-hover')) !== -1);
  });

  // Update AOS dropdown
  var attrs = component.getAttributes();
  var aosVal = attrs['data-aos'] || '';
  document.getElementById('aos-select').value = aosVal;
  document.getElementById('aos-options').style.display = aosVal ? 'flex' : 'none';
  if (aosVal) {
    document.getElementById('aos-duration').value = attrs['data-aos-duration'] || '800';
    document.getElementById('aos-delay').value = attrs['data-aos-delay'] || '0';
  }

  // Update shadow buttons
  var currentShadow = (component.getStyle()['box-shadow'] || 'none').trim();
  document.querySelectorAll('.fx-section:nth-child(3) .fx-btn').forEach(function(btn) { btn.classList.remove('active'); });
  Object.keys(shadowPresets).forEach(function(key) {
    if (shadowPresets[key] === currentShadow) {
      var btns = document.querySelectorAll('.fx-section:nth-child(3) .fx-btn');
      var map = { 'none': 0, 'subtle': 1, 'medium': 2, 'heavy': 3, 'glow': 4, 'warm': 5 };
      if (btns[map[key]]) btns[map[key]].classList.add('active');
    }
  });

  // Update overlay buttons
  document.querySelectorAll('.fx-section:nth-child(4) .fx-btn').forEach(function(btn) { btn.classList.remove('active'); });
  var hasOverlay = false;
  overlayClasses.forEach(function(cls) {
    if (classes.indexOf(cls) !== -1) {
      hasOverlay = true;
      var map = { 'overlay-darken': 1, 'overlay-lighten': 2, 'overlay-gradient-dark': 3, 'overlay-gradient-color': 4 };
      var btns = document.querySelectorAll('.fx-section:nth-child(4) .fx-btn');
      if (btns[map[cls]]) btns[map[cls]].classList.add('active');
    }
  });
  if (!hasOverlay) {
    document.querySelectorAll('.fx-section:nth-child(4) .fx-btn')[0].classList.add('active');
  }
}

function hideEffectsPanel() {
  document.getElementById('effects-panel').classList.remove('visible');
}

function toggleHover(className, btn) {
  var sel = editor.getSelected();
  if (!sel) return;
  var has = (sel.getClasses() || []).indexOf(className) !== -1;
  if (has) {
    sel.removeClass(className);
    btn.classList.remove('active');
  } else {
    // Remove other hover classes first (one at a time)
    hoverClasses.forEach(function(c) { sel.removeClass(c); });
    document.querySelectorAll('.fx-btn[data-hover]').forEach(function(b) { b.classList.remove('active'); });
    sel.addClass(className);
    btn.classList.add('active');
  }
}

function setAosAnimation(value) {
  var sel = editor.getSelected();
  if (!sel) return;
  if (value) {
    sel.addAttributes({ 'data-aos': value });
    document.getElementById('aos-options').style.display = 'flex';
    // Set default duration/delay if not set
    var attrs = sel.getAttributes();
    if (!attrs['data-aos-duration']) sel.addAttributes({ 'data-aos-duration': '800' });
  } else {
    sel.removeAttributes('data-aos');
    sel.removeAttributes('data-aos-duration');
    sel.removeAttributes('data-aos-delay');
    sel.removeAttributes('data-aos-offset');
    document.getElementById('aos-options').style.display = 'none';
  }
  setTimeout(refreshAOS, 200);
}

function setAosDuration(val) {
  var sel = editor.getSelected();
  if (sel) sel.addAttributes({ 'data-aos-duration': val });
  setTimeout(refreshAOS, 100);
}

function setAosDelay(val) {
  var sel = editor.getSelected();
  if (sel) {
    if (parseInt(val) > 0) sel.addAttributes({ 'data-aos-delay': val });
    else sel.removeAttributes('data-aos-delay');
  }
  setTimeout(refreshAOS, 100);
}

function setShadow(preset, btn) {
  var sel = editor.getSelected();
  if (!sel) return;
  sel.addStyle({ 'box-shadow': shadowPresets[preset] || 'none' });
  // Update button states
  var parent = btn.parentElement;
  parent.querySelectorAll('.fx-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
}

function setOverlay(type, btn) {
  var sel = editor.getSelected();
  if (!sel) return;
  // Remove all overlay classes
  overlayClasses.forEach(function(cls) { sel.removeClass(cls); });
  // Add new one
  if (type !== 'none') {
    sel.addClass('overlay-' + type);
  }
  // Update button states
  var parent = btn.parentElement;
  parent.querySelectorAll('.fx-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
}

// ════════════════════════════════════════════════════════
// FLOATING ELEMENT TOOLBAR
// ════════════════════════════════════════════════════════
function showElementToolbar(component) {
  var toolbar = document.getElementById('element-toolbar');
  var el = component.getEl();
  if (!el) { toolbar.style.display = 'none'; return; }

  // Set label — show a friendly name based on classes/tag
  var tag = component.get('tagName') || 'div';
  var classes = component.getClasses() || [];
  var label = tag;
  var friendlyMap = {
    'project-header': 'Nav Bar', 'section-wrapper': 'Section', 'section-intro': 'Hero',
    'steps-section': 'Steps', 'step-card': 'Step Card', 'book-section': 'Book',
    'author-section': 'Author', 'testimonials-section': 'Testimonials',
    'launch-footer': 'Footer', 'two-col': '2 Columns', 'col-left': 'Left Col',
    'col-right': 'Right Col', 'container': 'Container', 'bg-form': 'Form',
    'field-group': 'Field', 'retailer-grid': 'Retailers', 'retailer-card': 'Retailer',
    'book-cover': 'Book Cover', 'book-detail': 'Book Info', 'author-image': 'Author Photo',
    'author-detail': 'Author Info', 'testimonial-card': 'Quote', 'nav-links': 'Nav Links',
    'btn-order': 'Order Btn', 'btn-submit': 'Submit Btn', 'order-btn': 'Order Btn',
  };
  for (var i = 0; i < classes.length; i++) {
    if (friendlyMap[classes[i]]) { label = friendlyMap[classes[i]]; break; }
  }
  if (label === tag) {
    var tagMap = { 'h1': 'Heading 1', 'h2': 'Heading 2', 'h3': 'Heading 3', 'h4': 'Heading 4',
      'p': 'Paragraph', 'a': 'Link', 'img': 'Image', 'section': 'Section', 'nav': 'Nav',
      'footer': 'Footer', 'button': 'Button', 'div': 'Block', 'span': 'Text',
      'blockquote': 'Quote', 'cite': 'Citation', 'hr': 'Divider', 'select': 'Dropdown',
      'input': 'Input', 'label': 'Label', 'form': 'Form', 'video': 'Video',
    };
    label = tagMap[tag] || tag;
  }
  document.getElementById('tb-label').textContent = label;

  // Set color swatch to current background
  var doc = editor.Canvas.getDocument();
  var iframeWin = doc ? (doc.defaultView || window) : window;
  var computed = iframeWin.getComputedStyle(el);
  var bgColor = computed.backgroundColor;
  var swatch = document.getElementById('tb-color-swatch');
  var colorInput = document.getElementById('tb-color-input');
  var opacityInput = document.getElementById('tb-opacity-input');
  var opacityLabel = document.getElementById('tb-opacity-label');
  if (bgColor && bgColor !== 'rgba(0, 0, 0, 0)' && bgColor !== 'transparent') {
    swatch.style.background = bgColor;
    var m = bgColor.match(/[\d.]+/g);
    if (m && m.length >= 3) {
      var hex = '#' + ((1 << 24) + (parseInt(m[0]) << 16) + (parseInt(m[1]) << 8) + parseInt(m[2])).toString(16).slice(1);
      colorInput.value = hex;
      // Read alpha if rgba
      var alpha = m.length >= 4 ? parseFloat(m[3]) : 1;
      opacityInput.value = Math.round(alpha * 100);
      opacityLabel.textContent = Math.round(alpha * 100) + '%';
    }
  } else {
    swatch.style.background = 'repeating-conic-gradient(#3a3a3a 0% 25%, #2a2a2a 0% 50%) 50%/8px 8px';
    opacityInput.value = 100;
    opacityLabel.textContent = '100%';
  }

  // Update bring-to-front button state
  var zIndex = component.getStyle()['z-index'] || '';
  var frontBtn = document.getElementById('tb-front-btn');
  if (frontBtn) frontBtn.classList.toggle('active', zIndex && parseInt(zIndex) > 0);

  // Position toolbar above the element
  toolbar.style.display = 'flex';
  positionToolbar(el, toolbar);
}

function positionToolbar(el, toolbar) {
  var frame = editor.Canvas.getFrameEl();
  if (!frame) return;
  var frameRect = frame.getBoundingClientRect();
  var elRect = el.getBoundingClientRect();

  var top = frameRect.top + elRect.top - toolbar.offsetHeight - 10;
  var left = frameRect.left + elRect.left + (elRect.width / 2) - (toolbar.offsetWidth / 2);

  // If no room above, show below
  if (top < 52) top = frameRect.top + elRect.bottom + 10;

  // Keep within viewport
  if (left < 4) left = 4;
  if (left + toolbar.offsetWidth > window.innerWidth - 4) left = window.innerWidth - toolbar.offsetWidth - 4;

  toolbar.style.top = top + 'px';
  toolbar.style.left = left + 'px';
}

function hideElementToolbar() {
  document.getElementById('element-toolbar').style.display = 'none';
}

// Toolbar actions
function tbSelectParent() {
  var sel = editor.getSelected();
  if (!sel) return;
  var parent = sel.parent();
  if (parent && parent.get('tagName')) {
    editor.select(parent);
  }
}

function tbMoveUp() {
  var sel = editor.getSelected();
  if (!sel) return;
  var parent = sel.parent();
  if (!parent) return;
  var index = parent.components().indexOf(sel);
  if (index > 0) {
    parent.components().remove(sel);
    parent.components().add(sel, { at: index - 1 });
    editor.select(sel);
  }
}

function tbMoveDown() {
  var sel = editor.getSelected();
  if (!sel) return;
  var parent = sel.parent();
  if (!parent) return;
  var siblings = parent.components();
  var index = siblings.indexOf(sel);
  if (index < siblings.length - 1) {
    siblings.remove(sel);
    siblings.add(sel, { at: index + 1 });
    editor.select(sel);
  }
}

function tbDuplicate() {
  var sel = editor.getSelected();
  if (!sel) return;
  var clone = sel.clone();
  sel.parent().components().add(clone, { at: sel.index() + 1 });
  editor.select(clone);
}

function tbDelete() {
  var sel = editor.getSelected();
  if (!sel) return;
  sel.remove();
}

function tbSetBgColor(color) {
  var sel = editor.getSelected();
  if (!sel) return;
  var opacity = parseInt(document.getElementById('tb-opacity-input').value) / 100;
  var rgba = hexToRgba(color, opacity);
  sel.addStyle({ 'background': '', 'background-image': 'none', 'background-color': rgba });
  document.getElementById('tb-color-swatch').style.background = rgba;
}

function tbSetOpacity(val) {
  var sel = editor.getSelected();
  if (!sel) return;
  document.getElementById('tb-opacity-label').textContent = val + '%';
  var hex = document.getElementById('tb-color-input').value;
  var opacity = parseInt(val) / 100;
  var rgba = hexToRgba(hex, opacity);
  sel.addStyle({ 'background': '', 'background-image': 'none', 'background-color': rgba });
  document.getElementById('tb-color-swatch').style.background = rgba;
}

function hexToRgba(hex, alpha) {
  var r = parseInt(hex.slice(1,3), 16);
  var g = parseInt(hex.slice(3,5), 16);
  var b = parseInt(hex.slice(5,7), 16);
  if (alpha >= 1) return hex;
  return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha.toFixed(2) + ')';
}

function tbBringToFront() {
  var sel = editor.getSelected();
  if (!sel) return;
  var current = sel.getStyle()['z-index'] || '';
  if (current && parseInt(current) > 0) {
    // Already in front — toggle it off (only clear z-index, preserve position if user-set)
    sel.addStyle({ 'z-index': '' });
    document.getElementById('tb-front-btn').classList.remove('active');
    showToast('Layer reset', 'success');
  } else {
    // Only add position:relative if currently static
    var el = sel.getEl();
    var doc = editor.Canvas.getDocument();
    var computedPos = (doc && el) ? (doc.defaultView || window).getComputedStyle(el).position : 'static';
    var styles = { 'z-index': '10' };
    if (computedPos === 'static') styles['position'] = 'relative';
    sel.addStyle(styles);
    document.getElementById('tb-front-btn').classList.add('active');
    showToast('Brought to front', 'success');
  }
}

function tbUploadImage() {
  var sel = editor.getSelected();
  if (!sel) return;
  var input = document.createElement('input');
  input.type = 'file';
  input.accept = 'image/*';
  input.style.display = 'none';
  document.body.appendChild(input);
  input.onchange = function() {
    var file = input.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev) {
      var src = ev.target.result;
      var classes = sel.getClasses() || [];
      var isPlaceholder = classes.indexOf('upload-placeholder') !== -1;
      var isRetailer = classes.indexOf('retailer-card') !== -1;

      if (isPlaceholder) {
        var existingText = sel.getEl() ? sel.getEl().textContent.trim() : 'Image';
        sel.components('');
        sel.set('content', '');
        sel.removeClass('upload-placeholder');
        if (isRetailer) {
          sel.append('<img src="' + src + '" alt="' + existingText + '" style="max-height:50px;max-width:80%;object-fit:contain;" />');
        } else {
          sel.append('<img src="' + src + '" alt="' + existingText + '" style="width:100%;height:100%;object-fit:cover;border-radius:4px;" />');
        }
      } else {
        // Non-placeholder — set as background
        sel.addStyle({
          'background-image': 'url(' + src + ')',
          'background-size': 'cover',
          'background-position': 'center',
          'background-repeat': 'no-repeat'
        });
      }
      editor.AssetManager.add([{ src: src, name: file.name, type: 'image' }]);
      input.remove();
      showToast('Image uploaded!', 'success');
    };
    reader.readAsDataURL(file);
  };
  input.click();
}

// Auto-detect and mark placeholder elements for upload
function markUploadPlaceholders() {
  var wrapper = editor.DomComponents.getWrapper();
  if (!wrapper) return;
  // Retailer cards without images
  wrapper.find('.retailer-card').forEach(function(card) {
    if (!card.find('img').length) card.addClass('upload-placeholder');
  });
  // Book cover placeholders
  wrapper.find('.book-cover').forEach(function(bc) {
    bc.components().forEach(function(child) {
      if (child.get('tagName') !== 'img' && !child.find('img').length) {
        child.addClass('upload-placeholder');
      }
    });
  });
  // Author image placeholders
  wrapper.find('.author-image').forEach(function(ai) {
    ai.components().forEach(function(child) {
      if (child.get('tagName') !== 'img' && !child.find('img').length) {
        child.addClass('upload-placeholder');
      }
    });
  });
}

// Reposition toolbar on canvas scroll
editor.on('load', function() {
  var canvasDoc = editor.Canvas.getDocument();
  if (canvasDoc) {
    canvasDoc.addEventListener('scroll', function() {
      if (rteActive) return;
      var sel = editor.getSelected();
      if (sel) showElementToolbar(sel);
    }, true);
  }
});

// ════════════════════════════════════════════════════════
// RTE (Rich Text Editor) — Text Color & Font Size
// ════════════════════════════════════════════════════════
(function() {
  var rte = editor.RichTextEditor;

  // Separator
  rte.add('sep1', { icon: '<span class="rte-sep"></span>', result: function(){} });

  // Text Color
  rte.add('textColor', {
    icon: '<span class="rte-color-wrap"><span style="font-weight:700;text-decoration:underline;text-decoration-color:var(--rte-clr,#ff0000);text-underline-offset:2px;">A</span><input type="color" value="#ff0000"></span>',
    event: 'change',
    result: function(r, action) {
      var input = action.btn.querySelector('input[type=color]');
      var color = input.value;
      r.exec('foreColor', color);
      // Update underline indicator
      var wrap = action.btn.querySelector('.rte-color-wrap span');
      if (wrap) wrap.style.textDecorationColor = color;
    },
    update: function(r, action) {
      var doc = r.doc || document;
      var color = doc.queryCommandValue('foreColor');
      if (color) {
        var input = action.btn.querySelector('input[type=color]');
        // queryCommandValue returns rgb(), convert to hex
        var hex = rgbToHex(color);
        if (hex && input) {
          input.value = hex;
          var wrap = action.btn.querySelector('.rte-color-wrap span');
          if (wrap) wrap.style.textDecorationColor = hex;
        }
      }
    }
  });

  // Font Size
  rte.add('fontSize', {
    icon: '<select class="rte-fontsize">' +
      '<option value="">Size</option>' +
      '<option value="12px">12</option><option value="14px">14</option>' +
      '<option value="16px">16</option><option value="18px">18</option>' +
      '<option value="20px">20</option><option value="24px">24</option>' +
      '<option value="28px">28</option><option value="32px">32</option>' +
      '<option value="36px">36</option><option value="42px">42</option>' +
      '<option value="48px">48</option><option value="56px">56</option>' +
      '<option value="64px">64</option><option value="72px">72</option>' +
      '</select>',
    event: 'change',
    result: function(r, action) {
      var sel = action.btn.querySelector('select');
      var size = sel.value;
      if (!size) return;
      // Use fontSize 7 as marker, then replace <font> tags with proper spans
      r.exec('fontSize', '7');
      var el = r.el;
      if (el) {
        var fonts = el.querySelectorAll('font[size="7"]');
        var ownerDoc = el.ownerDocument || document;
        fonts.forEach(function(font) {
          var span = ownerDoc.createElement('span');
          span.style.fontSize = size;
          span.innerHTML = font.innerHTML;
          font.parentNode.replaceChild(span, font);
        });
      }
      sel.value = ''; // Reset dropdown
    },
    update: function(r, action) {
      // Try to detect current font size from selection
      var doc = r.doc || document;
      var selObj = doc.getSelection();
      if (selObj && selObj.rangeCount > 0) {
        var node = selObj.anchorNode;
        if (node && node.nodeType === 3) node = node.parentNode;
        if (node) {
          var computed = (r.doc || document).defaultView.getComputedStyle(node);
          var px = Math.round(parseFloat(computed.fontSize));
          var select = action.btn.querySelector('select');
          var match = select.querySelector('option[value="' + px + 'px"]');
          select.value = match ? px + 'px' : '';
        }
      }
    }
  });

  // Helper: rgb string to hex
  function rgbToHex(rgb) {
    if (!rgb) return '';
    if (rgb.charAt(0) === '#') return rgb;
    var parts = rgb.match(/(\d+)/g);
    if (!parts || parts.length < 3) return '#000000';
    return '#' + parts.slice(0,3).map(function(x) {
      return ('0' + parseInt(x).toString(16)).slice(-2);
    }).join('');
  }
})();

// Keyboard shortcuts
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    if (document.getElementById('templateModal').classList.contains('active')) closeTemplates();
    if (document.getElementById('codeModal').classList.contains('active')) closeCode();
    if (document.getElementById('htmlEditorModal').classList.contains('active')) closeHtmlEditor();
  }
  // Don't intercept when typing in inputs/textareas
  var tag = (e.target.tagName || '').toLowerCase();
  if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
  var mod = e.metaKey || e.ctrlKey;
  if (mod && e.key === 'z' && !e.shiftKey) { e.preventDefault(); doUndo(); }
  if (mod && e.key === 'z' && e.shiftKey) { e.preventDefault(); doRedo(); }
  if (mod && e.key === 'y') { e.preventDefault(); doRedo(); }
  if (mod && e.key === 's') { e.preventDefault(); saveToServer(); }
  if (mod && e.key === 'd') { e.preventDefault(); tbDuplicate(); }
  if ((e.key === 'Delete' || e.key === 'Backspace') && !mod) {
    // Only delete if no contenteditable or input is focused
    if (e.target && e.target.getAttribute && e.target.getAttribute('contenteditable')) return;
    var sel = editor.getSelected();
    if (sel) { e.preventDefault(); sel.remove(); }
  }
});
