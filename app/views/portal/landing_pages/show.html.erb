<% content_for :page_title, 'Landing Page' %>
<% content_for :page_actions do %>
  <%= link_to 'Back to Campaign', portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<% if @landing_page.has_content? %>
  <%# ── STATE 3: Has content — edit + details + publish ── %>
  <div class="card" style="text-align:center;padding:40px;">
    <h3 style="text-transform:none;font-size:18px;color:var(--text-primary);margin-bottom:8px;">Your Landing Page</h3>
    <p class="text-secondary" style="margin-bottom:24px;">Your page has been built. Open the editor to make changes, or run the wizard to regenerate.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <%= link_to builder_portal_campaign_landing_page_path(@campaign), class: 'btn btn-primary', style: 'font-size:16px;padding:14px 32px;' do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Edit Page
      <% end %>
      <%= link_to wizard_portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary', style: 'font-size:14px;padding:10px 24px;' do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Run Wizard Again
      <% end %>
    </div>
  </div>

  <div class="two-col" style="margin-top:4px;">
    <div class="card">
      <h3>Page Details</h3>
      <div class="form-group">
        <div class="detail-label">Title</div>
        <div style="font-size:14px;margin-top:4px;"><%= @landing_page.title || 'Untitled' %></div>
      </div>
      <div class="form-group">
        <div class="detail-label">Page URL</div>
        <%= form_with model: @landing_page, url: portal_campaign_landing_page_path(@campaign), method: :patch, style: 'display:flex;align-items:center;gap:8px;margin-top:4px;' do |f| %>
          <span style="font-size:14px;font-family:monospace;color:var(--text-muted);">/pages/</span>
          <%= f.text_field :slug, value: @landing_page.slug, style: 'font-size:14px;font-family:monospace;padding:6px 10px;border:1px solid var(--border);border-radius:6px;flex:1;background:var(--bg-secondary);color:var(--text-primary);' %>
          <%= f.submit 'Update', class: 'btn btn-secondary btn-sm' %>
        <% end %>
      </div>
      <div class="form-group">
        <div class="detail-label">Status</div>
        <div style="margin-top:4px;">
          <% if @landing_page.published? %>
            <span class="status-badge status-live">Published</span>
          <% else %>
            <span class="status-badge status-draft">Draft</span>
          <% end %>
        </div>
      </div>
      <% if @landing_page.published_at %>
        <div class="form-group">
          <div class="detail-label">Published At</div>
          <div style="font-size:14px;margin-top:4px;" class="text-secondary"><%= @landing_page.published_at.strftime('%B %d, %Y at %l:%M %p') %></div>
        </div>
      <% end %>
    </div>

    <div class="card">
      <h3>Publish Controls</h3>
      <% if @landing_page.published? %>
        <div style="padding:16px;background:rgba(34,197,94,0.06);border-radius:10px;margin-bottom:16px;">
          <div style="font-size:13px;font-weight:600;color:#16A34A;margin-bottom:4px;">Live at:</div>
          <div style="display:flex;align-items:center;gap:8px;">
            <code style="font-size:13px;flex:1;" id="pub-url">/pages/<%= @landing_page.slug %></code>
            <button type="button" class="btn btn-secondary btn-sm" onclick="var u=document.getElementById('pub-url');navigator.clipboard.writeText(window.location.origin+u.textContent);this.textContent='Copied!';setTimeout(function(){this.textContent='Copy';}.bind(this),1500);">Copy</button>
          </div>
        </div>
        <%= button_to 'Unpublish', unpublish_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-danger btn-sm', form: { style: 'display:inline' } %>
      <% else %>
        <p class="text-secondary" style="margin-bottom:16px;font-size:14px;">Your page is ready to go live. Publishing makes it accessible at the slug URL.</p>
        <%= button_to 'Publish Page', publish_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-primary', form: { style: 'display:inline' } %>
      <% end %>
    </div>
  </div>

  <% if @submissions.any? %>
  <div class="card" style="margin-top:4px;">
    <h3>Form Submissions (<%= @landing_page.page_submissions.count %>)</h3>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="border-bottom:2px solid var(--border);text-align:left;">
            <th style="padding:8px 12px;font-size:12px;text-transform:uppercase;color:var(--text-muted);">Email</th>
            <th style="padding:8px 12px;font-size:12px;text-transform:uppercase;color:var(--text-muted);">Type</th>
            <th style="padding:8px 12px;font-size:12px;text-transform:uppercase;color:var(--text-muted);">Status</th>
            <th style="padding:8px 12px;font-size:12px;text-transform:uppercase;color:var(--text-muted);">Received</th>
          </tr>
        </thead>
        <tbody>
          <% @submissions.each do |sub| %>
            <tr style="border-bottom:1px solid var(--border);">
              <td style="padding:10px 12px;"><%= sub.email || 'N/A' %></td>
              <td style="padding:10px 12px;"><span class="status-badge status-draft"><%= sub.form_type.titleize %></span></td>
              <td style="padding:10px 12px;"><span class="status-badge status-<%= sub.new_submission? ? 'pending' : 'approved' %>"><%= sub.status.titleize %></span></td>
              <td style="padding:10px 12px;" class="text-muted"><%= time_ago_in_words(sub.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% end %>

<% elsif @landing_page.build_requested? %>
  <%# ── STATE 2: Build requested, waiting on Premiere ── %>
  <div class="card" style="text-align:center;padding:48px 40px;">
    <div style="width:48px;height:48px;margin:0 auto 16px;border-radius:50%;background:rgba(234,179,8,0.1);display:flex;align-items:center;justify-content:center;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CA8A04" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    </div>
    <h3 style="text-transform:none;font-size:18px;color:var(--text-primary);margin-bottom:8px;">Premiere Is Building Your Page</h3>
    <p class="text-secondary" style="margin-bottom:8px;max-width:400px;margin-left:auto;margin-right:auto;">Our team received your request<%= @landing_page.build_requested_at ? " #{time_ago_in_words(@landing_page.build_requested_at)} ago" : '' %> and is working on your landing page. We'll notify you when it's ready.</p>
    <p class="text-muted" style="font-size:13px;">Want to get started yourself instead?</p>
    <%= link_to builder_portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary btn-sm', style: 'margin-top:8px;' do %>
      Open Builder
    <% end %>
  </div>

<% else %>
  <%# ── STATE 1: No content, no build request — choice card ── %>
  <div class="card" style="text-align:center;padding:48px 40px;">
    <h3 style="text-transform:none;font-size:18px;color:var(--text-primary);margin-bottom:8px;">Landing Page Builder</h3>
    <p class="text-secondary" style="margin-bottom:24px;max-width:420px;margin-left:auto;margin-right:auto;">Create a custom landing page for your campaign. Generate one from your book data, build from scratch, or let us handle it.</p>

    <%# Custom slug input %>
    <div style="max-width:380px;margin:0 auto 28px;">
      <div class="detail-label" style="text-align:left;margin-bottom:6px;">Choose your page URL</div>
      <div style="display:flex;align-items:center;gap:4px;">
        <span style="font-size:14px;font-family:monospace;color:var(--text-muted);">/pages/</span>
        <input type="text" id="slug-input" value="<%= @landing_page.slug %>" placeholder="my-book-page" style="font-size:14px;font-family:monospace;padding:8px 10px;border:1px solid var(--border);border-radius:6px;flex:1;background:var(--bg-secondary);color:var(--text-primary);">
      </div>
    </div>

    <%# Use Wizard — recommended primary action %>
    <%= link_to wizard_portal_campaign_landing_page_path(@campaign), class: 'btn btn-primary', style: 'font-size:16px;padding:14px 32px;' do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Use Wizard
    <% end %>
    <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">Recommended — step-by-step page builder</div>

    <div style="margin:20px 0;font-size:13px;color:var(--text-muted);">or</div>

    <%# Build It Yourself — saves slug then redirects to builder %>
    <%= form_with model: @landing_page, url: portal_campaign_landing_page_path(@campaign), method: :patch, style: 'display:inline;' do |f| %>
      <input type="hidden" name="landing_page[slug]" id="build-slug-field">
      <input type="hidden" name="redirect_to_builder" value="1">
      <button type="submit" class="btn btn-secondary" style="font-size:14px;padding:10px 24px;" onclick="document.getElementById('build-slug-field').value=document.getElementById('slug-input').value;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Open Advanced Editor
      </button>
    <% end %>

    <div style="margin:20px 0;font-size:13px;color:var(--text-muted);">or</div>

    <%= button_to request_build_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-secondary', style: 'font-size:14px;padding:10px 24px;', data: { confirm: 'Send a build request to the Premiere team?' } do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Have Premiere Build It
    <% end %>
  </div>
<% end %>
