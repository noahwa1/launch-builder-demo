<% content_for :page_title, 'Landing Page' %>
<% content_for :page_actions do %>
  <%= link_to 'Back to Campaign', portal_campaign_path(@campaign), class: 'btn btn-secondary btn-sm' %>
<% end %>

<% if @landing_page.has_content? %>
  <%# ── STATE 3: Has content — edit + details + publish ── %>
  <div class="card text-center p-40">
    <h3 class="text-none text-xl text-primary mb-8">Your Landing Page</h3>
    <p class="text-secondary mb-24">Your page has been built. Open the editor to make changes, or run the wizard to regenerate.</p>
    <div class="d-flex gap-12 justify-center flex-wrap">
      <%= link_to builder_portal_campaign_landing_page_path(@campaign), class: 'btn btn-primary text-lg', style: 'padding:14px 32px;' do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Edit Page
      <% end %>
      <%= link_to wizard_portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary text-base', style: 'padding:10px 24px;' do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Run Wizard Again
      <% end %>
    </div>
  </div>

  <div class="two-col mt-4">
    <div class="card">
      <h3>Page Details</h3>
      <div class="form-group">
        <div class="detail-label">Title</div>
        <div class="text-base mt-4"><%= @landing_page.title || 'Untitled' %></div>
      </div>
      <div class="form-group">
        <div class="detail-label">Page URL</div>
        <%= form_with model: @landing_page, url: portal_campaign_landing_page_path(@campaign), method: :patch, class: 'd-flex items-center gap-8 mt-4' do |f| %>
          <span class="text-base text-mono text-muted">/pages/</span>
          <%= f.text_field :slug, value: @landing_page.slug, class: 'text-base text-mono rounded flex-1', style: 'padding:6px 10px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-primary);' %>
          <%= f.submit 'Update', class: 'btn btn-secondary btn-sm' %>
        <% end %>
      </div>
      <div class="form-group">
        <div class="detail-label">Status</div>
        <div class="mt-4">
          <% if @landing_page.published? %>
            <span class="status-badge status-live">Published</span>
          <% else %>
            <span class="status-badge status-draft">Draft</span>
          <% end %>
        </div>
      </div>
      <% if @landing_page.published_at %>
        <div class="form-group">
          <div class="detail-label">Published At</div>
          <div class="text-base mt-4 text-secondary"><%= @landing_page.published_at.strftime('%B %d, %Y at %l:%M %p') %></div>
        </div>
      <% end %>
    </div>

    <div class="card">
      <h3>Publish Controls</h3>
      <% if @landing_page.published? %>
        <div class="p-16 bg-success-light rounded-lg mb-16">
          <div class="text-md fw-600 mb-4" style="color:#16A34A;">Live at:</div>
          <div class="d-flex items-center gap-8">
            <code class="text-md flex-1" id="pub-url">/pages/<%= @landing_page.slug %></code>
            <button type="button" class="btn btn-secondary btn-sm" onclick="var u=document.getElementById('pub-url');navigator.clipboard.writeText(window.location.origin+u.textContent);this.textContent='Copied!';setTimeout(function(){this.textContent='Copy';}.bind(this),1500);">Copy</button>
          </div>
        </div>
        <%= button_to 'Unpublish', unpublish_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-danger btn-sm', form: { class: 'd-inline' } %>
      <% else %>
        <p class="text-secondary mb-16 text-base">Your page is ready to go live. Publishing makes it accessible at the slug URL.</p>
        <%= button_to 'Publish Page', publish_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-primary', form: { class: 'd-inline' } %>
      <% end %>
    </div>
  </div>

  <% if @submissions.any? %>
  <div class="card mt-4">
    <h3>Form Submissions (<%= @landing_page.page_submissions.count %>)</h3>
    <div style="overflow-x:auto;">
      <table class="w-full text-base" style="border-collapse:collapse;">
        <thead>
          <tr class="border-bottom" style="border-bottom-width:2px;text-align:left;">
            <th class="th-cell">Email</th>
            <th class="th-cell">Type</th>
            <th class="th-cell">Status</th>
            <th class="th-cell">Received</th>
          </tr>
        </thead>
        <tbody>
          <% @submissions.each do |sub| %>
            <tr class="border-bottom">
              <td class="td-cell"><%= sub.email || 'N/A' %></td>
              <td class="td-cell"><span class="status-badge status-draft"><%= sub.form_type.titleize %></span></td>
              <td class="td-cell"><span class="status-badge status-<%= sub.new_submission? ? 'pending' : 'approved' %>"><%= sub.status.titleize %></span></td>
              <td class="td-cell text-muted"><%= time_ago_in_words(sub.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <% end %>

<% elsif @landing_page.build_requested? %>
  <%# ── STATE 2: Build requested, waiting on Premiere ── %>
  <div class="card text-center" style="padding:48px 40px;">
    <div class="d-flex items-center justify-center mx-auto mb-16" style="width:48px;height:48px;border-radius:50%;background:rgba(234,179,8,0.1);">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#CA8A04" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    </div>
    <h3 class="text-none text-xl text-primary mb-8">Premiere Is Building Your Page</h3>
    <p class="text-secondary mb-8 max-w-sm mx-auto">Our team received your request<%= @landing_page.build_requested_at ? " #{time_ago_in_words(@landing_page.build_requested_at)} ago" : '' %> and is working on your landing page. We'll notify you when it's ready.</p>
    <p class="text-muted text-md">Want to get started yourself instead?</p>
    <%= link_to builder_portal_campaign_landing_page_path(@campaign), class: 'btn btn-secondary btn-sm mt-8' do %>
      Open Builder
    <% end %>
  </div>

<% else %>
  <%# ── STATE 1: No content, no build request — choice card ── %>
  <div class="card text-center" style="padding:48px 40px;">
    <h3 class="text-none text-xl text-primary mb-8">Landing Page Builder</h3>
    <p class="text-secondary mb-24 mx-auto" style="max-width:420px;">Create a custom landing page for your campaign. Generate one from your book data, build from scratch, or let us handle it.</p>

    <%# Custom slug input %>
    <div class="mx-auto" style="max-width:380px;margin-bottom:28px;">
      <div class="detail-label" style="text-align:left;margin-bottom:6px;">Choose your page URL</div>
      <div class="d-flex items-center gap-4">
        <span class="text-base text-mono text-muted">/pages/</span>
        <input type="text" id="slug-input" value="<%= @landing_page.slug %>" placeholder="my-book-page" class="text-base text-mono rounded flex-1" style="padding:8px 10px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-primary);">
      </div>
    </div>

    <%# Use Wizard — recommended primary action %>
    <%= link_to wizard_portal_campaign_landing_page_path(@campaign), class: 'btn btn-primary text-lg', style: 'padding:14px 32px;' do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Use Wizard
    <% end %>
    <div class="text-sm text-muted mt-4">Recommended — step-by-step page builder</div>

    <div class="text-md text-muted" style="margin:20px 0;">or</div>

    <%# Build It Yourself — saves slug then redirects to builder %>
    <%= form_with model: @landing_page, url: portal_campaign_landing_page_path(@campaign), method: :patch, class: 'd-inline' do |f| %>
      <input type="hidden" name="landing_page[slug]" id="build-slug-field">
      <input type="hidden" name="redirect_to_builder" value="1">
      <button type="submit" class="btn btn-secondary text-base" style="padding:10px 24px;" onclick="document.getElementById('build-slug-field').value=document.getElementById('slug-input').value;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        Open Advanced Editor
      </button>
    <% end %>

    <div class="text-md text-muted" style="margin:20px 0;">or</div>

    <%= button_to request_build_portal_campaign_landing_page_path(@campaign), method: :patch, class: 'btn btn-secondary text-base', style: 'padding:10px 24px;', data: { confirm: 'Send a build request to the Premiere team?' } do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Have Premiere Build It
    <% end %>
  </div>
<% end %>
